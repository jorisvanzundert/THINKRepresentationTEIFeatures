<expan>hete<ex>n</ex></expan> / So </ab>
<ab facs="#facs_224_r2l36">wollen vvir Jn / <expan>od<ex>er</ex></expan>
<expan>ire<ex>m</ex></expan>
<expan>ſcheinbot<ex>en</ex></expan> / mit <expan>ire<ex>m</ex></expan>
