</div><div type="regularised"><pb facs="#facs_193" id="96r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan> Wilhelm Frawnhofer,
                                                  <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, herczog
                                                  <expan>Heinr<ex>ichs</ex></expan>, hofmeister in
                                                Beyern</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan> her hofmeister, als uns
                                                  <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, herczog
                                                  <expan>Heinr<ex>ich</ex></expan>,
                                                  <expan>v<ex>er</ex>schr<ex>iben</ex></expan> hat
                                                von <expan>uns<ex>er</ex>r</expan>
<expan>burge<ex>r</ex></expan> habe und schulde
                                                wegen czu Landshute, darümb auch etliche die
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>yeczund<ex>en</ex></expan> czu
                                                  <expan>seine<ex>n</ex></expan> gnaden kumen,
                                                  <expan>bite<ex>n</ex></expan> wir
                                                  <expan>ew<ex>r</ex></expan>
<expan>erberk<ex>eit</ex></expan> mit
                                                  <expan>alle<ex>m</ex></expan>
<expan>fleisz</expan>, daz ir in
                                                  <expan>ew<ex>r</ex></expan> gunstige
                                                  <expan>fürdru<ex>n</ex>g</expan> gen
                                                  <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> herczog
                                                  <expan>Heinr<ex>ich</ex></expan> beweisen wöllet
                                                durch <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>, also daz sie darümb
                                                von seinen <expan>gnade<ex>n</ex></expan>
<expan>gnedikl<ex>ich</ex></expan> auszgerihtet
                                                werden, als wir euch das wol etc. Das
                                                  <expan>wölle<ex>n</ex></expan> etc.
                                                  <expan>Dat<ex>um</ex></expan> ut
                                                  <expan>sup<ex>ra</ex></expan>. </ab>
</div>
<div type="similiter">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Albr<ex>echt</ex></expan>
<expan>Preysing<ex>er</ex></expan>, vicztum
                                                  <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>,
                                                  <expan>hercz<ex>og</ex></expan>
<expan>Heinr<ex>ichs</ex></expan>, vicztum in Beyrn,
                                                  <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>.</ab>
