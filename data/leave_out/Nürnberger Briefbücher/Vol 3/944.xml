<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir bitten <expan>ew<ex>r</ex></expan>
<expan>hochwirdik<ex>eit</ex></expan> mit allem fleisz, daz
                                <expan>ew<ex>r</ex></expan> gnade unser
                            <expan>burge<ex>r</ex></expan> und kauflewte und auch ir habe und
                        kaufmanschaft und die iren in die <expan>nehstkünftige<ex>n</ex></expan>
<expan>vaste<ex>n</ex>messe</expan> gen Frankfürt und
                            <expan>wid<ex>er</ex></expan> darausz mit geleite gneͣdiglichen fürsehen
                        wölle, also daz sie ire hab und <pb facs="#facs_227" id="113r"/>kaufmanschaft und die
                        iren, die straszen durch <expan>ew<ex>r</ex></expan> lande, herschafte und
                        gepiete hin und <expan>herwid<ex>er</ex></expan> sicher geleytet werden, als
                        wir etc. Das wöllen etc. Und bitten des <expan>ew<ex>r</ex></expan> gnedig
                                <expan>v<ex>er</ex>schr<ex>iben</ex></expan> antwurt
                                <expan>wid<ex>er</ex></expan>
<expan>czuwisze<ex>n</ex></expan> bey disem <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>. <expan>Dat<ex>um</ex></expan> in die
                        scolastice <expan>virg<ex>inis</ex></expan> anno etc.
                                <expan>unde<ex>ci</ex><hi rend="sup">mo</hi></expan>.</ab></div>
<div type="similiter">
<ab><expan>H<ex>er</ex>n</expan> Thoman, grafen czü Ryneck;
                            <expan>h<ex>er</ex>n</expan>
<expan>Conr<ex>ad</ex></expan>, <expan>h<ex>er</ex>ren</expan> czu Weinsperg
                        von des geleyts <expan>weg<ex>en</ex></expan> ut in forma, antwurt bey
                                <expan>uns<ex>erm</ex></expan>
<expan>pot<ex>en</ex></expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan>
<expan>q<ex>ua</ex>rta</expan>
<expan>p<ex>ost</ex></expan>
<expan>invo<ex>ca</ex>vit</expan>.</ab>
</div>
