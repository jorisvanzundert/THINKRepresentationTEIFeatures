</div><div type="regularised"><pb facs="#facs_374" id="186v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Sweicker von Gundelfingen und <expan cert="unknwon">S.</expan>
<expan>Lay<ex>m</ex>miger</expan>
<expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>
