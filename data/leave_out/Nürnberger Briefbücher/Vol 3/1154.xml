</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Uns<ex>er</ex></expan>
<expan>fruntsch<ex>aft</ex></expan> czevor. Lieber
                            <expan>Pet<ex>er</ex></expan>, als du uns
                            <expan>geschr<ex>iben</ex></expan> hast <expan>vo<ex>n</ex></expan>
<expan>sölich<ex>er</ex></expan> beschedigung <expan>wege<ex>n</ex></expan>,
                        als dir <expan>vo<ex>n</ex></expan>
<expan>de<ex>n</ex></expan>
<expan>Perlaching<ex>ern</ex></expan>
<expan>gescheh<ex>e</ex>n</expan> sey, waist du
                            <expan>selb<ex>er</ex></expan> wol, daz <expan>and<ex>er</ex>n</expan>
                        der <expan>uns<ex>er</ex>n</expan> armen <expan>lewt<ex>e</ex>n</expan>
<expan>desgleich<ex>e</ex>n</expan> von in auch <add>unpilleich und
                                    ungüt<expan>lich<ex>e</ex>n</expan></add>
<expan>gescheh<ex>e</ex>n</expan> ist, und wissen dir darauf nicht
                                <expan>and<ex>er</ex>s</expan>
<expan>cze antwurt<ex>e</ex>n</expan>, dann das uns das
                                <expan>getrewlich<ex>e</ex>n</expan> leid ist.
                            <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii <expan>an<ex>te</ex></expan>
<expan>Lamp<ex>er</ex>ti</expan>.</ab>
