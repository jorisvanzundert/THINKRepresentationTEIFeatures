<add><ab facs="#facs_500_line_1576352166833_5171">
<del rend="strikethrough">er </del></ab></add> Jn in <expan>d<ex>er</ex></expan> cʒeit <expan>vnſ<ex>er</ex></expan> <expan>h<ex>e</ex>r</expan> <expan>vo<ex>n</ex></expan> <expan>wircʒb<ex>ur</ex>g</expan> </ab>
