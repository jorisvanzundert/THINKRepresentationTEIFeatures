<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Lieb<ex>er</ex></expan>
<expan>Conr<ex>ad,</ex></expan> als ir uns
                                <expan>v<ex>er</ex>schr<ex>iben</ex></expan> habt
                                <expan>vo<ex>n</ex></expan> <expan>S<ex>eitz</ex></expan> <expan>Gewd<ex>er</ex>s,</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>b<ex>ur</ex>g<ex>er</ex>s</expan>, und <expan>sein<ex>er</ex></expan>
                        wirtin <expan>weg<ex>en,</ex></expan>
<expan>hab<ex>e</ex>n</expan> wir <expan>ew<ex>r</ex>n</expan> brief wol
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                                <expan>besund<ex>er</ex></expan>, als ir schreibt, wie uns
                                <expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>vo<ex>n</ex></expan>
<expan>Wirczb<ex>ur</ex>g</expan> für ewch
                            <expan>geschrib<ex>e</ex>n</expan> hab etc. Nu
                            <expan>hab<ex>e</ex>n</expan> wir seinen <expan>gnad<ex>e</ex>n</expan>
                        auf die czeit, als er uns <expan>vo<ex>n</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>weg<ex>en</ex></expan> verschraib, <expan>geantw<ex>ur</ex>t,</expan>
                        daz wir den <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>ur</ex>g<ex>er</ex></expan> desmals <expan>vo<ex>n</ex></expan>
<expan>d<ex>er</ex></expan> klag geweist <expan>het<ex>e</ex>n,</expan> also
                        daz <expan>uns<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>vo<ex>n</ex></expan>
<expan>Wirczb<ex>ur</ex>g</expan> dem <expan>uns<ex>er</ex>n</expan>
<expan>czwisch<ex>e</ex>n</expan>
<expan>d<ex>er</ex>selb<ex>e</ex>n</expan> czeit und
                        <app><note><q type="date"><expan>pfingst<ex>en</ex></expan> tag</q>22.05.1412</note></app> beschiede und des
                                <expan>recht<ex>e</ex>n</expan>
<add>hülff</add>. Und spricht <expan>d<ex>er</ex></expan> unser, daz im das
                                <expan>v<ex>er</ex>czoge<ex>n</ex></expan>
<expan>word<ex>e</ex>n</expan> sey. Doch so <expan>hab<ex>e</ex>n</expan>
                        wir <expan>d<ex>ur</ex>h</expan>
<expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan> den <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> und sein hawsfrawn daran geweist, daz sie das
                        besteen <expan>lasse<ex>n</ex></expan> wöllen
                        <expan>hieczwisch<ex>e</ex>n</expan> und <app><note><q type="date"><expan>de<ex>m</ex></expan>
<expan>nehst<ex>e</ex>n</expan> sant Michels tag</q>29.09.1412</note></app>, also daz ir mit
                                <expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>vo<ex>n</ex></expan>
<expan>Wirczb<ex>ur</ex>g</expan> awstragt, daz in in
                            <expan>d<ex>er</ex></expan> czeit <expan>uns<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>vo<ex>n</ex></expan>
<expan>Wirczb<ex>ur</ex>g</expan> tag bescheid und des
                                <expan>recht<ex>e</ex>n</expan> helffe, daran sie sich vor
                                <expan>desselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>gnad<ex>e</ex>n</expan>
<expan>vo<ex>n</ex></expan> ew <expan>benüge<ex>n</ex></expan>
<expan>lasse<ex>n</ex></expan> wöllen, ob in das in
                            <expan>d<ex>er</ex></expan> czeit voll geen mag; und auch also ob ir czü
                        in iht <expan>czespreche<ex>n</ex></expan> het, daz ir ewch darumb von in an
                                <expan>de<ex>n</ex></expan>
<expan>rechte<ex>n</ex></expan> bey uns czü
                            <expan>Nur<ex>emberg</ex></expan>
<expan>benüge<ex>n</ex></expan> lazzet, do sie ew des
                            <expan>g<ex>er</ex>ne</expan> sein wöllen. <expan>Dat<ex>um</ex></expan>
                        in die <expan>s<ex>an</ex>c<ex>t</ex>i</expan> Oswaldi.</ab>
</div>
</div></body>
