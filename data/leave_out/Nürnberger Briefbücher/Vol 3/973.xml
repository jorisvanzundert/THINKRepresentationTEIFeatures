<div type="addressee">
<ab>Magnifico et excellenti <expan>domi<ex>ni</ex>o</expan>,
                                <expan>d<ex>omi</ex>no</expan> Michaeli Steno, duci Veneciarum etc,
                                <expan>spectabilibusq<ex>ue</ex></expan>
<expan>p<ex>rae</ex>poten<ex>ti</ex><hi rend="sup">b<ex>us</ex></hi></expan>
<expan>d<ex>omi</ex>nis</expan>, eius consilio venerando
                                <expan><ex>etc.</ex></expan></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Prompt<ex>is</ex></expan>
<expan>s<ex>er</ex>viciis</expan>
<expan>n<ex>ost</ex>ris</expan> cum <expan>sinc<ex>er</ex>issimis</expan>
                            aff<ex>e</ex>c<ex>t</ex>ib<ex>us</ex> excellencie et magnificenciis
                                <expan>v<ex>est</ex>ris</expan> continue
                                <expan>p<ex>rae</ex>oblat<ex>is</ex></expan>. Excelse et
                                <expan>g<ex>lo</ex>r<ex>i</ex>ose</expan>, magnifici
                                <expan><ex>et</ex></expan> spectabiles
                            <expan>d<ex>omi</ex>ni</expan>. <expan>Tenore<ex>m</ex></expan>
<expan>l<ex>itte</ex>ra<ex>rum</ex></expan> excellencie
                            <expan>v<ex>est</ex>re</expan>
<expan>r<ex>espo</ex>nsiva<ex>rum</ex></expan> ad ea que
                                <expan>gr<ex>at</ex><ex>i</ex>osi<ex>ta</ex>ti</expan>
<expan>v<ex>est</ex>re</expan>
<expan>nup<ex>er</ex></expan> ex parte Wilhelmi Rumell, Conradi Pirkheimer
                                <expan><ex>et</ex></expan> Rudolffi
                            <expan>Gundelfing<ex>er</ex></expan>
<expan>dil<ex>ec</ex>to<ex>rum</ex></expan>
<expan>civiu<ex>m</ex></expan>
<expan>n<ex>ost</ex>ro<ex>rum</ex></expan> scribenda
                                <expan>duxeram<ex>us</ex></expan>,
                            <expan>patefecim<ex>us</ex></expan>
<expan>civib<ex>us</ex></expan>
<expan>ip<ex>s</ex>is</expan>
<expan>n<ex>ost</ex>ris</expan>. Qui dicunt, <expan>q<ex>uod</ex></expan>,
                                <expan>q<ex>ua</ex>lit<ex>er</ex>cumq<ex>ue</ex></expan> sit de lege
                        municipali <expan>q<ex>ua</ex>m</expan> in <expan>civi<ex>ta</ex><hi rend="sup">te</hi></expan>
<expan>v<ex>est</ex>ra</expan>
<expan>Venet<ex>iarum</ex></expan>
<expan>habeat<ex>is</ex></expan>,
                            <expan>veru<ex>m</ex>tame<ex>n</ex></expan> eis aut aliis
                                <expan>hui<ex>us</ex></expan>
<expan>si<ex>mi</ex>le</expan>, <expan>p<ex>ro</ex>ut</expan>
<expan>nu<ex>n</ex>c</expan> solis <expan>ip<ex>s</ex>is</expan> in
                                <expan>districtu<ex>m</ex></expan>
<expan>Veronen<ex>sem</ex></expan>, nu<ex>m</ex>q<ex>uam</ex>
<expan>accid<ex>er</ex>it</expan> a <expan>t<ex>em</ex>p<ex>or</ex>e</expan>
                        quo ad <expan>man<ex>us</ex></expan>
<expan>v<ex>est</ex>ras</expan>
<expan>deven<ex>er</ex>it</expan>, <expan>neq<ex>ue</ex></expan> ante
                                <expan>mercimo<ex>n</ex>ia</expan>
<expan>quide<ex>m</ex></expan> sua, de <expan>quib<ex>us</ex></expan>
<expan>s<ex>er</ex>mo</expan>
<expan>e<ex>st</ex></expan> illinc <expan>direx<ex>er</ex>int</expan>,
                        nichil aliud scientes, <expan>q<ex>uam</ex></expan>
<expan>q<ex>uod</ex></expan> merces suas bono <expan><ex>et</ex></expan>
                        iusto possent, uti <expan>pride<ex>m</ex></expan>
<expan>q<ex>uam</ex></expan>
<expan>sepi<ex>us</ex></expan>, <expan>p<ex>er</ex></expan>
<expan>districtu<ex>m</ex></expan>
<expan>Veronen<ex>sem</ex></expan>
<expan>t<ex>ra</ex>nsduce<ex>re</ex></expan>,
                        <expan>sicq<ex>ue</ex></expan>, <expan>solut<ex>is</ex></expan> inde
                                <expan>solit<ex>is</ex></expan> ibidem <expan>p<ex>ro</ex></expan>
<expan>p<ex>er</ex>t<ex>ra</ex>nssitu</expan> daciis,
                                <expan>deniq<ex>ue</ex></expan>
<expan>cont<ex>ra</ex></expan>
<expan>ritu<ex>m</ex></expan>
<expan>l<ex>egi</ex>timu<ex>m</ex></expan>
<expan><ex>et</ex></expan> ratam
                                <expan>r<ex>ati</ex>o<ex>n</ex>nabilemq<ex>ue</ex></expan> loci
                                <expan><ex>et</ex></expan> patrie
                                <expan>co<ex>n</ex>suetudine<ex>m</ex></expan>, evi
                                <expan>durac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>firmit<ex>er</ex></expan>
<expan>obs<ex>er</ex>vata<ex>m</ex></expan>,
                            <expan>co<ex>m</ex>pulsi</expan> sint de eisdem
                            <expan>sup<ex>er</ex></expan>
<expan>adde<ex>re</ex></expan> et solvere centu<ex>m</ex>
<expan><ex>et</ex></expan> vigintisex <expan>ducat<ex>os</ex></expan> auri,
                        quod hac ante <expan>dismemoratu<ex>m</ex></expan>
<expan><ex>et</ex></expan>
<expan>inauditu<ex>m</ex></expan> prorsus existat,
                            <expan>n<ex>ec</ex></expan> hodie se aliud scire ferunt,
                                <expan>q<ex>uam</ex></expan>
<expan>q<ex>uod</ex></expan>
<expan>cuiusq<ex>ue</ex></expan>
<expan>mercimo<ex>n</ex>ia</expan> ibidem ad huc ut pridem
                                <expan>abs<ex>que</ex></expan>
<expan>i<ex>m</ex>ped<ex>i</ex>me<ex>n</ex>to</expan>
<expan>libe<ex>re</ex></expan>
<expan>t<ex>ra</ex>nsduci</expan>
<expan>p<ex>er</ex>mittan<ex>tur</ex></expan>
<expan><ex>et</ex></expan> in <expan>h<ex>uius</ex></expan>
<expan>obs<ex>er</ex>va<ex>n</ex>cia</expan>
<expan>n<ex>ec</ex></expan> alii <expan>huiusq<ex>ue</ex></expan>
<expan>p<ex>er</ex>turbati</expan> fuerint <expan>neq<ex>ue</ex></expan>
<expan>ip<ex>s</ex>i</expan>, nisi <expan>q<ex>uod</ex></expan> iam soli in
                                <expan>erepc<ex>i</ex>o<ex>n</ex>e</expan>
<expan>d<ex>i</ex>c<ex>t</ex>e</expan>
<expan>pecu<ex>n</ex>ie</expan> sint ab aliis
                            <expan>singualit<ex>er</ex></expan> segregati, quod sibi, re
                                <expan>ip<ex>s</ex>a</expan>
<expan>p<ex>er</ex>hibente</expan>, <expan>equu<ex>m</ex></expan>
<expan>vide<ex>ri</ex></expan>
<expan>no<ex>n</ex></expan> possit. <expan>Neq<ex>ue</ex></expan>
<expan>ip<ex>s</ex>i</expan> hoc petiverint seu <expan>r<ex>e</ex>quisierint
                        </expan> aut <expan>p<ex>ro</ex></expan>
<expan>b<ex>e</ex>n<ex>e</ex>fic<ex>i</ex>o</expan>
<expan>habe<ex>re</ex></expan> potuerint. Sperassent
                            <expan>e<ex>ni</ex>m</expan> ex eo <expan>q<ex>oud</ex></expan> Verona
                                <expan>v<ex>est</ex>ra</expan> foret, se
                            <expan>pot<ex>i</ex>us</expan>
<expan>gra<ex>tia</ex>m</expan>
<expan><ex>et</ex></expan>
<expan>p<ex>ro</ex>vent<ex>um</ex></expan>
<expan>co<ex>n</ex>sequi</expan>
<expan>qua<ex>m</ex></expan>
<expan>obstac<ex>u</ex>l<ex>u</ex>m</expan> sive
                                <expan>da<ex>m</ex>p<ex>nu</ex>m</expan>. Unde
                                <expan>celsitud<ex>in</ex>is</expan> vestre
                                <expan>clemencia<ex>m</ex></expan> suppl<ex>icite</ex>r
                                <expan>o<ex>mni</ex></expan> quo <expan>possum<ex>us</ex></expan>
                        studio <expan><ex>et</ex></expan>
<expan>obseq<ex>ui</ex>osi<ex>ta</ex><hi rend="sup">t<ex>is</ex></hi></expan>
<expan>aff<ex>e</ex>c<ex>t</ex>u</expan>
<expan>petim<ex>us</ex></expan>, obsecrando
                            <expan>q<ex>ua</ex>t<ex>enu</ex>s</expan> ex
                            <expan>sing<ex>u</ex>lari</expan>
<expan>gr<ex>ati</ex>a</expan>
<expan>civib<ex>us</ex></expan>
<expan><ex>et</ex></expan>
<expan>mercato<ex>r</ex>ib<ex>us</ex></expan>
<expan>n<ex>ost</ex>ris</expan>
<expan>benignit<ex>ur</ex></expan>
<expan>condescende<ex>re</ex></expan>
<expan>dignemi<ex>ni</ex></expan>,
                            <expan>q<ex>uem</ex>admod<ex>um</ex></expan> excellencie
                                <expan>v<ex>est</ex>re</expan>
<expan>p<ex>raese</ex>ns</expan>
<expan>sc<ex>ri</ex>psim<ex>us</ex></expan>
<expan><ex>et</ex></expan> petivimus, <expan>d<ex>ic</ex>tus</expan>
<expan>vi<ex>deli</ex>c<ex>et</ex></expan>
<expan>civib<ex>us</ex></expan>
<expan>n<ex>ost</ex>ris</expan>
<expan>d<ex>ic</ex>tos</expan> ducatos reddi <expan>eosq<ex>ue</ex></expan>
                        unacum aliis <expan>n<ex>ost</ex>ris</expan> in v<ex>est</ex>ris
                                <expan>dic<ex>ti</ex>onib<ex>us</ex></expan>
<expan>gr<ex>ati</ex>ose</expan> et <expan>favorabil<ex>ite</ex>r</expan>
<expan>tracta<ex>ri</ex></expan> mandando; <expan>cui<ex>us</ex></expan>
                            quide<ex>m</ex>
<expan>n<ex>ec</ex>non</expan>
<expan>om<ex>n</ex>is</expan> boni et <expan>gr<ex>ati</ex>e</expan> erga
                        magnificam <expan>pie<ex>ta</ex><hi rend="sup">tem</hi></expan>
                            v<ex>est</ex>ram indubie spem gerim<ex>us</ex>
<expan><ex>et</ex></expan>
<expan>p<ex>ro</ex>spectu<ex>m</ex></expan>
<expan><ex>et</ex></expan>
<expan>p<ex>ro</ex></expan>
<expan>excellen<ex>tia</ex></expan> vestra <expan>necno<ex>n</ex></expan>
<expan>v<ex>est</ex>ris</expan>
<expan>om<ex>n</ex>i</expan>
<expan>t<ex>em</ex>p<ex>or</ex>e</expan>
<expan>p<ex>ro</ex>mere<ex>r</ex>i</expan> desideranter
                                <expan>volum<ex>us</ex></expan>
<expan>iux<ex>ta</ex></expan> posse. <expan>Dat<ex>um</ex></expan> xxi die
                        martii anno d<ex>omi</ex>ni m<hi rend="sup">o</hi>cccc<hi rend="sup">o</hi>undecimo. <expan>P<ex>ro</ex>consules</expan> et Consules
                                <expan>ac<ex>tum</ex></expan>. <app>
<note place="bottomright">Petrus resignavit<ex>is</ex>
<expan>cu<ex>m</ex></expan> illa
                                <expan>li<ex>centi</ex>a</expan>.</note>
</app></ab>
