<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> als uns ewr
                            <expan>hochw<ex>irdikeit</ex></expan>
<expan>geschr<ex>iben</ex></expan> hat von <expan>Johan<ex>n</ex></expan>
<expan>Sot<ex>en</ex></expan> von Gellern, ewrs
                            <expan>burg<ex>er</ex>s</expan> und <expan>unt<ex>er</ex>sesse</expan>,
                                <expan>wege<ex>n</ex></expan>, wie im graf
                            <expan>Johan<ex>n</ex></expan> von Spanheim <expan>ju<ex>ni</ex><hi rend="superscript">or</hi></expan>
                        und Wilhelm von Bebemburg sein hab und kaufmanschafft
                                <expan>aufgehalt<ex>e</ex>n</expan>
<expan>un<ex>d</ex></expan> gen Purlaswab getriben
                            <expan>hab<ex>e</ex>n</expan> und wie derselb
                            <expan>Johan<ex>n</ex></expan> dem Wilhelm Rumel,
                            <expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan>, ii<hi rend="sup">c</hi>
<expan>un<ex>d</ex></expan> lxxx <expan>guld<ex>en</ex></expan> geschickt
                        hab, damit er sein burger lösen solt, die für dasselb gut gelobt
                                <expan>hete<ex>n</ex></expan> etc., lassen wir ewr gnad wissen, daz
                        wir den <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>burg<ex>er</ex></expan>
<expan>daru<ex>m</ex>b</expan> besant und czu rede gesaczt
                                <expan>hab<ex>e</ex>n</expan>, der hat uns
                            <expan>geantw<ex>ur</ex>t</expan>, daz im der
                                <expan>obgen<ex>an</ex>t<ex>e</ex></expan>
<expan>Johan<ex>n</ex></expan> Sot ii<hi rend="sup">c</hi> und lxxx
                                <expan>guld<ex>en</ex></expan>
<expan>geb<ex>e</ex>n</expan> hab, das er die fürbasz
                            <expan>vo<ex>n</ex></expan>
<expan>seine<ex>n</ex></expan> wegen <expan>seine<ex>n</ex></expan> burgen
                                <expan>antw<ex>ur</ex>t</expan> solt. Das hab er also getan, als er
                        im das auch <expan>selb<ex>er</ex></expan> czu
                                <expan>v<ex>er</ex>schreib<ex>e</ex>n</expan> maint.
                                <expan>Dan<ex>n</ex></expan> als ewr
                            <expan>hochw<ex>irdikeit</ex></expan> schreibt von ewrs nefen, des
                                <expan>burgg<ex>ra</ex>fen</expan> von
                            <expan>Nür<ex>emberg</ex></expan>, wegen, lassen wir ewr gnad wissen,
                        daz wir des nicht mechtig sein und das er auch unser <gap reason="illegible"/>
<expan>h<ex>er</ex>re</expan> nicht ist und keinen
                                    <add><expan>and<ex>er</ex>n</expan></add>
<expan>h<ex>er</ex>ren</expan>
<add>nicht</add>
<expan>hab<ex>e</ex>n</expan>
<expan>dan<ex>n</ex></expan> daz römisch reich; und wir sein auch der
                                <expan>egen<ex>an</ex>t<ex>en</ex></expan> graf
