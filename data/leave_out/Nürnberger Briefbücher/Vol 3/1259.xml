</div><div type="regularised"><pb facs="#facs_394" id="196v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Conrad<ex>en</ex></expan>, <expan>h<ex>er</ex>ren</expan> czu
                                <expan>Weinsp<ex>er</ex>g</expan>
</ab>
