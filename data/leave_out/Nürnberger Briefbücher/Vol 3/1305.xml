<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan> freund, als ir uns
                            <expan>geschr<ex>iben</ex></expan> habt von des tags
                                <expan>weg<ex>en</ex></expan>, als ir mit
                            <expan>Erking<ex>er</ex>n</expan>
<expan>vo<ex>n</ex></expan>
<expan>Sawnsh<ex>eim</ex></expan>
<expan>süche<ex>n</ex></expan> süllt czü <expan>Winsh<ex>eim</ex></expan>
                        und <expan>beg<ex>er</ex>t</expan>, daz wir ew <expan>uns<ex>er</ex></expan>
<expan>erb<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> darauf <expan>schicke<ex>n</ex></expan>,
                        dasselb <expan>wölle<ex>n</ex></expan> wir <expan>d<ex>ur</ex>h</expan>
<expan>ew<ex>r</ex>n</expan>
<expan>will<ex>e</ex>n</expan>
<expan>g<ex>er</ex>ne</expan> tün und <expan>bitt<ex>e</ex>n</expan> ewr
                                <expan>fruntsch<ex>aft</ex></expan>, ob <expan>d<ex>er</ex></expan>
                        tag abgieng, daz ir uns das czeitlich <expan>wisse<ex>n</ex></expan>
                        liesset. Und wo wir <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> in den und <expan>and<ex>er</ex>n</expan>
<expan>sach<ex>e</ex>n</expan> lieb, dinst und
                            <expan>fruntsch<ex>aft</ex></expan>
<expan>beweis<ex>en</ex></expan>
<expan>möht<ex>en</ex></expan>, das <expan>tet<ex>e</ex>n</expan> wir
                                <expan>allcz<ex>eit</ex></expan>
<expan>g<ex>er</ex>ne</expan>. <expan>Dat<ex>um</ex></expan>
<expan>d<ex>omi</ex>nica</expan>
<expan>invocav<ex>i</ex><hi rend="sup">t</hi></expan>.</ab>
</div>
