<add><ab facs="#facs_383_r1l30">wan </ab></add> wo wir ew etc <expan>Dat<ex>um</ex></expan> <expan>f<ex>er</ex>ıa</expan> vj̃ <expan>p<ex>oſt</ex></expan> <expan>kath<ex>er</ex>ine</expan> xȷ </ab>
</div>
</div><div type="regularised"><pb facs="#facs_383" id="191r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Hanse<ex>n</ex></expan> von <expan>Rosemb<ex>er</ex>g</expan>
