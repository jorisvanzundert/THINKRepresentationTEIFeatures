<del rend="strikethrough">ſelb </del> <expan>eg<ex>enante</ex></expan> Karl </ab>
<ab facs="#facs_494_r2l11"><expan>Holcʒſchüh<ex>er</ex></expan> vnd <expan>d<ex>er</ex></expan> <expan>Rechperg<ex>er</ex></expan> ſein arm man / <expan>dieſelb<ex>e</ex>n</expan> </ab>
