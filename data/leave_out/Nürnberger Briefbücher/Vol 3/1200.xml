<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als wir nehst <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>v<ex>er</ex>schr<ex>iben</ex></expan>
<add>und gebeten <expan>hete<ex>n</ex></expan></add>, daz ir uns einen ewrs
                        rats auf den tag gen <expan>Perchinge<ex>n</ex></expan>, der
                                <expan>czwisch<ex>e</ex>n</expan> dem Hiltpolt
                        <expan>Frawnberg<ex>er</ex></expan> und uns <app><note><q type="date">auf allersele tag</q>02.11.1411</note></app> beredt
                        was worden, <expan>leih<ex>e</ex>n</expan> und schicken woltett, also
                                <expan>lasze<ex>n</ex></expan> wir <expan>ew<ex>r</ex></expan> gnade
                        wiszen, daz uns derselb tag von dem <expan>Fraunberg<ex>er</ex></expan>
<expan>widerpote<ex>n</ex></expan> und ab ist; und dancken
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan>
<expan>fleisziklich<ex>e</ex>n</expan>. Und wo wir auch
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> lieb und dinst
                            <expan>beweise<ex>n</ex></expan>
<expan>möchte<ex>n</ex></expan>, das <expan>tet<ex>en</ex></expan> wir
                                <expan>allcz<ex>eit</ex></expan>
<expan>g<ex>er</ex>n</expan>.</ab>
</div>
<div type="similiter">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Fridr<ex>ich</ex></expan>, <expan>h<ex>er</ex>ren</expan> czu Heydeck
                                <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>.
                            <expan>H<ex>er</ex>n</expan> Steffan und
                            <expan>Heinr<ex>ich</ex></expan> von <expan>Absp<ex>er</ex>g</expan>
<expan>si<ex>mi</ex>l<ex>ite</ex>r</expan> in sua
                            <expan>for<ex>ma</ex></expan>
<expan>mutat<ex>is</ex></expan>
<expan>mutand<ex>is</ex></expan>. <expan>Si<ex>mi</ex>l<ex>ite</ex>r</expan>
<expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan> Schenken.</ab>
