<div type="addressee"><ab facs="#facs_35_r1l1">Katherina <expan>vo<ex>n</ex></expan> Pomern <expan>Pfalcʒg<ex>re</ex>fin</expan> </ab>
<ab facs="#facs_35_r1l2">beÿ Reyn vnd <expan>H<ex>er</ex>cʒogin</expan> in Beyrn </ab>
</div>
