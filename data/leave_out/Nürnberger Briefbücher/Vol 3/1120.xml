<ab facs="#facs_319_r1l36">tag mit <expan>de<ex>n</ex>ſelb<ex>e</ex>n</expan> <expan>vo<ex>n</ex></expan> <expan>Perlaching<ex>en</ex></expan> <expan>aufgenome<ex>n</ex></expan> </ab>
