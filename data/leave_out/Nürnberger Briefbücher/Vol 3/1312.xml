<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns nehst
                                <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> und wir ew
                                <expan>geantw<ex>ur</ex>t</expan>
<expan>hab<ex>e</ex>n</expan>
<expan>vo<ex>n</ex></expan> eins <expan>gütlich<ex>e</ex>n</expan> tages
                                <expan>weg<ex>en,</ex></expan> mit <expan>de<ex>n</ex></expan> edeln
                                <expan>h<ex>er</ex>ren</expan>
<expan>de<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan> Hanaw <expan>yecz<ex>unden</ex></expan> bey ew
                        in <expan>d<ex>er</ex></expan> messe cze süchen, und
                                <expan>besund<ex>er</ex></expan>, als ir uns
                                <expan>geschr<ex>iben</ex></expan> habt, daz ir in den
                            <add>acht</add> tag vor <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<expan>wisse<ex>n</ex></expan>
<expan>lasse<ex>n</ex></expan> solt, <expan>lasse<ex>n</ex></expan> wir ewr
                        ersame <expan>frewntsch<ex>aft</ex></expan> wissen, daz wir die
                                <expan>uns<ex>er</ex>n</expan>
<expan>daru<ex>m</ex>b</expan> czü ew <expan>cze schicke<ex>n</ex></expan>
                        mainen, daz die bey ew sein <app><note><q type="date">auf den <expan>mitwoch<ex>e</ex>n</expan> vor
                            <expan>de<ex>m</ex></expan> palmtag nu schirst</q>23.03.1412</note></app> czü
                                <expan>recht<ex>er</ex></expan> tagczeit. Und
                                <expan>ro<ex>gamus</ex></expan>, daz ir das
                            <expan>de<ex>n</ex></expan>
<expan>eg<ex>enanten</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>vo<ex>n</ex></expan> Hanaw also <expan>v<ex>er</ex>künden</expan>
                        wöllet und den <expan>uns<ex>er</ex>n</expan>
<expan>daryn<ex>n</ex>e</expan> beygestendig,
                            <expan>fürderl<ex>ich</ex></expan>, <expan>gerat<ex>e</ex>n</expan> und
                                <expan>beholffe<ex>n</ex></expan> sein, als wir
                                <expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> des wol
                            <expan>getrawe<ex>n</ex></expan> und das in
                            <expan>sölich<ex>e</ex>n</expan> und <expan>and<ex>er</ex>n</expan>
<expan>sach<ex>e</ex>n</expan> etc.</ab>
</div>
