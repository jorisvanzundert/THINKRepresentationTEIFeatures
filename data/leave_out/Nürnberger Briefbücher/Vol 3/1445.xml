<expan>Conrad<ex>en</ex></expan>,
                                                  <expan>h<ex>er</ex>ren</expan> czu
                                                  <expan>Weinsp<ex>ur</ex>g,<lb/></expan>
<expan>h<ex>er</ex>n</expan> Thoman, grafen czu
                                                Ryeneck<lb/> <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>
