<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, uns hat
                                                  <expan>Fridr<ex>ich</ex></expan>
<expan>vo<ex>n</ex></expan> Seldenegk, unser
                                                  <expan>dien<ex>er</ex></expan>,
                                                  <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>, wie
                                                ir <add>ew</add> von der sache
                                                  <expan>wege<ex>n</ex></expan> als
                                                  <expan>czwisch<ex>e</ex>n</expan> den von
                                                  <expan>d<ex>er</ex></expan> Ker <add>und</add>
                                                unser <expan>angenome<ex>n</ex></expan> und
                                                  <add><expan>vo<ex>n</ex></expan>
<expan>uns<ex>er</ex>n</expan> wegen</add> gar
                                                  <expan>gnediklich<ex>e</ex>n</expan> darein geredt
                                                habt, des wir <expan>ewr<ex>e</ex>n</expan>
<expan>fürstenlich<ex>e</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> mit
                                                  <expan>gancze<ex>m</ex></expan> fleisze
                                                  <expan>dank<ex>e</ex>n</expan>; und
                                                  <expan>hab<ex>e</ex>n</expan>
<expan>de<ex>m</ex>selb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan>
<expan>wid<ex>er</ex></expan>
<expan>geschr<ex>iben</ex></expan>, daz wir
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> czü eren ein gütlich
                                                steen und einen <expan>frewntlich<ex>e</ex>n</expan>
                                                tag <expan>aufneme<ex>n</ex></expan> wöllen, als er
                                                  <expan>ewr<ex>er</ex></expan> hochwirdikeit
                                                erczelen sol. Und wo wir
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> lieb, dienste und
                                                gevallnüzz <expan>beweise<ex>n</ex></expan>
<expan>möcht<ex>e</ex>n</expan>, des
                                                  <expan>w<ex>er</ex>en</expan> wir willig und
                                                  <expan>tet<ex>e</ex>n</expan> das auch czü allen
                                                  <expan>czeit<ex>e</ex>n</expan>
<expan>g<ex>er</ex>ne</expan>.</ab>
</div>
