<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, als <expan>Fridr<ex>ich</ex></expan>
<expan>vo<ex>n</ex></expan> Seldenegk, <expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan>, <expan>yeczund<ex>e</ex>n</expan> von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> bey <expan>ewr<ex>e</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan>
<expan>gewes<ex>en</ex></expan> ist <expan>vo<ex>n</ex></expan> des
                                <expan>entsage<ex>n</ex>s</expan> und czügriff
                            <expan>weg<ex>en</ex></expan>, als uns Hans <expan>vo<ex>n</ex></expan>
<expan>Perlaching<ex>en</ex></expan>, Marloch genant, und
                                <expan>vo<ex>n</ex></expan> seinen <expan>weg<ex>en</ex></expan>
<expan>Bering<ex>er</ex></expan> und Hans <expan>d<ex>er</ex></expan>
<expan>jüng<ex>er</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Perlaching<ex>en</ex></expan> und etlich
                            <expan>ande<ex>r</ex></expan> getan <expan>hab<ex>e</ex>n</expan>, also
                                <expan>ro<ex>gamus</ex></expan>, daz ir sie daran weisen wöllet, daz
                        sie sölich entsagen und vehe gen uns abtün und den
                            <expan>uns<ex>er</ex>n</expan> das ir <expan>wid<ex>er</ex></expan>
<expan>geb<ex>e</ex>n</expan> und keren <add>und auch die
                                    <expan>gevang<ex>en</ex></expan> ledig lassen</add>, wan wir
