<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns <expan>ab<ex>er</ex></expan>
<expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> habt
                            <expan>vo<ex>n</ex></expan> Mathes <expan>vo<ex>n</ex></expan> Oche,
                                <expan>ew<ex>r</ex>s</expan>
<expan>mitb<ex>ur</ex>g<ex>er</ex>s</expan>, <expan>weg<ex>en</ex></expan>,
                        als <expan>d<ex>er</ex></expan>
<expan>gevange<ex>n</ex></expan> ist, <expan>hab<ex>e</ex>n</expan>
<expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> vormals
                            <expan>geschr<ex>iben</ex></expan>, daz das in
                            <expan>uns<ex>er</ex>m</expan> gepiet niht
                            <expan>gescheh<ex>e</ex>n</expan>
<add>ist</add> und daz auch die, die das getan
                        <expan>hab<ex>e</ex>n</expan>, <add>nicht</add>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> sind und wir ir nicht mechtig sein,
                                <expan>sund<ex>er</ex></expan> daz es
                            <expan>gescheh<ex>e</ex>n</expan> ist in des
                            <expan>hochg<ex>eporn</ex></expan> etc., als man den
                            <expan>vo<ex>n</ex></expan> Prag nehst
                            <expan>geschrib<ex>e</ex>n</expan> hat. <expan>Pret<ex>er</ex></expan>.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra</ex></expan>.
                    </ab>
</div>
