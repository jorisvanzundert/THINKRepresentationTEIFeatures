<ab facs="#facs_163_r1l23"><expan>mitb<ex>ur</ex>g<ex>er</ex>s</expan> <expan>weg<ex>en</ex></expan> als <expan>d<ex>er</ex></expan> <expan>gevange<ex>n</ex></expan> ıſt / <expan>hab<ex>e</ex>n</expan> <expan>ewr<ex>er</ex></expan> <expan>frewntſch<ex>aft</ex></expan> vormals </ab>
