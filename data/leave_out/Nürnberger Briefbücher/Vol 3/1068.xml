<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, als wir <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> nehst
                            <expan>v<ex>er</ex>schr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan> von des <expan>erwirdige<ex>n</ex></expan>
