<ab facs="#facs_213_r1l8"><expan>volg<ex>en</ex></expan>
<del rend="strikethrough"> laſʒ </del> lieſʒ / vnd darauf hat vns derſelb <expan>vnſ<ex>er</ex></expan> <expan>h<ex>er</ex>re</expan> <expan>ew<ex>r</ex></expan> <expan>brud<ex>er</ex></expan> <expan>vvid<ex>er</ex></expan> <expan>geſchr<ex>iben</ex></expan> / als </ab>
<ab facs="#facs_213_r1l9">vvir <expan>ew<ex>r</ex>n</expan> <expan>gnad<ex>en</ex></expan> ſeins briefs / vnd auch <expan>vnſ<ex>er</ex>s</expan> briefs / als vvir Jm vormals <expan>habe<ex>n</ex></expan> <expan>v<ex>er</ex>ſchr<ex>iben</ex></expan></ab>
