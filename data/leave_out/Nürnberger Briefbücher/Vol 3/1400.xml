</front>
<body><div type="diplomatic"><pb facs="#facs_474" id="236v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_474_r1l1">Abbt cʒü <expan>VValtſachſ<ex>en</ex></expan> / </ab>
</div>
