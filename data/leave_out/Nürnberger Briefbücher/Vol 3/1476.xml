<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>L<ex>ieber</ex></expan>
                                                  Lorencz, ümb sölch feintschaft und
                                                  <expan>czweyu<ex>n</ex>g</expan>, als
                                                  <expan>czwische<ex>n</ex></expan> ew und den
                                                  Wildensteinern ist, das uns getreulich leid ist,
                                                  hat uns fraw Cristein, die Wildensteinerin,
                                                  burgerin, gebeten, daz wir euch
                                                  <expan>v<ex>er</ex>schreib<ex>e</ex>n</expan>
<expan>wölle<ex>n</ex></expan>, ob daz wer, daz ir
                                                  <expan>yend<ex>er</ex>t</expan> czu greiffen
                                                  würdt, daz ir <expan>dan<ex>n</ex></expan>
<expan>derselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>r</expan> burgerin und der
                                                  iren <add>durch <expan>uns<ex>er</ex>n</expan>
                                                  willen </add> darunter schonen und keinen schaden
                                                  czu <expan>czieh<ex>e</ex>n</expan> wöllet. Als
                                                  etc. Das <expan>wölle<ex>n</ex></expan>
                                                etc.</del></ab>
</div>
