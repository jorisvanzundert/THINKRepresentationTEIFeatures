<div type="addressee"><ab facs="#facs_139_r2l19"><expan>H<ex>er</ex>n</expan> Fridrich Stẏeber </ab>
<ab facs="#facs_139_r2l20"><expan>Dechant<ex>en</ex></expan> cʒu <expan>Bamb<ex>er</ex>g</expan> </ab>
</div>
