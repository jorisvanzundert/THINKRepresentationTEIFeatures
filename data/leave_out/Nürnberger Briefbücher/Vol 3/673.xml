<div type="addressee"><ab facs="#facs_102_r2l22">Hercʒog <expan>Heinr<ex>ich</ex></expan> </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab facs="#facs_102_r2l23"><expan>Gnedıg<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> / Vns hat fürgelegt Criſtan wolcʒhofer
                <expan>vnſ<ex>er</ex></expan>
<expan>B<ex>urger</ex></expan>
</ab>
<ab facs="#facs_102_r2l25">vvie <add><ab facs="#facs_102_r2l24">man </ab></add> Jm nu
            newlich cʒu landſhute <del rend="strikethrough">in der Stat </del> in Vrban </ab>
<ab facs="#facs_102_r2l27">Fünſingers herberg <add><ab facs="#facs_102_r2l26">aufgehalten
              </ab></add>
<del rend="strikethrough"><expan>genome<ex>n</ex></expan> ſein vvorden </del>
