<div type="content">
<ab><expan>Lieb<ex>er</ex></expan>
<expan>Wilh<ex>elm</ex></expan>, als ir uns
                                                  <expan>v<ex>er</ex>schr<ex>iben</ex></expan> und
                                                etlich <expan>uns<ex>er</ex>r</expan>
<expan>b<ex>ur</ex>g<ex>er</ex></expan> arm lewte an
                                                  <expan>ein<ex>er</ex></expan> czedeln in
                                                  <expan>ewre<ex>m</ex></expan> brief geschickt
                                                habt, <expan>wölle<ex>n</ex></expan> wir
                                                  <expan>diselb<ex>e</ex>n</expan>
<expan>arme<ex>n</ex></expan> lewte, die ir uns
                                                benant habt, <expan>g<ex>er</ex>n</expan> besenden
                                                und ir rede <expan>höre<ex>n</ex></expan> und ew
                                                  <expan>dan<ex>n</ex></expan> ein
                                                  <expan>antw<ex>ur</ex>t</expan>
<expan>wisse<ex>n</ex></expan>
<expan>lass<ex>en</ex></expan>, ob die
                                                  <expan>yema<ex>n</ex>t</expan>
<expan>vo<ex>n</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>weg<ex>en</ex></expan> an uns
                                                  <expan>vord<ex>er</ex>t</expan>.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>i<ex>n</ex></expan> die
                                                  <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
                                                Kyliani.</ab>
</div>
