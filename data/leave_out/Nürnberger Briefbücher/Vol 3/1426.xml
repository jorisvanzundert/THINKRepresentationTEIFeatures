<ab facs="#facs_489_r1l13">rede <expan>höre<ex>n</ex></expan> vnd ew <expan>dan<ex>n</ex></expan> ein <expan>antw<ex>ur</ex>t</expan> <expan>vvıſſe<ex>n</ex></expan> <expan>laſſ<ex>en</ex></expan> / ob die <expan>yema<ex>n</ex>t</expan> </ab>
