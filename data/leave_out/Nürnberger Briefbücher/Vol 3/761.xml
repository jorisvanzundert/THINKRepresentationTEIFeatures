<ab facs="#facs_142_r2l3"><expan>vnſ<ex>er</ex>r</expan> <expan>burge<ex>r</ex></expan> vvegen / den das Jr in <expan>ewr<ex>er</ex></expan> Stat cʒu Landſhute be = </ab>
<ab facs="#facs_142_r2l4">kümert iſt <expan>vvoꝛde<ex>n</ex></expan> / 
<del rend="strikethrough">vnd <expan>Ro<ex>gamus</ex></expan></del> / darümb <expan>ſende<ex>n</ex></expan> vvir cʒu <expan>ewr<ex>er</ex></expan> <expan>hoch<ex>wirdikeit</ex></expan> <expan>pet<ex>er</ex></expan> <expan>krag<ex>en</ex></expan> </ab>
<ab facs="#facs_142_r2l5">
<add>vnd</add> hanſen <expan>Mawr<ex>er</ex></expan> <expan>vnſ<ex>er</ex>n</expan> <expan>dien<ex>er</ex></expan> mit <expan>ew<ex>r</ex>n</expan> <expan>gnade<ex>n</ex></expan> dauon cʒu <expan>rede<ex>n</ex></expan> / vnd <expan>Ro<ex>gamus</ex></expan> </ab>
<ab facs="#facs_142_r2l6">etc ut in <expan>for<ex>ma</ex></expan> / <expan>Dat<ex>um</ex></expan> <expan>fe<ex>ri</ex>a</expan> ıj̃ poſt <expan>Margar<ex>ete</ex></expan> </ab>
</div>
</div><div type="regularised"><pb facs="#facs_142" id="70v"/><!--The following div is the container for the adress lines of the letter.-->
