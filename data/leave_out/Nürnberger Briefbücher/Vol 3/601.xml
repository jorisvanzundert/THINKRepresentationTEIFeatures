<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir schicken czu <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnade<ex>n</ex></expan> Hansen <expan>Camr<ex>er</ex></expan>,
                                <expan>uns<ex>er</ex>n</expan> diener, mit
                            <expan>ew<ex>r</ex>n</expan>
<add><expan>durchl<ex>euhtikeit</ex></expan></add> czureden von der habe und
                                <expan>kaufmans<ex>chaft</ex></expan>
<expan>wege<ex>n</ex></expan>, als den <expan>uns<ex>er</ex>n</expan> in
                                <expan>ewre<ex>m</ex></expan> land, herschaft und
                                <expan>gepiete<ex>n</ex></expan> in dem gepirge
                                <expan>aufgehalte<ex>n</ex></expan> und etliche der
                                <expan>uns<ex>er</ex>n</expan> damit bekumert
                            <expan>worde<ex>n</ex></expan> sein. Und
                        <expan>ro<ex>gamus</ex></expan>, waz der <expan>eg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> in <expan>ders<ex>elben</ex></expan> sache
                        czu disem mal an <expan>ew<ex>r</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan> werb <add>von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan></add>, daz in <expan>ew<ex>r</ex></expan>
                        gnade darynne <expan>gutlich<ex>e</ex>n</expan>
<expan>v<ex>er</ex>hören</expan> und im des <expan>gelaub<ex>e</ex>n</expan>
                        und in auch darümb <expan>gnediklich<ex>e</ex>n</expan>
<add>von <expan>ew<ex>r</ex>n</expan>
<expan>durchl<ex>euhtikeit</ex></expan></add>
<add><expan>v<ex>er</ex>t<ex>ragen</ex></expan> wollen</add>, als etc. Das
                                <expan>wolle<ex>n</ex></expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>ri</ex>a</expan> vi <expan>p<ex>ost</ex></expan>
<expan>circ<ex>umcisionem</ex></expan>
<expan>d<ex>omi</ex>ni</expan> anno <expan>deci<ex>m</ex>o</expan>.</ab>
</div>
