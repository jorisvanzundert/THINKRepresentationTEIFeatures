<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als ewr gnad nehst hie czü
                                <expan>Nur<ex>emberg</ex></expan> uns mit
                            <expan>de<ex>m</ex></expan>
<expan>Michelsperg<ex>er</ex></expan>
<expan>gütlich<ex>e</ex>n</expan> berichtet hat und darumb
                                <expan>awsgesproch<ex>e</ex>n</expan>, daz wir uns bey
                                <expan>uns<ex>er</ex>n</expan> trewen
                            <expan>ervar<ex>e</ex>n</expan>
<expan>solt<ex>e</ex>n</expan>, wer söliche smacheit
                            <expan>de<ex>m</ex></expan>
<expan>Michelsperg<ex>er</ex></expan> beweiset und erczeigt het, die di
                                <expan>uns<ex>er</ex>n</expan>
<expan>w<ex>er</ex>en</expan> und der wir noch mechtig
                            <expan>w<ex>er</ex>en</expan>, und das <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> mit <expan>uns<ex>er</ex>m</expan>
<expan>schreib<ex>e</ex>n</expan> cze wissen tün, also
                                <expan>lasse<ex>n</ex></expan> wir ewr
                            <expan>hochw<ex>irdikeit</ex></expan> wissen, daz wir uns darumb bey
                                <expan>uns<ex>er</ex>n</expan> trewen ervaren
                            <expan>hab<ex>e</ex>n</expan>, und wissen und künnen nyemant ervaren,
                        der der unser sey und des wir noch mechtig sein, der dem
                                <expan>Michelsperg<ex>er</ex></expan> sölich smacheit beweiset
                                <expan>od<ex>er</ex></expan> erczeigt hab, dann
                                <expan>ein<ex>er</ex></expan> genant Hertel, der was desmals des
                                <expan>Ulr<ex>ich</ex></expan>
<expan>Eglofstein<ex>er</ex>s</expan> knecht. Der ist sider her unser
                                <expan>dien<ex>er</ex></expan>
<expan>word<ex>e</ex>n</expan> mit <expan>eine<ex>m</ex></expan> pferde,
                        aber wir <expan>hab<ex>e</ex>n</expan> von <expan>demselb<ex>e</ex>n</expan>
                        Hertel nicht ervaren, daz er ihts dar czü getan hab, dann daz er bey
                                <expan>seine<ex>m</ex></expan>
<expan>h<ex>er</ex>ren</expan> dem <expan>Eglolfstein<ex>er</ex></expan>
                        gestanden sey. Und wan ewr gnad <expan>yeczund<ex>e</ex>n</expan> nicht hie
                                <expan>ob<ex>e</ex>n</expan> bey land ist, so
                            <expan>hab<ex>e</ex>n</expan>
<add>wir</add> das <expan>de<ex>m</ex></expan> Altman
                                <expan>Kemnat<ex>er</ex></expan>, <expan>ewre<ex>m</ex></expan>
<expan>hofmeist<ex>er</ex></expan>, auch also
                                <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>. Und wo etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii <expan>p<ex>ost</ex></expan> Mathej
                                <expan>ap<ex>osto</ex>li</expan>.</ab>
</div>
<div type="similiter">
<ab>Altman <expan>Kempnat<ex>er</ex></expan>
<expan>si<ex>mi</ex>l<ex>ite</ex>r</expan> nisi
                            <expan>mutat<ex>is</ex></expan>
<expan>mutand<ex>is</ex></expan>.</ab>
</div>
