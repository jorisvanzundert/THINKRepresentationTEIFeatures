<ab facs="#facs_210_r1l19"><expan>H<ex>einrich</ex></expan> <expan>vo<ex>n</ex></expan> <expan>Babemb<ex>er</ex>g</expan> / <expan>Laſſ<ex>en</ex></expan> wir <expan>ew<ex>r</ex></expan> <expan>erberk<ex>eit</ex></expan> <expan>vvıſſ<ex>en</ex></expan> . daʒ <expan>H<ex>einrich</ex></expan> Troſtperg </ab>
<ab facs="#facs_210_r1l20">vnd <expan>H<ex>einrich</ex></expan> <expan>v̈ltfeld<ex>er</ex></expan> bede <expan>yecʒunde<ex>n</ex></expan> nicht anheim ſind / So ıſt <expan>heinr<ex>ich</ex></expan> </ab>
