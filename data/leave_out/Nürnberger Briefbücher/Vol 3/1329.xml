<ab facs="#facs_429_r1l3">cʒu dem Berg / Grafe cʒu <expan>Raue<ex>n</ex>ſperg</expan> vnd <expan>h<ex>er</ex>re</expan> cʒu <expan>Blankenb<ex>er</ex>g</expan> </ab>
</div>
