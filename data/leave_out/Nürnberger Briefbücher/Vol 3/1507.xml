<div type="addressee">
<ab facs="#facs_528_r1l28"><expan>De<ex>m</ex></expan> Kecʒelſtorffer Hercʒog </ab>
<ab facs="#facs_528_r1l29"><expan>Joh<ex>ans</ex></expan>
<expan>Kuche<ex>n</ex>meiſter</expan>
</ab>
</div>
