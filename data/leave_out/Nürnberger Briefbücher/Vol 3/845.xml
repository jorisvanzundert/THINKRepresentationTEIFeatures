<ab facs="#facs_176_r2l23">ſeinen gank laſſen / . wo etc <expan>dat<ex>um</ex></expan> <expan>f<ex>er</ex>ıa</expan> iij̃ <expan>p<ex>oſt</ex></expan> <expan>Om<ex>n</ex>ȷ</expan> <expan>S<ex>an</ex>c<ex>t</ex>o<ex>rum</ex></expan> </ab>
