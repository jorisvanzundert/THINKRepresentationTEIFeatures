                                <expan>uns<ex>er</ex>s</expan>
<expan>burg<ex>er</ex>s</expan>, <expan>selige<ex>n</ex></expan>
<expan>erb<ex>e</ex>n</expan> czuklagen hab; lasz wir
                            <expan>ew<ex>r</ex></expan>
<expan>erberk<ex>eit</ex></expan> wissen, daz Hans Tintner,
                                <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan>, <add>sein sun</add>, czu der czeit niht
                        anheim <add>ist</add>; <expan>dan<ex>n</ex></expan>
<expan>wen<ex>n</ex></expan> derselb <expan>ew<ex>r</ex></expan> armman acht
                        tag vor <expan>uns<ex>er</ex></expan>
<expan>fr<ex>awen</ex></expan> tag liehtmesse <add>schierst</add> her czu
                        uns kumt, so <expan>wölle<ex>n</ex></expan> wir im <add>slewnigs</add>
                        rehten gern <expan>helffe<ex>n</ex></expan> von den
                            <expan>uns<ex>er</ex>n</expan>, czu den er cze
                            <expan>sprech<ex>e</ex>n</expan> hat, die <expan>dan<ex>n</ex></expan>
                        anheim sind <expan>ongeu<ex>er</ex>de</expan>. <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>ri</ex>a</expan> ii <expan>p<ex>ost</ex></expan> Erhardi
                                <expan>a<ex>nno</ex></expan>
<expan>undeci<ex>m</ex>o</expan>.</ab>
