<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Ersam<ex>er</ex></expan>, <expan>lieb<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, als wir <expan>ewr<ex>er</ex></expan> ersamkeit
                        vormals <expan>v<ex>er</ex>schr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan>
<expan>vo<ex>n</ex></expan>
<expan>Wilh<ex>elm</ex></expan> Rumels des <expan>jüng<ex>er</ex>n</expan>
                        und <expan>Hanse<ex>n</ex></expan>
<expan>Prünst<ex>er</ex>s,</expan>
<expan>uns<ex>er</ex>r</expan>
<expan>b<ex>ur</ex>g<ex>er,</ex></expan>
<expan>weg<ex>en,</ex></expan>
<add>daz</add> uns ir frewnde fürbraht <expan>het<ex>e</ex>n</expan>,
                        <add>wie</add> sich als hewre czü <app><note><q type="date"><expan>ost<ex>er</ex>n</expan></q>03.04.1412</note></app>, do
                                <expan>diselb<ex>e</ex>n</expan> czwen <expan>uns<ex>er</ex></expan>
<expan>b<ex>ur</ex>g<ex>er</ex></expan> czü Höeste
                            <expan>gewes<ex>en</ex></expan> wern, gefügt het, daz sie
                                <expan>ungev<ex>er</ex>lichen</expan> czü
                            <expan>de<ex>m</ex></expan> slosze <expan>gegange<ex>n</ex></expan>
<expan>w<ex>er</ex>en;</expan> darumb ir sie, als ir sie dann nicht erkant,
                                <expan>aufhalt<ex>e</ex>n</expan> lieszet, und als ew gesagt würd,
                        daz sie von hynnan weren, da lieszt ir sie ledig in sölicher masze, daz sie
                        vor uns sweren und wir ew <expan>vo<ex>n</ex></expan> iren
                                <expan>wege<ex>n</ex></expan>
<expan>schreib<ex>e</ex>n</expan>
<expan>solt<ex>e</ex>n</expan> in <expan>ein<ex>er</ex></expan> czeit, als
                                <expan>dan<ex>n</ex></expan> benant würd; dabey auch die
                                <expan>and<ex>er</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger,</ex></expan> ir frewnd, <expan>sprech<ex>e</ex>n,</expan>
                        daz die <expan>obgen<ex>anten</ex></expan>
<expan>Wilh<ex>elm</ex></expan> und Hans in nötlichen gescheften beide ir
                        selbs und <expan>ir<ex>er</ex></expan> frewnd awszen
                            <expan>w<ex>er</ex>en</expan> und so kürczlichen czü uns herheim nicht
                                <expan>kume<ex>n</ex></expan>
<expan>möht<ex>e</ex>n</expan>, as sie auch bede noch awszen sein und sider
                        her herheim <add>nicht</add>
<expan>kume<ex>n</ex></expan> sind. <expan>Lieb<ex>er</ex></expan>
<expan>h<ex>e</ex>r,</expan> als wir <expan>ewr<ex>er</ex></expan> erberkeit
                                <expan>dan<ex>n</ex></expan> vor auch
