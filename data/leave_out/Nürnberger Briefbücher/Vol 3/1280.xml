<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Lib<ex>e</ex>n</expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                                <expan>v<ex>er</ex>schr<ex>iben</ex></expan> habt
                                <expan>vo<ex>n</ex></expan> Jacob <expan>Topl<ex>er</ex>s</expan>,
                                <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>ur</ex>g<ex>er</ex>s</expan>, und des
                            <expan>Ulr<ex>ich</ex></expan> Heyfels <expan>weg<ex>en</ex></expan>,
                                <expan>hab<ex>e</ex>n</expan> wir <expan>ewr<ex>e</ex>n</expan>
                        briefe wol <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                                <expan>danke<ex>n</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan>
<expan>fleizzikl<ex>ich</ex></expan>
<expan>sölich<ex>er</ex></expan> müwe, als ir
                            <expan>daryn<ex>n</ex>e</expan>
<expan>d<ex>ur</ex>h</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> gehabt habt. Und
                            <expan>hab<ex>e</ex>n</expan> den <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan>
<add>und auch <expan>ande<ex>r</ex></expan>
<expan>sein<ex>er</ex></expan>
<expan>geswistr<ex>en</ex></expan> frewnde</add>
<expan>ewr<ex>e</ex>n</expan> brief <expan>höre<ex>n</ex></expan>
<expan>lasse<ex>n</ex></expan> und die <expan>habe<ex>n</ex></expan> uns
                        darauf <expan>geantw<ex>ur</ex>t</expan>, sie wollen den fride, den ir
                        beredt habt, <expan>hieczwisch<ex>e</ex>n</expan> und
                        <app><note><q type="date"><add><expan>de<ex>m</ex></expan>
<expan>nehst<ex>e</ex>n</expan></add> sant
                        <expan>Walp<ex>ur</ex>g<ex>en</ex></expan> tag</q>01.05.1412</note></app> und den tag allen
                            <add>mit im und seinen <expan>helff<ex>er</ex>n</expan></add>
<expan>halt<ex>e</ex>n</expan> und <add>mit im</add> einen
                                <expan>gütlich<ex>e</ex>n</expan> tag bey ew czü
                        <expan>Rot<ex>emburg</ex></expan> süchen <app><note><q type="date">auf den suntag
                            <expan>reminisce<ex>re</ex></expan></q>28.02.1412</note></app> in <expan>d<ex>er</ex></expan>
<expan>vaste<ex>n</ex></expan> nu schirst czü
                            <expan>recht<ex>er</ex></expan> tag czeit. Dann als ir schreibt
                                <expan>vo<ex>n</ex></expan>
<expan>d<ex>er</ex></expan> prantschaczung, das dunkt sie fremde und mainen,
                        daz das ungewönlich sey und daz das <expan>ungev<ex>er</ex>lich</expan>
                        bestee, biz man czü <expan>eine<ex>m</ex></expan>
<expan>gütlich<ex>e</ex>n</expan> tag kumt, da man
                            <expan>vo<ex>n</ex></expan>
<expan>de<ex>n</ex></expan> und <expan>and<ex>er</ex>n</expan> sachen rede;
                        und wil er das also <expan>ausneme<ex>n</ex></expan> und besteen
                                    <add><expan>lasse<ex>n</ex></expan></add>, das lasset uns
                                <expan>wid<ex>er</ex></expan>
<expan>wisse<ex>n</ex></expan> bey <expan>dise<ex>m</ex></expan>
<expan>bot<ex>e</ex>n</expan>, so <expan>solle<ex>n</ex></expan> er und sein
                                <expan>helff<ex>er</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>d<ex>er</ex></expan> sache <expan>weg<ex>en</ex></expan> die
                                <expan>obg<ex>enante</ex></expan> czeite vor uns und den
                                <expan>uns<ex>er</ex>n</expan> auch sicher sein.</ab>
</div>
