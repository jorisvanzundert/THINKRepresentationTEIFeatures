<ab facs="#facs_404_r1l23">vnd <expan>danke<ex>n</ex></expan> <expan>ewr<ex>er</ex></expan> <expan>frewntſch<ex>aft</ex></expan> <expan>fleıʒʒikl<ex>ich</ex></expan> . <expan>ſölıch<ex>er</ex></expan> müwe / als Jr <expan>daryn<ex>n</ex>e</expan> </ab>
<ab facs="#facs_404_r1l24"><expan>d<ex>ur</ex>h</expan> <expan>vnſ<ex>er</ex>n</expan> <expan>wılle<ex>n</ex></expan> gehabt habt / . vnd <expan>hab<ex>e</ex>n</expan> den <expan>eg<ex>enanten</ex></expan> <expan>vnſ<ex>er</ex>n</expan> <expan>B<ex>urger</ex></expan>
<add><ab facs="#facs_404_line_1576479950935_529">vnd auch <expan>ande<ex>r</ex></expan> </ab><ab facs="#facs_404_line_1576479953732_534"><expan>ſeın<ex>er</ex></expan> <expan>geſwiſtr<ex>en</ex></expan> </ab><ab facs="#facs_404_line_1576479956122_539">frewnde </ab></add> <expan>ewr<ex>e</ex>n</expan> </ab>
<ab facs="#facs_404_line_1576479824927_399">brief <expan>höre<ex>n</ex></expan> <expan>laſſe<ex>n</ex></expan> / vnd die <expan>habe<ex>n</ex></expan> vns darauf <expan>geantw<ex>ur</ex>t</expan> / . Sie wollen </ab>
