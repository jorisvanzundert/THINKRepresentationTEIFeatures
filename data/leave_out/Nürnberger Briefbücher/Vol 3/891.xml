</div><div type="regularised"><pb facs="#facs_201" id="100r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>Conr<ex>ad</ex></expan>
<expan>vo<ex>n</ex></expan> Aufsezz, amptman czüm Hof </ab>
