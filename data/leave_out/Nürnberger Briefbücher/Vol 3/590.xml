<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, als uns ewr gnade
                                <expan>v<ex>er</ex>schr<ex>iben</ex></expan> hat von der
                                <expan>wege<ex>n</ex></expan>, die <expan>vo<ex>n</ex></expan>
<add>den</add>
<expan>h<ex>er</ex>ren</expan> und steten von lantfrids
                                <expan>weg<ex>en</ex></expan> czü Czeil
                            <expan>lige<ex>n</ex></expan>, <expan>hab<ex>e</ex>n</expan> wir
                                <expan>ew<ex>r</ex>n</expan> brief wol
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan> und wissen
                                <expan>and<ex>er</ex>s</expan> nicht, dann daz
                            <expan>d<ex>er</ex></expan> rate her czü
                            <expan>Nur<ex>emberg</ex></expan> die iren gevertiget und den
                                <expan>bevolh<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan>, als <add>man auf</add> dem lantfrid davon
                                <expan>geschied<ex>e</ex>n</expan> ist, <add>und mainen, daz an den
                                    <expan>uns<ex>er</ex>n</expan> kein geprech sey</add>. Het ewr
                        gnad aber <add>an den <expan>and<ex>er</ex>n</expan></add> iht geprechens,
                        das würdt ir an den hawbtman und die <expan>and<ex>er</ex>n</expan> dez
                        lantfrids bringen, wan uns das sünderlich niht
                            <expan>bevolh<ex>e</ex>n</expan> ist; und wo wir
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan>
<expan>gediene<ex>n</ex></expan>
<expan>möht<ex>en</ex></expan>, das <expan>w<ex>er</ex>n</expan> wir willig
                        und <expan>tet<ex>e</ex>n</expan> das <expan>allcz<ex>eit</ex></expan>
<expan>g<ex>er</ex>ne</expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> v <expan>an<ex>te</ex></expan> Thome
                                <expan>ap<ex>osto</ex>li</expan> ix<hi rend="sup">o</hi>.
                                <expan>Unt<ex>er</ex></expan>
<expan>Mert<ex>ein</ex></expan>
<expan>Hall<ex>er</ex>s</expan>
<expan>insig<ex>el</ex></expan>.</ab>
</div>
