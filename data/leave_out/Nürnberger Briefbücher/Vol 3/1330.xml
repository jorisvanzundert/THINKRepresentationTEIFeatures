<ab><expan>De<ex>n</ex></expan>
<expan>fursich<ex>tigen</ex></expan>, <expan>ers<ex>amen</ex></expan>
<expan>un<ex>d</ex></expan> weis<ex>en</ex>
<expan>h<ex>er</ex>ren</expan>
