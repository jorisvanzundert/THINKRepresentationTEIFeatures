<expan>gnade<ex>n</ex></expan>
<expan>schicke<ex>n</ex></expan> und <expan>bestelle<ex>n</ex></expan>
                        wöllet, daz <expan>uns<ex>er</ex></expan>
<expan>burge<ex>r</ex></expan> und kauff leute und auch ir hab und
                        kauffmanschaft <expan>yeczund<ex>en</ex></expan> in die messe etc.
                                <expan>p<ex>re</ex>cise</expan> ut <expan>sup<ex>ra</ex></expan>
<expan cert="unknown">n<ex>otatus</ex></expan>
