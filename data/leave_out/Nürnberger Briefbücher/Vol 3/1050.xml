<body><div type="diplomatic"><pb facs="#facs_279" id="139r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_279_r1l16">Bẏſſchoff cʒu <expan>vvircʒb<ex>ur</ex>g</expan> </ab>
</div>
