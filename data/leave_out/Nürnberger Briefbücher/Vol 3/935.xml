<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, uns hat fürgelegt
                                                  Hans Edellman, <expan>uns<ex>er</ex></expan>
                                                  burger, wie in <expan>H<ex>er</ex>man</expan>
                                                  Weiszgerber, <expan>ew<ex>r</ex></expan>
                                                  mitburger, gen <expan>Bamb<ex>er</ex>g</expan> auf
                                                  geistlich gerihte <expan>gelade<ex>n</ex></expan>
                                                  hab von schulde wegen, als der
                                                  <expan>ew<ex>r</ex></expan> maint, die im der
                                                  <expan>egen<ex>ante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> schuldig sein
                                                  sülle; darumb doch vormals des
                                                  <expan>egen<ex>anten</ex></expan>
<expan>ew<ex>r</ex>s</expan>
<expan>mitburg<ex>er</ex>s</expan> gewalt dem
                                                  <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan> hie vor gerihte
                                                  <expan>czugesproch<ex>e</ex>n</expan> hat, darauff
                                                  ein urteil gevellet ist worden.</del>
<expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, uns hat
                                                  <expan>fürg<ex>elegt</ex></expan> Hans Edellman,
                                                  <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan>, wie im
                                                  <expan>H<ex>er</ex>man</expan> Weiszgerber,
                                                  <expan>ew<ex>r</ex></expan>
<expan>mitburg<ex>er</ex></expan>, mit
                                                  <expan>seine<ex>m</ex></expan> gewalte, den er her
                                                geschickt het, ümb etliche schulde, als er maint,
                                                die im der <expan>eg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> schuldig sein sölt,
                                                hie vor gerihte
                                                  <expan>czugesproch<ex>e</ex>n</expan> hab; darauff
                                                ein urteil gefallen sey und darüber in der
                                                  <expan>eg<ex>enante</ex></expan>
<expan>ew<ex>r</ex></expan>
<expan>mitburg<ex>er</ex></expan>
<expan>yecz<ex>unden</ex></expan> gen
                                                  <expan>Bamb<ex>er</ex>g</expan> auf geistlich
                                                gerihte geladen hab.
                                                <expan>Ro<ex>gamus</ex></expan>, daz ir
                                                  <expan>denselb<ex>e</ex>n</expan>
<expan>ew<ex>r</ex>n</expan>
<expan>mitburg<ex>er</ex></expan> daran weisen
                                                wöllet, daz er von der klag auf
                                                  <expan>geistl<ex>ich</ex></expan> gerihte lasse.
                                                Das wollen etc. Und het er
                                                  <expan>dan<ex>n</ex></expan> czu
                                                  <expan>de<ex>m</ex></expan>
<expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan> icht
                                                  <expan>czuspr<ex>echen</ex></expan>,
                                                  <expan>dar<ex>umb</ex></expan>
<expan>wölle<ex>n</ex></expan> wir im
                                                  <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbot<ex>en</ex></expan> etc. ut in
                                                  <expan>for<ex>ma</ex></expan>.
                                                  <expan>Antw<ex>ur</ex>t</expan> etc.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>sabb<ex>a</ex>to</expan>
<expan>p<ex>ost</ex></expan> Dorothee.</ab>
</div>
