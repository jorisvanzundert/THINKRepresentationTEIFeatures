<ab facs="#facs_211_r2l21">er <expan>darüb<ex>er</ex></expan> cʒü <expan>de<ex>n</ex></expan> <expan>vnſ<ex>er</ex>n</expan> ıht <expan>cʒeſprech<ex>e</ex>n</expan> het / <expan>Dar<ex>vmb</ex></expan> <expan>vvöll<ex>en</ex></expan> wir Jm </ab>
<ab facs="#facs_211_r2l22"><expan>od<ex>er</ex></expan> <expan>ſeine<ex>m</ex></expan> <expan>ſcheimbot<ex>en</ex></expan> mit <expan>ſeine<ex>m</ex></expan> <expan>volle<ex>n</ex></expan> gewalt <expan>vnu<ex>er</ex>cʒog<ex>en</ex></expan> <expan>ſlewnig<ex>en</ex></expan> </ab>
<ab facs="#facs_211_r2l23">recht <expan>g<ex>er</ex>ne</expan> <expan>helff<ex>en</ex></expan> wenn vvir des ermant <expan>w<ex>er</ex>d<ex>e</ex>n</expan> ſo <expan>d<ex>er</ex>ſelb</expan> <expan>vnſ<ex>er</ex></expan> <expan>B<ex>urger</ex></expan> </ab>
<ab facs="#facs_211_r2l24"><expan>anh<ex>eim</ex></expan> ıſt / vnd vvo etc <expan>ewr<ex>er</ex></expan> <expan>Erſ<ex>amkeit</ex></expan> <expan>vveiſh<ex>eit</ex></expan> lieb vnd dinſt bevveiſen </ab>
