                                                  <expan>gnade<ex>n</ex></expan> schicken und
                                                  <expan>bestelle<ex>n</ex></expan> wölle</add>, daz
                                                dem <expan>vorgen<ex>anten</ex></expan>
<expan>uns<ex>er</ex>m</expan> burger
