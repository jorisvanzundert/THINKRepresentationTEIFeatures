                                                  <expan>worde<ex>n</ex></expan>, darumb wir
                                                  <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>,
                                                  <expan>h<ex>e</ex>rczog</expan>
<expan>Heinr<ex>ich</ex></expan>, vormals etwieofft
                                                  <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan>.
                                                  <expan>Ro<ex>gamus</ex></expan>, daz ir dem
                                                  <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan> gen
                                                  <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> ewr günstige
