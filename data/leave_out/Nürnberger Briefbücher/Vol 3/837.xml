<body><div type="diplomatic"><pb facs="#facs_172" id="85v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_172_r2l1">Bẏſſchoff cʒu Eẏſtet </ab>
</div>
