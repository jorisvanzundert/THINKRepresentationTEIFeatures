<ab facs="#facs_477_r1l16">freuntlich recht <expan>vngeu<ex>er</ex>lıch<ex>e</ex>n</expan> vnd vvo wir etc <expan>dat<ex>um</ex></expan> <expan>f<ex>er</ex>ıa</expan> <expan>ſ<ex>e</ex>c<ex>un</ex>da</expan> </ab>
