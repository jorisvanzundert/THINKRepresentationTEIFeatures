<ab facs="#facs_477_r1l14">vvıldenſteinerin <expan>vnſ<ex>e</ex>r</expan> <expan>burg<ex>er</ex>ın</expan> <expan>hab<ex>e</ex>n</expan> vvir <expan>ewr<ex>e</ex>n</expan> brief wol <expan>v<ex>er</ex>nome<ex>n</ex></expan> </ab>
