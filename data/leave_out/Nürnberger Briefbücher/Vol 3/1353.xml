<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Lieb<ex>er</ex></expan> Wolfhart, als ir uns
                                <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> habt
                                <expan>vo<ex>n</ex></expan> des <expan>arme<ex>n</ex></expan> mannes
                                <expan>weg<ex>en</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Kalte<ex>n</ex>prunn,</expan>
<expan>hab<ex>e</ex>n</expan> wir <expan>ew<ex>r</ex>n</expan> brief wol
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                            <expan>lasse<ex>n</ex></expan>
<expan>ew<ex>r</ex></expan>
<expan>erberk<ex>eit</ex></expan> wissen, daz der bey uns cze vanknüzz
                                <expan>kume<ex>n</ex></expan> ist <expan>vo<ex>n</ex></expan> sache
                                <expan>wege<ex>n,</ex></expan> der man in beschuldigt,
                                <expan>daru<ex>m</ex>b</expan> wir uns wol czü
                                <expan>ervare<ex>n</ex></expan> mainen und wöllen uns an im nicht
                                <expan>v<ex>er</ex>gehen</expan>. Und wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb und
                            <expan>frewntsch<ex>aft</ex></expan>
<expan>beweise<ex>n</ex></expan>
<expan>möht<ex>en</ex></expan>, das <expan>tet<ex>e</ex>n</expan> wir
                                <expan>allcz<ex>eit</ex></expan>
<expan>g<ex>er</ex>ne</expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii pasche.</ab>
</div>
