<expan>vnſ<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> dem künig </ab>
<ab facs="#facs_10_line_1573554397225_139">
<del rend="strikethrough">gnaden </del> / fürderlich vnd beholffen ſein
