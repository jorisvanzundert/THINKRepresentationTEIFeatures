<body><div type="diplomatic"><pb facs="#facs_438" id="218v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab facs="#facs_438_r1l6">Der Edeln frawen / <expan>h<ex>er</ex>n</expan> Borſen
                        von Rẏſemburg </ab>
<ab facs="#facs_438_r1l7"><expan>elıch<ex>e</ex>n</expan>
<expan>vvıtıb<ex>e</ex>n</expan> pflegerin cʒu Tauſt <expan cert="medium">d<ex>etur</ex></expan>
</ab>
</div>
