<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Lieb<ex>e</ex>n</expan>
<expan>h<ex>er</ex>ren</expan>, als ir uns
                                <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> habt von wegen
                                <expan>Heinr<ex>ich</ex></expan> Trostpergs,
                            <expan>uns<ex>er</ex>s</expan>
<expan>burg<ex>er</ex>s</expan>, und <expan>Heinr<ex>ich</ex></expan>
<expan>Ultfeld<ex>er</ex>s</expan>, <expan>uns<ex>er</ex>s</expan>
<expan>dien<ex>er</ex>s</expan>, und auch <expan>Joh<ex>an</ex></expan>
<expan>Lantschreib<ex>er</ex>s</expan> und <expan>Heinr<ex>ich</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Bamb<ex>er</ex>g</expan>, <expan>lass<ex>en</ex></expan> wir
                                <expan>ew<ex>r</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz <expan>d<ex>er</ex></expan> Trostperg
                        und <expan>d<ex>er</ex></expan>
<expan>Ültfeld<ex>er</ex></expan> bede czü <expan>d<ex>er</ex></expan> czeit
                        nicht anheim sind; so ist <expan>Heinr<ex>ich</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Bamb<ex>er</ex>g</expan> nicht <expan>uns<ex>er</ex></expan>
<expan>b<ex>ur</ex>g<ex>er</ex></expan> noch <expan>dien<ex>er</ex></expan>;
                        und wir <expan>hab<ex>e</ex>n</expan> den <expan>eg<ex>enanten</ex></expan>
<expan>Joh<ex>an</ex></expan>
<expan>Lantschr<ex>eiber</ex></expan> besant und in
                            <expan>ew<ex>r</ex>n</expan> brief <expan>lasse<ex>n</ex></expan> hören
                        und <expan>d<ex>er</ex></expan> spricht, ir habt im darumb auch
                                <expan>geschrib<ex>e</ex>n</expan>, darauf er ew
                                <expan>selb<ex>er</ex></expan>
<expan>wid<ex>er</ex></expan>
<expan>geschrib<ex>e</ex>n</expan> und <expan>geantw<ex>ur</ex>t</expan>
                        hab; und wenn die <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> und <expan>dien<ex>er</ex></expan> her heim
                        kumen, so <expan>wölle<ex>n</ex></expan> wir sie darumb <add>auch</add> cze
                        red seczen und ew ir <expan>antw<ex>ur</ex>t</expan>
<expan>g<ex>er</ex>ne</expan> wissen lassen, ob uns
                            <expan>dan<ex>n</ex></expan>
<expan>yema<ex>n</ex>t</expan> von <expan>ew<ex>r</ex>n</expan>
<expan>wege<ex>n</ex></expan> daran manet. Und wo wir ew lieb und dinst
                                <expan>beweise<ex>n</ex></expan>
<expan>möht<ex>en</ex></expan>, das <expan>tet<ex>e</ex>n</expan> wir
                                <expan>allcz<ex>eit</ex></expan>
<expan>g<ex>er</ex>ne</expan>.</ab>
</div>
