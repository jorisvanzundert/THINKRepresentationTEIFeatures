<ab facs="#facs_94_r1l1">Hanſen vnd <expan>Pet<ex>er</ex></expan>
<expan>vo<ex>n</ex></expan> Tümfelt / <expan>vo<ex>n</ex></expan>
<expan>vlr<ex>ich</ex></expan>
<expan>Hall<ex>er</ex></expan>
</ab>
</div>
