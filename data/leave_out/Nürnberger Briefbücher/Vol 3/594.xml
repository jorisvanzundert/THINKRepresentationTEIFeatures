<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als wir Hansen
                        <expan>Mawr<ex>er</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, <expan>yeczund<ex>en</ex></expan> czu
                                <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>re<ex>n</ex></expan>, dem
                            <expan>römische<ex>n</ex></expan> künig,
                            <expan>schick<ex>en</ex></expan> von des guts wegen, als man den
                                <expan>uns<ex>er</ex>n</expan> in dem gepirg aufgehalten hat, haben
                        wir dem <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan>
<expan>bevolhe<ex>n</ex></expan>
<expan>sünd<ex>er</ex>liche<ex>n</ex></expan> mit
                            <expan>ew<ex>r</ex>n</expan> gnaden davon czureden. Und
                                <expan>ro<ex>gamus</ex></expan>, was <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> etc. <expan>gnediglich<ex>e</ex>n</expan>
                        verhören und <expan>ew<ex>r</ex></expan> hilff und
                            <expan>fürderu<ex>n</ex>g</expan> gen <expan>uns<ex>er</ex>m</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, dem künig, darczu tün wöllet, als wir czu
                                <expan>ew<ex>r</ex>n</expan> gnaden besunder
                                <expan>getrawe<ex>n</ex></expan> haben und umb ewr
                                <expan>hochw<ex>irdikeit</ex></expan> allzeit
                            <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan> wöllen. <expan>Dat<ex>um</ex></expan> in
                                <expan>vig<ex>i</ex>lia</expan>
<expan>nativi<ex>ta</ex><hi rend="sup">t<ex>is</ex></hi></expan>
<expan>Christi</expan> anno ix<hi rend="sup">o</hi>. </ab>
</div>
