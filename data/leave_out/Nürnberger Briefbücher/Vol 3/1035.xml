</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>e</ex>r</expan>, als wir die <expan>uns<ex>er</ex>n</expan> czü
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> geschicket <expan>hab<ex>e</ex>n</expan> von
                                <expan>d<ex>er</ex></expan> nam <expan>weg<ex>en</ex></expan>, als
                                <expan>dan<ex>n</ex></expan>
<expan>etlich<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>ur</ex>g<ex>er</ex>n</expan> und
                            <expan>kawflewt<ex>e</ex>n</expan>
<expan>gescheh<ex>e</ex>n</expan> ist, <expan>hab<ex>e</ex>n</expan> sie uns
                        wol <expan>embot<ex>e</ex>n</expan> und <expan>cze wisse<ex>n</ex></expan>
                        getan, daz sich ewr fürstlich hochwirdikeit <add>gar</add> gnediklich darumb
                                <expan>angenome<ex>n</ex></expan> und
                            <expan>ernstlich<ex>e</ex>n</expan> dar czü getan hab, dar czü hab
                                <expan>ew<ex>r</ex></expan> gnad <expan>vo<ex>n</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan>
<expan>de<ex>n</ex></expan>
<expan>edeln</expan>
<expan>h<ex>er</ex>ren</expan>, <expan>de<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan> Hanaw, auch <expan>botsch<ex>aft</ex></expan>
                        getan, des <add>aller wir</add>
<expan>ew<ex>r</ex>n</expan> gnaden czemal
                            <expan>fleizziklich<ex>e</ex>n</expan> danken. Und
                                <expan>ro<ex>gamus</ex></expan>, daz ir <expan>ew<ex>r</ex></expan>
                        gnad auch fürbas darczü wenden wollet, damit es den
                            <expan>uns<ex>er</ex>n</expan>
<add><expan>vo<ex>n</ex></expan>
<expan>ir<ex>er</ex></expan> hab</add>
<add><expan>weg<ex>en</ex></expan></add>
<add>vollen</add> czü awstrag und <expan>güte<ex>n</ex></expan> end kum
                            <add>und auch czü den sachen, als gen <expan>de<ex>n</ex></expan>
<add><expan>h<ex>er</ex>ren</expan></add>
<expan>vo<ex>n</ex></expan> Hanaw tün und <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>e</ex>n</expan> uns und die
                                <expan>uns<ex>er</ex>n</expan>
<expan>daryn<ex>n</ex>e</expan> gnediklich
                                <expan>bevolhe<ex>n</ex></expan> sein <expan>lasse<ex>n</ex></expan>
                            wöllet</add>, als wir <expan>ewr<ex>e</ex>n</expan>
<expan>fürstl<ex>ichen</ex></expan>
<expan>gnad<ex>e</ex>n</expan> des wol getrawen und umb
                                <expan>ewr<ex>er</ex></expan>
<expan>hochw<ex>irdikeit</ex></expan> czü allen
                            <expan>czeit<ex>e</ex>n</expan>
<expan>willekl<ex>ich</ex></expan> und <expan>g<ex>er</ex>ne</expan>
<expan>v<ex>er</ex>diene<ex>n</ex></expan>
<expan>wölle<ex>n</ex></expan>.</ab>
</div>
