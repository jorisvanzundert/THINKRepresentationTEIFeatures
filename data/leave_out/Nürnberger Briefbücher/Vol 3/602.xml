<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="head"><ab>Den <expan>hernachges<ex>chriben</ex></expan> <expan>p<ex>er</ex>son</expan> yeder ut in <expan>for<ex>ma</ex></expan> </ab></div>
<div type="content">
<ab>Edler und lieber <expan>h<ex>er</ex>re</expan>, wir
                            <expan>schicke<ex>n</ex></expan> czu <expan>uns<ex>er</ex>n</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Osterr<ex>eich</ex></expan>
<expan>Hanse<ex>n</ex></expan>
<expan>Camr<ex>er</ex></expan>, <expan>uns<ex>er</ex>n</expan> diener, von
                        der habe und <expan>kauffmans<ex>chaft</ex></expan>
<expan>wege<ex>n</ex></expan>, als den <expan>uns<ex>er</ex>n</expan> in
                                <expan>de<ex>m</ex></expan> gepirge
                            <expan>aufgehalte<ex>n</ex></expan> und damit der
                            <expan>uns<ex>er</ex>n</expan>
<add>etliche</add>
<expan>bekum<ex>er</ex>t</expan>
<expan>worde<ex>n</ex></expan> sein. Und <expan>Ro<ex>gamus</ex></expan>,
                        daz ir dem <expan>uns<ex>er</ex>m</expan> darynne
                            <expan>ew<ex>r</ex></expan> günstig hilff und
                            <expan>fürdr<ex>ung</ex></expan> gen
                            <expan>de<ex>n</ex>selb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>h<ex>er</ex>re<ex>n</ex></expan> von
                            <expan>Osterr<ex>eich</ex></expan>
<expan>beweise<ex>n</ex></expan> wollet, als etc. Das
                            <expan>wölle<ex>n</ex></expan> etc.</ab>
</div>
<div type="similiter">
<ab><expan>Berhtold<ex>en</ex></expan>, bysschoff czu
                            <expan>Freysing<ex>en</ex></expan>, <expan>oberst<ex>en</ex></expan>
                        kanczler, <lb/><expan>h<ex>er</ex>n</expan>
<expan>Görge<ex>n</ex></expan>, bysschof czu Passaw,
                                <expan>oberste<ex>n</ex></expan> kanczler,
                            <lb/><expan>h<ex>er</ex>n</expan> Hartman von
                            <expan>Potte<ex>n</ex>dorff</expan>, <expan>oberst<ex>en</ex></expan>
                        marschalk czu <expan>Ost<ex>erreich</ex></expan>,
                            <lb/><expan>h<ex>er</ex>n</expan> Otten von Meissaw,
                                <lb/><expan>h<ex>er</ex>n</expan>
<expan>Hanse<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan> Liehtenstein, <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>r<ex>en</ex></expan>, <expan>h<ex>e</ex>rczog</expan>
                            Leup<ex>old</ex>, <expan>hof<ex>meister</ex></expan>,
                                <lb/><expan>h<ex>er</ex>n</expan>
<expan>Kransperg<ex>er</ex></expan>, <expan>h<ex>er</ex>re</expan> zu
                                <expan>Pet<ex>er</ex>nell</expan>, dem grafen von
                                <expan>Meydb<ex>ur</ex>g</expan>, <lb/>dem
                            <expan>ersame<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, <expan>h<ex>er</ex>n</expan>
<expan>Con<ex>rad</ex></expan> von
                                Carst,
                                <expan>unt<ex>er</ex>kanczler</expan> czu
                            <expan>Oster<ex>reich</ex></expan>. </ab>
</div>
