<ab facs="#facs_268_r1l38">ew ſelber 
<del rend="strikethrough">ſein <expan>antvv<ex>ur</ex>t</expan> vnd <expan>maynu<ex>n</ex>g</expan> darümb <expan>v<ex>er</ex>ſchreib<ex>e</ex>n</expan></del></ab>
