<add><ab facs="#facs_268_r1l30"><expan>h<ex>er</ex>n</expan> <expan>Joh<ex>an</ex></expan> Poſſen vnd </ab></add> <expan>Heinr<ex>ich</ex></expan> <expan>Troſp<ex>er</ex>gs</expan> </ab>
<ab facs="#facs_268_r1l32"><expan>vnſ<ex>er</ex>s</expan> burgers vvegen / des danken vvir <expan>ewr<ex>er</ex></expan> freuntſchaft </ab>
<ab facs="#facs_268_r1l34">mit <expan>gancʒe<ex>m</ex></expan> fleiſʒ 
<add><ab facs="#facs_268_line_1576578899729_2114">vnd <expan>wölle<ex>n</ex></expan> das </ab><ab facs="#facs_268_line_1576578902305_2119">gern vmb ew </ab><ab facs="#facs_268_line_1576578905552_2124">verſchulden </ab></add> / vnd <expan>hab<ex>e</ex>n</expan> darümb den <expan>egen<ex>anten</ex></expan> ~ <expan>vnſ<ex>er</ex>n</expan> <expan>burg<ex>er</ex></expan> </ab>
