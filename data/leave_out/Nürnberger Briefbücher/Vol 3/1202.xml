<ab facs="#facs_362_r1l6">wir <expan>hab<ex>e</ex>n</expan> Jm <expan>wıd<ex>er</ex></expan> <expan>geſchrib<ex>e</ex>n</expan> vnd einen <expan>and<ex>er</ex>n</expan> tag <expan>beſchied<ex>e</ex>n</expan> </ab>
