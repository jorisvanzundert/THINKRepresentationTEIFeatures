<div type="regularised">
<pb facs="#facs_544" id="271v"/>
<!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab/>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="head">
<ab><expan>No<ex>ta</ex></expan>
<expan>b<ex>e</ex>n<ex>e</ex></expan></ab>
</div>
<div type="content">
<ab><expan>It<ex>em</ex></expan> ez ist <expan>fe<ex>ri</ex>a</expan> v
                                <expan>an<ex>te</ex></expan> Nycolay im rate erteilt worden anno
                            ix<hi rend="sup">no</hi> et <expan>o<ex>mn</ex>ib<ex>us</ex></expan>
<expan>sc<ex>ri</ex>pto<ex>r</ex>ib<ex>us</ex></expan>
<expan><ex>com</ex>missu<ex>m,</ex></expan> daz <add>man</add>
<expan>kheine<ex>m</ex></expan>
<expan>geistliche<ex>n</ex></expan> manne noch gotshause khein eygenschaft
                        an <expan>kheine<ex>m</ex></expan>
<add>hause noch</add> gute hie in der stat <expan>gelege<ex>n</ex></expan>
<expan>czuschreib<ex>e</ex>n</expan> sol, und bedarff auch niht darein
                                <expan>schreib<ex>e</ex>n,</expan> daz ez mit
                            <expan>ire<ex>m</ex></expan>
<expan>wille<ex>n</ex></expan>
<expan>gescheh<ex>e</ex>n</expan> sey. <expan>Dan<ex>n</ex></expan> allein
                        so sol das <expan>bleib<ex>e</ex>n</expan> bey der form, die
                                <expan>h<ex>er</ex>nach</expan>
<expan>v<ex>er</ex>czeiche<ex>n</ex>t</expan> ist.
                            <lb/><expan>It<ex>em</ex></expan> man sol in auch niht darein
                                    <add><expan>schreib<ex>e</ex>n</expan></add>, daz ez in an iren
                        rehten unschedlich sein sülle, <expan>wen<ex>n</ex></expan> czwen ein kauff
                        miteinander ümb ein hause tun etc. <expan>Dan<ex>n</ex></expan> man sol
                        allweg den czins darein <expan>schreib<ex>e</ex>n</expan> ut in
                                <expan>for<ex>ma</ex></expan>
<expan>subseq<ex>uen</ex>ti</expan>. <expan>It<ex>em</ex></expan> man hat
                        uns <expan>daru<ex>m</ex></expan> gesagt, daz wir
                            <expan>hinte<ex>n</ex>nach</expan>
<expan>schreib<ex>e</ex>n</expan>
<expan>sülle<ex>n</ex></expan> doch <expan>unschedl<ex>ich</ex></expan> den
                                <expan>geistlich<ex>e</ex>n</expan> etc. an
                            <expan>ire<ex>m</ex></expan>
<expan>eges<ex>chriben</ex></expan> czinse und
                            <expan>rechte<ex>n</ex></expan> etc. und <expan>solte<ex>n</ex></expan>
                        auch die <expan>vasnachthun<ex>er</ex></expan> hie aussen lassen. <add>Ad
                                    <expan>mand<ex>atum</ex></expan>
<expan>Joh<ex>an</ex></expan> Tucher</add>. <lb/><expan>P<ex>rop</ex><hi rend="sup">t</hi><ex>er</ex></expan> N., daz im N. etc. <expan cert="unknown">h. r. v. r.</expan>
<expan>czu k<ex>aufen</ex></expan>
<expan>g<ex>eben</ex></expan> ir hawse, czenehst an N.
                                <expan>geleg<ex>en</ex></expan>, darausz das gotshaus N. etc.
                                <expan>jerl<ex>ich</ex></expan> het N. etc. im etc. und gelobt in,
                        des also cze wern, als reht wer. <lb/><expan>It<ex>em</ex></expan> und sind
                                <expan>dan<ex>n</ex></expan> reht, die czu
                            <expan>de<ex>m</ex></expan> hause gehören, die sol man
                                <expan>dan<ex>n</ex></expan> auch czum
                            <expan>leczste<ex>n</ex></expan> hinczu <expan>secze<ex>n</ex></expan>,
                        also mit <expan>de<ex>m</ex></expan>
<expan>rehte<ex>n</ex></expan> etc. und auch mit der
                                <expan>bescheid<ex>en</ex></expan>, daz dasselb haus des
                                <expan>eg<ex>enanten</ex></expan> N. und
                            <expan>sein<ex>er</ex></expan>
<expan>erb<ex>er</ex>n</expan> erb sein sölt und etc. ut in
                                <expan>for<ex>ma</ex></expan>. <expan>It<ex>em</ex></expan> man sol
                        den <expan>geistlich<ex>e</ex>n</expan>
<expan>leute<ex>n</ex></expan>
<add>ire czins</add> voran <expan>schreib<ex>e</ex>n</expan>. <lb/>Auch ist
                        czu wissen, daz man khein brief <expan>unt<ex>er</ex></expan> des gerihts
                                <expan>ins<ex>igel</ex></expan> mer
                            <expan>schreib<ex>e</ex>n</expan> sol, do <expan>ein<ex>er</ex></expan>
<expan>de<ex>m</ex></expan>
<expan>and<ex>er</ex>n</expan> sein varnde habe, ez sein pferd,
                                <expan>wäge<ex>n</ex></expan> oder süst, wie das
                                <expan>gena<ex>n</ex>t</expan> sey, czu pfande einseczt und doch
                                <expan>dieselb<ex>e</ex>n</expan> varnde <add>hab</add> dannoch
                        selber <expan>ynne<ex>n</ex></expan> hat und die wendt und kert etc.</ab>
</div>
<div type="head">
<ab><pb facs="#facs_545" id="272r"/>Alia forma </ab>
</div>
<div type="content">
<ab>
<expan>P<ex>rop</ex><hi rend="sup">t</hi><ex>er</ex></expan>
<expan>Heinr<ex>ich</ex></expan> von Kulmach <expan>test<ex>is</ex></expan>
                        etc., daz im Hans Humel et <expan>Kung<ex>en</ex></expan>, uxor,
                                <expan>hete<ex>n</ex></expan> reht und redlich <expan>czu
                                k<ex>aufen</ex></expan>
<expan>geb<ex>e</ex>n</expan> ire czwey hewser, eins bey Frawntor, darynne
                        sie wonhaft <expan>w<ex>er</ex>n,</expan> darausz das gotshause czu sant
                                <expan>Seb<ex>olt</ex></expan>
<expan>jerl<ex>ich</ex></expan> het fünff pfunt
                                <expan>h<ex>a</ex>ll<ex>e</ex>r,</expan> und das ander, dabey in der
                        Golgengassen czenehst am Fügell <expan>gelege<ex>n,</ex></expan> darausz das
                        gotshaus czu sant <expan>Laurencze<ex>n</ex></expan>
<expan>jerl<ex>ich</ex></expan> het einhalb pfunt
                                <expan>h<ex>a</ex>ll<ex>e</ex>r</expan> mynder vier haller; im, dem
                                <expan>eg<ex>enanten</ex></expan>
<expan>Heinr<ex>ich</ex></expan> von Kulmach, <expan>Anne<ex>n</ex></expan>
                        uxori et <expan>h<ex>ere</ex><hi rend="sup">b</hi><ex>us</ex></expan>
<expan>cze hab<ex>e</ex>n</expan> und <expan>cze niesse<ex>n</ex></expan>
<expan>furb<ex>az</ex></expan> ewigklich und
                            <expan>gelobte<ex>n</ex></expan> sie, der also cze weren, als reht wer
                        mit der <expan>bescheydenh<ex>eit</ex></expan>, daz die
                                <expan>selb<ex>e</ex>n</expan> czwey hewser des
                                <expan>vorg<ex>enanten</ex></expan> Humels,
                            <expan>sein<ex>er</ex></expan> wirtin und <expan>ir<ex>er</ex></expan>
<expan>erb<ex>er</ex>n</expan> erb <expan>solte<ex>n</ex></expan> sein und
                                    <add><expan>jerlich<ex>e</ex>n</expan></add> den
                                <expan>obgen<ex>anten</ex></expan> goczhewsern,
                                <expan>mitname<ex>n</ex></expan> czu sant Sebolt fünff pfunt
                                <expan>h<ex>a</ex>ll<ex>e</ex>r</expan> ausz dem hause, darynne sie
                                <expan>yecz<ex>unden</ex></expan> wonhaft wern, und czu sant
                                <expan>Laur<ex>enczen</ex></expan> ein <add>halb</add> pfunt
                                    <add><expan>h<ex>a</ex>ll<ex>e</ex>r</expan></add> mynder vier
                                <expan>h<ex>a</ex>ll<ex>e</ex>r</expan> ausz
                            <expan>de<ex>m</ex></expan>
<expan>and<ex>er</ex>n</expan> hause an der Golgengassen
                                <expan>geleg<ex>en,</ex></expan>
<expan>geb<ex>e</ex>n</expan>
<expan>solte<ex>n;</ex></expan> und darczu solten sie <add>auch</add> von
                                <expan>denselb<ex>e</ex>n</expan> czwein hewsern dem
                                <expan>obg<ex>enanten</ex></expan>
<expan>H<ex>einrich</ex></expan> von Kulmach, <expan>Anne<ex>n</ex></expan>
                        uxori et <expan>h<ex>ere</ex><hi rend="sup">b</hi><ex>us</ex></expan>
<add>alle jar</add>
<expan>jerl<ex>ich</ex></expan> czinsen und <expan>geb<ex>e</ex>n</expan>
                        sechs <expan>guld<ex>en</ex></expan> der stat <expan>weru<ex>n</ex>g</expan>
                        czu <expan>Nur<ex>emberg</ex></expan> halb
                                <expan>Wallp<ex>ur</ex>g<ex>en</ex></expan>, Ɉ
                                <expan>Mich<ex>aelis</ex></expan>
<expan>fürb<ex>as</ex></expan> etc.</ab>
</div>
