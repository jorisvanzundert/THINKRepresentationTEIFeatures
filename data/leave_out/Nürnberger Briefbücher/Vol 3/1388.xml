<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><add><expan>Uns<ex>er</ex></expan>
<expan>fruntsch<ex>aft</ex></expan></add>,
                            <expan>lieb<ex>er</ex></expan>
<add>Fricz,</add> als <add>du</add> uns
                            <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<add>hast</add> von C. <expan>Pfincz<ex>ing</ex></expan>,
                                <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>ur</ex>g<ex>er</ex>s</expan>, <expan>weg<ex>en</ex></expan> und
                        eins halben tüchs <expan>vo<ex>n</ex></expan> Prüchsel,
                                <expan>lasse<ex>n</ex></expan> wir dich
                            <expan>wisse<ex>n,</ex></expan> daz derselb
                            <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> czü der czeit nicht anheim ist; doch wer es,
                        daz <add>du</add> darumb czü uns herein <expan>kume<ex>n</ex></expan>
                        woltst, wenn <add>du</add> dann <expan>hieczwisch<ex>e</ex>n</expan> und
                        <expan>de<ex>m</ex></expan> <app><note><q type="date">nehsten sant Johans tag czü sübenden</q>24.06.1412</note></app>
                        herein <add>wilt</add>, so solt du unser geleitte vier tag
                                <expan>hab<ex>e</ex>n</expan> czü uns und
                            <expan>vo<ex>n</ex></expan> uns, für uns und alle die
                                <expan>uns<ex>er</ex>n</expan> und bey uns in
                            <expan>d<ex>er</ex></expan> stat für allermeniklich
                                <expan>ungev<ex>er</ex>lichen</expan>. Als <add>du</add> uns
                                <expan>dan<ex>n</ex></expan> auch <expan>geschrib<ex>e</ex>n</expan>
                        hast <expan>vo<ex>n</ex></expan> eins pferds <expan>wege<ex>n</ex></expan>,
                        das <add>dir</add> gen Lawffe hinein ein entloffen sey,
                                <expan>denselb<ex>e</ex>n</expan> brief
                            <expan>hab<ex>e</ex>n</expan> wir <expan>Pet<ex>er</ex></expan>
<expan>Hall<ex>er</ex></expan> und Hansen Teczel,
                            <expan>unse<ex>r</ex></expan>
<expan>lieb<ex>e</ex>n</expan>
<expan>burge<ex>r</ex></expan> und <expan>ratgesell<ex>e</ex>n</expan>,
                        hören lassen und die <expan>sprech<ex>e</ex>n</expan>, daz sie sich darumb
                        an <expan>ire<ex>m</ex></expan> amptman und den <expan>vo<ex>n</ex></expan>
                        Lawffe ervaren wöllen und <add>dir</add>
<expan>selb<ex>er</ex></expan> ein <expan>antw<ex>ur</ex>t</expan>
<expan>schreib<ex>e</ex>n.</expan>
