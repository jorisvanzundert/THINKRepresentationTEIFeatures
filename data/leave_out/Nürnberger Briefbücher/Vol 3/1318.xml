<expan>Gorge<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Lıechte<ex>n</ex>ſt<ex>ein</ex></expan> /
                            <expan>dẏecʒe<ex>n</ex></expan> Marſchalk </ab>
<ab facs="#facs_424_r1l4"><expan>Erhart<ex>e</ex>n</expan>
<expan>vo<ex>n</ex></expan>
<expan>Liechte<ex>n</ex>ſtein</expan> vnd <expan>Eberhart<ex>e</ex>n</expan>
                        fuchs vormals <expan>v<ex>er</ex>ſchr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan>
</ab>
<ab facs="#facs_424_r1l5"><expan>hab<ex>e</ex>n</expan> vvir
