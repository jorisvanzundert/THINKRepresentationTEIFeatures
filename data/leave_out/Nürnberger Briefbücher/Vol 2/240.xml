<div type="linguisticAnalysis"><ab><w join="" lemma="" msd="" part="" pos=""><fLib><f name=" "/></fLib></w></ab></div>
</front>
<body><div type="diplomatic"><pb facs="#facs_138" id="67v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_138_r1l22">Oſwalten Lengenfelder cʒü <expan>VVelchemb<ex>er</ex>g</expan> / . </ab>
</div>
