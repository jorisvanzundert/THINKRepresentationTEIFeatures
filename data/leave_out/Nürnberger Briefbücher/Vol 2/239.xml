<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Johan<ex>n</ex></expan>, als <expan>Conr<ex>ad</ex></expan> Newsteter
                        des <expan>Ulr<ex>ich</ex></expan> Hallers, Conrad
                                <expan>Paumg<ex>artner</ex></expan> und Peringer Schuczen,
                                <expan>uns<ex>er</ex></expan> burger, armenlewte auf
                                <expan>uns<ex>er</ex>s</expan> gnedigen
                            <expan>h<ex>er</ex>ren</expan>, des <expan>römisch<ex>e</ex>n</expan>
                        künigs, hofgerihte <add>hat</add> geladen, davon auch der
                                <expan>eg<ex>enante</ex></expan>
<expan>Ulr<ex>ich</ex></expan> Haller nehst mit euch czu
                                <expan>Rotemb<ex>ur</ex>g</expan> auf der Tauber geredt
                            <add>hat</add>. Also <expan>bite<ex>n</ex></expan> wir ewr
                                <expan>erberk<ex>eit</ex></expan>
<expan>fleiss<ex>iklichen</ex></expan>, daz ir durch
                            <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>ew<ex>r</ex></expan> hilff und <expan>fürdru<ex>n</ex>g</expan>
                        darczu tun wollet, daz der <expan>eg<ex>enanten</ex></expan>,
                                <expan>uns<ex>er</ex>r</expan>
<expan>burg<ex>er</ex></expan>, armleute <add>her</add> heim geweyset
                        werden, als etc. Das <expan>wölle<ex>n</ex></expan> etc. Und het
                                <expan>dan<ex>n</ex></expan> der <expan>egen<ex>ante</ex></expan>
<expan>Conr<ex>ad</ex></expan> Newstetter czu
                            <expan>denselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>armenleute<ex>n</ex></expan> icht <expan>zusprech<ex>e</ex>n</expan>,
                                <expan>dar<ex>umb</ex></expan> so <expan>wölle<ex>n</ex></expan> die
                                <expan>eg<ex>enanten</ex></expan>, <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheimbot<ex>en</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>volle<ex>n</ex></expan> gewalte <add>von
                                <expan>dens<ex>elben</ex></expan> iren
                                <expan>armenleut<ex>en</ex></expan></add>
<expan>unv<ex>er</ex>czog<ex>en</ex></expan> sleunigs
                            <expan>rehte<ex>n</ex></expan>
<expan>g<ex>er</ex>n</expan> helffen, <expan>wen<ex>n</ex></expan> sie des
                        ermant <expan>werde<ex>n</ex></expan>. <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>r</ex>ia</expan> ii post Katherine anno viii<hi rend="sup">vo
                        </hi></ab>
</div>
