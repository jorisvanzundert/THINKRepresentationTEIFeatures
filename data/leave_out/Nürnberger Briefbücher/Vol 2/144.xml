                        ir durch <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> dem <expan>egen<ex>anten</ex></expan> Thomas
                                <expan>Ratgeb<ex>e</ex>n</expan> gen
                                    <expan><expan>de<ex>n</ex>selb<ex>e</ex>n</expan></expan>
<expan>meist<ex>er</ex>n</expan> des <expan>egen<ex>anten</ex></expan>
                        hantwerks <expan>ew<ex>r</ex></expan> günstige
                            <expan>fürdru<ex>n</ex>g</expan> beweisen wöllet, daz sie in
                            <add>unbekumert und in</add>
<expan>gütlich<ex>e</ex>n</expan> von in <expan>kume<ex>n</ex></expan>
                        lassen. Das <expan>wölle<ex>n</ex></expan> etc.</ab>
