<ab facs="#facs_82_line_1574359523541_306"><expan>antvv<ex>ur</ex>t</expan> <expan>wıd<ex>er</ex></expan> cʒu vviſſen / <expan>dat<ex>um</ex></expan> <expan>fe<ex>ri</ex>a</expan> ṽ <expan>p<ex>oſt</ex></expan> vlrici A viij<hi rend="sup">uo</hi></ab>
