<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, uns hat furgelegt
                                                Conrad <expan>Weissenburg<ex>er</ex></expan>,
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, wie daz man in czu
                                                Beheim gefangen hab für einen, den
                                                  <expan>ewr<ex>er</ex></expan>
                                                burgermeister, her <expan>Heinr<ex>ich</ex></expan>
                                                Nothaft, in <expan>seine<ex>n</ex></expan>
<expan>slosze<ex>n</ex></expan> und fencknüsse
                                                  <add>gefangen ligen</add> hab, der im von Beheim
                                                herausz zugefürt sey worden, und spricht auch der
                                                  <expan>eg<ex>enante</ex></expan>,
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, daz er niht ledig
                                                werden müg, ez sey <expan>dan<ex>n</ex></expan>, daz
                                                der <expan>egen<ex>ante</ex></expan>,
                                                  <expan>ew<ex>r</ex></expan> burger meister,
                                                  <expan>denselb<ex>e</ex>n</expan>, den er
                                                  <add>also</add> in <expan>sein<ex>er</ex></expan>
                                                venknüsse hab, ledig lasse; nu mag
                                                  <expan>ew<ex>r</ex></expan> weisheit wol
                                                  <expan>v<ex>er</ex>sten</expan>, solt der
                                                  <expan>egen<ex>ante</ex></expan>,
                                                  <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan>, also für den, den
                                                  <expan>ew<ex>r</ex></expan>
<expan>egen<ex>anten</ex></expan> burgermeister in
                                                  <expan>sein<ex>er</ex></expan> venknüsse hat, als
                                                uns <expan>fürgeb<ex>e</ex>n</expan> ist, leyden und
                                                gefangen sein, damit er doch nihts czeschicken hat,
                                                daz dem <expan>uns<ex>er</ex>n</expan> gar
                                                  <expan>ungütliche<ex>n</ex></expan> daran
                                                geschehe. <expan>Dar<ex>umb</ex></expan>
<expan>ro<ex>gamus</ex></expan>, daz ir
                                                  <expan>d<ex>ur</ex>h</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>de<ex>m</ex></expan>
<expan>egen<ex>anten</ex></expan>,
                                                  <expan>uns<ex>er</ex>m</expan>
<expan>b<ex>urger</ex></expan>, gen
                                                  <expan>demselb<ex>e</ex>n</expan>
<expan>ew<ex>r</ex>m</expan> burgermeister ewr
                                                hilff, <expan>fürdru<ex>n</ex>g</expan> und
                                                  <expan>gute<ex>n</ex></expan>
<expan>wille<ex>n</ex></expan> beweisen wöllet, ob
                                                derselb <expan>ew<ex>r</ex></expan>
<expan>burg<ex>er</ex>meister</expan> den, den er
                                                also in <expan>sein<ex>er</ex></expan> venknüsse
                                                hat, ledig wolt lassen, den worten, daz der
                                                  <expan>vorgen<ex>ante</ex></expan>,
                                                  <expan>uns<ex>e</ex>r</expan> burger, auch ledig
                                                würde. Das <expan>wölle<ex>n</ex></expan> etc. Und
                                                biten des <expan>ew<ex>r</ex></expan> freuntlich
                                                  <expan>v<ex>er</ex>schr<ex>iben</ex></expan>
<expan>antw<ex>ur</ex>t</expan>
<expan>wid<ex>er</ex></expan> czu wissen.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>ri</ex>a</expan> v
                                                  <expan>p<ex>ost</ex></expan> Ulrici a viii<hi rend="sup">vo</hi>.</ab>
</div>
