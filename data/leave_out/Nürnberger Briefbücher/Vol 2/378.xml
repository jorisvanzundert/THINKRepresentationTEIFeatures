<ab facs="#facs_214_r1l39">
<del rend="strikethrough"><expan>vnſ<ex>er</ex>n</expan> <expan>vville<ex>n</ex></expan></del> / <expan>de<ex>m</ex></expan> <expan>eg<ex>enanten</ex></expan> ~ <expan>vnſ<ex>er</ex>m</expan> burger / daſſelb ſein pellein </ab>
