<body><div type="diplomatic"><pb facs="#facs_70" id="33v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><del rend="crossout"><ab facs="#facs_70_r3l20"><expan>H<ex>er</ex>n</expan> Hanſen von Hawſen <expan>Ritt<ex>er</ex></expan> </ab>
<ab facs="#facs_70_r3l21">vnd <expan>Seitʒe<ex>n</ex></expan> von Hawſen <expan>ſeine<ex>m</ex></expan> <expan>vett<ex>er</ex>n</expan> </ab>
