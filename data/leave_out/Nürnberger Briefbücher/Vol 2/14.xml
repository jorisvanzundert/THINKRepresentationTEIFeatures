<add><ab facs="#facs_10_line_1576651638545_298">vnd bey <expan>de<ex>m</ex></expan> <expan>M<ex>a</ex>rkart<ex>en</ex></expan> </ab><ab facs="#facs_10_line_1576651640999_303">waltman <expan>vnſ<ex>er</ex>m</expan> </ab><ab facs="#facs_10_line_1576651643595_308">dıener empoten </ab></add>
<del rend="strikethrough"> vnd gebeten </del>
<add><ab facs="#facs_10_r1l6">
<del rend="strikethrough">empoten </del></ab></add> haben von Mertein Gewders vnd Matheis </ab>
<ab facs="#facs_10_r1l10">wenigheincʒen <expan>vnſ<ex>er</ex>r</expan> <expan>Burge<ex>r</ex></expan> wegen / <expan>hab<ex>e</ex>n</expan> wir <expan>ew<ex>r</ex>n</expan> <expan>gnade<ex>n</ex></expan> </ab>
