<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Lieb<ex>er</ex></expan>
<expan>Conr<ex>ad</ex></expan>, uns hat <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>r</expan>, <expan>burgg<ex>ra</ex>f</expan> Johans,
                                <expan>geschrib<ex>e</ex>n</expan>, wie du den
                            <expan>H<ex>er</ex>man</expan> Kriechenvogt, seinen
                                <expan>dien<ex>er</ex></expan>, auf geistlich gerichte
                                <expan>gelad<ex>e</ex>n</expan> habst. Nu heiszen wir dich, daz du
                                <expan>diselb<ex>e</ex>n</expan> klage also besteen lassest und
                        nicht <expan>v<ex>er</ex>rer</expan> treibst, alslang bis du czü uns kumst
                        und daz wir mit dir davon reden, und die weil nichts dar czü tüst.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii <expan>an<ex>te</ex></expan> Anthonii.</ab>
