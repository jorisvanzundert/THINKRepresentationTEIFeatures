<ab facs="#facs_212_r2l12"><expan>v<ex>er</ex>ſloʒʒe<ex>n</ex></expan> in <expan>dıſe<ex>m</ex></expan> briefe / . Nu ıſt <expan>Heinr<ex>ich</ex></expan> von <expan>Abtſp<ex>er</ex>g</expan> <expan>vo<ex>n</ex></expan> des <expan>eg<ex>enanten</ex></expan> <expan>vnſ<ex>er</ex>s</expan> <expan>h<ex>er</ex>ren</expan> <expan>vveg<ex>en</ex></expan> </ab>
