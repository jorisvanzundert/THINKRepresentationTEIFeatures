<expan>ewr<ex>er</ex></expan>
<expan>freuntſch<ex>aft</ex></expan> des beſunder wol
                                <expan>getr<ex>awen</ex></expan> / das
                            <expan>wölle<ex>n</ex></expan>
</ab>
<ab facs="#facs_55_r1l32">wir vmb <expan>ew<ex>r</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>allcʒ<ex>eit</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dıenen</expan>
