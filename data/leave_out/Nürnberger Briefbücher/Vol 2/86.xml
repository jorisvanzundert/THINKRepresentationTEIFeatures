                            <expan>durchl<ex>euhtigen</ex></expan>
<expan>hochg<ex>eporen</ex></expan>
<expan>fürſte<ex>n</ex></expan> vnd <expan>h<ex>er</ex>ren</expan> / hercʒog </ab>
