<del rend="strikethrough"> v̈ber <expan>ew<ex>r</ex>n</expan></del></ab>
<ab facs="#facs_230_r1l7">auf ewrn erſten brief darvmb 
<del rend="strikethrough"><expan>geantw<ex>ur</ex>t</expan></del>
