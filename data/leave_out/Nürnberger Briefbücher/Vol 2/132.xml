                            <expan>wan<ex>n</ex></expan>
<add>wir <expan>ung<ex>er</ex>n</expan></add>
<add>wider reht tun wolten</add>. <expan>Dat<ex>um</ex></expan> in
                            <expan>vigilia</expan>
<expan>b<ex>ea</ex>to<ex>rum</ex></expan> Petri et Pauli
