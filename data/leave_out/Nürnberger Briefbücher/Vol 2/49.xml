<ab facs="#facs_30_r2l29">vnd <expan>bitte<ex>n</ex></expan> etc vvas die ~ <expan>eg<ex>enanten</ex></expan> <expan>vnſ<ex>er</ex></expan> <expan>B<ex>urger</ex></expan> vnd <expan>dien<ex>er</ex></expan> / <expan>dar<ex>ümb</ex></expan> cʒu <expan>dıſe<ex>m</ex></expan> mal </ab>
