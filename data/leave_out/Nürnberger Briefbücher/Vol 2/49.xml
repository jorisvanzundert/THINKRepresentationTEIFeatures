<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als wir <expan>ew<ex>r</ex>n</expan>
<expan>küniglich<ex>en</ex></expan>
<expan>gnad<ex>en</ex></expan> vor etwydicke
                                <expan>geschr<ex>iben</ex></expan> haben von des czolls
                                    <expan>wege<ex>n</ex></expan>, als <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von Wirczburg <add>von uns und den
                                        <expan>uns<ex>er</ex>n</expan></add> czu haben und czu nemen
                            maint, und als uns ewr küniglich gnade vormals gnediglichen vertröst hat
                                <add>ewr küniglich</add> brief czu geben, daz wir des über
                                    <expan>hab<ex>e</ex>n</expan> sein söllen, <add>des wir
                                        <expan>ew<ex>r</ex>n</expan>
<expan>künicli<ex>chen</ex></expan> etc.</add> Und als wir auch
                                    <expan>dar<ex>umb</ex></expan> nehst die
                                <expan>uns<ex>er</ex>n</expan> gen
                                <expan>Heidelb<ex>er</ex>g</expan> czu <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> gesant haben, den
                                <expan>ew<ex>r</ex></expan>
<add><expan>kunigl<ex>iche</ex></expan></add>
<expan>hochwir<ex>dikeit</ex></expan>
<expan>hinwid<ex>er</ex></expan>
<expan>zukome<ex>n</ex></expan> gezielt hat,
                                    <add><expan>d<ex>er</ex></expan>
<expan>zwische<ex>n</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>re<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Wirczb<ex>ur</ex>g</expan> und der ritterschaft zu
                                        hei<expan>delb<ex>er</ex>g</expan></add> auf
                                    <expan>de<ex>n</ex></expan>
<app>
<note><q type="date">suntag judica schierst</q>01.04.1408</note>
</app>. Also senden wir czu <expan>ew<ex>r</ex>n</expan>
<expan>künigl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>Conr<ex>aden</ex></expan>
<expan>Molit<ex>or</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan>, und Hansen
                                <expan>Camer<ex>er</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, mit <expan>ew<ex>r</ex></expan>
<expan>hochwir<ex>dikeit</ex></expan> davon
                                <expan>czured<ex>en</ex></expan> und <expan>bitte<ex>n</ex></expan>
                            etc., was die <expan>eg<ex>enanten</ex></expan>,
                                <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> und <expan>dien<ex>er</ex></expan>,
                                    <expan>dar<ex>umb</ex></expan> czu <expan>dise<ex>m</ex></expan>
                            mal an <expan>ew<ex>r</ex></expan> gnade <expan>werbe<ex>n</ex></expan>
                            von <expan>uns<ex>er</ex>n</expan>
<expan>wege<ex>n</ex></expan>, daz ir <add>sie darin gutlich
                                        <expan>v<ex>er</ex>hore<ex>en</ex></expan></add> in des
                                    <expan>glaub<ex>e</ex>n</expan> und
                                <expan>gnediglich<ex>e</ex>n</expan> von <expan>ew<ex>r</ex></expan>
<expan>hochwir<ex>dikeit</ex></expan>
<expan>vertige<ex>n</ex></expan> und uns des <expan>ew<ex>r</ex></expan>
<expan>kuniglich<ex>en</ex></expan> brief <expan>geb<ex>e</ex>n</expan>
                            wöllet, das wir <add>und die unsern</add> desselben czolls
                                    <expan>überhab<ex>e</ex>n</expan>
<add>und damit <expan>umbesw<ex>er</ex>t</expan></add> werden als wir
                            des etc. Auch <expan>hete<ex>n</ex></expan> wir
                                <expan>g<ex>er</ex>n</expan> etlich <expan>uns<ex>er</ex>s</expan>
                            rats <expan>dar<ex>umb</ex></expan> czu <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> geschickt etc.</del></ab>
