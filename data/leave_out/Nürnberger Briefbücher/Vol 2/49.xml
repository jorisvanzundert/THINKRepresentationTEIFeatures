<ab facs="#facs_30_r2l26">Alſo ſenden vvir cʒu <expan>ew<ex>r</ex>n</expan> <expan>künigl<ex>ichen</ex></expan> <expan>gnad<ex>en</ex></expan> <expan>Conr<ex>aden</ex></expan> <expan>Molit<ex>or</ex></expan> <expan>vnſ<ex>er</ex>n</expan> <expan>B<ex>urger</ex></expan> </ab>
