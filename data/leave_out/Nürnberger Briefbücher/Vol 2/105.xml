<ab facs="#facs_65_r3l9">wir darauf wider beẏ <expan>dıſe<ex>m</ex></expan> <expan>vnſ<ex>er</ex>m</expan> <expan>bote<ex>n</ex></expan> <expan>dat<ex>um</ex></expan> <expan>fe<ex>ri</ex>a</expan> vȷ̃ <expan>an<ex>te</ex></expan> Eraſmi </ab>
