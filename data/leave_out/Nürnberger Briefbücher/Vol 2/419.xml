<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan> her Hans,
                                                  <expan>Wilh<ex>elm</ex></expan> und
                                                  <expan>Albr<ex>echt</ex></expan>, uns
                                                  <expan>hab<ex>e</ex>n</expan> fürgelegt fraw
                                                Agnes, die Ulman Stromerin,
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>ur</ex>gerin</expan>, und Görg Stromeir,
                                                ir sun, <expan>uns<ex>er</ex></expan>
<expan>b<ex>ur</ex>ger</expan>, wie daz ir dem
                                                  <expan cert="unknown">H.</expan> Pfeiffer
                                                  <expan>vo<ex>n</ex></expan> Pürheim, irem armman,
                                                der <expan>hint<ex>er</ex></expan> in sicze und den
                                                mit tür und tor besliessen, seine pferde, sein vihe
                                                und <expan>ande<ex>r</ex></expan> sein habe genomen
                                                und <add>in</add> auch darczu gefangen habt.
                                                  <expan>Ro<ex>gamus</ex></expan>, daz ir durch
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>de<ex>m</ex>selb<ex>e</ex>n</expan>
<add>irem</add> armmanne seine pferde, sein vihe und
                                                waz ir im <expan>genome<ex>n</ex></expan> habt
                                                  <expan>widergeb<ex>e</ex>n</expan> und in auch der
                                                venknüsse ledig lassen und
                                                  <expan>sage<ex>n</ex></expan> wöllet, als etc. Das
                                                  <expan>wölle<ex>n</ex></expan> etc.
                                                  <expan>Dat<ex>um</ex></expan> in die
                                                  <expan>visitat<ex>i</ex>o<ex>n</ex>is</expan>
<expan>b<ex>ea</ex>te</expan> Marie.</ab>
</div>
