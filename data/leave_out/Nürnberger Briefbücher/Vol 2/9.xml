<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><app>
<note place="marginleft">
<expan cert="medium">R<ex>ecipimus</ex></expan>
<expan cert="medium">cut<ex>is</ex></expan>
</note>
</app>
<expan>Hochwirdig<ex>er</ex></expan> fürst und gnedigen
                                <expan>lieb<ex>e</ex>n</expan>
<expan>h<ex>er</ex>ren</expan>, uns <expan>hab<ex>e</ex>n</expan> unser lieb
                                <expan>burge<ex>r</ex></expan> und ratgesellen Mertein und Peter, dy
                        Haller, Wilhelm Mendell und Sebolt <expan>Pfincz<ex>ing</ex></expan> wol
                        gesagt, wie daz ir in gen <expan>uns<ex>er</ex>s</expan> gnedigen
                                <expan>h<ex>er</ex>ren</expan>, des
                            <expan>roͦmisch<ex>e</ex>n</expan> künigs, gnaden gar gewegen und
                        fürderlich gewesen seit als von des czolls wegen, den
                            <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von Wirczburg von <expan>de<ex>n</ex></expan>
<expan>uns<ex>er</ex>n</expan> czu <expan>hab<ex>e</ex>n</expan> und cze
                        nemen maint wider <expan>uns<ex>er</ex></expan> brief und freyheit. Darauff
                        ir in von <expan>desselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, des künigs, wegen
                                <expan>gnediklich<ex>e</ex>n</expan>
<expan>geantw<ex>ur</ex>t</expan> habt, daz wir und dy
                            <expan>uns<ex>er</ex>n</expan>
<expan>desselb<ex>e</ex>n</expan> czolls <expan>überhab<ex>e</ex>n</expan>
                        sein und des niht <expan>geb<ex>e</ex>n</expan> süllen, des wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> mit <expan>gancze<ex>m</ex></expan> fleisz
                                <expan>dancke<ex>n</ex></expan> und biten
                            <expan>ew<ex>r</ex></expan>
<expan>hochwirdik<ex>eit</ex></expan> und edell
                                <expan>fleiszkl<ex>ichen</ex></expan>, daz ir uns fürbaz aber
                                <expan>ew<ex>r</ex></expan> gnade und
                            <expan>fürdru<ex>n</ex>g</expan> gen <expan>uns<ex>er</ex>m</expan>
<add><expan>gnedig<ex>en</ex></expan></add>
<expan>h<ex>er</ex>ren</expan>, <expan>de<ex>m</ex></expan> künig,
                                <expan>günstikl<ex>ichen</ex></expan> beweisen wöllet, daz uns von
                        seinen gnaden ein brief werde, daz wir und dy <expan>uns<ex>er</ex>n</expan>
<expan>desselb<ex>e</ex>n</expan> czolls <expan>überhab<ex>e</ex>n</expan>
<expan>werde<ex>n</ex></expan> nach <expan>ausweysu<ex>n</ex>g</expan>
<expan>uns<ex>er</ex>r</expan> brief und freyheit, als wir des
                                <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, des künigs, gnaden und auch
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> und
                        edell <expan>besund<ex>er</ex></expan>  wol <expan>getrawe<ex>n</ex></expan>. Das begern wir
                                <expan>allcz<ex>eit</ex></expan>
<expan>willikl<ex>ichen</ex></expan> zu <expan>v<ex>er</ex>dienen</expan>.
                                <expan>Dat<ex>um</ex></expan><expan cert="high">Valen<ex>tini</ex></expan><app>
<note><gap reason="damaged"/>.</note>
</app>
