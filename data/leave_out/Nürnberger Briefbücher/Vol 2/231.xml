<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><expan>Gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, als uns <expan>ew<ex>r</ex></expan> gnade
                                    <add><expan>ab<ex>er</ex></expan></add>
<expan>geschrib<ex>e</ex>n</expan> hat von Hansen Karls wegen, das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                            <expan>hab<ex>e</ex>n</expan>
<add><expan>dar<ex>umb</ex></expan> in gegenwertikeit
                                    <expan>desselb<ex>e</ex>n</expan>
<expan>H<ex>ans</ex></expan> Karl</add> die
                            <expan>uns<ex>er</ex>n</expan> besant und zu rede gesaczt; <add>und also
                            hat sich</add> do <expan>eygentlich<ex>e</ex>n</expan> erfunden, daz
                            <add>derselb <expan>K<ex>arl</ex></expan>
<expan>etliche<ex>n</ex></expan></add> den
                            <expan>uns<ex>er</ex>n</expan> schuldig bleibt und im die
                                <expan>uns<ex>er</ex>n</expan> niht, <add>als das die
                                    <expan>uns<ex>er</ex>n</expan>
<expan>ew<ex>r</ex>n</expan> graf <expan>Albr<ex>echt</ex></expan>
<expan>gnade<ex>n</ex></expan>, do ir nehst hie bey uns ward, wol
                            erczelt <expan>hab<ex>e</ex>n</expan>, daz wir hoffen, ir seit des noch
                            wol yndenk</add>. Auch so <expan>hab<ex>e</ex>n</expan> wir den Peter
                        Tafler besunder von <expan>seine<ex>n</ex></expan>
<expan>wege<ex>n</ex></expan> czurede gesaczt und der hat uns
                                <expan>geantw<ex>ur</ex>t</expan>, daz er niht wisse, daz er im
                        ichts schuldig sey. Möht oder wölt er in darüber rehtes niht
                                <expan>erlasse<ex>n</ex></expan>, so wöl er im oder
                                <expan>seine<ex>n</ex></expan>
<expan>scheimbote<ex>n</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>volle<ex>n</ex></expan> gewalt <expan>unv<ex>er</ex>czogens</expan>
                        sleunigs <expan>rehte<ex>n</ex></expan> gern darümb sein <add>hie zu
                                    <expan>nur<ex>emberg</ex></expan></add>
<add>vor des <expan>r<ex>eichs</ex></expan>
<expan>riht<ex>er</ex></expan> nach</add>
<expan>uns<ex>er</ex></expan> stat reht, <expan>wen<ex>n</ex></expan> er des
                        ermant <add>wirdt und auch <add>wer</add>
</add> daran sich doch ein yeder billich und <add>auch</add> vormals genüget
                        hat lassen, des die sprüch weder grunt noch <expan>pode<ex>n</ex></expan>
<expan>antreffe<ex>n</ex></expan>. <pb facs="#facs_133" id="65r"/> Gnedigen
                                <expan>h<ex>er</ex>ren</expan>, als <expan>dan<ex>n</ex></expan> die
                                <expan>uns<ex>er</ex>n</expan> die sach vor
                            <expan>ew<ex>r</ex>n</expan>
<add>graf <expan>Albr<ex>echt</ex></expan></add>
<expan>gnad<ex>en</ex></expan> als <expan>eygentliche<ex>n</ex></expan>
                        fürbraht <expan>hab<ex>e</ex>n</expan>, so <expan>hab<ex>e</ex>n</expan> wir
                        trost <add>czu</add>
<expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> gehabt, daz in <expan>ew<ex>r</ex></expan>
                        gnade daran geweist het, daz er sich billich daran benüget het lassen; und
                                <expan>hete<ex>n</ex></expan> wir darynne czweifel gehabt, so
                                <expan>hete<ex>n</ex></expan> wir das braht für
                                <expan>uns<ex>er</ex>n</expan>
<expan>h<ex>er</ex>ren</expan> margrafen <expan>Wilh<ex>elm</ex></expan> von
                        Meihsen und so <expan>hete<ex>n</ex></expan> wir getrawet, daz er geschaffet
                        het, das abgetan. So <expan>hab<ex>e</ex>n</expan> wir das durch
                                <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan> gelassen und <expan>ew<ex>r</ex></expan>
                        edell damit geeret. Nu trifft uns die sache samentlich niht an,
                                        <add><add><expan>dar<ex>umb</ex></expan></add> wir im niht
                            schuldig sein zu <expan>kheine<ex>m</ex></expan> tage zu
                                    <expan>kume<ex>n</ex></expan></add>.
                            <expan>Dar<ex>umb</ex></expan>
<expan>ro<ex>gamus</ex></expan>, daz ir den
                            <expan>egen<ex>anten</ex></expan> Hansen Karl durch
                                <expan>uns<ex>er</ex></expan> dinst <expan>wille<ex>n</ex></expan>
                        daran weisen und in auch darczu <expan>halte<ex>n</ex></expan> wöllet, daz
                        er sich on reht von den <expan>uns<ex>er</ex>n</expan>
<expan>benuge<ex>n</ex></expan> lasse, des wir im gern behölffen sein
                                <expan>wolle<ex>n</ex></expan>, <expan>wen<ex>n</ex></expan> wir des
                        ermant <expan>werde<ex>n</ex></expan>, so die
                        <expan>uns<ex>er</ex>n</expan>, czu den er
                            <expan>czusprech<ex>e</ex>n</expan> hat, anheim sind etc. Und wir
                                <expan>getrawe<ex>n</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> wol, daz ir uns basz
                            <expan>dan<ex>n</ex></expan>
<expan>sein<ex>er</ex></expan> fürgabe <expan>gelaub<ex>e</ex>n</expan>
                        wöllet, <expan>wan<ex>n</ex></expan>
<expan>ew<ex>r</ex></expan> gnade wol erfaren mag, wie er sich czu
                                <expan>Kob<ex>ur</ex>g</expan>
<expan>gehalte<ex>n</ex></expan> hat, die sich auch von
                                <expan>seine<ex>n</ex></expan>
<expan>wege<ex>n</ex></expan>
<expan>angenome<ex>n</ex></expan> und uns darümb
                                <expan>v<ex>er</ex>schr<ex>iben</ex></expan>
<add>und sich auch sein von <expan>solch<ex>er</ex></expan>
                                    un<expan>redlich<ex>er</ex></expan> sprüch <add>und
                                        <expan>and<ex>er</ex>r</expan> sach</add> wegen entteussert
                                    <expan>hab<ex>e</ex>n</expan></add>. Das
                            <expan>wölle<ex>n</ex></expan> etc.
                            <lb/><expan>Alb<ex>recht</ex></expan>
<expan>Ebn<ex>er</ex></expan>
<expan>p<ex>er</ex></expan> se.<app>
<note place="bottomcentral">abest</note>
</app>
