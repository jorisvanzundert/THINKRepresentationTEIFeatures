</front>
<body><div type="diplomatic"><pb facs="#facs_48" id="22v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_48_r1l1">der Stat Luͦbeck </ab>
</div>
