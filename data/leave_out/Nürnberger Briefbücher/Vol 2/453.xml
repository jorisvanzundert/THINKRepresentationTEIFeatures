<body><div type="diplomatic"><pb facs="#facs_245" id="121r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_245_r2l14"><expan>Johan</expan> Erʒbiſchof cʒu Meintʒ </ab>
</div>
