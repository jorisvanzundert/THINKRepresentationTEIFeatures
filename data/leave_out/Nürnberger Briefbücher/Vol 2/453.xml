<add><ab facs="#facs_245_line_1574260477704_2075">als </ab></add> lang </ab><ab facs="#facs_245_r1l7"><expan>gütliche<ex>n</ex></expan>
<del rend="strikethrough"> beſten </del>
<add><ab facs="#facs_245_r1l6">ge<gap reason="illegible"/>en </ab></add> hat 
<add><ab facs="#facs_245_r2l21">vnd </ab></add> </ab><ab facs="#facs_245_r1l8">
<del rend="strikethrough">laſʒen / vnd </del></ab></add> von <expan>ew<ex>r</ex>n</expan> <expan>gnade<ex>n</ex></expan> noch <expan>ſchicke<ex>n</ex></expan> </ab>
<ab facs="#facs_245_r2l20">vnd beſtellen wöllet / daʒ demſelbn <expan>vnſ<ex>er</ex>m</expan> <expan>Burg<ex>er</ex></expan> diſſelb ſein 
