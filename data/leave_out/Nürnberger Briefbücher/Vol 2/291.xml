<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>L<ex>ieber</ex></expan>
<expan>Frewdemberg<ex>er</ex></expan>, als ir dem Anthoni
                                <add>Beheim</add>, der nu nehst <expan>uns<ex>er</ex></expan>
                            burgermeister gewesen ist, <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
                            habt, wie euch <add>der</add> Gorg Jareysen beschuldig, daz ir uns
                                <add>in</add>, als er <add>vert</add> czum parkstein gefangen
                                <add>gelegen sey</add>, <expan>geantw<ex>ur</ex>t</expan>
<expan>hab<ex>e</ex>n</expan> wolt. Davon wissen wir niht,
                                    <expan>wan<ex>n</ex></expan> wir <add>noch
                                        <expan>yemand<ex>en</ex></expan> von</add>
<add><expan>uns<ex>er</ex>n</expan>
<expan>wege<ex>n</ex></expan> euch des</add> nye angemutet
                                    <expan>hab<ex>e</ex>n</expan>. <expan>Dat<ex>um</ex></expan>
<expan>sabb<ex>a</ex>to</expan>
<expan>p<ex>ost</ex></expan>
<expan>co<ex>n</ex>v<ex>er</ex>s<ex>ionem</ex></expan>
<expan>s<ex>an</ex>c<ex>t</ex>i</expan> Pauli.</del></ab>
