<ab facs="#facs_220_r3l33">euch das als ſpete <expan>empote<ex>n</ex></expan> <expan>hab<ex>e</ex>n</expan> / <expan>vvan<ex>n</ex></expan> vns <expan>vnſ<ex>er</ex>s</expan> <expan>h<ex>er</ex>ren</expan> des </ab>
