<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<add>her
                                                  <expan>Freude<ex>m</ex>berg<ex>er</ex></expan></add>,
                                                uns hat fürgelegt <expan>fr<ex>aw</ex></expan>
                                                Margret, die Harstorfferin,
                                                  <expan>uns<ex>er</ex></expan> burgerin, wie daz ir
                                                Hansen, des Ülleins sun, bey dem steg von
                                                Esschembach, der ein erb hinter ir <add>hab</add>
                                                und auch ir armman sey, gefangen habt.
                                                  <expan>Ro<ex>gamus</ex></expan>, daz ir
                                                  <expan>d<ex>ur</ex>h</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> den
                                                  <expan>egen<ex>anten</ex></expan>,
                                                  <expan>uns<ex>er</ex>r</expan> burgerin armman,
                                                ledig lassen wöllet, als etc. Das
                                                  <expan>wölle<ex>n</ex></expan> etc. <add>Und</add>
                                                lat uns des <expan>ew<ex>r</ex></expan> freuntlich
                                                  <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<expan>antw<ex>ur</ex>t</expan> wider wissen.</ab>
