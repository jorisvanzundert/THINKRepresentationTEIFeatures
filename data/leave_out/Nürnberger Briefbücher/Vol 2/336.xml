<ab facs="#facs_192_r1l23">als <expan>geſt<ex>er</ex>n</expan> <expan>geantw<ex>ur</ex>t</expan> <expan>word<ex>e</ex>n</expan> / daʒ vvir <expan>ew<ex>r</ex>n</expan> <expan>gnad<ex>e</ex>n</expan> nicht ee </ab>
