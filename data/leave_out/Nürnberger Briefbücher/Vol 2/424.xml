<ab facs="#facs_233_r2l38"><expan>ire<ex>m</ex></expan> <expan>ſcheimbot<ex>e</ex>n</expan> mit <expan>ire<ex>m</ex></expan> <expan>volle<ex>n</ex></expan> gewalt / <expan>vnu<ex>er</ex>cʒogen</expan> <expan>ſlewnig<ex>en</ex></expan> recht <expan>g<ex>er</ex>n</expan> helffen </ab>
