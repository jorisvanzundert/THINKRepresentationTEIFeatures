<del rend="strikethrough">hat </del> iſt fürgelegt worden / vvie </ab>
<ab facs="#facs_62_line_1574254222776_1507">daʒ Jr den <expan>Conr<ex>ad</ex></expan> <expan>weiſʒemburg<ex>er</ex></expan> <expan>vnſ<ex>ern</ex></expan> <expan>B<ex>urger</ex></expan>
