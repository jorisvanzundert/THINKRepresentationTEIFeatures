<del rend="strikethrough">für</del>
<add><ab facs="#facs_62_line_1574254225726_1512">von </ab></add> <expan>h<ex>er</ex>n</expan> <expan>heinr<ex>ich</ex></expan> Nothafts 
<add><ab facs="#facs_62_r4l13">wegen </ab></add> <expan>gefange<ex>n</ex></expan> habt / <expan>Ro<ex>gamus</ex></expan> / daʒ Jr durch </ab>
<ab facs="#facs_62_r4l15"><expan>vnſ<ex>er</ex>n</expan> <expan>wille<ex>n</ex></expan> den <expan>egen<ex>anten</ex></expan> <expan>vnſ<ex>er</ex>n</expan> <expan>B<ex>urger</ex></expan> ledig laſſen wöllet / 
