<body><div type="diplomatic"><pb facs="#facs_62" id="29v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_62_r4l9">Dem <expan>Erb<ex>er</ex>n</expan> veſten Buſcho </ab>
<ab facs="#facs_62_r4l10"><expan>Burgr<ex>afen</ex></expan>
