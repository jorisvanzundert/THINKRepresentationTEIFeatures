<ab facs="#facs_101_line_1574775983307_540">
<add><ab facs="#facs_101_line_1574775620707_497"><expan>k<ex>üniklich</ex></expan> <expan>hoch<ex>wirdikeit</ex></expan> </ab></add> darẏnne 
