<expan>Hanſe<ex>n</ex></expan>
<expan>Starke<ex>n</ex></expan>
</ab><ab facs="#facs_206_line_1576747929043_6834">vnd
                                        <expan>ſeın<ex>er</ex></expan> geſellſchaft </ab></add>
<add><ab facs="#facs_206_r1l26">
<del rend="strikethrough">man </del></ab></add>
<del rend="strikethrough"> daʒ Jr Jm </del> cʒweẏ vaſʒ mit Senſen in dem
                                <expan>eıne<ex>n</ex></expan>
<expan>ſechſhund<ex>er</ex>t</expan>
</ab>
<ab facs="#facs_206_r1l31">
<del rend="strikethrough">vnd eine </del> vnd ın <expan>de<ex>m</ex></expan>
<expan>and<ex>er</ex>n</expan> v<hi rend="sup">C</hi> vnd xxxv ſenſein ſein
