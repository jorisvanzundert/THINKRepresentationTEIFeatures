<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als wir <expan>ewr<ex>er</ex></expan>
                        hochwirdikeit vormals <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> und
                                <expan>gebete<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan> von Hansen vom Stern, des Ecken vom Stern,
                                <expan>uns<ex>er</ex>s</expan> burgers,
                            <expan>selige<ex>n</ex></expan>, suns, wegen, den etwievil habe von
                                <expan>Hanse<ex>n</ex></expan> vom Stern,
                            <expan>selige<ex>n</ex></expan>, <expan>seine<ex>m</ex></expan>
<expan>vett<ex>er</ex>n</expan>, czu <expan>Wirczb<ex>ur</ex>g</expan>
<expan>anerstorb<ex>e</ex>n</expan> sey und besunder etliche
                                <expan>leh<ex>e</ex>n</expan>, die von <expan>ewr<ex>er</ex></expan>
                        hochwirdikeit <expan>czuleh<ex>e</ex>n</expan> rüren; <add>also hat uns der
                                    <expan>eg<ex>enante</ex></expan>, <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan>, fürbraht, wie im
                                <expan>ew<ex>r</ex></expan> gnade darümb
                                <expan>eine<ex>n</ex></expan> tag auf <expan>de<ex>n</ex></expan>
<expan>nehstk<ex>ünftigen</ex></expan>
<expan>sunt<ex>ag</ex></expan> für <expan>ew<ex>r</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>bescheyd<ex>en</ex></expan> hab</add>; darümb derselb Hans von
                        Stern, <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan>, und auch mit im
                            <expan>sein<ex>er</ex></expan> vormünde <expan>ein<ex>er</ex></expan>,
                                <expan>H<ex>er</ex>man</expan> Geysel,
                            <expan>yecz<ex>unden</ex></expan>
<add>auf <expan>denselb<ex>e</ex>n</expan> tag</add> czu
                            <expan>ew<ex>r</ex>n</expan> gnaden kumen.
                            <expan>Ro<ex>gamus</ex></expan>, daz ir
                            <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan> durch <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>gnedikl<ex>ichen</ex></expan>
<expan>leih<ex>e</ex>n</expan> und auch von <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan>
<expan>schicke<ex>n</ex></expan> und <expan>bestelle<ex>n</ex></expan>
                        wollet, daz im <expan>ande<ex>r</ex></expan> hab, die im von
                                <expan>de<ex>m</ex></expan>
<expan>eg<ex>enanten</ex></expan>, <expan>seine<ex>m</ex></expan>
<expan>vett<ex>er</ex>n</expan>, czu <expan>Wirczb<ex>ur</ex>g</expan>
<expan>anerstorb<ex>e</ex>n</expan> ist, <add>darczu er
                                <expan>dan<ex>n</ex></expan> reht hat</add>, on hindernüsse volg und
                        werde, als etc. Das <expan>wölle<ex>n</ex></expan> etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>r</ex>ia</expan> iiii <expan>an<ex>te</ex></expan>
<expan>corp<ex>or</ex>is</expan>
<expan>Christi</expan>.</ab>
