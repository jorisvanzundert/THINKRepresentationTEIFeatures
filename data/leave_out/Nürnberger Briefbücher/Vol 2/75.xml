<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, als wir vormals
                                                  <add>etwieofft</add> czu
                                                  <expan>uns<ex>er</ex>s</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, des roͦmischen
                                                künigs, und auch czu <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan>
<add>etlich <expan>uns<ex>er</ex></expan>
<expan>ratgeselle<ex>n</ex></expan> und auch
                                                  darnach</add>
<expan>Conr<ex>aden</ex></expan> Molitor,
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan>, und Hansen Camrer,
                                                  <expan>uns<ex>er</ex>n</expan> diener, gesant
                                                  <expan>hab<ex>e</ex>n</expan> von des czolls
                                                  <expan>wege<ex>n</ex></expan>, als
                                                  <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von
                                                  <expan>Wirczb<ex>ur</ex>g</expan> von den
                                                  <expan>uns<ex>er</ex>n</expan> wider
                                                  <expan>uns<ex>er</ex></expan> brief und freyheit
                                                  <expan>hab<ex>e</ex>n</expan> wil und czenemen
                                                maint. Also senden wir yeczund aber darümb czu
                                                  <expan>desselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>s</expan> gnedigen
                                                  <expan>h<ex>er</ex>ren</expan>, des
                                                  <expan>römisch<ex>e</ex>n</expan> kunigs, und auch
                                                czu <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> die
                                                  <expan>egen<ex>anten</ex></expan>,
                                                  <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> und diener, von
                                                sölcher <expan>vertrostu<ex>n</ex>g</expan> wegen,
                                                als in <expan>dan<ex>n</ex></expan> von
                                                  <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>, dem künig, <add>und
                                                  von ew</add> von <expan>uns<ex>er</ex>n</expan>
                                                wegen <expan>gescheh<ex>e</ex>n</expan> ist und bit
                                                  <expan>ew<ex>r</ex></expan> gnade <add>und
                                                  edell</add> mit <expan>alle<ex>m</ex></expan>
                                                fleisze, daz ir in gen
                                                  <expan>uns<ex>er</ex>m</expan>
<add><expan>gned<ex>igen</ex></expan></add>
<expan>h<ex>er</ex>ren</expan>,
                                                  <expan>de<ex>m</ex></expan> künig,
                                                  <expan>ew<ex>r</ex></expan> gnedig
                                                  <expan>furdru<ex>n</ex>g</expan>
<expan>gunstikl<ex>ichen</ex></expan> beweisen
                                                wöllet, das uns von <expan>seine<ex>n</ex></expan>
<expan>künigl<ex>ichen</ex></expan>
<expan>gnade<ex>n</ex></expan>
<add>des ein vollig ende</add>
<expan>werde<ex>n</ex></expan>, daz wir und die
                                                  <expan>uns<ex>er</ex>n</expan> sölchs czols
                                                  <expan>überhab<ex>e</ex>n</expan>
<expan>werde<ex>n</ex></expan>, als wir gefreyet
                                                sein, als etc. Das <expan>wolle<ex>n</ex></expan>
                                                etc. <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>r</ex>ia</expan> iii
                                                  <expan>p<ex>ost</ex></expan> Georii anno m<hi rend="sup">o</hi>cccc octavo.</ab>
</div>
