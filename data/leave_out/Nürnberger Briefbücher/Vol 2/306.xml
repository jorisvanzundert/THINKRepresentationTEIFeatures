<ab facs="#facs_176_r1l15">abetün <add><ab facs="#facs_176_line_1576745819010_5410">vnd auch ſein </ab><ab facs="#facs_176_line_1576745822849_5420">klag <del rend="strikethrough">die cʒeıt </del>
