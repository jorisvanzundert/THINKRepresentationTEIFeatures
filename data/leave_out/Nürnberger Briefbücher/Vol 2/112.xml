<expan>ew<ex>r</ex></expan>
<del rend="strikethrough">n</del>
<expan>B<ex>ur</ex>g<ex>er</ex></expan> cʒu dem vnſern icht cʒu </ab>
<ab facs="#facs_68_r1l31"><expan>ſpreche<ex>n</ex></expan>
<expan>dar<ex>umb</ex></expan>
<expan>wölle<ex>n</ex></expan> wir Jm <add><ab facs="#facs_68_r1l29"><expan>od<ex>er</ex></expan> aber
