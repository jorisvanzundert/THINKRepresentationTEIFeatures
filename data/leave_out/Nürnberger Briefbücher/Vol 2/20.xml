<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><expan>Hoch<ex>wirdiger</ex></expan> fürste und gnedigen <expan>lieb<ex>e</ex>n</expan>
<expan>h<ex>er</ex>ren</expan>, als <expan>uns<ex>er</ex></expan> lieb
                                <expan>burg<ex>er</ex></expan> und
                            <expan>ratgeselle<ex>n</ex></expan>, <expan>Mert<ex>ein</ex></expan> und
                        Peter, die Haller, <expan>Wilh<ex>elm</ex></expan> Mendel und
                                <expan>Seb<ex>olt</ex></expan> Pfinczing, an
                            <expan>uns<ex>er</ex>s</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan>, des <expan>r<ex>ömischen</ex></expan>
                        künigs, <expan>gnade<ex>n</ex></expan> nehst czu
                            <expan>Mergenth<ex>eim</ex></expan> von <expan>uns<ex>er</ex>n</expan>
<expan>wege<ex>n</ex></expan> braht <expan>hab<ex>e</ex>n</expan> als von
                        des czolls <expan>wege<ex>n</ex></expan>, den <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von <expan>Wirczb<ex>ur</ex>g</expan> von den
                                <expan>uns<ex>er</ex>n</expan> wider <expan>uns<ex>er</ex></expan>
                        brief und freyheit <expan>czuhab<ex>e</ex>n</expan> und czenemen maint.
                        Darauff ir in von <expan>dess<ex>elben</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<add><expan>gned<ex>igen</ex></expan></add>
<expan>h<ex>er</ex>ren</expan>, des <expan>k<ex>ünigs</ex></expan>, wegen,
                            <add>als sie uns gesagt ha<app>
<note><gap reason="illegible"/>,</note>
</app></add> gar <expan>gnedikl<ex>ichen</ex></expan>
<expan>geantw<ex>ur</ex>t</expan> habt, daz wir und die
                                <expan>uns<ex>er</ex>n</expan>
<expan>desselb<ex>e</ex>n</expan> czolls <expan>überhab<ex>e</ex>n</expan>
                        sein und des niht <expan>geb<ex>e</ex>n</expan> süllen, <add>als wir
                                    <expan>dan<ex>n</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> vormals auch
                                <expan>ges<ex>chriben</ex></expan>
<expan>hab<ex>e</ex>n</expan></add>. <expan>Dar<ex>umb</ex></expan>
<expan>ro<ex>gamus</ex></expan>, daz ir uns <expan>ew<ex>r</ex></expan>
<add>gnade</add> und fürdrung gen <expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>, dem künig, günsticklich
                                <expan>beweise<ex>n</ex></expan> wollet, daz uns von
                                <expan>seine<ex>n</ex></expan>
<expan>kunigl<ex>ichen</ex></expan>
<expan>gnade<ex>n</ex></expan> ut retro folio ii<hi rend="sup">o</hi> stat
                                <expan><ex>con</ex>clusio</expan> etc. </ab></div>
</div></body>
