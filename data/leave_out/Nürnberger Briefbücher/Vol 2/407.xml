<ab facs="#facs_227_r1l16">wider in die <expan>teẏlu<ex>n</ex>g</expan> <expan>werffe<ex>n</ex></expan> vnd <expan>dan<ex>n</ex></expan> <expan>gleich<ex>e</ex>n</expan> teil daran <expan>aufheb<ex>e</ex>n</expan> </ab>
