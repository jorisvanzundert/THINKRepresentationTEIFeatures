<del rend="strikethrough">Ervvirdıgen </del>
<add><ab facs="#facs_227_r1l1">Erſamen </ab></add> <expan>h<ex>er</ex>ren</expan> / <expan>h<ex>er</ex>n</expan> Johanſen vom Burn </ab>
<ab facs="#facs_227_r1l3">Probſt des Stiffts cʒu ſant Stephan ʒu <expan>Bamb<ex>er</ex>g</expan> </ab>
</div>
