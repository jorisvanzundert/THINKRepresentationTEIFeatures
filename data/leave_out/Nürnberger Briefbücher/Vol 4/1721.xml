<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde,</ex></expan> als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von
                            <expan>ew<ex>r</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>Andr<ex>eas</ex></expan> Spons <expan>weg<ex>en</ex></expan>, wie dem
                        etlich <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> ein vardel parchants und ein vesslein mit
                        gesmeyd bey uns <expan>v<ex>er</ex>botten</expan>
<expan>hab<ex>e</ex>n</expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>v<ex>er</ex>nom<ex>en</ex></expan> und lassen ewr
                                <expan>fürsichtik<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir die <expan>uns<ex>er</ex>n</expan>,
                        die die sache antrift, <expan>daru<ex>m</ex>b</expan>
<expan>v<ex>er</ex>hört</expan>
<expan>habe<ex>n</ex></expan>; die <expan>spreche<ex>n</ex></expan>, sie
                                <expan>hab<ex>e</ex>n</expan> die <expan>vorg<ex>enante</ex></expan>
                        hab <add>vor etwievil <expan>zeit<ex>en</ex></expan></add> mit dem recht bey
                        uns <expan>v<ex>er</ex>botten</expan> und <expan>well<ex>e</ex>n</expan> der
                        sache mit recht bey uns nach <expan>uns<ex>er</ex>s</expan> gerichts lawff
                                <expan>g<ex>er</ex>n</expan> zu austrag
                            <expan>kome<ex>n</ex></expan>, und <expan>hab<ex>e</ex>n</expan> uns
                                <expan>gebett<ex>en</ex></expan>, sie dabey lassen zu
                                <expan>beleibe<ex>n</ex></expan>. <expan>Daru<ex>m</ex>b</expan>,
                                <expan>l<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, so mag ewr <expan>b<ex>urger</ex></expan>
                        nu wol <expan>gedenk<ex>en</ex></expan>, die hab mit recht bey uns nach
                                <expan>uns<ex>er</ex>s</expan> gerichts lawff zu
                                <expan>ledig<ex>en</ex></expan>, ob im des ein notdurft ist. So
                                <expan>welle<ex>n</ex></expan> wir im, <add>wenn er zu uns kombt und
                            des begert,</add> umb <expan>ew<ex>r</ex>n</expan>
<expan>will<ex>e</ex>n</expan>
<pb facs="#facs_103" id="51v"/>slewnigs <expan>frewntl<ex>ichen</ex></expan>
<expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> und auch wol gunnen, darczu er recht hat;
                        auch <expan>hab<ex>e</ex>n</expan> wir von den
                            <expan>uns<ex>er</ex>n</expan>
<expan>v<ex>er</ex>nom<ex>en</ex></expan>, daz die
                                <expan>vorg<ex>enante</ex></expan> hab von
                            <expan>beid<ex>er</ex></expan>
<expan>brüd<ex>er</ex></expan>
<expan>weg<ex>en</ex></expan> Peters und <expan>and<ex>er</ex>r</expan> der
                        Spon bey uns <expan>v<ex>er</ex>botten</expan> sey, daz uns niht wol füklich
                        ist, die <expan>uns<ex>er</ex>n</expan>
<add>von</add> iren <expan>recht<ex>en</ex></expan> ze
                                <expan>werff<ex>en</ex></expan>
<expan>od<ex>er</ex></expan> ze weisen; denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra.</ex></expan>
</ab>
</div>
