<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>hofm<ex>eiste</ex>r</expan>, uns hat der hochgeborn furst und
                                <expan>h<ex>er</ex>re</expan>
<expan>h<ex>e</ex>r</expan>
<expan>Fridr<ex>ich</ex></expan>, <expan>burggr<ex>af</ex></expan> czu
                                <expan>Nür<ex>emberg,</ex></expan>
<expan>oberst<ex>er</ex></expan>
<expan>v<ex>er</ex>weser</expan> der mark zu
                            <expan>Brandemb<ex>ur</ex>g,</expan>
<expan>verschr<ex>iben,</ex></expan> wie daz der
                            <expan>all<ex>er</ex></expan> durchlewchtigst fürst und
                                <expan>h<ex>er</ex>re</expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sig<ex>mund</ex></expan>, <expan>römisch<ex>er</ex></expan> und zu
                                <expan>Ung<ex>er</ex>n</expan> etc. kunig,
                            <expan>uns<ex>er</ex></expan>
<expan>gnedigst<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, <expan>kurczl<ex>ich</ex></expan>
<expan>will<ex>e</ex>n</expan> habe, das land <expan>h<ex>er</ex>auf</expan>
                        und auch zu uns ze <expan>kome<ex>n</ex></expan>.
                            <expan>Bitt<ex>en</ex></expan> wir ewr <expan>erberk<ex>eit</ex></expan>
                        mit <expan>gancze<ex>m</ex></expan> fleisz, ob ir iht
                                <expan>v<ex>er</ex>nom<ex>en</ex></expan> hett, auf wenn das
                        beschehen sölt, und ob ir iht <expan>and<ex>er</ex>r</expan> lewfft von
                                <expan>dems<ex>elben</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren,</expan> dem <expan>r<ex>ömischen</ex></expan> künig,
                        west, die ewch gebüren uns ze <expan>verschr<ex>eiben</ex></expan>, daz ir
                        uns bey <expan>dis<ex>em</ex></expan>
<expan>bott<ex>en</ex></expan> davon <expan>verschr<ex>eiben</ex></expan>
                        wellet, so vil ewch gefüklich sey, als wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wol getrawen. Das
                            <expan>well<ex>e</ex>n</expan> wir etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>cruc<ex>is</ex></expan>
<expan>exalta<ex>tati</ex><hi rend="sup">o<ex>n</ex>e</hi>.</expan>
</ab>
</div>
