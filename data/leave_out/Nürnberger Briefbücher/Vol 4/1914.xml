<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, von <expan>sölich<ex>er</ex></expan> angriff
                                <expan>weg<ex>en,</ex></expan> die uns Fricz vom Eglofstein und sein
                                <expan>helff<ex>er</ex></expan> getan <expan>habe<ex>n</ex></expan>,
                        hat sich der hochgeporn fürst und herre <expan>h<ex>e</ex>r</expan>
<expan>Joh<ex>an,</ex></expan> pfallnczgraf bey Reyn und
                            <expan>h<ex>er</ex>czog</expan> in Payern,
                            <expan>angenom<ex>en</ex></expan> und so<expan>v<ex>er</ex>ren</expan>
                        mit uns gerett, daz wir <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan> verfolgt <expan>habe<ex>n</ex></expan>,
                                <expan>ein<ex>en</ex></expan>
<expan>gütliche<ex>n</ex></expan> tag vor <expan>seine<ex>n</ex></expan>
<expan>gnade<ex>n</ex></expan> mit <expan>Fricze<ex>n</ex></expan> vom
                                <expan>Eglofst<ex>ein</ex></expan>
<expan>daru<ex>m</ex>b</expan> zu <expan>suche<ex>n</ex></expan> zu
                        Sulczbach, auf den <app><note><q type="date">sunntag vor sand Jacobs tag schierist</q>21.07.1415</note></app> zu nacht da zu
                        sein. <expan>Bitt<ex>en</ex></expan> wir ewr
                            <expan>hoch<ex>wirdikeit</ex></expan> mit
                            <expan>gancze<ex>m</ex></expan> fleisz, daz ir uns einen ausz
                                <expan>ew<ex>r</ex>n</expan> reten auf
                            <expan>dens<ex>elben</ex></expan> tag <expan>leihe<ex>n</ex></expan> und
                        senden wellet, der bey <expan>uns<ex>er</ex>n</expan>
<expan>frewnd<ex>en</ex></expan> da sey und <expan>uns<ex>er</ex>n</expan>
                        gelimpf und ungelimpf da <expan>v<ex>er</ex>höre</expan>. Und getrawen
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> wol, ir <expan>v<ex>er</ex>czeihet</expan>
                        uns des niht; das <expan>well<ex>e</ex>n</expan> wir umb ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> allczeit
                                <expan>willikl<ex>ich</ex></expan> und <expan>g<ex>er</ex>n</expan>
                        verdienen. Et <expan>r<ex>espo</ex>nsum</expan>.
                            <expan>Dat<ex>um</ex></expan> ut <expan>sup<ex>ra</ex></expan>. </ab>
</div>
<div type="similiter">
<ab><expan>It<ex>em</ex></expan> frawn <expan>Elisabet<ex>en</ex></expan> geborn
                        von Payern, <expan>uns<ex>er</ex>s</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren,</expan> burggraf <expan>Fridr<ex>ich,</ex></expan>
                        elicher gemaheln
                                <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>.<lb/><expan>It<ex>em</ex></expan>
                        den von <expan>Regensp<ex>ur</ex>g</expan> umb ein erber
                                <expan>bottsch<ex>aft</ex></expan> ausz irem
                                rat.<lb/><expan>It<ex>em</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Hanns<ex>en</ex></expan> Gebolf vom
                            <expan>Degemb<ex>er</ex>g,</expan> vicztum zu Amberg, selb da hin zu
                        komen, et <expan>mutat<ex>is</ex></expan>
<expan>muta<ex>n</ex>dis</expan> in <expan>litt<ex>er</ex>is.</expan>
</ab>
</div>
