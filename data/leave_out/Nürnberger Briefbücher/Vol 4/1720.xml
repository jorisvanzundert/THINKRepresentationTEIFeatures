<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>hofm<ex>eiste</ex>r,</expan> als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von <expan>C<ex>onrad</ex></expan>
<expan>Swarczenberg<ex>er</ex>s</expan> und <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan> Cristan <expan>Arempawr<ex>er</ex>s</expan>
<expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>v<ex>er</ex>nom<ex>en</ex></expan> und
                            <expan>lass<ex>en</ex></expan> ewr <expan>erberk<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir <expan>dens<ex>elben</ex></expan>
<expan>Arempawr<ex>er</ex></expan> für uns besant und
                            <expan>daru<ex>m</ex>b</expan> zu rede gesaczt
                            <expan>habe<ex>n</ex></expan>. Der hat uns
                            <expan>geantw<ex>ur</ex>t,</expan> wie in der
                            <expan>vorg<ex>enante</ex></expan>
<expan>Swarczemberg<ex>er</ex></expan> vor etwievil zeiten
                                <expan>v<ex>er</ex>seczet</expan> hab, da er sich selb hab von
                        müssen lösen, als er auch des <expan>br<ex>iefs</ex></expan> und
                                <expan>ins<ex>igel</ex></expan> hab; darczu hab er
                                <expan>dems<ex>elben</ex></expan>
<expan>Swarczemberg<ex>er</ex></expan>
<expan>sein<ex>en</ex></expan> harnasch gelihen, des alles er von im noch
                        nie <expan>bekome<ex>n</ex></expan> künd, des er zu grossen
                                <expan>schad<ex>en</ex></expan>
<expan>kome<ex>n</ex></expan>. Nu hab er die sache mit recht gen im
                                <expan>angefang<ex>en</ex></expan> und well auch die mit recht
                                <expan>g<ex>er</ex>n</expan>
<expan>austrag<ex>en</ex></expan>. <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>erberk<ex>eit</ex></expan> mit
                        fleisz, daz ir mit dem <expan>obg<ex>enanten</ex></expan>
<expan>Swarcze<ex>n</ex>b<ex>er</ex>g<ex>er</ex></expan> reden und
                                <expan>bestell<ex>e</ex>n</expan> wellet, daz er den
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> ausricht und unklaghaft mache, als das wol
                        pillich ist, wan wir <expan>dens<ex>elben</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> von <expan>seine<ex>n</ex></expan>
<expan>recht<ex>en</ex></expan> niht <expan>gewerffe<ex>n</ex></expan>
                        künnen. Das <expan>well<ex>e</ex>n</expan> wir umb ewr
                                <expan>erberk<ex>eit</ex></expan> allczeit
                                <expan>willikl<ex>ich</ex></expan> und <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra.</ex></expan>
</ab>
</div>
