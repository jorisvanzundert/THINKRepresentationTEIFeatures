</front>
<body><div type="diplomatic"><pb facs="#facs_40" id="20r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_40_r2l1"><expan>Hılpolt<ex>en</ex></expan> <expan>frawnberg<ex>er</ex></expan> ʒu Prunn </ab>
</div>
