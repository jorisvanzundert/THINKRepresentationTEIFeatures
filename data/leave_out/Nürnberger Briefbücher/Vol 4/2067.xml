<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Heinr<ex>ich,</ex></expan> als du uns
                            <expan>verschr<ex>iben</ex></expan> und
                            <expan>geantw<ex>ur</ex>t</expan> hast und geleyts für uns begerst etc.,
                        das <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>
                        und manen dich aber <expan>ernstl<ex>ich</ex></expan>, wes wir dich
                                <expan>gemane<ex>n</ex></expan>
<expan>mug<ex>en</ex></expan>, daz du <expan>h<ex>er</ex>ein</expan> für uns
                                <expan>kom<ex>m</ex>est,</expan> und auf das, daz du dem
                                <expan>nachkom<ex>m</ex>est</expan>, als du uns
                                <expan>yecz<ex>unden</ex></expan>
<expan>geschr<ex>iben</ex></expan> hast. Wenn du denn
                                <expan>hiezwisch<ex>en</ex></expan>
<app>
<note><q type="date">sunntags schierist</q>22.03.1416</note>
</app> zu uns <expan>h<ex>er</ex>ein</expan>
<expan>kom<ex>m</ex>st</expan>, so <expan>well<ex>e</ex>n</expan> wir dir
                        vier tag geleyt <expan>geb<ex>e</ex>n</expan> on
                            <expan>gev<ex>er</ex>d</expan> und dein red hören.
                            <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan>
<expan>remi<ex>ni</ex>sce<ex>re</ex></expan>. </ab>
</div>
