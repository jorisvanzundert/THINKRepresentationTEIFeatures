<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sattelpog<ex>er,</ex></expan> als wir ewch
                                                nehst <expan>verschr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan> von der schuld
                                                  <expan>weg<ex>en,</ex></expan> die uns Hilpolt
                                                  <expan>Frawnberg<ex>er</ex></expan> zu Prunn
                                                schuldig ist, <expan>daru<ex>m</ex>b</expan> ir
                                                  <expan>uns<ex>er</ex></expan> bürg seyt,
                                                  <expan>lass<ex>en</ex></expan> wir ewr
                                                  <expan>erberk<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir
                                                  <expan>ders<ex>elben</ex></expan> schuld noch niht
                                                beczalt <expan>worde<ex>n</ex></expan> sein.
                                                  <expan>Daru<ex>m</ex>b</expan> bitten und manen
                                                wir ewch mit disem brief, daz ir
                                                  <expan>unv<ex>er</ex>zogenl<ex>ich</ex></expan> in
                                                den <expan>nehst<ex>en</ex></expan> xiiii
                                                  <expan>tag<ex>en</ex></expan>
<expan>eine<ex>n</ex></expan>
<expan>erb<ex>er</ex>n</expan> knecht mit
                                                  <expan>eine<ex>m</ex></expan> pferd schikt gen
                                                  <expan>P<ex>er</ex>ching</expan> in
                                                  <expan>Pet<ex>er</ex></expan> Windisch hawse
                                                  <expan>das<ex>elbst,</ex></expan> der darinn
                                                laiste nach <expan>uns<ex>er</ex>s</expan>
<expan>schuldbr<ex>iefs</ex></expan> sag alslang,
                                                bis wir der <expan>vorg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>r</expan> schuld nach des
                                                  <expan>egen<ex>anten</ex></expan>
<expan>schuldbr<ex>iefs</ex></expan> sag beczalt
                                                  <expan>w<ex>er</ex>den</expan>. Und getrawen
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit,</ex></expan> ir
                                                  <expan>v<ex>er</ex>czieht</expan> uns des niht.
                                                Das <expan>well<ex>e</ex>n</expan> wir allczeit
                                                  <expan>g<ex>er</ex>n</expan> umb ewch
                                                  <expan>v<ex>er</ex>dienen</expan>.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>remi<ex>ni</ex>sce<ex>re.</ex></expan>
</ab>
</div>
