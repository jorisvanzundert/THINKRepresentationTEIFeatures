<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Albr<ex>echt,</ex></expan> als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von des
                            <expan>Tüm<ex>m</ex>erlein</expan> Swoben <expan>weg<ex>en</ex></expan>,
                        wie sich der vor uns entsicze, wan er des
                            <expan>Frawnberg<ex>er</ex>s</expan> knecht
                            <expan>gewes<ex>en</ex></expan> sey, und sey doch niht bey
                                <expan>uns<ex>er</ex>m</expan>
<expan>schad<ex>en</ex></expan>
<expan>gewes<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>v<ex>er</ex>nom<ex>en</ex></expan>. Nu sein die zweytracht, die
                                <expan>zwisch<ex>e</ex>n</expan>
<expan>Hilpolt<ex>en</ex></expan> Frawn<expan>berg<ex>er</ex></expan> und
                                <expan>uns<ex>er</ex></expan> und auch <expan>all<ex>er</ex></expan>
                        der, die auf beiden tailn <expan>darunt<ex>er</ex></expan>
<expan>v<ex>er</ex>dacht</expan> gewest sint, gütlich
                            <expan>v<ex>er</ex>richt</expan> und <expan>abgetrag<ex>en,</ex></expan>
                        als ewr <expan>erberk<ex>eit</ex></expan> das villeiht wol mag
                                <expan>v<ex>er</ex>nomen</expan>
<expan>hab<ex>e</ex>n</expan>. Und darumb bedarff sich der
                                <expan>vorg<ex>enante</ex></expan> Swob vor uns und den
                                <expan>uns<ex>er</ex>n</expan> niht
                            <expan>entsicze<ex>n,</ex></expan> daz er des
                            <expan>obg<ex>enanten</ex></expan>
<expan>Frawnberg<ex>er</ex>s</expan> knecht <add>in
                                    <expan>ders<ex>elben</ex></expan> zeit</add>
<expan>gewes<ex>en</ex></expan> ist, denn wir <expan>beg<ex>er</ex>n</expan>
                        im <expan>daru<ex>m</ex>b</expan> keins argen ze
                            <expan>gewarte<ex>n</ex></expan>. Wer <expan>ab<ex>er</ex></expan>, daz
                        er mit uns <expan>od<ex>er</ex></expan> den <expan>uns<ex>er</ex>n</expan>
                        iht <expan>and<ex>er</ex>s</expan> ze <expan>schik<ex>en</ex></expan> hett,
                        daz uns zu disen <expan>zeit<ex>en</ex></expan> niht
                                <expan>wissenl<ex>ich</ex></expan> ist, so
                            <expan>well<ex>e</ex>n</expan> wir im durch
                            <expan>ewr<ex>er</ex></expan> pett <expan>will<ex>e</ex>n</expan>
<expan>hiezwisch<ex>en</ex></expan> und <app><note><q type="date">sant Michelstag</q>29.09.1414</note></app>
<expan>g<ex>er</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>sicherh<ex>eit</ex></expan> und gelait <expan>geb<ex>e</ex>n</expan>,
                            <add>on geverde</add>. Und wenn er in <expan>ders<ex>elben</ex></expan>
                        zeit zu uns kombt, sein rede <expan>v<ex>er</ex>hören</expan>. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> etc. <expan>Dat<ex>um</ex></expan> in
                        vigilia <expan>assumpc<ex>i</ex>o<ex>n</ex>is</expan>
<expan>b<ex>ea</ex>te</expan>
<expan>Ma<ex>r</ex>ie.</expan>
</ab>
