<body><div type="diplomatic"><pb facs="#facs_186" id="93r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_186_r2l2">Hanſen vnd Jörgen </ab>
<ab facs="#facs_186_r2l3">von Eẏberg <expan>geprüd<ex>er</ex>n</expan> </ab>
</div>
