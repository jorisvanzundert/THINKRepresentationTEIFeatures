<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> burggraf, als ir uns bey Wölfel
                                <expan>Schulth<ex>eisz,</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan>, <expan>verschr<ex>iben</ex></expan> und
                                <expan>geantw<ex>ur</ex>t</expan> habt als von der hab
                                <expan>weg<ex>en</ex>,</expan> die den
                            <expan>uns<ex>er</ex>n</expan> nehst in der geneh bey ewch
                                <expan>genome<ex>n</ex></expan> ist <expan>word<ex>en</ex></expan>
                        etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>bitt<ex>en</ex></expan> ewr
                                <expan>erberk<ex>eit</ex></expan> mit fleiss, was
                                <expan>ders<ex>elben</ex></expan> hab noch
                            <expan>vorhande<ex>n</ex></expan> und belyben sey, die der
                                <expan>uns<ex>er</ex>n</expan> ist, daz ir die
                                <expan>Ulr<ex>ich</ex></expan> Mayr,
                            <expan>antwurt<ex>er</ex></expan> disz briefs, den die
                                <expan>uns<ex>er</ex>n</expan>
<expan>daru<ex>m</ex>b</expan> ausgesant <expan>habe<ex>n</ex></expan>,
                                <expan>wid<ex>er</ex></expan>
<expan>schik<ex>en</ex></expan> und <expan>antwurte<ex>n</ex></expan> wellet
                        und den <expan>uns<ex>er</ex>n</expan> ewr <expan>fürdru<ex>n</ex>g</expan>
                        und guten <expan>will<ex>e</ex>n</expan> beweiset, als wir ewch wol getrawn.
                        Das <expan>well<ex>e</ex>n</expan> wir allczeit <expan>g<ex>er</ex>n</expan>
                        umb ewch <expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>p<ex>ur</ex>ifica<ex>ci</ex><hi rend="sup">o<ex>n</ex>is</hi></expan>
                        Marie. </ab>
</div>
<div type="similiter">
<ab><expan>It<ex>em</ex></expan> der stat zum <expan>Elmbog<ex>en</ex></expan>
<expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>
<expan>mutat<ex>is</ex></expan>
<expan>muta<ex>n</ex>dis</expan> et excepto als ir uns bey Wölfel
