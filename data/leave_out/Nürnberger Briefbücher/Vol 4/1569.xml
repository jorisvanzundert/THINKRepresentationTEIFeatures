<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Uns<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> bevor. <expan>H<ex>einrich</ex></expan>
<expan>Vett<ex>er</ex></expan>, als du uns <add>nehst</add>
<expan>verschr<ex>iben</ex></expan> und <expan>jecz<ex>unden</ex></expan>
                        ein <expan>antw<ex>ur</ex>t</expan>
<expan>geford<ex>er</ex>t</expan> hast, als von der schuld
                                <expan>weg<ex>en</ex></expan>, die dir von den
                            <expan>uns<ex>er</ex>n</expan> bey uns söll
                            <expan>v<ex>er</ex>potten</expan> sein etc., das
                            <expan>hab<ex>e</ex>n</expan> wir
                            <expan>v<ex>er</ex>nom<ex>en</ex></expan>. Nu
                            <expan>hab<ex>e</ex>n</expan> wir dir vormals
                            <expan>daru<ex>m</ex>b</expan>
<expan>verschr<ex>iben</ex></expan> und <expan>geantw<ex>ur</ex>t</expan>,
                        daz du das mit <expan>deine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit <expan>volle<ex>m</ex></expan>
                        gwalt vor des reichs <expan>richt<ex>er</ex></expan> bey uns ze
                                <expan>Nur<ex>emberg</ex></expan> mit
                            <expan>frewntl<ex>ichen</ex></expan>
<expan>recht<ex>en</ex></expan> mugst <expan>erford<ex>er</ex>n</expan> und
                                <expan>austrag<ex>en</ex></expan>. Das
                            <expan>wisse<ex>n</ex></expan> wir noch niht ze
                            <expan>end<ex>er</ex>n</expan>. Und als du <add>uns</add>
<expan>geschr<ex>iben</ex></expan> hast, wie wir dir in
                                <expan>uns<ex>er</ex>m</expan> brief und auch die
                                <expan>üb<ex>er</ex>geschrift</expan> darauf
                            <expan>and<ex>er</ex>s</expan>
<expan>geschr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan> denn vor, <expan>v<ex>er</ex>steest</expan> du
                        wol, daz niht not ist, daz du uns weisest, wie wir
                            <expan>uns<ex>er</ex></expan> brief <expan>schreibe<ex>n</ex></expan>
                        laszen, denn wir wissen wol, wie wir dir und <expan>deine<ex>n</ex></expan>
<expan>gleiche<ex>n</ex></expan> schreiben <expan>sull<ex>e</ex>n</expan>.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>Joh<ex>an</ex>is</expan>
<expan>bap<ex>tis</ex><hi rend="sup">te</hi></expan>. </ab>
</div>
