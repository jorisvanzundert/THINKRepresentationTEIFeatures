<div type="content">
<ab><add><expan>Uns<ex>er</ex></expan> dinst bevor</add>.
                            <expan>L<ex>ieber</ex></expan> her <expan>Frawnberg<ex>er</ex></expan>,
                        wir senden czu <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>
