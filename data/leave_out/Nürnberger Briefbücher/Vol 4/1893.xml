<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> vicztum, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von Wilhelm
                                <expan>Messing<ex>er</ex>s</expan>
<expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>vernom<ex>en</ex></expan> und <expan>well<ex>e</ex>n</expan> dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>Wilh<ex>e</ex>l<ex>m</ex></expan>
<expan>Messing<ex>er</ex></expan>, wenn er des
                            <expan>hiezwisch<ex>en</ex></expan> und <app>
<note><q type="date">sand Kylians tag schierist</q>08.06.1415</note>
</app> begert, <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> zu lieb zu uns und von uns drey tag
                                <expan>g<ex>er</ex>n</expan> geleyt <expan>geb<ex>e</ex>n</expan>
                        für uns und die <expan>uns<ex>er</ex>n</expan> on
                            <expan>gev<ex>er</ex>de</expan> und sein red hören. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>Joh<ex>an</ex>is.</expan>
</ab>
</div>
