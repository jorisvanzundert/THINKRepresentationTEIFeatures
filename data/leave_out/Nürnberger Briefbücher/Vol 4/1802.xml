<del rend="strikethrough">lat vns <expan>daru<ex>m</ex>b</expan> eẅr <expan>verſchr<ex>iben</ex></expan> <expan>antw<ex>ur</ex>t</expan> <expan>wıd<ex>er</ex></expan> <expan>wıſſ<ex>en</ex></expan> bey <expan>dıſe<ex>m</ex></expan> <expan>botte<ex>n</ex></expan></del> <expan>dat<ex>um</ex></expan> </ab>
