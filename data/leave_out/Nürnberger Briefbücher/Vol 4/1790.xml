</front>
<body><div type="diplomatic"><pb facs="#facs_137" id="68v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_137_r1l1"><expan>H<ex>er</ex>n</expan> <expan>Heınr<ex>ich</ex></expan> <expan>Nothaft<ex>en</ex></expan> ʒum <expan>VVermb<ex>er</ex>g</expan> </ab>
<ab facs="#facs_137_r1l2">vıcʒtum Jn Nider payern etc </ab>
</div>
