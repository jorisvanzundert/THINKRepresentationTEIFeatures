<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Fridr<ex>ich</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von
                            <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>weg<ex>en</ex></expan>
<expan>Heinr<ex>ich</ex></expan>
<expan>Rum<ex>m</ex>els</expan> des <expan>elt<ex>er</ex>n</expan> etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan> ewch
                                <expan>wiss<ex>en</ex></expan>, daz wir in
                            <expan>daru<ex>m</ex>b</expan> czu rede gesaczt
                            <expan>hab<ex>e</ex>n</expan>. Der hat uns
                            <expan>geantw<ex>ur</ex>t,</expan> daz er <expan>ewr<ex>er</ex></expan>
<expan>swyg<ex>er</ex></expan> noch ewch niht schuldig sey, als er ewch
                                <expan>daru<ex>m</ex>b</expan>
<expan>selb<ex>er</ex></expan> maint sein <expan>antw<ex>ur</ex>t</expan> zu
                        tun. Wie <expan>daru<ex>m</ex>b</expan> dewcht <expan>ewr<ex>er</ex></expan>
<expan>swyg<ex>er</ex></expan> oder ewch, daz ir
                            <expan>darüb<ex>er</ex></expan> zu im iht <expan>zu
                            sprech<ex>en</ex></expan> hett, <expan>daru<ex>m</ex>b</expan>
<expan>well<ex>e</ex>n</expan> wir ewch oder <expan>ew<ex>r</ex>n</expan>
                        schein <expan>bott<ex>en</ex></expan> mit <expan>ew<ex>r</ex>m</expan>
<expan>voll<ex>e</ex>n</expan> gwalt <expan>frewntl<ex>ich</ex></expan>
                        slewnigs <expan>recht<ex>en</ex></expan> von
                            <expan>dems<ex>elben</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> anheim ist, on
                            <expan>gev<ex>er</ex>de</expan>. Und getrawen ewch, ir lat ewch des
                                <expan>genüg<ex>en</ex></expan>; denn wo wir ewch lieb
                                <expan>od<ex>er</ex></expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>. </ab>
</div>
