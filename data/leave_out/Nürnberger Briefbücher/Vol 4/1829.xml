<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns ein urteil
                                <expan>verschr<ex>iben</ex></expan> geschikt habt, wie Hanns
                                <expan>Herdeg<ex>en,</ex></expan>
<expan>burg<ex>er</ex></expan> zu Winsheim, Göczen
                            <expan>Leyr<ex>er,</ex></expan>
<expan>ew<ex>r</ex>m</expan>
<expan>b<ex>urger</ex></expan>, <expan>zugesproch<ex>en</ex></expan> hat als
                        von etwievil schulde <expan>weg<ex>en</ex></expan>, die er im on
                                <expan>sein<ex>en</ex></expan> schaden beczalt solt
                                <expan>hab<ex>e</ex>n,</expan> und uns bitt, den
                                <expan>Wagn<ex>er</ex></expan>, des Herdegens
                            <expan>brud<ex>er</ex></expan>, <expan>daru<ex>m</ex>b</expan> zu
                                <expan>v<ex>er</ex>hören</expan> etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>
                        und <expan>lass<ex>en</ex></expan> ewch <expan>wiss<ex>en</ex></expan>, daz
                        wir den <expan>vorg<ex>enanten</ex></expan>
<expan>Wagn<ex>er</ex></expan>
<expan>genan<ex>n</ex>t</expan>
<expan cert="unknown">H.</expan> Pfnürr <expan>daru<ex>m</ex>b</expan> auf
                        sein eyt gefragt <expan>habe<ex>n</ex></expan>. Der hat uns gesagt, daz im
                        Göcz <expan>Leyr<ex>er</ex></expan> mit <expan>seine<ex>n</ex></expan>
                        trewen in sein hand gelobet, die schulde, die er dem
                                <expan>obg<ex>enanten</ex></expan>
<expan>Hanns<ex>en</ex></expan>
<expan>Herdeg<ex>en,</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>brud<ex>er,</ex></expan> schuldig <expan>w<ex>er</ex>e,</expan> on
                        sein <expan>schad<ex>en</ex></expan> zu beczaln <app>
<note><q type="date">xiiii tag nach sand Lorenczen tag nehst
                                            <expan>v<ex>er</ex>gang<ex>en</ex></expan></q>24.08.1414</note>
</app>. Also hab er im allrerst in der <app>
<note><q type="date"><expan>palmwoch<ex>en</ex></expan>
<expan>nehstv<ex>er</ex>gang<ex>en</ex></expan></q>24.–30.03.1415</note>
</app> xxvii <expan>l<ex>i</ex>b<ex>ra</ex></expan> daran beczalt und sey im
                        wol <expan>wissenl<ex>ich</ex></expan>, daz sein
                            <expan>brud<ex>er</ex></expan>, der <expan>Herdeg<ex>en</ex></expan>,
                        das gelt zu schaden <expan>genome<ex>n</ex></expan> hab nach der
                                <expan>vorg<ex>enanten</ex></expan> frist. Das
                            <expan>v<ex>er</ex>kunden</expan> wir und
                            <expan>schik<ex>en</ex></expan> ewch <expan>ew<ex>r</ex>n</expan> brief
                                <expan>wid<ex>er</ex></expan> hierinn verslossen. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>fr<ex>ewntschaft</ex></expan> etc. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra.</ex></expan>
</ab>
</div>
