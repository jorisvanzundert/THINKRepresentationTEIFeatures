<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>pfleg<ex>er</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von
                            <expan>ew<ex>r</ex>s</expan>
<expan>armman<ex>n</ex>s</expan>
<expan>Han<ex>n</ex>sen</expan>
<expan>Biderman<ex>n</ex>s</expan> von Osterweylr und der Prewnin,
                                <expan>selig<ex>en</ex></expan>, <expan>uns<ex>er</ex>r</expan>
<expan>burg<ex>er</ex>in</expan>, <expan>weg<ex>en</ex></expan> etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>hab<ex>e</ex>n</expan>
<expan>daru<ex>m</ex>b</expan>
<expan>Han<ex>n</ex>sen</expan> Tucher den <expan>elt<ex>er</ex>n</expan>
                        und <expan>Conr<ex>ad</ex></expan>
<expan>Pöczling<ex>er,</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex>,</expan> besant und zu rede gesaczt. Die
                                <expan>hab<ex>e</ex>n</expan> uns <expan>geantw<ex>ur</ex>t</expan>,
                        wie daz es <expan>yecz<ex>unden</ex></expan> in dem dritten jare sey, daz
                        Agnes Prewnin, selig, <expan>uns<ex>er</ex></expan>
<expan>b<ex>urgerin</ex></expan>, bey uns von tods
                            <expan>weg<ex>en</ex></expan>
<expan>abgang<ex>en</ex></expan> sey. Die hab bey irem
                                <expan>lebentig<ex>en</ex></expan> leib mit
                                <expan>wolbedacht<ex>em</ex></expan> mut ein redlich gescheft getan,
                                <expan>v<ex>er</ex>sigelt</expan> mit der stat zu
                                <expan>Nür<ex>emberg</ex></expan> anhangendem
                                <expan>ins<ex>igel,</ex></expan>
<expan>darüb<ex>er</ex></expan> sie die <expan>obg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> beide zu <expan>vormünd<ex>en</ex></expan><pb facs="#facs_115" id="57v"/>
<expan>genome<ex>n</ex></expan> und in <expan>voll<ex>e</ex>n</expan> gwalt
                                <expan>geb<ex>e</ex>n</expan> hab, das also
                                <expan>auszericht<ex>en</ex></expan>.
                            <expan>Ders<ex>elben</ex></expan> gescheft <expan>hab<ex>e</ex>n</expan>
                        auch sie getrewlich und <expan>ungev<ex>er</ex>lich</expan> ausgericht, als
                        denn die frawe das geschaft hat; dewcht <expan>ab<ex>er</ex></expan> den
                                <expan>vorg<ex>enanten</ex></expan>
<expan>ew<ex>r</ex>n</expan> arm<expan>man<ex>n</ex></expan>
<expan>od<ex>er</ex></expan> sein weib, daz sie
                            <expan>darüb<ex>er</ex></expan> zu den
                            <expan>obg<ex>enanten</ex></expan>
<expan>vormünd<ex>en</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urgern</ex></expan>, iht zu <expan>sprech<ex>en</ex></expan>
<expan>hett<ex>en</ex></expan>, so <expan>welle<ex>n</ex></expan> sie in
                                <expan>od<ex>er</ex></expan> iren
                            <expan>scheinbott<ex>en</ex></expan> mit irem
                            <expan>voll<ex>e</ex>m</expan> gwalt <expan>frewtl<ex>ich</ex></expan>
                        slewnigs <expan>recht<ex>en</ex></expan> sein vor des reichs
                                <expan>richt<ex>er</ex></expan> bey uns zu
                                <expan>Nür<ex>emberg,</ex></expan> wenn sie des ermant
                                <expan>w<ex>er</ex>den,</expan> so die
                            <expan>uns<ex>er</ex>n</expan> anheim sind, on
                            <expan>gev<ex>er</ex>de</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan> Anthonii. </ab>
