<ab facs="#facs_190_r1l17">Greẅcʒ <expan>Hawbtm<ex>an</ex></expan> ʒu Bernaw . <expan>H<ex>er</ex>n</expan> <expan>Heinr<ex>ich</ex></expan> <expan>H<ex>er</ex>ren</expan> ʒu </ab>
