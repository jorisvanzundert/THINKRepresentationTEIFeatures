<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sattelpog<ex>er</ex></expan>, von der vii<hi rend="sup">c</hi> und
                        lxii <expan>guld<ex>en</ex></expan>
<expan>weg<ex>en</ex></expan>, die uns Hilpolt
                            <expan>Frawnberg<ex>er</ex></expan> zu Prunn schuldig ist und auf den
                        <app><note><q type="date"><expan>nehstv<ex>er</ex>gang<ex>en</ex></expan> sand Merteins tag</q>11.11.1414</note></app>
                        beczalt solt <expan>hab<ex>e</ex>n</expan>, darauf ir mit
                                <expan>etlich<ex>e</ex>n</expan>
<expan>and<ex>er</ex>n</expan> unser bürg seyt, tun wir
                                <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> zu wissen, daz uns die
                                <expan>uns<ex>er</ex>n,</expan> die die sache antrift, teglich
                                <expan>daru<ex>m</ex>b</expan> anrüffen, wan der
                                <expan>vorg<ex>enante</ex></expan> Hilpolt
                                <expan>Frawnberg<ex>er</ex></expan>
<expan>dies<ex>elb</ex></expan> schulde bis her
                            <expan>v<ex>er</ex>czogen</expan> und niht beczalt hat.
                                <expan>Daru<ex>m</ex>b</expan> so <expan>bitt<ex>en</ex></expan> wir
                        ewr <expan>erberk<ex>eit</ex></expan> mit fleiss, ir wellt schiken und
                                <expan>bestell<ex>e</ex>n</expan>, daz wir
                            <expan>derselb<ex>e</ex>n</expan> schulde noch
                            <expan>unv<ex>er</ex>czogenlich</expan> beczalt
                            <expan>w<ex>er</ex>den</expan>; das <expan>well<ex>e</ex>n</expan> wir
                        umb ewr <expan>erberk<ex>eit</ex></expan> allczeit
                            <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>, wan uns niht lieb <pb facs="#facs_112" id="56r"/><expan>w<ex>er</ex>e,</expan>
<expan>sölt<ex>en</ex></expan> wir ewch <expan>daru<ex>m</ex>b</expan>
<expan>zusprech<ex>en</ex></expan> und manen nach
                            <expan>uns<ex>er</ex>s</expan> briefs sag. Und lat uns
                                <expan>daru<ex>m</ex>b</expan> ewr
                            <expan>verschr<ex>iben</ex></expan>
<expan>antw<ex>ur</ex>t</expan>
<expan>wid<ex>er</ex></expan>
<expan>wiss<ex>en</ex></expan> bey <expan>dis<ex>em</ex></expan>
<expan>bott<ex>en.</ex></expan> D<expan>at<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan> Erhardi. </ab>
</div>
