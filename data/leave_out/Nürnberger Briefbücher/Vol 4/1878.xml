                            <expan>ſchık<ex>en</ex></expan>
<expan>habe<ex>n</ex></expan> denn guts Vnd
                            <expan>getrawte<ex>n</ex></expan>
</ab>
<ab facs="#facs_178_r1l26">Jm <expan>deſgleıch<ex>en</ex></expan> auch / Des
