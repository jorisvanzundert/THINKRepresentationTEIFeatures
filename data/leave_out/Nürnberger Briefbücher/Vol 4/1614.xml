<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>durlewchtik<ex>eit</ex></expan>
<expan>jecz<ex>unden</ex></expan> aber <expan>verschr<ex>iben</ex></expan>
                        hat von Wernher Newmeirs <expan>weg<ex>en</ex></expan> etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>v<ex>er</ex>nomen</expan>. Nu <expan>hab<ex>e</ex>n</expan> wir
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> vormals zu
                            <expan>gut<ex>er</ex></expan> mass <expan>verschr<ex>iben,</ex></expan>
                        wie sich die sache gehandelt hat, und beschiht uns von
                                <expan>dems<ex>elben</ex></expan> Newmeir ungütlich, daz er
                                <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> die sache <expan>and<ex>er</ex>s</expan>
                        fürgibt. Wie <expan>daru<ex>m</ex>b</expan> so
                            <expan>well<ex>e</ex>n</expan> wir kürczlich
                            <expan>uns<ex>er</ex></expan> selbs <expan>botsch<ex>aft</ex></expan> zu
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>daru<ex>m</ex>b</expan> tun und die sache
                                <expan>v<ex>er</ex>antwurt<ex>en</ex></expan>. Denn wa wir
                                <expan>ewr<ex>er</ex></expan>
<expan>durlewhtik<ex>eit</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan>
<expan>beweis<ex>en</ex></expan>
<expan>möcht<ex>en,</ex></expan> des <expan>wölt<ex>en</ex></expan> wir
                        willig sein und <expan>g<ex>er</ex>n</expan> tun.
                            <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra.</ex></expan>
</ab>
</div>
