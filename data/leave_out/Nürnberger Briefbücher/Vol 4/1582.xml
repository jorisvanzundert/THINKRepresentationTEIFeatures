<ab facs="#facs_22_r1l18">vnd kauffmanſchaft <expan>wıdergeb<ex>e</ex>n</expan> wöllet Als etc das <expan>wolle<ex>n</ex></expan> etc </ab>
<ab facs="#facs_22_r1l19"><expan>dat<ex>um</ex></expan> <expan>Sabb<ex>a</ex>to</expan> <expan>an<ex>te</ex></expan> Kyliani </ab>
