<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde,</ex></expan> als ir uns
                            <expan>verschr<ex>iben</ex></expan> und <expan>gebette<ex>n</ex></expan>
                        habt, ewch zu <expan>verschr<ex>eiben</ex></expan> als
                            <expan>vo<ex>n</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren,</expan> des <expan>römisch<ex>en</ex></expan> und zu
                                <expan>Ung<ex>er</ex>n</expan> etc. künigs, oder
                                <expan>and<ex>er</ex>r</expan> newer lewff
                            <expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan>
                        wir wol <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan>
                        ewr <expan>ersamk<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir <expan>v<ex>er</ex>nomen</expan>
<expan>hab<ex>e</ex>n</expan>, daz der <expan>vorg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> der römisch künig, zu Parys sein sülle und da
                                <expan>richtigu<ex>n</ex>g</expan> meyne zu
                            <expan>such<ex>en</ex></expan>
<expan>zwisch<ex>en</ex></expan> den zweyen künigreichen Frankenreich und
                        Engelland. Doch <expan>wiss<ex>en</ex></expan> wir des kein
                                <expan>aigensch<ex>aft</ex></expan> und
                            <expan>wiss<ex>en</ex></expan> zu <expan>dis<ex>en</ex></expan>
<expan>zeit<ex>en</ex></expan> niht <expan>and<ex>er</ex>r</expan>
<expan>treffenlich<ex>er</ex></expan> lewft, ewch zu
                                <expan>verschr<ex>eiben</ex></expan>. <expan>W<ex>er</ex>e</expan>
                        aber, daz wir hienach icht erfüren <expan>od<ex>er</ex></expan> gewar
                                <expan>wurd<ex>en,</ex></expan> daz uns
                            <expan>notdurft<ex>en</ex></expan>
<add>dewcht</add>, <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> zu
                            <expan>v<ex>er</ex>künd<ex>en,</ex></expan> das
                            <expan>wölt<ex>en</ex></expan> wir <expan>g<ex>er</ex>n</expan> tun.
                                <expan>Desgleich<ex>en</ex></expan> getrawn wir
                                <expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> auch wol. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan>
<expan>invocav<ex>i</ex><hi rend="sup">t</hi>.</expan>
</ab>
