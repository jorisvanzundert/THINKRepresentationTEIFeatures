<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Albr<ex>echt</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von der frawen zu der
                                <expan>Seligenport<ex>en</ex></expan> und
                            <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan> des <expan>Elwang<ex>er</ex>s</expan>
<expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>v<ex>er</ex>nom<ex>en</ex></expan> und lassen ewch
                                <expan>wiss<ex>en</ex></expan>, daz wir
                            <expan>dens<ex>elben</ex></expan>
<expan>Elwang<ex>er</ex></expan> für uns besant und
                            <expan>daru<ex>m</ex>b</expan> zu rede gesaczt
                            <expan>hab<ex>e</ex>n</expan>; der hat uns
                            <expan>geantw<ex>ur</ex>t</expan>, daz im in
                            <expan>dens<ex>elben</ex></expan>
<expan>sach<ex>e</ex>n</expan> gar ungütlich
                            <expan>beschehe<ex>n</ex></expan> sey und beschehe. Wie
                                <expan>daru<ex>m</ex>b</expan> so <expan>hab<ex>e</ex>n</expan> wir
                        doch so <expan>v<ex>er</ex>r</expan> mit im gerett, daz er <add>dem gericht
                                    <expan>ein<ex>en</ex></expan> aufslag geben und die sache
                            ansteen lassen wil</add> bis auf das nehst lantgericht, daz zum Stain
                            <add>oder zu <expan>d<ex>er</ex></expan> Freynstat</add> wirt, ze
                                be<expan>suche<ex>n</ex></expan>, ob die von der
                                <expan>Selig<ex>en</ex>porten</expan> und er
                                <expan>dazwisch<ex>en</ex></expan> gütlich <pb facs="#facs_41" id="20v"/>
<expan>muge<ex>n</ex></expan> geaint <expan>w<ex>er</ex>den</expan>.
                                <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewch, ir wellt ewr
                                <expan>fürdru<ex>n</ex>g</expan> darczu tun, daz unser
                                <expan>b<ex>urger</ex></expan> bey gleich beleibe. Das
                                <expan>well<ex>e</ex>n</expan> wir allczeit
                            <expan>g<ex>er</ex>n</expan> umb ewch <expan>v<ex>er</ex>dienen</expan>.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra.</ex></expan>
</ab>
</div>
