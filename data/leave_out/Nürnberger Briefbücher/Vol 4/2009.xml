<ab facs="#facs_245_r1l22"><expan>Dat<ex>um</ex></expan> <expan>f<ex>er</ex>ıa</expan> vȷ<hi rend="sup">a</hi> <expan>an<ex>te</ex></expan> <expan>Kath<ex>e</ex>r<ex>ine</ex></expan> / Antwurt </ab>
