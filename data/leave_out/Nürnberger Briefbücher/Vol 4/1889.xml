<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Frawnberg<ex>er</ex></expan>, als ir uns
                            <expan>yecz<ex>unden</ex></expan>
<expan>verschr<ex>iben</ex></expan> habt von der geltschuld
                                <expan>weg<ex>en,</ex></expan> die ir uns schuldig seyt etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu hat sich die sache gar lank
                        verczogen, darumb <expan>hab<ex>e</ex>n</expan> wir von
                                <expan>uns<ex>er</ex>r</expan> notdurft
                            <expan>weg<ex>en</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>bürge<ex>n</ex></expan> gemant nach
                            <expan>ausweisu<ex>n</ex>g</expan>
<expan>uns<ex>er</ex>s</expan> schuldbriefs und können auch dem zu
                                <expan>dis<ex>en</ex></expan>
<expan>zeit<ex>en</ex></expan>
<expan>and<ex>er</ex>s</expan> niht getun. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan> Viti. </ab>
</div>
