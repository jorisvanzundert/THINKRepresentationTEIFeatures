<ab><expan>H<ex>er</ex>n</expan>
<expan>Fridrich<ex>en</ex></expan> Awer, <expan>Pet<ex>er</ex>n</expan>
<expan>Valkenstein<ex>er,</ex></expan>
<expan>v<ex>er</ex>wesern</expan> des lands in
                            <expan>Nid<ex>er</ex>n</expan> Payern etc.,
                            <expan>Eberhart<ex>en</ex></expan>
<expan>Nussperg<ex>er</ex></expan> und <expan>Conr<ex>ad</ex></expan>
