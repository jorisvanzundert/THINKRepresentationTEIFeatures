<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Heinr<ex>ich</ex></expan>, als du uns
                            <expan>verschr<ex>iben</ex></expan> hast und dein
                            <expan>burg<ex>er</ex>recht</expan> an <expan>deine<ex>m</ex></expan>
                        brief aufsenst etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan>
                        dich <expan>wiss<ex>en,</ex></expan> daz das niht gewonlich bey uns ist.
                        Denn hast du von der oder <expan>and<ex>er</ex>r</expan> sache
                                <expan>weg<ex>en</ex></expan> icht an uns zu
                            <expan>bring<ex>en</ex></expan>, das macht du müntlich tun, so wirt dir
                        ein <expan>antw<ex>ur</ex>t</expan>
<expan>daru<ex>m</ex>b</expan>. <expan>Dat<ex>um</ex></expan>
<expan>s<ex>ub</ex></expan> sigillo <expan>m<ex>a</ex>g<ex>ist</ex>ri
                                civiu<ex>m</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>invocav<ex>i</ex><hi rend="sup">t</hi></expan>. </ab>
</div>
