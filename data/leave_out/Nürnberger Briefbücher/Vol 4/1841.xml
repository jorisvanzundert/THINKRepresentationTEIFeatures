<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von gelts
                            <expan>weg<ex>en</ex></expan>, daz <expan>Johan<ex>n</ex></expan> von
                        Bechein, ewr <expan>dien<ex>er</ex></expan>, <expan>hind<ex>er</ex></expan>
                        den Stromeir bey uns gelegt süll <expan>hab<ex>e</ex>n,</expan>
<expan>daru<ex>m</ex>b</expan> uns ewr gnade vormals auch
                                <expan>geschrib<ex>e</ex>n</expan> hab und
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> kein redlich antwurt von uns
                                <expan>worde<ex>n</ex></expan> sey etc., das
                            <expan>habe<ex>n</ex></expan> wir wol <expan>vernome<ex>n</ex></expan>.
                        Nu <expan>hab<ex>e</ex>n</expan> wir <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> vormals <expan>daru<ex>m</ex>b</expan>
<expan>verschr<ex>iben</ex></expan> und <expan>geantw<ex>ur</ex>t,</expan>
                        des sich <expan>Johan<ex>n</ex></expan> von Bechem billich
                                <expan>benüg<ex>en</ex></expan> liess. Wie
                            <expan>daru<ex>m</ex>b</expan> so <expan>hab<ex>e</ex>n</expan> wir
                                <expan>Görg<ex>en</ex></expan>
<expan>Strom<ex>er,</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex>,</expan>
<expan>daru<ex>m</ex>b</expan>
<expan>ab<ex>er</ex></expan> zu rede gesaczt; der hat uns
                                <expan>geantw<ex>ur</ex>t,</expan> daz er der sache niht gehandelt
                        noch zu <expan>schik<ex>en</ex></expan> gehabt hab. Denn es hab sich bey
                        seiner <expan>mut<ex>er</ex></expan>
<expan>selig<ex>en</ex></expan>
<expan>lebendig<ex>en</ex></expan>
<expan>zeit<ex>en</ex></expan>
<expan>v<ex>er</ex>loffen</expan>, daz die etwievil gelts von
                                <expan>redlich<ex>er</ex></expan> schult
                            <expan>weg<ex>en,</ex></expan> die ir Arnolt von Buch schuldig
                                <expan>w<ex>er</ex>e</expan>, mit recht bey uns behabt hab, und sey
                            <add>auch</add> dasselb gelt <expan>Johan<ex>n</ex></expan> von Becheim
                        niht <expan>zugestande<ex>n</ex></expan>. Dewcht
                            <expan>ab<ex>er</ex></expan>
<expan>dens<ex>elben</ex></expan>
<expan>Johan<ex>n</ex></expan> von Becheim, daz er
                            <expan>darüb<ex>er</ex></expan> zu dem
                            <expan>vorg<ex>enanten</ex></expan> Görg <expan>Strom<ex>er</ex></expan>
                        iht <expan>zu sprech<ex>en</ex></expan> hett, <expan>daru<ex>m</ex>b</expan>
<expan>well<ex>e</ex>n</expan> wir im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt <expan>frewntl<ex>ich</ex></expan>
                        slewnigs <expan>recht<ex>en</ex></expan> von dem
                            <expan>obg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>b<ex>urger</ex></expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nur<ex>emberg,</ex></expan> wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> anheim ist, on
                            <expan>gev<ex>er</ex>de</expan>. Und <expan>bitt<ex>en</ex></expan> und
                        getrawn <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex>,</expan> ir wellt mit dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>Johan<ex>n</ex></expan> von Pecheim, <expan>ew<ex>r</ex>m</expan>
<expan>dien<ex>er,</ex></expan>
<expan>schik<ex>en</ex></expan> und <expan>bestell<ex>e</ex>n,</expan> daz
                        er sich des <expan>benüg<ex>en</ex></expan> lasse. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> lieb <expan>od<ex>er</ex></expan>
                        dienst etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
