</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sattelpog<ex>er,</ex></expan> als wir ewch vormals etwieoft
                                <expan>verschr<ex>iben</ex></expan> und gemant
                                <expan>habe<ex>n,</ex></expan> ewr knecht und pferd zu
                                <expan>schik<ex>en</ex></expan> gen Perching zu
                                <expan>laist<ex>en</ex></expan> nach <expan>uns<ex>er</ex>s</expan>
<expan>schuldbr<ex>iefs</ex></expan> sag als lang, bis wir von
                                <expan>Hilpolt<ex>en</ex></expan>
                            F<expan>rawnberg<ex>er</ex></expan>
<expan>uns<ex>er</ex>r</expan> schulde, <expan>daru<ex>m</ex>b</expan> ir
                                <expan>uns<ex>er</ex></expan> bürg seyt, beczalt
                                <expan>wurde<ex>n</ex></expan>, des bisher niht
                                <expan>bescheh<ex>en</ex></expan> ist; also manen wir ewch
                                <expan>ernstl<ex>ich</ex></expan> mit disem brief, daz ir noch
                                <expan>unv<ex>er</ex>czogenl<ex>ich</ex></expan>
<expan>ein<ex>en</ex></expan>
<expan>erb<ex>er</ex>n</expan> knecht mit <expan>eine<ex>m</ex></expan>
                        pferd schikt gen <expan>P<ex>er</ex>chnig</expan> in
                            <expan>Pet<ex>er</ex></expan> Windisch hawse, der da laiste von pferden
                        zu pferden, und auch ausz der <expan>laistu<ex>n</ex>g</expan> niht
                                <expan>kome<ex>n</ex></expan> nach <expan>uns<ex>er</ex>s</expan>
<expan>schuldbr<ex>iefs</ex></expan> sag, bis wir der
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>r</expan> schulde beczalt
                            <expan>w<ex>er</ex>den</expan>. Und getrawen
                            <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> noch, ir <expan>v<ex>er</ex>czieht</expan>
                        uns des niht <expan>leng<ex>er.</ex></expan>
<expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi> Bonifacii. </ab>
</div>
<div type="similiter">
<ab><expan>It<ex>em</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Wernh<ex>er</ex>n</expan>
<expan>Parsperg<ex>er</ex></expan> zu Parsperg<lb/>Görgen
                                <expan>Frawnberg<ex>er</ex></expan> zum Hag dem
                                <expan>jüng<ex>er</ex>n</expan><lb/><expan>Wilhelm<ex>en</ex></expan>
                        vom Wolfstein zur
                                <expan>Solczb<ex>ur</ex>g</expan><lb/><expan>Gebhart<ex>en</ex></expan>
                        Judman zu Affekln <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>
<lb/><expan>Ausgenom<ex>en</ex></expan> dem
                            <expan>Barsperg<ex>er</ex></expan> hat man in
                            <expan>seine<ex>m</ex></expan>
<expan>br<ex>ief</ex></expan> hieaussen gelassen, des
                            <expan>bish<ex>er</ex></expan> niht <expan>bescheh<ex>en</ex></expan>
                        ist, wan er hatt <expan>ein<ex>en</ex></expan> knecht etwielang in der
                                <expan>laistu<ex>n</ex>g</expan> gehabt. </ab>
</div>
