<expan>Han<ex>n</ex>s</expan>
<expan>Am<ex>m</ex>an</expan> fürbas <expan>sein<ex>en</ex></expan>
<expan>pfen<ex>n</ex>ing</expan> an einem <expan>offen<ex>en</ex></expan>
