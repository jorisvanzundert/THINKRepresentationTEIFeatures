<div type="content"><ab><app>
<note place="marginleft">
<expan>No<ex>n</ex></expan>
<expan>e<ex>st</ex></expan>
<expan>p<ex>raese</ex>ntata</expan>. </note>
</app><del rend="crossout">Aller <expan>durchl<ex>euhtigster</ex></expan>
<expan>f<ex>ürst</ex></expan> und <expan>h<ex>er</ex>re</expan>,
                                    <expan>uns<ex>er</ex></expan>
<expan>un<ex>ternikeit</ex></expan>
<expan>sch<ex>uldig</ex></expan> und <expan>w<ex>illig</ex></expan>
<expan>d<ex>ienst</ex></expan> sein <expan>ewr<ex>er</ex></expan>
<expan>künigl<ex>ich</ex></expan>
<expan>ma<ex>iestat</ex></expan> allczeit mit
                                <expan>g<ex>anczem</ex></expan>
<expan>f<ex>leisz</ex></expan> voran bereit.
                                <expan>Gnedigst<ex>er</ex></expan> fürst und
                                <expan>h<ex>er</ex>re</expan>, als uns ewr
                                <expan>kunigl<ex>ich</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan> von der
                                    <expan>jüdisch<ex>eit</ex></expan> bey uns und von Jüdel, juden,
                                    <expan>weg<ex>en</ex></expan>
<expan>yecz<ex>unden</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                                    <expan>v<ex>er</ex>nom<ex>en</ex></expan> und
                                    <expan>schik<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan> zu <expan>ewr<ex>er</ex></expan>
<expan>künigl<ex>ich</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>
<expan>Pet<ex>er</ex></expan>
<expan>Krag<ex>en</ex></expan>, <expan>weis<ex>er</ex></expan> disz
                                    <expan>br<ex>iefs</ex></expan>, dem wir befolhen
                                    <expan>habe<ex>n</ex></expan>, mit <expan>ewr<ex>er</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan> davon zu reden; und
                                    <expan>bitt<ex>en</ex></expan> ewr
                                <expan>künigl<ex>ich</ex></expan>
<expan>ma<ex>iestat</ex></expan>
<expan>demütikl<ex>ich</ex></expan> und mit
                                <expan>g<ex>anczem</ex></expan>
<expan>f<ex>leisz</ex></expan>, was der
                                <expan>obg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan>
<expan>daru<ex>m</ex>b</expan> zu disem mal an ewr
                                    <expan>hoch<ex>wirdikeit</ex></expan> werbe und bitte, daz ewr
                                    <expan>künigl<ex>ich</ex></expan> gnade in darinn gütlich
                                    <expan>v<ex>er</ex>hören</expan>,
                                <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und auch <expan>daru<ex>m</ex>b</expan>
<expan>gnedikl<ex>ich</ex></expan> von <expan>ewr<ex>er</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan>
<expan>fertig<ex>en</ex></expan> welle, als wir des
                                    <expan>dens<ex>elben</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>künigl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> wol getrawen. Das
                                <expan>well<ex>e</ex>n</expan> wir umb ewr
                                <expan>künigl<ex>ich</ex></expan>
<expan>ma<ex>iestat</ex></expan> allczeit
                                <expan>willikl<ex>ich</ex></expan> und <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan> ut
                                    <expan>sup<ex>ra.</ex></expan>
</del></ab></div>
