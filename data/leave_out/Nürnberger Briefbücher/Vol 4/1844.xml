<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sattelpog<ex>er,</ex></expan> als wir ewch
                                                nehst von der schulde <expan>weg<ex>en,</ex></expan>
                                                die uns Hilpolt <expan>Frawnberg<ex>er</ex></expan>
                                                zu Prunn schuldig ist,
                                                  <expan>daru<ex>m</ex>b</expan> ir
                                                  <expan>uns<ex>er</ex></expan> bürg seyt,
                                                  <expan>verschr<ex>iben</ex></expan> und auch
                                                gemant <expan>habe<ex>n</ex></expan>, ewr knecht und
                                                pferd zu <expan>schik<ex>en</ex></expan> gen
                                                Perching, zu <expan>laiste<ex>n</ex></expan> nach
                                                  <expan>uns<ex>er</ex>s</expan>
<expan>schuldbr<ex>iefs</ex></expan> sag in
                                                  <expan>Pet<ex>er</ex></expan> Windisch hawse
                                                  <expan>das<ex>elbst</ex></expan>, alslang bis wir
                                                  <expan>uns<ex>er</ex>r</expan> schulde beczalt
                                                wurden etc., daz aber ir uns noch bisher
                                                  <expan>v<ex>er</ex>czogen</expan> habt. Also
                                                  <expan>bitt<ex>en</ex></expan> und manen wir ewch
                                                  <expan>ab<ex>er</ex></expan> mit disem
                                                  <expan>br<ex>ief</ex></expan>, daz ir noch
                                                  <expan>unv<ex>er</ex>czogenl<ex>ich</ex></expan>
<expan>ein<ex>en</ex></expan>
<expan>erb<ex>er</ex>n</expan> knecht mit
                                                  <expan>eine<ex>m</ex></expan> pferd schikt gen
                                                Perching in des <expan>vorg<ex>enante</ex>n</expan>
<expan>Pet<ex>er</ex></expan> Windisch hawse
                                                  <expan>das<ex>elbst,</ex></expan> zu laisten nach
                                                des <expan>obg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>schuldbr<ex>iefs</ex></expan> sag, alslang
                                                bis wir der <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>r</expan> schulde beczalt
                                                  <expan>w<ex>er</ex>den</expan>. Und getrawn auch
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit,</ex></expan> ir
                                                  <expan>v<ex>er</ex>czieht</expan> uns des niht
                                                  <expan>leng<ex>er</ex></expan>, wan uns niht lieb
                                                  <expan>w<ex>er</ex>e</expan>, daz wir ewch dar umb
                                                  <expan>ernstlich<ex>er</ex></expan>
<expan>schreibe<ex>n</ex></expan> oder
                                                  <expan>erford<ex>er</ex>n</expan>
<expan>sölt<ex>en</ex></expan>.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Nerey et Achillei.
                                        </ab>
</div>
