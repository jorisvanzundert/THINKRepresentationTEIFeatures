<expan>burge<ex>r</ex></expan> sey, also daz <expan>kh<ex>ein</ex></expan>
                        auszman etc. <expan>Dar<ex>umb</ex></expan>
<expan>ro<ex>gamus,</ex></expan> daz ir <expan>denselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>bur<ex>gern</ex></expan>
<expan>dies<ex>elb</ex></expan> ir hab <expan>widergeb<ex>e</ex>n</expan>
