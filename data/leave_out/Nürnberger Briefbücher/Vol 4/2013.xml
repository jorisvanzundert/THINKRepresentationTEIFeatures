<body><div type="diplomatic"><pb facs="#facs_247" id="123v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_247_r1l6">Byſſchoff cʒu <expan>wircʒb<ex>ur</ex>g</expan> </ab>
</div>
