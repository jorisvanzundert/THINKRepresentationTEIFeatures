<body><div type="diplomatic"><pb facs="#facs_233" id="116v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_233_r2l12"><expan>Hercʒ<ex>og</ex></expan> <expan>heinr<ex>ich</ex></expan> von Bayern </ab>
</div>
