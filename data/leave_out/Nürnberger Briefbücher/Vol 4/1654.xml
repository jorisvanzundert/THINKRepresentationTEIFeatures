<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>hofmeist<ex>er</ex></expan>, als ir nehst dem
                                                  <expan>erwirdig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>n</expan>
<expan>Joh<ex>an,</ex></expan>
<expan>h<ex>er</ex>ren</expan> zu Heydek, thumprobst
                                                zu <expan>Bamb<ex>er</ex>g,</expan>
<expan>geschr<ex>iben</ex></expan> habt von der von
                                                Krottembach <expan>weg<ex>en</ex></expan> etc., also
                                                  <expan>hab<ex>e</ex>n</expan> uns etlich
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger,</ex></expan> die
                                                  <expan>dies<ex>elben</ex></expan> sache antrift,
                                                auf hewt <expan>ein<ex>en</ex></expan>
<expan>br<ex>ief</ex></expan> fürbracht, daran der
                                                  <expan>vorg<ex>enante</ex></expan>
<expan>h<ex>er</ex>re</expan> von Heidek
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>geantw<ex>ur</ex>t</expan> hat, den wir
                                                  <expan>aufgebroche<ex>n</ex></expan> und
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>hab<ex>e</ex>n</expan>
<expan>v<ex>er</ex>hören</expan> lassen und den wir
                                                ewch hierinn <expan>v<ex>er</ex>slossen</expan>
<expan>sende<ex>n</ex></expan>. Nu
                                                  <expan>hab<ex>e</ex>n</expan> uns die
                                                  <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>geantw<ex>ur</ex>t</expan>, daz sie der sache
                                                bey <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> auch
                                                  <expan>g<ex>er</ex>n</expan>
<expan>beleibe<ex>n</ex></expan>
<expan>well<ex>e</ex>n</expan> in
                                                  <expan>all<ex>er</ex>mass,</expan> als der
                                                thumprobst das <expan>verschr<ex>iben</ex></expan>
                                                und <expan>gebotte<ex>n</ex></expan> hat.
                                                  <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr
                                                  <expan>erberk<ex>eit</ex></expan> mit fleisz, daz
                                                ir ewch der sache also
                                                  <expan>anneme<ex>n</ex></expan> und
                                                  <expan>ein<ex>en</ex></expan> austrag
                                                  <expan>mache<ex>n</ex></expan> und auch das dem
                                                  <expan>obg<ex>enanten</ex></expan>
<expan>h<ex>er</ex>ren</expan> von Heydek und
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> ze tun
                                                  <expan>anschreibe<ex>n</ex></expan>
<add>und die <expan>br<ex>ief</ex></expan> herein
                                                  schiken</add> wellet; so
                                                  <expan>well<ex>e</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<add>das bottenlon <expan>g<ex>er</ex>n</expan>
                                                  beczaln und</add> die
                                                  <expan>br<ex>ief</ex></expan> fürbas hinweg
                                                  <expan>schik<ex>en</ex></expan>. Und getrawn
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> wol, daz ir uns
                                                des niht <expan>v<ex>er</ex>zeihet</expan>. Das
                                                  <expan>well<ex>e</ex>n</expan> wir allczeit
                                                  <expan>willikl<ex>ich</ex></expan> umb ewch
                                                  <expan>v<ex>er</ex>dienen</expan>.
                                                  <expan>Dat<ex>um</ex></expan> ut
                                                  <expan>s<ex>upra</ex></expan>. </ab>
