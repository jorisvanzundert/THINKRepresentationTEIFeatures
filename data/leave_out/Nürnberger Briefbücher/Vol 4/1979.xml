<body><div type="diplomatic"><pb facs="#facs_228" id="114r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_228_r1l2">Hanſen Troſſperg </ab>
<ab facs="#facs_228_r1l3">vnſerm burger </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab facs="#facs_228_r1l4"><expan>Vnſ<ex>er</ex></expan> freuntſchaft beuor / Hans Troſſperg / Vns hat fürgelegt </ab>
<ab facs="#facs_228_r1l5">Burkhart peſler <expan>vnſ<ex>er</ex></expan> Burger / vvie du Jm 
<del rend="strikethrough">ſein habe </del> cʒu Frankfurt </ab>
