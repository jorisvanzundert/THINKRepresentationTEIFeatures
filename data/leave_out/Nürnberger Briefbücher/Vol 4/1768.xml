<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> als uns ewr
                            <expan>durlewchtik<ex>eit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von Salman, ewers juden,
                                <expan>weg<ex>en</ex></expan> zu Ispruk und des Strölein, juden, bey
                        uns zu <expan>Nür<ex>emberg</ex></expan> gesessen etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Und ist uns
                            <expan>ders<ex>elben</ex></expan>
<expan>ewr<ex>er</ex></expan> gnaden brief <add>bey xiiii
                                    <expan>tag<ex>en</ex></expan></add> erst
                                <expan>geantw<ex>ur</ex>t</expan> worden. Also
                                <expan>lass<ex>en</ex></expan> wir ewr
                            <expan>hoch<ex>wirdikeit</ex></expan> wissen, daz wir den
                                <expan>vorg<ex>enanten</ex></expan> Strölein, juden, zustunden für
                        uns besant und <expan>ernstl<ex>ich</ex></expan>
<expan>daru<ex>m</ex>b</expan> zu rede geseczt
                        <expan>hab<ex>e</ex>n</expan>. Der hat uns
                            ge<expan>antw<ex>ur</ex>t,</expan> wie daz Elgast, jud, ir
                                <expan>beid<ex>er</ex></expan> vatter, eins mals
                                <expan>ungev<ex>er</ex>lich</expan> bey uns zu
                                <expan>Nür<ex>emberg</ex></expan>
<expan>durchgeritte<ex>n</ex></expan> sey und in sölich krankheit anstiess,
                        daz er stürb; und sey <expan>ders<ex>elb</ex></expan> Elgast, jud, in
                                <expan>sölich<ex>er</ex></expan> armut
                            <expan>gewes<ex>en,</ex></expan> daz er nichts <add>gehabt noch</add>
<expan>gelass<ex>en</ex></expan> hab, als das <expan>and<ex>er</ex>n</expan>
                        des <expan>vorg<ex>enante</ex>n</expan> Elgasts sünen wol
                                <expan>wissenl<ex>ich</ex></expan> sey, die in
                            <expan>daru<ex>m</ex>b</expan> niht anlangen. Wie
                            <expan>daru<ex>m</ex>b</expan> so spricht der
                                <expan>obg<ex>ena</ex>nt<ex>e</ex></expan> Strölein, jud, dewcht
                                <expan>Salman<ex>n,</ex></expan>
<expan>ewr<ex>er</ex></expan> gnaden juden, daz er
                            <expan>darüb<ex>er</ex></expan> zu im iht zu
                            <expan>sprech<ex>en</ex></expan> hett, so well er im
                                <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt <expan>frewntl<ex>ichen</ex></expan>
<expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan> sein vor des reichs
                            <expan>richt<ex>er</ex></expan>
<expan>od<ex>er</ex></expan> vor dem juden rat bey uns zu
                                <expan>Nur<ex>emberg</ex>,</expan> wenn er des ermant
                                <expan>w<ex>er</ex>de,</expan> so er anheim sey, on
                                <expan>gev<ex>er</ex>de</expan>. Denn wo wir
                            <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan>
<expan>beweis<ex>en</ex></expan>
<expan>möcht<ex>en</ex></expan>, des <expan>w<ex>er</ex>en</expan> wir
                        willig und teten das <expan>g<ex>er</ex>n</expan>.
                            <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nicam</expan>
<add>oculi.</add>
</ab>
