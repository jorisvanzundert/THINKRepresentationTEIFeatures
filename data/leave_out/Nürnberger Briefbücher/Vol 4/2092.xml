<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von <expan>Fricze<ex>n</ex></expan>
                        von Meyental <expan>weg<ex>en</ex></expan>, wie ewr gnade und er uns
                                <expan>geschr<ex>iben</ex></expan> und wir
                            <expan>darüb<ex>er</ex></expan> niht <expan>geantw<ex>ur</ex>t</expan>
<expan>hab<ex>e</ex>n</expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan> ewr
                        gnade <expan>wiss<ex>en,</ex></expan> daz wir in der
                            <expan>woch<ex>en</ex></expan> nehst <expan>Fricze<ex>n</ex></expan> von
                        Mayental ein <expan>antw<ex>ur</ex>t</expan>
<expan>hab<ex>e</ex>n</expan>
<expan>schreib<ex>en</ex></expan>
<expan>lass<ex>en</ex></expan> und <expan>g<ex>er</ex>n</expan>
<expan>geb<ex>e</ex>n</expan>
<expan>hett<ex>en,</ex></expan>
<expan>w<ex>er</ex>e</expan> die an uns <expan>geford<ex>er</ex>t</expan>
<expan>worde<ex>n</ex></expan>. Denn als uns ewr
                                <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von <expan>Stepf<ex>an</ex></expan>
<expan>Stüchs<ex>en</ex></expan> und <expan>Hanns<ex>en</ex></expan>
                        Türrigel <expan>weg<ex>en</ex></expan>, den <expan>well<ex>e</ex>n</expan>
                        wir von der sache <expan>weg<ex>en</ex></expan> keins argen
                                <expan>gewarte<ex>n</ex></expan> und <expan>wiss<ex>en</ex></expan>
                        zu <expan>dis<ex>en</ex></expan>
<expan>zeit<ex>en</ex></expan> mit in niht zu
                            <expan>schike<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan> denn guts. Denn wo wir
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>palma<ex>rum</ex></expan>. </ab>
</div>
