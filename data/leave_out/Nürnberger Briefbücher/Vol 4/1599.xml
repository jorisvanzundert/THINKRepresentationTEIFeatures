<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> vicztum, wir <expan>schik<ex>en</ex></expan> zu
                                <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>Barth<ex>o</ex>l<ex>omäus</ex></expan> Neythart,
                                <expan>uns<ex>er</ex>n</expan>
<expan>ratschreib<ex>er</ex></expan>, <expan>antwurt<ex>er</ex></expan> disz
                                <expan>br<ex>iefs</ex></expan>, dem wir befolhen
                                <expan>hab<ex>e</ex>n</expan>, von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> mit ewch ze reden als von des handels
                                <expan>weg<ex>en</ex></expan> des <expan>gefang<ex>en</ex></expan>,
                        den die <expan>uns<ex>er</ex>n</expan> zu der <expan>Weyd<ex>en</ex></expan>
                        zu gefenknuss bracht <expan>hett<ex>en</ex></expan>. Und
                                <expan>bitt<ex>en</ex></expan> ewr <expan>erberk<ex>eit</ex></expan>
                        mit fleisz, was er von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> zu disem mal an ewch
                            <expan>w<ex>er</ex>be</expan> als von des
                            <expan>obg<ex>enanten</ex></expan> handels
                            <expan>weg<ex>en,</ex></expan> daz ir im das
                            <expan>gelawbe<ex>n</ex></expan> und auch <expan>daru<ex>m</ex>b</expan>
                        gütlich <expan>ausricht<ex>en</ex></expan> und von ewch
                                <expan>fertig<ex>en</ex></expan> wellet, als wir ewch wol getrawn.
                        Das <expan>well<ex>e</ex>n</expan> wir umb ewr
                            <expan>erberk<ex>eit</ex></expan> etc. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra.</ex></expan>
</ab>
