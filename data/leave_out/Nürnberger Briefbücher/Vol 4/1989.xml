<expan>uns<ex>er</ex>r</expan> burger diener darynne durch
                                <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>gunstiklich<ex>e</ex>n</expan>
<add>mit <expan>ewr<ex>er</ex></expan>
<expan>furdru<ex>n</ex>g</expan></add>
