<body><div type="diplomatic"><pb facs="#facs_24" id="12r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_24_r1l13">Hannſen Streber <expan>vnſ<ex>er</ex>m</expan> <expan>B<ex>urger</ex></expan> </ab>
