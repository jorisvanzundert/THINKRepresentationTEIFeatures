<ab facs="#facs_266_r2l26"> <expan>h<ex>er</ex>re</expan> ~ der von Eppenſtein 
<del rend="strikethrough">auf </del> in <expan>ewre<ex>m</ex></expan> geleite <expan>aufgehalte<ex>n</ex></expan> hab <expan>Mitname<ex>n</ex></expan> vt <expan>ſu<ex>pra</ex></expan> <expan>p<ex>rae</ex>ciſe</expan> </ab>
<ab facs="#facs_266_r2l27">
<add><ab facs="#facs_266_r1l1"><expan>vſq<ex>ue</ex></expan></ab></add> <expan>Ro<ex>gamus</ex></expan> daʒ Jr den <expan>eg<ex>enanten</ex></expan> ~ <expan>vnſ<ex>er</ex>n</expan> <expan>B<ex>urger</ex></expan> <expan>ew<ex>r</ex></expan> gnedige <expan>fürdru<ex>n</ex>g</expan> darynne <expan>beweiſe<ex>n</ex></expan> wöllet </ab>
