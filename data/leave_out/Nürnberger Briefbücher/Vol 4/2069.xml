<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von <expan>Hanns<ex>en</ex></expan>
                        Rüsembachs, <expan>ew<ex>r</ex>s</expan>
<expan>burkman<ex>n</ex>s</expan> und <expan>dien<ex>er</ex>s</expan>,
                                <expan>weg<ex>en</ex></expan>, den <expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan>
<expan>gefang<ex>en</ex></expan>
<expan>hab<ex>e</ex>n</expan>, etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan> ewr
                        gnade <expan>wiss<ex>en,</ex></expan> daz newlich gar vil rewbrey umb uns
                                <expan>bescheh<ex>en</ex></expan> und die lewt, die zu uns und von
                        uns <expan>wand<ex>er</ex>n</expan>, in der geneh bey uns vast
                                <expan>geschund<ex>en</ex></expan> und
                                <expan>ernid<ex>er</ex>geworff<ex>en</ex></expan> sein
                                <expan>word<ex>en,</ex></expan>
<add>als das <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> auch wol mag
                                    ver<expan>nom<ex>m</ex>en</expan>
<expan>hab<ex>e</ex>n</expan></add>. Also <expan>hett<ex>en</ex></expan>
                        wir nehst ettlich <expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> von <expan>sölich<ex>er</ex></expan> sache
                                <expan>weg<ex>en</ex></expan> auf die
                            <expan>strass<ex>en</ex></expan> geschikt, die sein <add>gar spat</add>
                        auf den <expan>vorg<ex>enanten</ex></expan> Rüsembach und ettlich
                                <expan>and<ex>er</ex></expan>, die geverlich
                                <expan>geritt<ex>en</ex></expan> sein und greysige hab an der hand
                        gefürt <expan>hab<ex>e</ex>n</expan>, <expan>gestoss<ex>en</ex></expan> und
                                <expan>hab<ex>e</ex>n</expan> in <expan>gefang<ex>en</ex></expan>
                        und zu uns bracht. Wie <expan>daru<ex>m</ex>b</expan> so
                                <expan>well<ex>e</ex>n</expan> wir uns doch umb
                                <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> bett <expan>will<ex>e</ex>n</expan> darinn
                        niht <expan>v<ex>er</ex>gahen</expan> und der sache eygenlich erfarn; denn
                        wo wir <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> dienst und wol
                            <expan>gefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra</ex></expan>. </ab>
</div>
<div type="similiter">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Johans<ex>en,</ex></expan>
<expan>graf<ex>en</ex></expan> zu Wertheim,
                                <expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>
<expan>mutat<ex>is</ex></expan>
<expan>muta<ex>n</ex>dis.</expan>
