<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde,</ex></expan> uns <expan>hab<ex>e</ex>n</expan> etlich
                                <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> und die <expan>uns<ex>er</ex>n</expan>
                        fürbracht, wie daz sie bey ewch zu <expan>Kam<ex>m</ex></expan> mit zöllen
                        beswert <add>und an gefordert</add>
<expan>w<ex>er</ex>den</expan>
<expan>and<ex>er</ex>s,</expan> denn von alter
                            <expan>herkome<ex>n</ex></expan> und vormals beschehen sey,
                                <expan>bitt<ex>en</ex></expan> wir ewr
                            <expan>frewnts<ex>chaft</ex></expan> mit fleiss, daz ir
                                <expan>schik<ex>en</ex></expan> und
                            <expan>bestell<ex>e</ex>n</expan> wellet, daz mit den
                                <expan>uns<ex>er</ex>n</expan> kein newekeit bey ewch
                                <expan>angefang<ex>en</ex></expan> und
                            <expan>sölich<ex>er</ex></expan>
<expan>ungewönlich<ex>er</ex></expan> zöll fürbas
                            <expan>v<ex>er</ex>tragen</expan>
<expan>w<ex>er</ex>den</expan>, wan wir <expan>ung<ex>er</ex>n</expan>
<expan>gestatt<ex>en</ex></expan>
<expan>wölt<ex>en</ex></expan>, daz kein newekeit mit den
                                <expan>ew<ex>r</ex>n</expan> bey uns
                            <expan>angefang<ex>en</ex></expan> wurd. Und tut darinn, als etc. Das
                                <expan>well<ex>e</ex>n</expan> etc. Und lat uns
                                <expan>daru<ex>m</ex>b</expan> ewr frewntlich,
                                <expan>verschr<ex>iben</ex></expan>
<expan>antw<ex>ur</ex>t</expan>
<expan>wid<ex>er</ex></expan>
<expan>wiss<ex>en</ex></expan> bey <expan>dis<ex>em</ex></expan>
<expan>bott<ex>en</ex></expan>. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra.</ex></expan>
</ab>
