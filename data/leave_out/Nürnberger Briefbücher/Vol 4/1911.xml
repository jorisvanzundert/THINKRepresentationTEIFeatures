<body><div type="diplomatic"><pb facs="#facs_196" id="98r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_196_r1l21">Der Stat ʒu <expan>vveıſſemb<ex>ur</ex>g</expan> </ab>
</div>
