<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><app>
<note place="marginleft">
<expan>No<ex>n</ex></expan>
<expan>e<ex>st</ex></expan>
<expan>p<ex>raese</ex>ntata</expan>. </note>
</app><del rend="crossout"><expan>Uns<ex>er</ex></expan>
<expan>frewntl<ex>ich</ex></expan> dienst bevor.
                                <expan>L<ex>ieber</ex></expan> Petro, uns hat der
                                    <expan>all<ex>er</ex></expan> durchlewchtigst furst und
                                    <expan>h<ex>er</ex>re</expan>
<expan>h<ex>e</ex>r</expan>
<expan>Sig<ex>mund</ex></expan>, <expan>rö<ex>mischer</ex></expan> und
                            zu <expan>Ung<ex>er</ex>n</expan> etc. kunig,
                                <expan>uns<ex>er</ex></expan>
<expan>gnedigst<ex>er</ex></expan>
<expan>h<ex>er</ex>re,</expan> von der
                                <expan>judisch<ex>eit</ex></expan>
<expan>weg<ex>en</ex></expan> bey uns als von etlichs gelts
                                    <expan>weg<ex>en,</ex></expan> daz sie von Jüdel, juden,
                                    <expan>eingenome<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>
<expan>yecz<ex>unden</ex></expan>
<expan>verschr<ex>iben</ex></expan>. <expan>Daru<ex>m</ex>b</expan> wir
                                    <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>
<expan>Pet<ex>er</ex></expan>
<expan>Krag<ex>en,</ex></expan>
<expan>weis<ex>er</ex></expan> disz <expan>br<ex>iefs</ex></expan>,
                            hinauf <expan>schik<ex>en,</ex></expan> die
                                <expan>vorg<ex>enante</ex></expan>
<expan>jüdisch<ex>eit</ex></expan> gen <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren,</expan> des künigs,
                                <expan>gnad<ex>en</ex></expan> in den <expan>sach<ex>e</ex>n</expan>
                            zu <expan>v<ex>er</ex>antwurt<ex>en,</ex></expan> als er ewch die sach
                                    <expan>müntl<ex>ich</ex></expan> wol erczeln wirt. Auch so hat
                                    <expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, der <expan>r<ex>ömisch</ex></expan>
<expan>k<ex>ünig</ex></expan>, <expan>h<ex>er</ex>n</expan><pb facs="#facs_136" id="68r"/>
</del><del rend="crossout">Borssen von <expan>Rysemb<ex>ur</ex>g</expan> und
                            dem Bohuss, <expan>burggraf<ex>en</ex></expan> zum
                                    <expan>Pfreymb<ex>er</ex>g,</expan> von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> nehst <expan>verschr<ex>iben</ex></expan>;
                                    <expan>dies<ex>elben</ex></expan>
<expan>br<ex>ief</ex></expan> wir in geschikt
                                <expan>hab<ex>e</ex>n</expan>. Nu <expan>hab<ex>e</ex>n</expan> sie
                                    <expan>uns<ex>er</ex>m</expan>
<expan>gned<ex>igen</ex></expan>
<expan>h<ex>er</ex>ren,</expan> dem <expan>k<ex>ünig</ex>,</expan> mit
                            iren <expan>brief<ex>en</ex></expan>
<expan>wid<ex>er</ex>umb</expan>
<expan>geantw<ex>ur</ex>t</expan>. <expan>Dies<ex>elben</ex></expan>
<expan>br<ex>ief</ex></expan> wir dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan> auch <expan>befolhe<ex>n</ex></expan>
<expan>hab<ex>e</ex>n,</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gned<ex>igen</ex></expan>
<expan>h<ex>er</ex>ren,</expan> dem <expan>k<ex>ünig,</ex></expan> zu
                                    <expan>antw<ex>ur</ex>ten</expan>, wan wir die niht
                                    <expan>aufbrech<ex>en</ex></expan>
<expan>wolte<ex>n</ex></expan>, uns <expan>w<ex>er</ex>e</expan> denn
                            das geurlawbt <expan>gewes<ex>en</ex></expan>. Nu
                                <expan>w<ex>er</ex>e</expan> uns ein notdurft, daz uns
                                    <expan>dies<ex>elben</ex></expan>
<expan>br<ex>ief</ex></expan> oder <expan>ab<ex>er</ex></expan>
<expan>abschr<ex>ift</ex></expan> davon <expan>w<ex>er</ex>den</expan>
<expan>möcht<ex>en</ex>,</expan> daz wir uns darnach auch
                                    <expan>weste<ex>n</ex></expan> zu
                                <expan>richte<ex>n</ex></expan>. <expan>Bitt<ex>en</ex></expan> wir
                            ewch mit fleiss, daz ir dem <expan>obg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan> in den <expan>sach<ex>e</ex>n</expan>
                            beiden ewr <expan>frewntl<ex>ich</ex></expan>
<expan>anweisu<ex>n</ex>g</expan> tun und auch
                                    <expan>fürderl<ex>ich</ex></expan> und
                                <expan>hilffl<ex>ich</ex></expan> sein wellet, als wir etc.; das
                                    <expan>well<ex>e</ex>n</expan> wir etc.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra.</ex></expan>
</del></ab></div>
