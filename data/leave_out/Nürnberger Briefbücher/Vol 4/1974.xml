</div><div type="regularised"><pb facs="#facs_225" id="112v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan> Johansen, pfalczgrafen bey Rein und herczogen
                        in Beyrn </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr hochwirdikeit
                                <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan> hat von Heincz
                                <expan>Planckenstein<ex>er</ex>s</expan>,
                            <expan>uns<ex>er</ex>s</expan>
<expan>burg<ex>er</ex>s</expan>, <expan>wege<ex>n,</ex></expan> wie er
                                    <add><expan>de<ex>m</ex></expan></add>
<expan>Hanse<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan> Eglofstein, <expan>ewr<ex>e</ex>m</expan>
                        burkman <expan>czu<ex>m</ex></expan>
<expan>Rotemb<ex>er</ex>g</expan>, sein gut auf das lantgericht gen
                                <expan>Nüremb<ex>er</ex>g</expan> geladen hab etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                            <expan>hab<ex>e</ex>n</expan> vormals davon nicht gewiszt;
                                <expan>dan<ex>n</ex></expan> wir <expan>hab<ex>e</ex>n</expan> den
                                <expan>egen<ex>an</ex>t<ex>en</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>burg<ex>er</ex></expan>
<expan>ewr<ex>e</ex>n</expan>
<expan>gnade<ex>n</ex></expan> czu eren für uns besant und
                                <expan>daru<ex>m</ex>b</expan>
<add>mit im <expan>sov<ex>er</ex>re</expan> geredt </add> und daran
                        geweiset, daz er recht von <expan>de<ex>m</ex></expan>
<expan>egen<ex>an</ex>t<ex>en</ex></expan> Hansen vom Eglofstein,
                                <expan>ewr<ex>e</ex>m</expan> burkman, vor
                            <expan>ewr<ex>e</ex>m</expan> hofgericht <expan>neme<ex>n</ex></expan>
                        sol und wil. <expan>Ro<ex>gamus</ex></expan>, daz ir
                            <expan>de<ex>m</ex></expan>
<expan>egen<ex>an</ex>t<ex>en</ex></expan>
<expan>uns<ex>er</ex>m</expan> burger <expan>daru<ex>m</ex>b</expan> tag
                        bescheyden <add>und seczen <expan>vo<ex>n</ex></expan>
<expan>de<ex>m</ex></expan>
<expan>eg<ex>enanten</ex></expan>
<expan>Hanse<ex>n</ex></expan>
<expan>vo<ex>n</ex></expan> Eglofstein</add> und im
                                <expan>unv<ex>er</ex>czoge<ex>n</ex>s</expan> slewnigs recht
                        widerfaren lassen wollet. Het <expan>dan<ex>n</ex></expan> der
                                <expan>egen<ex>an</ex>t<ex>e</ex></expan> Hans
                            <expan>vo<ex>n</ex></expan> Eglofstein czu
                                <expan>de<ex>m</ex>selb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan> icht cze sprechen,
                            <expan>daru<ex>m</ex>b</expan>
<expan>wolle<ex>n</ex></expan> wir im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbote<ex>n</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>volle<ex>n</ex></expan> gewalt
                            <expan>unv<ex>er</ex>czoge<ex>n</ex>s</expan> slewnigs
                                <expan>rechte<ex>n</ex></expan>
<expan>g<ex>er</ex>ne</expan> helffen hie vor des reichs
                                <expan>richt<ex>er</ex></expan> bey uns czu
                            <expan>Nüremb<ex>er</ex>g,</expan>
<expan>wen<ex>n</ex></expan> wir des <expan>erma<ex>n</ex>t</expan>
<expan>werde<ex>n,</ex></expan> so derselb <expan>uns<ex>e</ex>r</expan>
<expan>burg<ex>er</ex></expan> anheim ist, <expan>ongev<ex>er</ex>d</expan>.
                                <expan>Dan<ex>n</ex></expan> wo wir <expan>ewr<ex>er</ex></expan>
<expan>hochw<ex>irdikeit</ex></expan>; a<expan>ntw<ex>ur</ex>t</expan>.
                                <expan>Dat<ex>um</ex></expan> ut <expan>sup<ex>ra.</ex></expan>
</ab>
</div>
