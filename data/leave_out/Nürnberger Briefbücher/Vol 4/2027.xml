<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> Hanns, als wir
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> nehst
                                                  <expan>verschr<ex>iben</ex></expan> und
                                                  <expan>geantw<ex>ur</ex>t</expan>
<expan>habe<ex>n</ex></expan> von der gült
                                                  <expan>weg<ex>en</ex></expan>, die ir uns auf <app>
<note><q type="date">sand Michelstag
                                                  <expan>nehstv<ex>er</ex>gangen</expan></q>29.09.1415</note>
</app>
<expan>v<ex>er</ex>fallen</expan> und noch schuldig
                                                seyt, daz uns niht füklich
                                                  <expan>w<ex>er</ex>e,</expan> die
                                                  <expan>leng<ex>er</ex></expan> zu steen
                                                  <expan>lass<ex>en</ex></expan>. Nu ist uns seither
                                                des noch kein <expan>ausrichtigu<ex>n</ex>g</expan>
                                                von ewch <expan>gescheh<ex>en</ex></expan>.
                                                  <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewch
                                                  <expan>ab<ex>er</ex></expan>, ir gedenkt, daz wir
                                                der gült
                                                  <expan>unv<ex>er</ex>czogenl<ex>ich</ex></expan>
                                                beczalt <expan>w<ex>er</ex>den</expan>. Wan
                                                gescheͣch des niht, so
                                                  <expan>wölte<ex>n</ex></expan> wir
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>bürg<ex>en</ex></expan> alsbald nach den
                                                  <expan>veyrtag<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan>
                                                  zu<expan>sprech<ex>en</ex></expan> und manen nach
                                                  <expan>uns<ex>er</ex>s</expan> briefs sag, und
                                                sehen doch lieber, daz irs darczu niht
                                                  <expan>kome<ex>n</ex></expan> laszt.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>vigi<ex>lia</ex></expan> Thome. </ab>
</div>
