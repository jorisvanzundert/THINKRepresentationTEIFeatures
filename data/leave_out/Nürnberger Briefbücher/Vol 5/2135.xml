<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr gnade nehst
                                    <expan>v<ex>er</ex>schr<ex>iben</ex></expan> hat von sach wegen
                            antreffende <expan>ew<ex>r</ex>n</expan> juden Josse und Joheln
                                    <expan>uns<ex>er</ex>n</expan> juden etc.
                                <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>v<ex>er</ex>nomen</expan>. Und <expan>hab<ex>e</ex>n</expan>
<add>darümb</add>
<expan>uns<ex>er</ex>n</expan> dyener <expan>Burkh<ex>art</ex></expan>
                            Reickershofer czu <expan>ew<ex>r</ex>n</expan> gnaden gesant, der uns
                                <add>wider</add> gesagt hat, wie er
                                <expan>denselb<ex>e</ex>n</expan> handel, als sich der bey uns
                                    <expan>v<ex>er</ex>loffen</expan> hat,
                                <expan>ew<ex>r</ex>n</expan> gnaden wol erczelt und fürbraht hab,
                            als der <expan>dan<ex>n</ex></expan> an uns kumen ist. Aber wie darümb
                            dewht <expan>ew<ex>r</ex></expan> gnade, daz der
                                    <expan>vorgen<ex>ante</ex></expan> Johel jude oder aber der
                            judenrate bey uns icht anders getan heten, <expan>dan<ex>n</ex></expan>
                            billich wer, so wöllet <expan>yemand<ex>en</ex></expan> der ewrn in
                            einer kürcze darümb herczu uns schicken, <add>die sache</add>
<add>czu</add> verhören. Wer <expan>dan<ex>n</ex></expan> daz,
                                    <expan>uns<ex>er</ex>r</expan> juden icht unbillichs getan
                                    <expan>hete<ex>n</ex></expan>, darczu wöllten wir durch
                                    <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan> tun, <add>daz wir hofften</add>, daz
                                <add>ewr gnade vernemen solt, daz uns solch sach niht lieb
                            wer</add>. <add>Und getrawen <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan> wol, ir wollet das also umb
                                        <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> tun. Möcht</add>
<add>aber des niht gesein, het <expan>dan<ex>n</ex></expan> der
                                        <expan>obgen<ex>ante</ex></expan>
<expan>ew<ex>r</ex></expan> jude Josse czu
                                    <expan>de<ex>m</ex></expan>
<expan>vorgen<ex>anten</ex></expan> Johell
                                    <expan>od<ex>er</ex></expan> aber czu
                                    <expan>dheine<ex>m</ex></expan>
<expan>and<ex>er</ex>n</expan>
<expan>uns<ex>er</ex>n</expan> juden icht <expan>cze
                                        spreche<ex>n</ex></expan>, darümb</add>
<expan>wölle<ex>n</ex></expan> wir
                                    dem<add><expan>selb<ex>e</ex>n</expan></add>
<expan>ew<ex>r</ex>m</expan> judem Josse <add>oder aber
                                        <expan>seine<ex>m</ex></expan></add>
<add><expan>scheinpote<ex>n</ex></expan> mit
                                    <expan>seine<ex>m</ex></expan>
