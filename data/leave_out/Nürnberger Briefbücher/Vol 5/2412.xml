<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, es ist <expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>römische<ex>n</ex></expan> etc. künigs
                <expan>hofmeist<ex>er</ex></expan>, graf Ludweig von
            <expan>Öting<ex>en</ex></expan>, <expan>newlich<ex>e</ex>n</expan> bey uns
                <expan>gewes<ex>en</ex></expan>; also <expan>hab<ex>e</ex>n</expan> wir
                <expan>uns<ex>er</ex></expan> frewnd von <expan>uns<ex>er</ex>m</expan> rate mit
                <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan> reden <expan>lass<ex>en</ex></expan> als von Venedyer
            fart <expan>weg<ex>en</ex></expan>, darczu sein gnade den <expan>uns<ex>er</ex>n</expan>
            günstiklich <expan>geantw<ex>ur</ex>tt</expan> hat, daz er niht
              <expan>wid<ex>er</ex>raten</expan> wölt, die reichs stett, die die sach berüre,
                <expan>möchte<ex>n</ex></expan> die sache an <expan>uns<ex>er</ex>n</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan> den künig <expan>bringe<ex>n</ex></expan>,
                <expan>seine<ex>n</ex></expan>
<expan>küniglich<ex>e</ex>n</expan>
<expan>gnad<ex>en</ex></expan> ir notdurft <add>darinn</add> erczeln und bitten
                <expan>lass<ex>en</ex></expan>, sölich gebott gen in abczutun; möcht er denn darinn
            den <expan>stette<ex>n</ex></expan> icht fürdrung oder guts
              <expan>will<ex>e</ex>n</expan> beweisen, des wölt er willig sein.
                <expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, <expan>wolte<ex>n</ex></expan> wir niht
                <expan>lass<ex>en</ex></expan> nach dem wir wol <expan>v<ex>er</ex>steen</expan>,
            daz den <expan>stette<ex>n</ex></expan> vil daran ligt, wir
              <expan>wölte<ex>n</ex></expan>
<expan>ewer<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> das in <expan>gut<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan> also <expan>v<ex>er</ex>künd<ex>en</ex></expan> und
            ob ir ein <expan>gefalle<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan> woltet <expan>od<ex>er</ex></expan> geraten dewht, die
            stette, die das berürt, von den <expan>sache<ex>n</ex></expan> sich zu
                <expan>unt<ex>er</ex>reden</expan>, so <expan>wolte<ex>n</ex></expan> wir
                <expan>uns<ex>er</ex></expan> frewnde gen Nördlingen <expan>od<ex>er</ex></expan> in
            ewr stat, ob das niht neher sein möcht, zu <expan>eine<ex>m</ex></expan> tag, den ir uns
            und <expan>söliche<ex>n</ex></expan>
<expan>stette<ex>n</ex></expan>
<expan>secze<ex>n</ex></expan> und <expan>v<ex>er</ex>künden</expan> wurdet,
                <expan>daru<ex>m</ex>b</expan>
<expan>g<ex>er</ex>n</expan>
<expan>schik<ex>en</ex></expan>, ob man da icht guts finden möcht. So
                <expan>hab<ex>e</ex>n</expan> wir <expan>uns<ex>er</ex>n</expan> guten
                <expan>frewnd<ex>en</ex></expan> den von Costencz und von
              <expan>Augsp<ex>ur</ex>g</expan>
<expan>daru<ex>m</ex>b</expan> auch <expan>verschr<ex>iben</ex></expan>. Was nu ewr
                <expan>meynu<ex>n</ex>g</expan> in den <expan>sache<ex>n</ex></expan> sein welle,
            das mugt ir uns bey disem <expan>bott<ex>en</ex></expan> in
              <expan>gut<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan> wol <expan>verschr<ex>eiben</ex></expan>. Denn wo
            wir <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst etc.
                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>Michahel<ex>is</ex></expan>
</ab>
</div>
