<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ew wol
                            <expan>wissenl<ex>ich</ex></expan> ist wie <expan>uns<ex>er</ex></expan>
                        und <expan>and<ex>er</ex>r</expan> reichs stette,
                            <expan>uns<ex>er</ex>r</expan> guten frewnde,
                            <expan>erb<ex>er</ex>n</expan>
<expan>bott<ex>en</ex></expan> nehst von <expan>Heylprunn<ex>en</ex></expan>
<expan>geschaid<ex>en</ex></expan> sind von der sache
                            <expan>weg<ex>en</ex></expan>, <expan>daru<ex>m</ex>b</expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>
<expan>marggr<ex>af</ex></expan>
<expan>Fridr<ex>ich</ex></expan> von Brandemburg den
                            <expan>stette<ex>n</ex></expan> dahin betagt hett,
                                <expan>besund<ex>er</ex></expan> daz seinr
                            <expan>gnad<ex>en</ex></expan>
<expan>meynu<ex>n</ex>g</expan> was, daz der stette
                            <expan>erb<ex>er</ex>n</expan>
<expan>bott<ex>en</ex></expan>
<app>
<note><q type="date">auf nu sunntag zu nacht</q>01.10.1419</note>
</app><expan>daru<ex>m</ex>b</expan>
<expan>wid<ex>er</ex></expan> zu ew gen <expan>Heylprunn<ex>en</ex></expan>
<expan>kome<ex>n</ex></expan>
<expan>sölle<ex>n</ex></expan>. Nu wan <expan>uns<ex>er</ex></expan> rate
                        von <expan>gebreche<ex>n</ex>s</expan>
<expan>weg<ex>en</ex></expan> des sterbens, der etwas bey uns regniert,
                                <expan>yecz<ex>unden</ex></expan> niht
                            <expan>besam<ex>n</ex>et</expan> was, so <expan>hab<ex>e</ex>n</expan>
                        wir den <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>h<ex>er</ex>ren</expan> den <expan>marggr<ex>afen</ex></expan>
<expan>gebette<ex>n</ex></expan> uns zu <expan>v<ex>er</ex>tragen</expan>,
                        daz wir <expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan>
<expan>yecz<ex>unden</ex></expan> niht bedörften gen
                                <expan>Heylprunn<ex>en</ex></expan>
<expan>schik<ex>en</ex></expan> und <expan>bitt<ex>en</ex></expan> ewr
                                <expan>weish<ex>eit</ex></expan> mit <expan>gancze<ex>m</ex></expan>
                        fleiss, daz ir uns bey disem <expan>bott<ex>en</ex></expan> in
                                <expan>gut<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan> und geheim
                            <expan>verschr<ex>eiben</ex></expan> wellet, als vil ewch
                                <expan>füklich<ex>e</ex>n</expan> sey, wie der stette
                                <expan>erb<ex>er</ex>n</expan> botten, <add>die yecz zu ewch
                                    <expan>kome<ex>n</ex></expan></add>, und auch ir dem <pb facs="#facs_57" id="27v"/>
<expan>eg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> dem <expan>marggr<ex>afen</ex></expan>
<expan>od<ex>er</ex></expan> seinr <expan>botsch<ex>aft</ex></expan> von der
                                <expan>obg<ex>enante</ex>n</expan> sache
                            <expan>weg<ex>en</ex></expan>
<expan>geantw<ex>ur</ex>t</expan>
<expan>hab<ex>e</ex>n</expan>
<expan>od<ex>er</ex></expan> wie man <expan>daru<ex>m</ex>b</expan> von ewch
                                <expan>geschaid<ex>en</ex></expan> sey, und uns darinn
                                <expan>frewnts<ex>chaft</ex></expan> und guten
                            <expan>will<ex>e</ex>n</expan> beweiset. Als etc. Das
                                <expan>well<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>ip<ex>s</ex>a</expan> die <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
<expan>Michahel<ex>is</ex></expan>.</ab>
</div>
