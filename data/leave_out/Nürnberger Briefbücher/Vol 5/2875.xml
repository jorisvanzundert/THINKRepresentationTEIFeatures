<expan>Albr<ex>echt</ex></expan>
<expan>Preysing<ex>er</ex></expan>,
                                <expan>vicztume<ex>n</ex></expan><lb/><expan>H<ex>er</ex>n</expan>
                        Sweykern von Gundelfing<lb/><expan>Conr<ex>ad</ex></expan> von Asch,
                        chamerer czu landshut, <gap reason="illegible"/>
<expan>si<ex>mi</ex>l<ex>ite</ex>r</expan>. </ab></div>
</div></body>
