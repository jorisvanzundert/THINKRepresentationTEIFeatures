<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von der schulde
                                <expan>weg<ex>en</ex></expan> die Sighart Vörchel dem Göbel
                        Schachczabel, <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>dien<ex>er</ex></expan> und <expan>b<ex>urger</ex></expan> zu Cöln,
                        schuldig sey etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan>
                        ewr <expan>fürstenl<ex>ich</ex></expan> gnade
                        <expan>wiss<ex>en</ex></expan>, daz der
                            <expan>vorg<ex>ena</ex>nt<ex>e</ex></expan> Sighart Vörchtel in etwievil
                        jaren in <expan>uns<ex>er</ex>r</expan> stat niht
                            <expan>gewes<ex>en</ex></expan> und auch <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> niht ist; und als wir
                                <expan>v<ex>er</ex>nom<ex>m</ex>en</expan>
<expan>hab<ex>e</ex>n</expan>, so hat er sich in
                            <expan>Sybenbürg<ex>en</ex></expan> geseczt und weib und kind daselbs.
                        Und als uns ewr <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von erbs
                            <expan>weg<ex>en</ex></expan>, daz <expan>dens<ex>elben</ex></expan>
                        Sighart bey uns anerstorben sülle sein, darumb <expan>hab<ex>e</ex>n</expan>
                        wir des <expan>egen<ex>anten</ex></expan> Göbels
                                <expan>scheinbott<ex>en</ex></expan>, der yecz bey uns
                                <expan>gewes<ex>en</ex></expan> ist, <expan>unt<ex>er</ex></expan>
                        awgen gebotten, hett er zu <expan>keine<ex>m</ex></expan> der
                                <expan>uns<ex>er</ex>n</expan>, der wir mechtig sein
                                <expan>daru<ex>m</ex>b</expan> icht zu sprechen, so
                                <expan>wolte<ex>n</ex></expan> wir im
                            <expan>frewntl<ex>ich</ex></expan> slewnigs
                            <expan>rechte<ex>n</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>geholff<ex>en</ex></expan>
<expan>hab<ex>e</ex>n</expan> und <expan>well<ex>e</ex>n</expan>
<add>noch</add>
<expan>dems<ex>elben</ex></expan> Göbel Schachczabel
                            <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt, ob er zu
                            <expan>keine<ex>m</ex></expan> der <expan>uns<ex>er</ex>n</expan>, der
                        wir mechtig sein, <expan>daru<ex>m</ex>b</expan> icht
                                <expan>zuspreche<ex>n</ex></expan> hett,
                            <expan>frewntl<ex>ich</ex></expan> slewnigs
                            <expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>dies<ex>elben</ex></expan>
                        die <expan>uns<ex>er</ex>n</expan> bey uns anheim sein, on geverd. Denn wo
                        wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>i<ex>n</ex></expan> festo <expan>penthecost<ex>en</ex></expan>.</ab>
</div>
