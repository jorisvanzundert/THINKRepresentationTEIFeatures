                                <expan>w<ex>er</ex>e</expan>. <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>fürstenl<ex>ich</ex></expan>
                        gnade mit fleisz, ir wellet den <expan>obg<ex>enanten</ex></expan>
<expan>Reinh<ex>art</ex></expan> Freyen, <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>dien<ex>er</ex></expan>, umb <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>
