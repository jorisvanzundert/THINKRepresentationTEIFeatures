<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von des handels
                                <expan>weg<ex>en</ex></expan>, der sich
                            <expan>zwisch<ex>en</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Hartu<ex>n</ex>g</expan>
<expan>vom</expan>
<expan>Eglofst<ex>ein</ex></expan> und ein dem
                            <expan>uns<ex>er</ex>n</expan>
<expan>v<ex>er</ex>loffen</expan> hab, etc., das
                            <expan>habe<ex>n</ex></expan> wir wol <expan>vernom<ex>en</ex></expan>;
                        und als ewr <expan>fürstenl<ex>ich</ex></expan> gnade nehst vor <app>
<note><q type="date"><expan>weyhenn<ex>achten</ex></expan></q>25.12.1422</note>
</app>
<expan>daru<ex>m</ex>b</expan> auch schraib, <expan>ders<ex>elb</ex></expan>
                        bott wolt keinr antwurt harren, also <expan>schikt<ex>en</ex></expan> wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>uns<ex>er</ex></expan> schriftliche <expan>antw<ex>ur</ex>t</expan>
                        bey <pb facs="#facs_578" id="288r"/>
<expan>uns<ex>er</ex></expan> selbs <expan>bott<ex>en</ex></expan> zum
                        Newnmarkt, da wolt die zeit <expan>nyema<ex>n</ex>t</expan>
<expan>dies<ex>elb</ex></expan>
<expan>antw<ex>ur</ex>t</expan>
<expan>neme<ex>n</ex></expan>
<expan>od<ex>er</ex></expan> was villeiht <expan>nyema<ex>n</ex>ts</expan>
                        befolhen, als uns der <expan>uns<ex>er</ex></expan> sagt. Also
                                <expan>lass<ex>en</ex></expan> wir ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz uns Hanns Züll, der
                                <expan>visch<ex>er</ex></expan>, <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, vor <expan>etliche<ex>n</ex></expan>
<expan>zeite<ex>n</ex></expan> klagt, wie im der Wölfel Vogt zu Henffenvelt,
                        Ülin und <expan>Pet<ex>er</ex></expan>, <expan>h<ex>e</ex>r</expan>
<expan>Hartu<ex>n</ex>gs</expan>
<expan>vom<ex>m</ex></expan>
<expan>Eglofst<ex>ein</ex></expan> knecht, sein pfeͣrd, visch und
                                <expan>karre<ex>n</ex></expan> auf des reichs
                                <expan>strass<ex>en</ex></expan>
<expan>genome<ex>n</ex></expan>
<expan>hette<ex>n</ex></expan> on recht, daran sie uns und dem
                                <expan>uns<ex>er</ex>n</expan> unrecht getan
                            <expan>habe<ex>n</ex></expan>, als ewr gnade auch wol
                                <expan>v<ex>er</ex>steen</expan> mag. Als denn ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade in
                            <expan>ew<ex>r</ex>m</expan>
<expan>vord<ex>er</ex>n</expan>
<expan>br<ex>ief</ex></expan> meldt von <expan>selig<ex>er</ex></expan>
                        gedechtnuss <expan>keys<ex>er</ex></expan> und
                            <expan>and<ex>er</ex>r</expan>
<expan>fürst<ex>en</ex></expan> und <expan>h<ex>er</ex>ren</expan>
<expan>br<ex>ief</ex></expan> und gepott <expan>weg<ex>en</ex></expan> etc.,
                                <expan>bitt<ex>en</ex></expan> wir ewr gnade zu
                                <expan>wiss<ex>en</ex></expan>, daz wir von
                                <expan>löblich<ex>er</ex></expan>
<expan>gedecht<ex>nuss</ex></expan>
<expan>römische<ex>n</ex></expan>
<expan>keys<ex>er</ex>n</expan> und <expan>künig<ex>en</ex></expan> auch
                                <expan>gnedikl<ex>ich</ex></expan> gefreyet und
                                <expan>herkom<ex>en</ex></expan> seyn, nemlich daz man von speis und
                        von trank zu und von <expan>uns<ex>er</ex>r</expan> stat
                                <expan>füre<ex>n</ex></expan>, <expan>treibe<ex>n</ex></expan> und
