<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns <add>in guter</add>
<expan>frewntsch<ex>aft</ex></expan>
<expan>verschr<ex>iben</ex></expan> habt, <add>wie ir</add>
<expan>uns<ex>er</ex></expan>
<expan>gute<ex>n</ex></expan> frewnde die reichs stette von der von
                                <expan>Weinsp<ex>er</ex>g</expan> handels
                            <expan>weg<ex>en</ex></expan> in <expan>ewer<ex>er</ex></expan> stat
                        gemant habt <app>
<note><q type="date">auf <expan>Symo<ex>n</ex>is</expan> et Jude
                                    schierist</q>28.10.1420</note>
</app> nach <expan>auszweisu<ex>n</ex>g</expan>
<expan>ew<ex>r</ex>s</expan> briefs etc., das <expan>hab<ex>e</ex>n</expan>
                        wir wol <expan>vernom<ex>en</ex></expan> und <expan>dank<ex>en</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan>
<expan>ew<ex>r</ex>s</expan> guten <expan>getrawe<ex>n</ex></expan> mit
                                <expan>gancze<ex>m</ex></expan> fleiss und
                            <expan>lass<ex>en</ex></expan> ewch <expan>wiss<ex>en</ex></expan>, daz
                        auf disz zeit etwievil <expan>h<ex>e</ex>rschaft</expan> und
                                <expan>rittersch<ex>aft</ex></expan> bey uns sein, <add>sich
                                <expan>zu v<ex>er</ex>suchen</expan> von unwillen und handels
                                    <expan>weg<ex>en</ex></expan>
<expan>zwisch<ex>en</ex></expan>
<expan>uns<ex>er</ex>r</expan>
<expan>h<ex>er</ex>ren</expan> marggraf <expan>Fridr<ex>ich</ex></expan>
                            von <expan>Brandemb<ex>ur</ex>g</expan> und
                                <expan>h<ex>er</ex>czog</expan> Ludweigs von Peyern und der iren, ob
                            icht guts darinn <expan>gefunde<ex>n</ex></expan> möcht
                                    <expan>w<ex>er</ex>den</expan></add>, daz wir niht wol ledig
                                <expan>gewes<ex>en</ex></expan> sein; doch
                            <expan>well<ex>e</ex>n</expan> wir <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> bey <expan>uns<ex>er</ex></expan> selbs
                                <expan>botsch<ex>aft</ex></expan> kürczlich ein
                                <expan>antw<ex>ur</ex>t</expan>
<expan>daru<ex>m</ex>b</expan> tun. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>Michahel<ex>is</ex></expan>.</ab>
</div>
