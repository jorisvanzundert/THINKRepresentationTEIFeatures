<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, uns sein hewt fru <add>durch
                                    <expan>uns<ex>er</ex>s</expan> herren
                                <expan>burggr<ex>af</ex></expan>
<expan>Joh<ex>ansen</ex></expan>
<expan>botsch<ex>aft</ex></expan></add> zwen brief
                                <expan>geantw<ex>ur</ex>t</expan>
<expan>word<ex>en</ex></expan> von <expan>uns<ex>er</ex>n</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan>
<expan>Johans<ex>en</ex></expan> und
                            <add><expan>dems<ex>elben</ex></expan></add>
<expan>burggr<ex>af</ex></expan>
<expan>Joh<ex>ansen</ex></expan>, der wir ewch
                            <expan>beid<ex>er</ex></expan>
<expan>hierinn<ex>en</ex></expan>
<expan>abschr<ex>ift</ex></expan>
<expan>v<ex>er</ex>slossen</expan>
<expan>send<ex>en</ex></expan>, daz ir ewch dest bas in den
                                <expan>sache<ex>n</ex></expan> wisset zu
                            <expan>halte<ex>n</ex></expan>. Nu <expan>well<ex>e</ex>n</expan> wir
                                <expan>darüb<ex>er</ex></expan>
<expan>sicze<ex>n</ex></expan> und <expan>gedenke<ex>n</ex></expan>, wie wir
                        die sache handeln und den <expan>vorgen<ex>anten</ex></expan>
<expan>fürste<ex>n</ex></expan>
<expan>v<ex>er</ex>antw<ex>ur</ex>ten</expan>
<expan>well<ex>e</ex>n</expan>. Und wie wir des zu rat
                            <expan>w<ex>er</ex>den</expan> und besliessen,
                            <expan>well<ex>e</ex>n</expan> wir ewch <expan>uns<ex>er</ex></expan>
<expan>meynu<ex>n</ex>g</expan> aber
                                <expan>unv<ex>er</ex>czogenl<ex>ich</ex></expan> zu wissen tun.
                                <expan>Dat<ex>um</ex></expan>
<expan>ip<ex>s</ex>a</expan> die <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
                        Martini <expan>s<ex>ub</ex></expan> sigillo
                            <expan>m<ex>a</ex>g<ex>ist</ex>ri civiu<ex>m</ex></expan>.</ab>
</div>
