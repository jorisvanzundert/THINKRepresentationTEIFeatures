<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan> yecz
                            <expan>verschr<ex>iben</ex></expan> hat von Anshells
                                <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>jude<ex>n</ex></expan>
<expan>weg<ex>en</ex></expan>, <expan>daru<ex>m</ex>b</expan> ir uns vormals
                        mer <expan>geschrib<ex>e</ex>n</expan> habt etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>.
                        Nu <expan>hab<ex>e</ex>n</expan> wir <expan>desselb<ex>e</ex>n</expan> mals
                                <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>geantw<ex>ur</ex>tt</expan> und dem Anshelln
                            <expan>jud<ex>en</ex></expan> rechts bey uns zu
                            <expan>helffe<ex>n</ex></expan>
<expan>gebotte<ex>n</ex></expan>, als wir gefreyet und
                                <expan>herkome<ex>n</ex></expan> sein; und
                            <expan>hab<ex>e</ex>n</expan> auch mit der
                            <expan>jüdisch<ex>eit</ex></expan> bey uns do geredt
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan> auch zu <expan>antw<ex>ur</ex>ten</expan>,
                        die das getan <expan>hab<ex>e</ex>n</expan>, als sie uns
                                <expan>hab<ex>e</ex>n</expan> gesagt, denn auch die
                                <expan>jüdisch<ex>eit</ex></expan> bey uns noch
                                <expan>meyne<ex>n</ex></expan> nach<expan>zukome<ex>n</ex></expan>.
                        Wie <expan>daru<ex>m</ex>b</expan> so <expan>hab<ex>e</ex>n</expan> wir
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> zu lieb den judenrat bey uns besant
                        und auf <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> schrift <expan>ernstl<ex>ich</ex></expan> zu
                        rede gesaczt. Die <expan>hab<ex>e</ex>n</expan> uns
                            <expan>geantw<ex>ur</ex>tt</expan>, daz sie der
                            <expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan> kein hab <expan>abgenome<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>. Denn was die
                            <expan>jüdisch<ex>eit</ex></expan> bey uns gemeinclich
                                <expan>uns<ex>er</ex>n</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>römische<ex>n</ex></expan>
<expan>künig<ex>en</ex></expan>
<expan>od<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan> den es gebürt hab an
                            <expan>gemeine<ex>n</ex></expan>
<expan>stewre<ex>n</ex></expan>
<expan>od<ex>er</ex></expan> sust ye zu <expan>zeite<ex>n</ex></expan>
                        pflichtig <expan>gewese<ex>n</ex></expan> sein <expan>od<ex>er</ex></expan>
<expan>geb<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan>, da sey <expan>dies<ex>elb</ex></expan>
<expan>Secklin<ex>n</ex></expan> umb ir anczal allweg nach
                                <expan>gleiche<ex>n</ex></expan>
<expan>pilliche<ex>n</ex></expan>
<expan>dinge<ex>n</ex></expan> und nach <expan>ir<ex>er</ex></expan>
<expan>jüdische<ex>n</ex></expan> form und <expan>gewonh<ex>eit</ex></expan>
                        bey uns angelegt <expan>word<ex>en</ex></expan> und sölich gelt an die
                        stett, da es hin gebürt hab, <expan>gefall<ex>e</ex>n</expan>, also daz sie
                        der <expan>Secklin<ex>n</ex></expan> noch <expan>ir<ex>er</ex></expan>
<expan>erbe<ex>n</ex></expan> hab gar <expan>nichcze<ex>n</ex></expan>
<pb facs="#facs_111" id="54v"/>
<expan>innenhab<ex>e</ex>n</expan>. <expan>Getrawe<ex>n</ex></expan> wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>fürstenliche<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>jude<ex>n</ex></expan>
<expan>obg<ex>ena</ex>nt</expan>
<expan>unt<ex>er</ex>richt</expan> zu <expan>schaff<ex>en</ex></expan>, daz
                        er sich des oder <expan>sölich<ex>er</ex></expan> recht, als wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> vormals <expan>verschr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan>, <expan>genüge<ex>n</ex></expan> lasse. Möcht
                                <expan>ab<ex>er</ex></expan> des niht gesein, so
                                <expan>meyne<ex>n</ex></expan> der judenrate bey uns, sie
                                <expan>od<ex>er</ex></expan> ir <expan>voll<ex>er</ex></expan> gwalt
                                <expan>well<ex>e</ex>n</expan>
<expan>ewr<ex>er</ex></expan> gnaden <expan>jude<ex>n</ex></expan> dem
                        Ansshelln <expan>g<ex>er</ex>n</expan> eins <expan>rechte<ex>n</ex></expan>
<expan>daru<ex>m</ex>b</expan> sein vor dem
                                <expan>all<ex>er</ex>durchlewchtigise<ex>n</ex></expan>
<expan>fürste<ex>n</ex></expan> und <expan>h<ex>er</ex>ren</expan>,
                                <expan>h<ex>er</ex>n</expan>
<expan>Sigmund<ex>en</ex></expan>
<expan>römisch<ex>e</ex>m</expan> zu <expan>Ung<ex>er</ex>n</expan> und zu
                        Beheim etc. künig, <expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, des camerknechte sie sein.
                                <expan>Getrawe<ex>n</ex></expan> wir, daz ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> wol
                            <expan>v<ex>er</ex>stee</expan>, daz der judenrate bey uns gelimpf und
                        rechts gnug da mit <expan>piete<ex>n</ex></expan>. Denn wo wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
                        ut <expan>s<ex>upra</ex></expan>.</ab>
