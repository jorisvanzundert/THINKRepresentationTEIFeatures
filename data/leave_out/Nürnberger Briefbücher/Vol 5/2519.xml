<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> vicztum, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von der
                                <expan>Parsperg<ex>er</ex></expan> und des Seligman juden
                                <expan>weg<ex>en</ex></expan> etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>.
                        Nu als ir in <expan>dems<ex>elben</ex></expan>
<expan>br<ex>ief</ex></expan> schreibt <add>und</add> ewch villeiht
                                <expan>fürgebe<ex>n</ex></expan> ist, daz die
                                <expan>Parsperg<ex>er</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>sölte<ex>n</ex></expan> sein, tun wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>
<expan>zuwiss<ex>en</ex></expan>, daz <expan>dies<ex>elben</ex></expan> von
                        Parsperg <expan>ritt<ex>er</ex></expan> und knecht und der
                                <expan>h<ex>er</ex>ren</expan>
<expan>dien<ex>er</ex></expan> und <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> niht sind, und <expan>hab<ex>e</ex>n</expan>
                        uns müntlich und schriftlich <expan>gebette<ex>n</ex></expan>, dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>Seligma<ex>n</ex></expan> juden kein geleyt bey uns zu
                                <expan>geb<ex>e</ex>n</expan>, darumb uns
                            <expan>sölich<ex>er</ex></expan> sache <expan>zu
                            v<ex>er</ex>fahen</expan>
<expan>auszzuspreche<ex>n</ex></expan> niht
                            <expan>füklich<ex>e</ex>n</expan> und niht not ist, dem
                                <expan>obg<ex>enante</ex>n</expan>
<expan>Seligma<ex>n</ex></expan> geleyt bey uns zu
                            <expan>geb<ex>e</ex>n</expan>; und <expan>bitt<ex>en</ex></expan> ewr
                                <expan>erberk<ex>eit</ex></expan>, das von uns in gut zu versteen.
                        Denn wo wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan>
<expan>remi<ex>ni</ex>sce<ex>re</ex></expan>.</ab>
</div>
