<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von der nom
                            <expan>weg<ex>en</ex></expan>, die den <expan>uns<ex>er</ex>n</expan>
                        von <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> dienern <expan>beschehe<ex>n</ex></expan> ist
                        zu Fewcht etc., haben wir wol <expan>v<ex>er</ex>nomen</expan>. Und als ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade darynn berürt, wie söliche
                        recht von des frevels <expan>weg<ex>en</ex></expan>, die die von Fewcht mit
                        den <expan>ew<ex>r</ex>n</expan>
<expan>begange<ex>n</ex></expan>
<expan>sülle<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>, <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> zusteen <expan>sülle<ex>n</ex></expan>
<expan>zu richte<ex>n</ex></expan>, und wie doch
                            <expan>uns<ex>er</ex></expan> gnedige fraw die marggrefin, ewr mum,
                        darein auch spreche etc., <expan>getrawe<ex>n</ex></expan> wir, daz sich ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> und
                            <expan>uns<ex>er</ex></expan> fraw die
                            <expan>marggrefin<ex>n</ex></expan>
<expan>daru<ex>m</ex>b</expan> wol eynen <expan>sülle<ex>n</ex></expan> und
                                <expan>wisse<ex>n</ex></expan> zu eynen. Nu als wir
                                <expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> zu <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> etwieoft gesandt
                            <expan>habe<ex>n</ex></expan> von der scheden
                            <expan>weg<ex>en</ex></expan>, die den <expan>uns<ex>er</ex>n</expan>
