<ab facs="#facs_389_r3l25">eẅr gnedıg <expan>verſchr<ex>iben</ex></expan>
                        antwurt <expan>wıd<ex>er</ex></expan> bey dıſem
                            <expan>vnſ<ex>er</ex>m</expan>
<expan>dıen<ex>er</ex></expan>
</ab>
<ab facs="#facs_389_r3l26"><expan>dat<ex>um</ex></expan> ut
