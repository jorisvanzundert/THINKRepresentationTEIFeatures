<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> vicztum, als ir uns bey
                            <expan>Hanns<ex>en</ex></expan>
<expan>Mawr<ex>er</ex></expan>, <expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan>, <expan>verschr<ex>iben</ex></expan> und
                                <expan>geantw<ex>ur</ex>tt</expan> habt als von
                                <expan>uns<ex>er</ex>r</expan>
<expan>b<ex>urger</ex></expan>
<expan>ir<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> und hab <expan>weg<ex>en</ex></expan>, die ir
                        nehst <expan>aufgehalt<ex>en</ex></expan> habt etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Und <expan>send<ex>en</ex></expan>
<expan>dens<ex>elben</ex></expan>
<expan>Hanns<ex>en</ex></expan>
<expan>Mawr<ex>er</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>wid<ex>er</ex></expan> zu <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>, dem wir befolhen
                            <expan>hab<ex>e</ex>n</expan> mit ewch <expan>davo<ex>n</ex></expan> zu
                        reden. <expan>Ro<ex>gamus</ex></expan>, was er in
                            <expan>ders<ex>elben</ex></expan> sache zu disem mal von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewch <expan>w<ex>er</ex>be</expan>, daz ir
                        im das <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und ewch umb <expan>uns<ex>er</ex>n</expan>
<expan>will<ex>e</ex>n</expan>
<expan>frewntlich<ex>e</ex>n</expan> und den <expan>uns<ex>er</ex>n</expan>
                        guten <expan>will<ex>e</ex>n</expan> darinn beweisen wellet, als wir ewch
                        des wol getrawen. Denn <pb facs="#facs_11" id="4v"/>als ir uns
                                <expan>verschr<ex>iben</ex></expan> habt,
                            <expan>Gompr<ex>echt</ex></expan> juden bey uns daran zu weisen, daz er
                        Meyr Lyntheim, <expan>ew<ex>r</ex>m</expan>
<expan>jud<ex>en</ex></expan> und <expan>dien<ex>er</ex></expan>, von des
                                <expan>weg<ex>en</ex></expan> ir uns vormals auch habt
                                <expan>verschr<ex>iben</ex></expan>, bessrung tu, als er
                                <expan>and<ex>er</ex>n</expan> getan hab etc. Nu
                                <expan>hab<ex>e</ex>n</expan> wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> vormals
                            <expan>verschr<ex>iben</ex></expan>, daz uns
                            <expan>Salma<ex>n</ex></expan> jud gesagt hat, daz der
                                <expan>vorg<ex>enante</ex></expan> Meyr Lyntheim, nach dem und er
                            <add>und</add> der <expan>eg<ex>enante</ex></expan>
<expan>Gompr<ex>echt</ex></expan> jud in <expan>gebett<ex>en</ex></expan>
                        und er sich des <expan>v<ex>er</ex>fangen</expan> hett, von
                                <expan>uns<ex>er</ex>r</expan> stat <expan>geczog<ex>en</ex></expan>
                        und darnach niht <expan>wid<ex>er</ex></expan> zu im
                            <expan>kome<ex>n</ex></expan> sey. Also daz der
                                <expan>Gompr<ex>echt</ex></expan> jud des niht sewmig sey
                                <expan>gewes<ex>en</ex></expan>; so ist uns die sache niht wissend,
                        daz ewr <expan>erberk<ex>eit</ex></expan> wol
                            <expan>v<ex>er</ex>steen</expan> mag, daz wir
                            <expan>Gompr<ex>echt</ex></expan>
<expan>jud<ex>en</ex></expan> von der sache <expan>weg<ex>en</ex></expan>
                        niht wissen zu weisen <expan>bessru<ex>n</ex>g</expan>
<expan>od<ex>er</ex></expan>
<expan>and<ex>er</ex>s</expan>
<add>zu</add> tun. Dewht <expan>ab<ex>er</ex></expan> den
                                <expan>obg<ex>enanten</ex></expan> Meyr Lyntheim, daz er
                                <expan>darub<ex>er</ex></expan> zu dem
                            <expan>vorg<ex>enanten</ex></expan>
<expan>Gompr<ex>echt</ex></expan>
<expan>jud<ex>en</ex></expan> icht <expan>zuspreche<ex>n</ex></expan> hett,
                        so <expan>well<ex>e</ex>n</expan> wir im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
