<ab>Illustri et excelso <expan>p<ex>ri</ex>ncipi</expan> et
                            <expan>d<ex>omi</ex>nio</expan>, <expan>d<ex>omi</ex>no</expan> Ludwico
                        de Cabilone principi Auraye <expan>comitiq<ex>ue</ex></expan>
<expan>Gebenn<ex>ensi</ex></expan> ac <expan>d<ex>omi</ex>nio</expan> de
                        Arlato etc.</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab>Illustris et excelse princeps <expan>magnificeq<ex>ue</ex></expan>
<expan>d<ex>omi</ex>ne</expan>
<expan>g<ex>ene</ex>rose</expan>
<expan>subiect<ex>is</ex></expan>
<expan>s<ex>er</ex>vitor<ex>um</ex></expan>
<expan>p<ex>ro</ex>mptitudi<ex>n</ex>e</expan> diligenti
                                <expan>v<ex>est</ex>ris</expan> excellentiis
                            <expan>hu<ex>m</ex>ili</expan>
<expan>cu<ex>m</ex></expan>
<expan>reco<ex>m</ex>mandac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>p<ex>rae</ex>miss<ex>is</ex></expan>.
                            <expan>L<ex>itte</ex>ram</expan>
<expan>v<ex>est</ex>re</expan>
<expan>celsitudi<ex>ni</ex>s</expan> nobis
                                <expan>t<ex>ra</ex>nsmiss<ex>is</ex></expan> ac pridie
                                <expan>p<ex>raese</ex>ntat<ex>is</ex></expan>
<expan>c<ex>on</ex>tinente<ex>r</ex></expan>
<expan>qual<ex>ite</ex>r</expan> quidam vocatus Rudolphus de Grup ad
                                <expan>requesta<ex>m</ex></expan> ut dicit cuiusdam mercatoris
                        vocati Chambath <expan>cep<ex>er</ex>it</expan>
<expan>quosda<ex>m</ex></expan>
<expan>v<ex>est</ex>ros</expan> ambasiatores <expan>existentes</expan> in
                        salvo <expan>c<ex>on</ex>ductu</expan>
<expan>d<ex>omi</ex>ni</expan>
<expan>imp<ex>er</ex>ator<ex>is</ex></expan> et eos detineat
                                <expan>p<ex>en</ex>sionarios</expan> in
                            <expan>quoda<ex>m</ex></expan>
<expan>fortali<ex>ci</ex>o</expan>
<expan>p<ex>ro</ex>pe</expan> nos
                            <expan>ex<ex>iste</ex>nt<ex>is</ex></expan>
<expan>vocat<ex>is</ex></expan> Geishen etc.
                                <expan>hu<ex>m</ex>il<ex>ite</ex>r</expan>
<expan>accepim<ex>us</ex></expan>. Et ea in <expan>ip<ex>s</ex>a</expan>
<expan>h<ex>o</ex>ra</expan>
<expan>c<ex>on</ex>tenta</expan> de <expan>quib<ex>us</ex></expan>
<expan>t<ex>ame</ex>n</expan> nobis nil <expan>c<ex>on</ex>stabat</expan> ab
                        antea <expan>pensari<ex>us</ex></expan> diligenter, et exinde
                                <expan>c<ex>on</ex>turbati</expan>
<expan>sum<ex>us</ex></expan> et <expan>dolem<ex>us</ex></expan> quoniam
                                <expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>neq<ex>ue</ex></expan> alia sinistra gesta seu
                                <expan>inequitat<ex>es</ex></expan>
<expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>c<ex>on</ex>turbat<ex>um</ex></expan>
<expan>a<ex>n</ex>i<ex>mu</ex>m</expan> et <expan>auditu<ex>m</ex></expan>.
                        Quare excellenti magnificencie vestre insinuare
                            <expan>duxi<ex>mus</ex></expan>
<expan>p<ex>er</ex>p<ex>raese</ex>ntes</expan>
<expan>q<ex>ui</ex></expan>
<expan>ip<ex>s</ex>i</expan> Rudolphus de Grup ac
                                <expan>Joh<ex>an</ex>n<ex>e</ex>s</expan> Chambath necnon
                                <expan>ip<ex>su</ex>m</expan>
<expan>fortaliciu<ex>m</ex></expan> Geishen in
                            <expan>v<ex>est</ex>ra</expan>
<expan>l<ex>itte</ex>ra</expan>
<expan>no<ex>m</ex>i<ex>n</ex>at<ex>is</ex></expan> nobis pernitus
                                <expan>s<ex>ic</ex>ut</expan>
<expan>ignot<ex>is</ex></expan>. <expan>S<ex>ed</ex></expan>
<expan>v<ex>est</ex>re</expan> excellencie intuitu
                                <expan>strutiniu<ex>m</ex></expan>
<expan>n<ex>ost</ex>r<ex>u</ex>m</expan> inter mercatores
                                <expan>n<ex>ost</ex>ros</expan>
<expan>p<ex>ro</ex></expan>
<expan>ip<ex>s</ex>is</expan> attente <expan>habuim<ex>us</ex></expan> et ex
                                <expan>quorund<ex>am</ex></expan>
<expan>relac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>p<ex>er</ex>cepim<ex>us</ex></expan>
<expan>q<ex>ui</ex></expan>
<expan>d<ex>ic</ex>t<ex>u</ex>m</expan>
<expan>fortaliciu<ex>m</ex></expan>
<expan>al<ex>ii</ex>s</expan> remote a <expan>n<ex>ost</ex>ra</expan>
                        civitate <expan>Nuremberg<ex>is</ex></expan> versus
                            <expan>v<ex>est</ex>re</expan>
<expan>d<ex>omi</ex>nac<ex>i</ex>o<ex>n</ex>is</expan>
<expan>p<ex>ar</ex>tes</expan> ac <expan>p<ex>ro</ex>vincias</expan>
<expan>situ<ex>m</ex></expan> sit ita <expan>q<ex>ui</ex></expan> sub
                                <expan>n<ex>ost</ex>ra</expan>
<expan>d<ex>om</ex>i<ex>na</ex>c<ex>i</ex>o<ex>n</ex>e</expan> seu
                                <expan>p<ex>ostes</ex>tate</expan>
<expan>n<ex>u</ex>llaten<ex>us</ex></expan>
<expan>exist<ex>u</ex>nt</expan>
<expan>necq<ex>ue</ex></expan> ad ho<hi rend="sup">c</hi>
<expan>q<ex>uic</ex>q<ex>uam</ex></expan>
<expan>face<ex>re</ex></expan>
<expan>possum<ex>us</ex></expan> aut <expan>valem<ex>us</ex></expan>.
                                <expan>Ver<ex>um</ex></expan> si
                            <expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>f<ex>a</ex>c<ex>tu</ex>m</expan> sub
                                <expan>d<ex>om</ex>i<ex>na</ex>c<ex>i</ex>o<ex>n</ex>e</expan>
<expan>n<ex>ost</ex>ra</expan> ac <expan>p<ex>ostes</ex>tate</expan>
<expan>p<ex>er</ex>petratu<ex>m</ex></expan> extitisset
                                <expan>quicq<ex>ui</ex>d</expan>
<expan>exist<ex>u</ex>nt</expan> ad <expan>h<ex>o</ex><hi rend="sup">c</hi></expan>
<expan>face<ex>re</ex></expan>
<expan>potuissem<ex>us</ex></expan> sive <expan>debuissem<ex>us</ex></expan>
<expan>ob <expan>reve<ex>re</ex>nciam</expan></expan> sacri
                                <expan>imp<ex>er</ex>ii</expan>
<expan>atq<ex>ue</ex></expan>
<expan>v<ex>est</ex>ri</expan>
<expan>iux<ex>ter</ex></expan> iuris ac
                            <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
<expan>exigentia<ex>m</ex></expan>
<expan>p<ex>ar</ex>ati</expan>
<expan>utiq<ex>ue</ex></expan>
<expan>fuissem<ex>us</ex></expan> et <expan>essem<ex>us</ex></expan> dubio
                                <expan>p<ex>ro</ex>cul</expan>
<add>moto</add>. Idcirco <expan>p<ex>r</ex>inceps</expan>
<expan>p<ex>rae</ex>clare</expan>
<expan>v<ex>est</ex>ram</expan>
<expan>illustr<ex>is</ex></expan>
<expan>magnificencia<ex>m</ex></expan>
<expan>om<ex>n</ex>i</expan> qua <expan>possu<ex>mus</ex></expan>
<expan>diligen<ex>ter</ex></expan> et
                            <expan>aff<ex>ec</ex>tu<ex>m</ex></expan>
<expan>p<ex>re</ex>camur</expan>
<expan>p<ex>re</ex>cib<ex>us</ex></expan>
<expan>p<ex>rae</ex>attent<ex>is</ex></expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan> placeat innate clemencie
                                <expan>v<ex>est</ex>re</expan>
<expan>n<ex>ost</ex>ram</expan> obsequiosam
                            <expan>voluntate<ex>m</ex></expan>
<pb facs="#facs_598" id="298r"/><expan>p<ex>ro</ex>inde</expan>
<expan>g<ex>ene</ex>rose</expan> acceptare ac
                            <expan>n<ex>ost</ex>ros</expan> mercatores et incolas
                                <expan>n<ex>ost</ex>ras</expan> in suis causis et negotiis
                                <expan>tractand<ex>um</ex></expan> seu
                            <expan>ventiland<ex>um</ex></expan>
<expan>unacu<ex>m</ex></expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan> bonis rebus mercimoniis ac rebus in
                        terris <expan>loc<ex>is</ex></expan> ac <expan>districtib<ex>us</ex></expan>
<expan>v<ex>est</ex>re</expan>
<expan>d<ex>omi</ex>nac<ex>i</ex>o<ex>n</ex>i</expan>
<expan>subiect<ex>is</ex></expan>
<expan>g<ex>ene</ex>rose</expan> favere et recomissos
                            <expan>h<ex>abe</ex>re</expan>
<expan>dignemi<ex>ni</ex></expan>
<expan>atq<ex>ue</ex></expan>
<expan>ip<ex>s</ex>os</expan>
<expan>v<ex>est</ex>ratib<ex>us</ex></expan> benigne conmendare
                                    <add><expan>p<ex>ro</ex>ut</expan>
<expan>hacten<ex>us</ex></expan>
<expan>g<ex>ene</ex>rosius</expan> fecistis et
                                <expan>que<ex>m</ex></expan></add>
<expan>admodu<ex>m</ex></expan> de <expan>v<ex>est</ex>ra</expan>
<expan>g<ex>ene</ex>rosa</expan>
<expan>celsitud<ex>in</ex>is</expan> clemencia
                            <expan>c<ex>on</ex>fidenter</expan>
<expan>speram<ex>us</ex></expan>. Quod <expan>p<ex>ro</ex></expan> eadem
                        clemencia <expan>v<ex>est</ex>ra</expan>
<add>ac <expan>v<ex>est</ex>ratib<ex>us</ex></expan></add> cordiali
                                    <add><expan>cupim<ex>us</ex></expan></add>
<expan>aff<ex>e</ex>c<ex>t</ex>u<ex>m</ex></expan> sedule
                                <expan>p<ex>ro</ex>mereri</expan>.
                            <expan>Altissim<ex>us</ex></expan>
<expan>v<ex>est</ex>ram</expan>
<expan>illustr<ex>is</ex></expan> magnificencie
                            <expan>persona<ex>m</ex></expan>
<expan>incolume<ex>m</ex></expan> ac <expan>p<ex>ro</ex>spere</expan>
<expan>c<ex>on</ex>servare</expan>
<expan>dignet<ex>ur</ex></expan>
<expan>t<ex>em</ex>p<ex>or</ex>ib<ex>us</ex></expan>
<expan>diut<ex>ur</ex>nis</expan>. <expan>Sc<ex>ri</ex>pt<ex>is</ex></expan>
