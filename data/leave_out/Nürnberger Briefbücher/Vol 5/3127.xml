<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout">Lieber <add>her</add> hofmeister, ewren brief, den ir
                            uns von ewrs <expan>swag<ex>er</ex>s</expan>
<expan>h<ex>er</ex>n</expan>
<expan>Conr<ex>ad</ex></expan>
<expan>Truchsesse<ex>n</ex></expan> wegen gesant habt, ist uns erst als
                            gestern ge<expan>antw<ex>ur</ex>t</expan> worden. Nu <add>kom</add>
<expan>Johan<ex>n</ex>s</expan>
<expan>Lantschr<ex>eiber</ex></expan> am nehsten suntag davor
                                <add>für</add> uns und bat uns auch von
                                <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, des marggrafen, und ewrn wegen in
                            sölcher masz, als ir uns <expan>dan<ex>n</ex></expan>
<expan>geschrib<ex>e</ex>n</expan> habt, darauff wir im desmals czu
                                    <expan>antw<ex>ur</ex>t</expan>
<expan>gab<ex>e</ex>n</expan>, als wir auch
                                <expan>yeczund<ex>en</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> antwurtten, daz wir die sache gen dem
                                    <expan>egen<ex>anten</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Conrad<ex>en</ex></expan>
<add>durch <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>re<ex>n</ex></expan> des
                                        <expan>margr<ex>afen</ex></expan> und
                                    <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>g<ex>er</ex>n</expan></add> acht tag lenger
                                    <expan>dan<ex>n</ex></expan> vor ansteen lassen wöllen <add>in
                                der masz, als <expan>dan<ex>n</ex></expan> vor
                                        <expan>czwisch<ex>e</ex>n</expan> uns und im begriffen
                                ist</add>; <expan>dan<ex>n</ex></expan> wo wir
                                    <expan>desselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> des <expan>margr<ex>afen</ex></expan>
                            gnaden und <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb und dinst etc.
                                    <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>ri</ex>a</expan> vi <expan>an<ex>te</ex></expan> Anthoni.
                        </del></ab>
</div>
