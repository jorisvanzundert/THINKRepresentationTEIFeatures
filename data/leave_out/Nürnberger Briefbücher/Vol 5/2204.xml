<ab><expan>H<ex>er</ex>n</expan> Mertein vom <expan>Liechtenstein</expan>,
                        thumprobst zu Bamberg </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Erwirdig<ex>er</ex></expan> lieber
                                                  <expan>h<ex>er</ex>re</expan>, als wir vormals
                                                auch <expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> zu
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erwirdik<ex>eit</ex></expan> gesant
                                                  <expan>hab<ex>e</ex>n</expan> von
                                                  <expan>uns<ex>er</ex>r</expan>
<expan>b<ex>urger</ex></expan> armer lewt
                                                  <expan>weg<ex>en</ex></expan>, die da recht
                                                  <expan>hab<ex>e</ex>n</expan> in die weld und
                                                  <expan>hölcz<ex>er</ex></expan>, die in das ambt
                                                gen Fürt gehörn, <expan>dies<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> an
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erwirdik<ex>eit</ex></expan> ein stallung des
                                                banns, den ir do <expan>angefang<ex>en</ex></expan>
                                                hett beredt etc., <expan>hab<ex>e</ex>n</expan>
<add><expan>ders<ex>elben</ex></expan></add>
<expan>uns<ex>er</ex>r</expan>
<expan>b<ex>urger</ex></expan> arm lewt
                                                  <expan>hoffnu<ex>n</ex>g</expan> gehabt, ir söltet
                                                die sache <expan>hab<ex>e</ex>n</expan>
<expan>falle<ex>n</ex></expan> lassen, und
                                                  <expan>hab<ex>e</ex>n</expan> uns fürbracht wie ir
                                                die sache mit bann gegen in
                                                  <expan>wid<ex>er</ex></expan>
<expan>angefang<ex>en</ex></expan> habt.
                                                  <expan>Daru<ex>m</ex>b</expan> wir
                                                  <expan>Hanns<ex>en</ex></expan>
<expan>Newstett<ex>er</ex></expan>,
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>,
                                                  <expan>yecz<ex>unden</ex></expan>
<expan>ab<ex>er</ex></expan> zu
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erwirdik<ex>eit</ex></expan>
<expan>schik<ex>en</ex></expan>, mit ew
                                                  <expan>davo<ex>n</ex></expan> zu reden et
                                                  <expan>roga<ex>mus</ex></expan> in
                                                  <expan>for<ex>ma</ex></expan> credencie.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan> Luce.</ab>
