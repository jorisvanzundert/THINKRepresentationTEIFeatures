</div><div type="regularised"><pb facs="#facs_514" id="256r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Lud<ex>wig</ex></expan>, <expan>pfallnczgr<ex>af</ex></expan> bey
                        Reyn, des <expan>heilig<ex>en</ex></expan>
<expan>römische<ex>n</ex></expan> reichs
                            <expan>ercztruchsess<ex>en</ex></expan> und
                            <expan>herczog<ex>en</ex></expan> in Peyern,
                            <expan>uns<ex>er</ex>m</expan>
<expan>gnedige<ex>n</ex></expan>
<expan>h<ex>er</ex>ren</expan></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als ewr
                            <expan>durchlewch<ex>tikeit</ex></expan> uns und
                            <expan>and<ex>er</ex>n</expan>
<expan>frenkische<ex>n</ex></expan>
<expan>stette<ex>n</ex></expan>, <expan>uns<ex>er</ex>n</expan> guten
                                <expan>frewnd<ex>en</ex></expan>,
                            <expan>verschr<ex>iben</ex></expan> hat von der befelhnuss
                                <expan>weg<ex>en</ex></expan> eins
                            <expan>stathalt<ex>er</ex></expan> und <expan>fürwes<ex>er</ex></expan>
                        ambts, daz der <expan>all<ex>er</ex></expan> durchlewchtigist fürst und
                                <expan>h<ex>er</ex>re</expan>, <expan>h<ex>e</ex>r</expan>
<expan>Sigmu<ex>n</ex>d</expan>, <expan>römisch<ex>er</ex></expan>, zu
                                <expan>Ung<ex>er</ex>n</expan> und zu Beheim etc. künig,
                                <expan>uns<ex>er</ex></expan>
<expan>gnedigist<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> dem <expan>hochwirdig<ex>en</ex></expan>
<expan>fürste<ex>n</ex></expan> und <expan>h<ex>er</ex>ren</expan>,
                                <expan>h<ex>er</ex>n</expan>
<expan>Conr<ex>ad</ex></expan>, <expan>erczbisch<ex>of</ex></expan> zu
                        Meincz, <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, getan hab etc., das haben wir wol
                                <expan>vernom<ex>en</ex></expan> und <expan>welle<ex>n</ex></expan>
                        den <expan>vorgen<ex>anten</ex></expan>
<expan>stette<ex>n</ex></expan>, <expan>uns<ex>er</ex>n</expan> nachpawrn,
                                <expan>dens<ex>elben</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>br<ex>ief</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>künd<ex>en</ex></expan> und zu
                            <expan>wiss<ex>en</ex></expan> tun. Dabey tun wir
                            <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> zu <expan>wiss<ex>en</ex></expan>, daz uns
                        der <expan>obg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von Meincz von der
                            <expan>vorg<ex>enante</ex>n</expan> befelhnuss des
                                <expan>stathalt<ex>er</ex></expan> und
                            <expan>fürwes<ex>er</ex></expan> ambts, daz
                            <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>beschehe<ex>n</ex></expan> sey, auch
                            <expan>v<ex>er</ex>schriben</expan> und <expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> auf yecz <app><note><q type="date">sand Gallen tag</q>16.10.1422</note></app> gen Worms zu
                                <expan>schik<ex>en</ex></expan> begert hat, als sein gnade
                                <expan>and<ex>er</ex>n</expan>
<expan>stette<ex>n</ex></expan> zum reiche gehörig in dewtschen
                                <expan>land<ex>en</ex></expan>
<expan>desgleiche<ex>n</ex></expan> auch <expan>verschr<ex>iben</ex></expan>
                        und begert hab; da meyne sein <expan>hoch<ex>wirdikeit</ex></expan>, uns und
                        den <expan>and<ex>er</ex>n</expan> des <expan>egen<ex>anten</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des künigs <expan>meynu<ex>n</ex>g</expan>
                        fürczulegen und sehen und hören zu <expan>lass<ex>en</ex></expan> briefe,
                        die <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan> uber das <expan>obg<ex>enante</ex></expan>
<expan>stathalt<ex>er</ex></expan> ambt <expan>gegebe<ex>n</ex></expan>
                        seyn, <pb facs="#facs_515" id="256v"/>und auch <expan>and<ex>er</ex></expan> brief,
                        die der <expan>vorg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedigist<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> der künig uns und den
                            <expan>and<ex>er</ex>n</expan> zum reich gehörig schreibe. Denn wo wir
                        ewerr <expan>durchlewch<ex>tikeit</ex></expan> dienst und wolgefallen etc.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra</ex></expan>.</ab>
</div>
</div></body>
