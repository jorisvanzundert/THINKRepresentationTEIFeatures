<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, des <expan>hochgebor<ex>e</ex>n</expan>
<expan>furst<ex>en</ex></expan> und <expan>h<ex>er</ex>ren</expan>,
                                <expan>h<ex>er</ex>n</expan>
<expan>Stepf<ex>an</ex></expan>, <expan>pfallnczgraf<ex>en</ex></expan> bey
                        Reyn und <expan>h<ex>er</ex>czog<ex>en</ex></expan> in Peyern,
                                <expan>jüdin<ex>n</ex></expan> eine genant Golde
                                <expan>Gensin<ex>n</ex></expan> meynt, etlich sprüche zu
                                <expan>hab<ex>e</ex>n</expan> zu der Secklin jüdinn bey uns,
                                <expan>dazwische<ex>n</ex></expan> sich etlich schrift rede und
                                <expan>wid<ex>er</ex>rede</expan>
<expan>ergang<ex>en</ex></expan> hat. Nu ist Michel, jud von <pb facs="#facs_7" id="2v"/>Weil, für uns <expan>kome<ex>n</ex></expan>, und hat uns
                        gesagt wie in die <expan>vorg<ex>enante</ex></expan>
<expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan> mit <expan>ire<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt und
                            <expan>gwaltzbrief<ex>en</ex></expan> von der
                            <expan>egen<ex>anten</ex></expan> sache <expan>weg<ex>en</ex></expan>
                        nehst gesant hab, daz er auf den <app>
<note><q type="date">ertag nach dem sunntag judica
                                            <expan>nehstv<ex>er</ex>gang<ex>en</ex></expan></q>04.04.1419</note>
</app> in <expan>ewer<ex>er</ex></expan> stat gen Meincz
                                <expan>kome<ex>n</ex></expan> sey. Also hab er darnach in
                                <expan>gegenwürtik<ex>eit</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>burg<ex>er</ex>meist<ex>er</ex></expan>, des
                                <expan>obg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, <expan>h<ex>er</ex>czog</expan>
<expan>Stepf<ex>an</ex>, </expan> zweyr <expan>schreib<ex>er</ex></expan>,
                        ewrs <expan>statschreib<ex>er</ex>s</expan>, des juden
                                <expan>hohmeist<ex>er</ex>s</expan> und
                            <expan>and<ex>er</ex>r</expan> person daselbs bey ewch den juden
                                <expan>hohmeist<ex>er</ex></expan> von der
                            <expan>Secklin<ex>n</ex></expan>
<expan>weg<ex>en</ex></expan>
<expan>gebette<ex>n</ex></expan>, und die <expan>vorgen<ex>ante</ex></expan>
                        sache gen der Golden Gensin zum <expan>recht<ex>en</ex></expan> auf in
                                <expan>gebotte<ex>n</ex></expan>. Und erbutt sich
                                <expan>all<ex>e</ex>m</expan> dem <expan>g<ex>er</ex>n</expan> gnug
                        zu tun, daz von <expan>ders<ex>elben</ex></expan> sache
                                <expan>weg<ex>en</ex></expan>
<app>
<note><q type="date">auf den <expan>freit<ex>ag</ex></expan> vor dem
                                    sunntag <expan>invocav<ex>i</ex><hi rend="sup">t</hi></expan>
<expan>nehstvergang<ex>en</ex></expan></q>04.03.1419</note>
</app>, <expan>zwisch<ex>en</ex></expan>
<expan>beide<ex>n</ex></expan> teiln bey uns beredt
                            <expan>w<ex>er</ex>e</expan>
<expan>word<ex>en</ex></expan>. Und des hab er von
                            <expan>ew<ex>r</ex>n</expan>
<expan>burg<ex>er</ex>meist<ex>er</ex>n</expan> ein geschribne zewknuss von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan>
<expan>gebette<ex>n</ex></expan> und begert, die im niht
                            <expan>w<ex>er</ex>den</expan> möcht, und doch
                            <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>, <expan>h<ex>er</ex>czog</expan>
<expan>Stepf<ex>an</ex></expan>, <expan>schreib<ex>er</ex>n</expan> in der
                        sache ein <expan>v<ex>er</ex>schribne</expan> zewknuss bey ewch
                                <expan>geb<ex>e</ex>n</expan>
<expan>word<ex>en</ex></expan> sey, als wir
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan>
