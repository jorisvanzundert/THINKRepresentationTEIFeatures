<ab facs="#facs_367_r2l28"><expan>Dat<ex>um</ex></expan> <expan>f<ex>er</ex>ıa</expan> ıȷ<hi rend="sup">a</hi> <expan>an<ex>te</ex></expan> <expan>E<ex>pi</ex>ph<ex>an</ex>ıa</expan> <expan>dom<ex>in</ex>j</expan> </ab>
