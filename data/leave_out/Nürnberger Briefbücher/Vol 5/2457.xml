</front>
<body><div type="diplomatic"><pb facs="#facs_200" id="99r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_200_r2l20">der Stat cʒu <expan>Nördling<ex>en</ex></expan> </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab facs="#facs_200_r2l21"><expan>L<ex>ieben</ex></expan> <expan>fr<ex>eunde</ex></expan> vns hat <expan>fürg<ex>elegt</ex></expan> Salman Jude bey vns cʒu <expan>Nür<ex>emberg</ex></expan> geſeſſen </ab>
<ab facs="#facs_200_r2l22">vvie daʒ Er etwaʒ ſache mit dem hanſen <expan>lawging<ex>er</ex></expan> <expan>ew<ex>r</ex>m</expan> <expan>mitburg<ex>er</ex></expan> </ab>
<ab facs="#facs_200_r2l23">cʒehandeln hab . als von eins hawſes wegen / das der <expan>egen<ex>ante</ex></expan> Salman </ab>
<ab facs="#facs_200_r2l24">bey euch <expan>v<ex>er</ex>kaufft</expan> hab / Darümb Jm ſein habe bey euch bekümert </ab>
<ab facs="#facs_200_r2l25">worden vnd Jn bederſeit ein tag cʒum rehten bey euch <expan>cʒeſuch<ex>e</ex>n</expan> nu </ab>
<ab facs="#facs_200_r2l26">auf ſant Merteins tag ſchıerſt beſcheyden ſey / Vnd <expan>wan<ex>n</ex></expan> ſolch </ab>
<ab facs="#facs_200_r2l27">vnfride <expan>yecʒund<ex>en</ex></expan> in <expan>de<ex>n</ex></expan> <expan>land<ex>en</ex></expan> <expan>auferſtande<ex>n</ex></expan> ſein / <expan>Dar<ex>ümb</ex></expan> der <expan>egen<ex>an</ex>t<ex>e</ex></expan> </ab>
<ab facs="#facs_200_r2l28">Salman cʒu der cʒeit hinüber cʒu euch niht ſıcher getraw <expan>ʒekume<ex>n</ex></expan> </ab>
<ab facs="#facs_200_r2l29">Hyrümb <expan>Ro<ex>gamus</ex></expan> . daʒ Jr den <expan>egen<ex>anten</ex></expan> tag / <expan>cʒwiſch<ex>e</ex>n</expan> ewrm mitburger </ab>
<ab facs="#facs_200_r2l30">
<add><ab facs="#facs_200_r1l1">vnd </ab></add> dem <expan>vorg<ex>enanten</ex></expan> Salman Juden . <expan>d<ex>ur</ex>h</expan> <expan>vnſ<ex>er</ex>n</expan> <expan>wille<ex>n</ex></expan> erlengen wollet / Das </ab>
<ab facs="#facs_200_r2l31"><expan>wölle<ex>n</ex></expan> etc / vnd <expan>bıtte<ex>n</ex></expan> des <expan>ew<ex>r</ex></expan> <expan>fr<ex>euntlich</ex></expan>
<add><ab facs="#facs_200_line_1577090918193_2272"><expan>verſ<ex>chriben</ex></expan> </ab></add> <expan>antvv<ex>ur</ex>t</expan> wider / darnach ſich der <expan>eg<ex>enante</ex></expan> Jude </ab>
<ab facs="#facs_200_r2l32">cʒerihten wiſʒ . <expan>dat<ex>um</ex></expan> <expan>fe<ex>ri</ex>a</expan> ıııj̃ <expan>an<ex>te</ex></expan> <expan>Om<ex>n</ex>ȷ</expan> <expan>S<ex>an</ex>c<ex>t</ex>o<ex>rum</ex></expan> A xx <hi rend="sup"> o </hi></ab>
</div>
</div><div type="regularised"><pb facs="#facs_200" id="99r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Der stat czu <expan>Nördling<ex>en</ex></expan>
</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, uns hat <expan>fürg<ex>elegt</ex></expan>
                        Salman, jude bey uns czu <expan>Nür<ex>emberg</ex></expan> gesessen, wie daz
                        er etwaz sache mit dem Hansen <expan>Lawging<ex>er</ex></expan>,
                                <expan>ew<ex>r</ex>m</expan>
<expan>mitburg<ex>er</ex></expan>, czehandeln hab, als von eins hawses
                        wegen, das der <expan>egen<ex>ante</ex></expan> Salman bey euch
                                <expan>v<ex>er</ex>kaufft</expan> hab, darümb im sein habe bey euch
                        bekümert worden und in bederseit ein tag czum rehten bey euch
                                <expan>czesuch<ex>e</ex>n</expan>
<app>
<note><q type="date">nu auf sant Merteins tag
                                schierst</q>11.11.1420</note>
</app> bescheyden sey. Und <expan>wan<ex>n</ex></expan> solch unfride
                                <expan>yeczund<ex>en</ex></expan> in <expan>de<ex>n</ex></expan>
<expan>land<ex>en</ex></expan>
<expan>auferstande<ex>n</ex></expan> sein, <expan>dar<ex>ümb</ex></expan>
                        der <expan>egen<ex>an</ex>t<ex>e</ex></expan> Salman czu der czeit hinüber
                        czu euch niht sicher getraw <expan>zekume<ex>n</ex></expan>. Hyrümb
                                <expan>ro<ex>gamus</ex></expan>, daz ir den
                                <expan>egen<ex>anten</ex></expan> tag
                            <expan>czwisch<ex>e</ex>n</expan> ewrm mitburger <add>und</add> dem
                                <expan>vorg<ex>enanten</ex></expan> Salman juden
                            <expan>d<ex>ur</ex>h</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> erlengen wollet. Das
                            <expan>wölle<ex>n</ex></expan> etc. Und <expan>bitte<ex>n</ex></expan>
                        des <expan>ew<ex>r</ex></expan>
<expan>fr<ex>euntlich</ex></expan>
<add><expan>vers<ex>chriben</ex></expan></add>
<expan>antw<ex>ur</ex>t</expan> wider, darnach sich der
                                <expan>eg<ex>enante</ex></expan> jude cze rihten wisz.
                                <expan>Dat<ex>um</ex></expan>
<expan>fe<ex>ri</ex>a</expan> iiii <expan>an<ex>te</ex></expan>
<expan>om<ex>n</ex>i</expan>
<expan>s<ex>an</ex>c<ex>t</ex>o<ex>rum</ex></expan>
<expan>a<ex>nno</ex></expan> xx <hi rend="sup"> o </hi>.</ab>
</div>
