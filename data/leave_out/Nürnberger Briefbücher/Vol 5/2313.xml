<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> und <expan>gebette<ex>n</ex></expan>
                        habt, <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> etwas meͣre von
                            <expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, dem <expan>römische<ex>n</ex></expan> künig,
                        und auch von den Hussen zu <expan>schreibe<ex>n</ex></expan> etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Und als wir von den
                                <expan>uns<ex>er</ex>n</expan>
<expan>v<ex>er</ex>nemen</expan>, <add>die awsz und ein
                                    <expan>wand<ex>er</ex>n</expan></add>, so steet es in dem lande
                        zu Beheim <expan>laid<ex>er</ex></expan> etwas
                            <expan>küm<ex>m</ex>erlich</expan>, daz sich der Hussen
                                <expan>gesellsch<ex>aft</ex></expan> vast sterkt und mert, so ist
                        uns auch kürczlich ein <expan>abschr<ex>ift</ex></expan>
<expan>geantw<ex>ur</ex>tt</expan>
<expan>word<ex>en</ex></expan>, als der <expan>lanth<ex>er</ex>ren</expan>
                        einr zu Beheim, der von <expan>Wartemb<ex>er</ex>g</expan>, dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, dem künig, und er und etlich
                                <expan>and<ex>er</ex></expan>
<expan>lanth<ex>er</ex>ren</expan> und behemische gemein
                                <expan>etliche<ex>n</ex></expan>
<expan>behemische<ex>n</ex></expan>
<expan>stette<ex>n</ex></expan>
<expan>süll<ex>e</ex>n</expan>
<expan>verschr<ex>iben</ex></expan>
<expan>hab<ex>e</ex>n</expan>; <expan>ders<ex>elben</ex></expan>
<expan>abschr<ex>ift</ex></expan> wir <expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> ein <expan>abschr<ex>ift</ex></expan>
<expan>hierynn<ex>en</ex></expan>
<expan>versloss<ex>en</ex></expan>
<expan>schik<ex>en</ex></expan>. Doch möcht
                            <expan>ders<ex>elben</ex></expan> schrift <expan>mind<ex>er</ex></expan>
<expan>od<ex>er</ex></expan> mer sein so <expan>hab<ex>e</ex>n</expan> wir
                        auch <expan>v<ex>er</ex>nomen</expan>, daz der
                            <expan>obg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> der künig nu talang <pb facs="#facs_123" id="60v"/>auf
                        den berg zun <expan>Kutte<ex>n</ex></expan>
<expan>kome<ex>n</ex></expan> sey <expan>od<ex>er</ex></expan> kürczlich
                                <expan>kome<ex>n</ex></expan> sülle und daz im
                                <expan>ritt<ex>er</ex>schaft</expan> und volk vast zureite und zu
                        ziehe, daz wir getrawn unser <expan>h<ex>e</ex>rgot</expan> süll es gut
                                <expan>mache<ex>n</ex></expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>asce<ex>n</ex>sio<ex>n</ex>is</expan>
<expan>d<ex>omi</ex>ni</expan>.</ab>
