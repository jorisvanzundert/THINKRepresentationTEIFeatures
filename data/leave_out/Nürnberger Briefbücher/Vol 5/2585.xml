</div><div type="regularised"><pb facs="#facs_267" id="132v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>Cuilib<ex>et</ex></expan>
<expan>unu<ex>m</ex></expan>. <expan>H<ex>er</ex>n</expan>
<expan>Ernst<ex>en</ex></expan> und <expan>h<ex>er</ex>n</expan>
<expan>Wilhelm<ex>m</ex></expan>, <expan>gebrud<ex>er</ex>n</expan>,
                                <expan>pfallnczgraf<ex>en</ex></expan> bey Reyn und
                                <expan>h<ex>er</ex>czog<ex>en</ex></expan> in Peyern</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir <expan>bitt<ex>en</ex></expan> ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> czu
                            <expan>wiss<ex>en</ex></expan>, daz sich <expan>Ulr<ex>ich</ex></expan>,
                                <expan>Conr<ex>ad</ex></expan> und Bertlein von Swangow,
                                <expan>gebrud<ex>er</ex></expan>, die <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>dien<ex>er</ex></expan> seyn, als wir
                            <expan>v<ex>er</ex>nomen</expan> haben, vor etlichen
                                <expan>czeit<ex>en</ex></expan> ein <expan>uns<ex>er</ex>s</expan>
                        geswornen <expan>b<ex>urgers</ex></expan>
<expan>gena<ex>n</ex>t</expan>
<expan>F<ex>riedrich</ex></expan> Zesel <expan>geg<ex>en</ex></expan> uns
                                <expan>angenome<ex>n</ex></expan>, uns
                            <expan>daru<ex>m</ex>b</expan>
<expan>verschr<ex>iben</ex></expan> und wir in
                            <expan>geantw<ex>ur</ex>tt</expan> haben. <expan>Daru<ex>m</ex>b</expan>
                        wir <expan>Hanns<ex>en</ex></expan> Göldlein <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan> zu <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>schik<ex>en</ex></expan>, dem wir <expan>befolhe<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>, mit <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>davo<ex>n</ex></expan> zu reden, und <expan>bitt<ex>en</ex></expan>
                        ewr <expan>hoch<ex>wirdikeit</ex></expan> dienstlich und mit fleiss, was
                                <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> zu disem mal in
                            <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr <expan>fürstenl<ex>ich</ex></expan>
                        gnade werbe, daz ir in darinn <expan>gnedikl<ex>ich</ex></expan> verhörn, im
                        des <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und <expan>günstikl<ex>ich</ex></expan>
<add><expan>daru<ex>m</ex>b</expan></add> von <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>fertig<ex>en</ex></expan> wellet. Als etc. Das wellen etc.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra</ex></expan>.</ab>
</div>
