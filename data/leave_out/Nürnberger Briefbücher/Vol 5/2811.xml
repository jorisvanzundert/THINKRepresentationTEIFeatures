<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als etlich
                                                  <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> den Mertein, des
                                                Nikel Erharts knecht, bey ewch zu fenknuss bracht
                                                und uns zu <expan>wiss<ex>en</ex></expan> getan
                                                haben, daz ir ewch darinne frewntlich und gutwillig
                                                beweist habt, des <expan>dank<ex>en</ex></expan> wir
                                                  <expan>ewer<ex>er</ex></expan> weisheit mit
                                                  <expan>gancze<ex>m</ex></expan> fleisz und
                                                  <expan>schik<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan> zu
                                                  <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> Moriczen Awracher,
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, dem wir befolhen
                                                haben mit ew <expan>davo<ex>n</ex></expan> zu reden.
                                                  <expan>Bitt<ex>en</ex></expan> wir ewr
                                                  <expan>frewnts<ex>chaft</ex></expan>
<expan>fleissikl<ex>ich</ex></expan>, was
                                                  <expan>ders<ex>elb</ex></expan> unser
                                                  <expan>dien<ex>er</ex></expan> zu <pb facs="#facs_386" id="192r"/>disem male in
                                                  <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> von
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewch werbe, daz ir
                                                im des <expan>genczl<ex>ich</ex></expan> gelawben
                                                und ewch darinn <expan>ab<ex>er</ex></expan> so
                                                frewntlich und fürderlich beweisen und darczu tun
                                                wellet, als wir <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wol getrawen und
                                                ewch und den <expan>ew<ex>r</ex>n</expan> bey uns
                                                  <expan>g<ex>er</ex>n</expan> tun wölten. Das
                                                wellen wir umb ewr <expan>ersamk<ex>eit</ex></expan>
                                                etc. <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan>
<expan>p<ex>ost</ex></expan> Dorothee
                                                  <expan>virg<ex>in</ex>is</expan>.</ab>
</div>
