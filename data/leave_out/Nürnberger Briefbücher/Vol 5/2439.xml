<ab facs="#facs_190_r1l5"><expan>dyen<ex>er</ex>s</expan> . vnd <expan>vnſ<ex>er</ex>s</expan> <expan>B<ex>urgers</ex></expan> <expan>Conr<ex>ad</ex></expan> payrs etc das <expan>hab<ex>e</ex>n</expan> vvir vvol </ab>
