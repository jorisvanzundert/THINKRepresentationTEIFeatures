<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>v<ex>er</ex>schr<ex>iben</ex></expan> hat, von wegen
                                <expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan>
<expan>Amman<ex>n</ex>s</expan>, <expan>tumh<ex>er</ex>re<ex>n</ex></expan>
                        czu <expan>Eystet<ex>en</ex></expan>, <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>dyen<ex>er</ex>s</expan>, und <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>Conr<ex>ad</ex></expan> Payrs etc., das <expan>hab<ex>e</ex>n</expan>
                        wir wol <expan>v<ex>er</ex>nome<ex>n</ex></expan> und
                            <expan>hab<ex>e</ex>n</expan> umb <expan>ew<ex>r</ex>n</expan>
<expan>gnade<ex>n</ex></expan>
<expan>wille<ex>n</ex></expan>
<expan>denselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> besant und ernstlich czu rede geseczt und
                        auch <expan>dens<ex>elben</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan> sein rede selbs erczelen lassen; darczu
                                <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>geantw<ex>ur</ex>t</expan> hat, daz er
                            <expan>dems<ex>elben</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan> nye nihts schuldig worden sey oder gelten
                        sülle <expan>dan<ex>n</ex></expan> sein pruder,
                            <expan>Han<ex>n</ex>s</expan> Amman, der vor
                            <expan>czeite<ex>n</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> gewesen und ein ley ist, hab im etlich
                        sprüch, die er ümb geltschulde von <expan>sein<ex>er</ex></expan> swyger
                        seligen wegen czu im main <expan>cze hab<ex>e</ex>n</expan>,
                                <expan>übergeb<ex>e</ex>n</expan>, darümb er doch
                                <expan>ders<ex>elben</ex></expan>
<expan>sein<ex>er</ex></expan>
<expan>swig<ex>er</ex></expan> bey iren <expan>lebendige<ex>n</ex></expan>
<expan>czeite<ex>n</ex></expan> mit <expan>de<ex>n</ex></expan>
<expan>rehte<ex>n</ex></expan> bey uns ein genüg getan hab. Darnach
                                <expan>hab<ex>e</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex>meiste<ex>r</ex></expan> dem
                                <expan>vorgen<ex>anten</ex></expan>
<expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan>
