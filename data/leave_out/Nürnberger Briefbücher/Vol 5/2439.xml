<ab facs="#facs_190_r1l9"><expan>geantvv<ex>ur</ex>t</expan> hat / Daʒ Er <expan>demſ<ex>elben</ex></expan> <expan>h<ex>er</ex>n</expan> <expan>heinr<ex>ich</ex></expan> nye nihts ſchuldig </ab>
