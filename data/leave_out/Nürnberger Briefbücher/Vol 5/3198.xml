<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>amptm<ex>an</ex></expan>, als ir uns <expan>ab<ex>er</ex></expan>
<expan>verschr<ex>iben</ex></expan> und <expan>gebette<ex>n</ex></expan>
                        habt von <expan>weg<ex>en</ex></expan>
<expan>Eb<ex>er</ex>lin</expan> Hasennests, <expan>Ott<ex>en</ex></expan>
                        Zynnagels und <expan cert="unknown">H.</expan> Wilden etc., das
                                <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu <expan>w<ex>er</ex>en</expan> wir
                                <expan>söllich<ex>er</ex></expan> sache lieber
                            <expan>v<ex>er</ex>tragen</expan>, doch umb <expan>ew<ex>r</ex>n</expan>
                        willen <expan>welle<ex>n</ex></expan> wir <expan>dens<ex>elben</ex></expan>
                        dreyn <expan>k<ex>ürczlich</ex></expan>
<expan>hiezwisch<ex>en</ex></expan> <app><note><q type="date"><expan>pfingst<ex>en</ex></expan> schierist</q>23.05.1423</note></app>
                         umb alle
                                <expan>v<ex>er</ex>gang<ex>en</ex></expan> sache keins argen
                                <expan>gewarte<ex>n</ex></expan> für uns und die
                                <expan>uns<ex>er</ex>n</expan> on <expan>gev<ex>er</ex>de</expan>,
                        also doch, ob sie <expan>dazwisch<ex>en</ex></expan> das reichs
                                <expan>strass<ex>en</ex></expan> und die zu <pb facs="#facs_608" id="303r"/>und von uns <expan>wand<ex>er</ex>n</expan> und auch uns und die
                                <expan>uns<ex>er</ex>n</expan> niht <expan>m<ex>er</ex></expan>
<expan>beschedig<ex>en</ex></expan>; denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb oder dienst etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan> judica. </ab>
</div>
