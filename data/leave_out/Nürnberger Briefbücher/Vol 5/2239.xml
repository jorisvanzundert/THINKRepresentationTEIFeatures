<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von <expan>weg<ex>en</ex></expan>
                        Anshelln <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> juden und der
                            <expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan>, seinr <expan>mut<ex>er</ex></expan> bey uns
                        wonhaft etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>vernom<ex>en</ex>.</expan> Nu <expan>hab<ex>e</ex>n</expan>
                        wir die <expan>vorg<ex>enante</ex>n</expan>
<expan>Secklin<ex>n</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>jüdin<ex>n</ex></expan> von sache <expan>weg<ex>en</ex></expan>, die
                        wir in <expan>sund<ex>er</ex>heit</expan> zu ir
                            <expan>hab<ex>e</ex>n</expan> zu <expan>uns<ex>er</ex>n</expan>
<expan>hande<ex>n</ex></expan>
<expan>genome<ex>n</ex></expan> und <expan>hoffe<ex>n</ex></expan> uns
                                <expan>darynn<ex>en</ex></expan>
<expan>zuhalte<ex>n</ex></expan> und zutun, daz wir wol
                                <expan>getrawe<ex>n</ex></expan> zu
                            ver<expan>antw<ex>ur</ex>ten</expan>. Denn als der
                                <expan>eg<ex>enante</ex></expan> Anshell jud meynt, daz er sölich
                        hab bey uns hab etc., da ist uns niht <expan>wissenl<ex>ich</ex></expan>
                        von. Wie <expan>daru<ex>m</ex>b</expan> dewht
                            <expan>dens<ex>elben</ex></expan> Anshelln, daz er zu der hab
                                <expan>od<ex>er</ex></expan> zu <expan>yema<ex>n</ex>t</expan> bey
                        uns, des wir mechtig sein, icht zu <expan>spreche<ex>n</ex></expan> hett, so
                                <expan>well<ex>e</ex>n</expan> wir im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan> schein<expan>botte<ex>n</ex></expan> mit
                                <expan>seine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt umb <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>will<ex>e</ex>n</expan> slewnigs <pb facs="#facs_81" id="39v"/>
<expan>rechte<ex>n</ex></expan> bey uns <expan>g<ex>er</ex>n</expan>
<expan>helffe<ex>n</ex></expan>
<expan>ungev<ex>er</ex>lichen</expan>. Und als <add>uns</add> ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade
                                <expan>verschr<ex>iben</ex></expan> hat, mit der
                                <expan>jüdisch<ex>eit</ex></expan> bey uns zu
                                <expan>bestell<ex>e</ex>n</expan> etc., mit den
                            <expan>hab<ex>e</ex>n</expan> wir <expan>davo<ex>n</ex></expan> geredt,
                        die meynen <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> selbs <expan>daru<ex>m</ex>b</expan>
<expan>zu antw<ex>ur</ex>ten</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi <hi rend="sup"> a </hi>
<expan>an<ex>te</ex></expan>
<expan>festu<ex>m</ex></expan>
<expan>nati<ex>vi</ex>tat<ex>is</ex></expan> Christi.</ab>
