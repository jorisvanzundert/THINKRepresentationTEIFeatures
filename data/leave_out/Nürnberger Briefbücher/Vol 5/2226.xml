<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan> yecz
                            <expan>verschr<ex>iben</ex></expan> hat von
                            <expan>uns<ex>er</ex>s</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>weg<ex>en</ex></expan> marggraf <expan>Fridr<ex>ich</ex></expan> von
                                <expan>Brandemb<ex>ur</ex>g</expan> etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>
                        und <expan>hab<ex>e</ex>n</expan> umb <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>will<ex>e</ex>n</expan> den <expan>offen<ex>en</ex></expan> brief,
                        als ewr gnade <expan>fürste<ex>n</ex></expan>,
                            <expan>h<ex>er</ex>ren</expan> und <expan>stette<ex>n</ex></expan>
<expan>v<ex>er</ex>schreibt</expan>, und die copey eins
                                <expan>schuldbr<ex>iefs</ex></expan>, die uns ewr bott mit
                                <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> brief <expan>geantw<ex>ur</ex>tt</expan> hat,
                        auch <expan>v<ex>er</ex>höret</expan> und <expan>lass<ex>en</ex></expan> ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade
                            <expan>wiss<ex>en</ex></expan>, daz uns sölich zwytracht allweg laid
                                <expan>gewes<ex>en</ex></expan> und noch laid sein und da die
                        gütlich <expan>abgieng<ex>en</ex></expan> und bericht
                            <expan>wurde<ex>n</ex></expan>, das sehen und
                            <expan>horte<ex>n</ex></expan> wir <expan>uns<ex>er</ex>s</expan> teyls
                        zumal <expan>g<ex>er</ex>n</expan>. Und könten wir icht guts darczu
                                <expan>gediene<ex>n</ex></expan>, des <expan>wölte<ex>n</ex></expan>
                        wir willig sein. Denn wo wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. das teten wir mit
                                <expan>will<ex>e</ex>n</expan>
<expan>g<ex>er</ex>n</expan>. <expan>Dat<ex>um</ex></expan> ut
                                <expan>s<ex>upra</ex></expan>.</ab>
