<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><app>
<note place="marginleft"> In bapiro. </note>
</app>
<expan>Uns<ex>er</ex></expan>
<expan>fr<ex>ewntschaft</ex></expan> bevor. <expan>L<ex>ieber</ex></expan>
                        Lewpolt, als du uns <expan>verschr<ex>iben</ex></expan> hast von
                                <expan>Ulr<ex>ich</ex></expan> Fütrers des
                            <expan>elt<ex>er</ex>n</expan>, seins suns und Lorencz Rüczen
                                <expan>uns<ex>er</ex>r</expan>
<expan>b<ex>urger</ex></expan>
<expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                                <expan>vernom<ex>en</ex></expan> und <expan>hab<ex>e</ex>n</expan>
<expan>dies<ex>elben</ex></expan> die <expan>uns<ex>er</ex>n</expan> für uns
                        besant und <expan>daru<ex>m</ex>b</expan> czurede gesaczt. So steet ir rede
                        ungeleich gen deinr schrift, doch <expan>habe<ex>n</ex></expan> wir
                                <expan>sov<ex>er</ex>ren</expan> mit in geredt, daz sie dir selb
                                <expan>daru<ex>m</ex>b</expan> ein antwurt tun
                                <expan>sulle<ex>n</ex></expan>. Dewht dich aber, daz du
                                <expan>darüb<ex>er</ex></expan> zu in icht zu
                                <expan>sprehe<ex>n</ex></expan> hettst, so
                            <expan>well<ex>e</ex>n</expan> wir dir <expan>od<ex>er</ex></expan>
<expan>deine<ex>m</ex></expan>
<expan>scheinbotte<ex>n</ex></expan> mit <expan>deine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt <expan>frewntl<ex>ich</ex></expan>
                        slewnigs <expan>rechte<ex>n</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>dies<ex>elben</ex></expan>
                        die <expan>uns<ex>er</ex>n</expan>, zu den du
                            <expan>zuspreche<ex>n</ex></expan> hettst, anheim sein on geverde.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan> judica. </ab></div>
