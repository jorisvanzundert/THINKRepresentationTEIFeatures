<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Erwirdig<ex>en</ex></expan> und <expan>l<ex>ieben</ex></expan>
<expan>h<ex>er</ex>ren</expan>, als ir uns
                            <expan>verschr<ex>ieben</ex></expan> habt von
                            <expan>weg<ex>en</ex></expan>
<expan>etlich<ex>er</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Bamb<ex>er</ex>g</expan>
                        hofgesinde und der <expan>ew<ex>r</ex>n</expan>, die ir in
                                <expan>ew<ex>r</ex>m</expan>
<expan>br<ex>ief</ex></expan> benennet habt, und des handels der
                                <expan>geg<ex>en</ex></expan>
<expan>etliche<ex>n</ex></expan> den <expan>uns<ex>er</ex>n</expan>
<expan>am<ex>m</ex></expan>
<app>
<note><q type="date"><expan>nehstv<ex>er</ex>gang<ex>en</ex></expan>
<expan>freit<ex>ag</ex></expan></q>11.12.1422</note>
</app>
<expan>ergang<ex>en</ex></expan> und <expan>beschehe<ex>n</ex></expan> ist,
                        etc., das <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu meynen
                            <expan>dies<ex>elben</ex></expan> die <expan>uns<ex>er</ex>n</expan>,
                        daz <pb facs="#facs_557" id="277v"/>sich <expan>ders<ex>elb</ex></expan> handel
                                <expan>and<ex>er</ex>s</expan>, <add>denn die
                                <expan>ew<ex>r</ex>n</expan>
<expan>fürgebe<ex>n</ex></expan></add>, gemacht und
                                <expan>ergang<ex>en</ex></expan> habe.
                            <expan>Daru<ex>m</ex>b</expan>
<expan>schik<ex>en</ex></expan> wir zu <expan>ewr<ex>er</ex></expan>
<expan>wirdik<ex>eit</ex></expan>
<expan>Hanns<ex>en</ex></expan>
<expan>Erlpek<ex>en</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, dem wir befolhen
                            <expan>habe<ex>n</ex></expan>, mit ew <expan>davo<ex>n</ex></expan> zu
                        reden, und <expan>bitt<ex>en</ex></expan> ewr
                            <expan>erwirdik<ex>eit</ex></expan>, was <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> in den <expan>vorgen<ex>anten</ex></expan>
                        sachen zu disem mal von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ew <expan>w<ex>er</ex>be</expan>, daz ir im
                        das <expan>genczl<ex>ich</ex></expan> gelawbet und ewch auch darinn
                        beweiset, als etc. Denn wo wir <expan>ewr<ex>er</ex></expan>
<expan>erwirdik<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi> post Lucye. </ab>
</div>
