</div>
</div><div type="regularised"><pb facs="#facs_9" id="3v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Nobile et generoso <expan>d<ex>omi</ex>nio</expan>,
                            <expan>d<ex>omi</ex>no</expan> Barczkoni de Cunstat
                            <expan>al<ex>ia</ex>s</expan> in Bodiebrad etc.</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab>Obsequiosa <expan>semp<ex>er</ex></expan> voluntate
                                <expan>p<ex>rae</ex>miss<ex>is</ex></expan>.
                            <expan>Nob<ex>i</ex>lis</expan> ac
                            <expan>g<ex>e</ex>n<ex>er</ex>ose</expan>
<expan>d<ex>omi</ex>ne</expan> Licz preces sive
                                <expan>sc<ex>ri</ex>pt<ex>is</ex></expan>
<expan>nostr<ex>is</ex></expan>
<expan>al<ex>ii</ex>s</expan>
<expan>v<ex>est</ex>re</expan>
<expan>nobil<ex>ta</ex><hi rend="sup">ti</hi></expan>
<expan>pozrect<ex>is</ex></expan> ex <expan>p<ex>ar</ex>te</expan>
<expan>hon<ex>orabi</ex><hi rend="sup">liu<ex>m</ex></hi></expan>
<expan>d<ex>omi</ex>nor<ex>um</ex></expan>
<expan>p<ex>rae</ex>p<ex>osi</ex>ti</expan> et
                                <expan>mansionarior<ex>um</ex></expan> penes nos in aula <note><q type="inline"><expan>b<ex>ea</ex>tississi<ex>m</ex>e</expan></q>Die
                            korrekte Form wäre "beatissime".</note>
<expan>virg<ex>in</ex>is</expan> Marie
                            <expan>rac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>quorunda<ex>m</ex></expan>
<expan>debitor<ex>um</ex></expan>
<expan>suor<ex>um</ex></expan>
<expan>p<ex>er</ex>solvendo<ex>rum</ex></expan> a
                            <expan>v<ex>est</ex>ra</expan>
<expan>nob<ex>i</ex>li<expan>ta</expan><hi rend="sup">te</hi></expan>
<expan>hucusq<ex>ue</ex></expan> locum ex
                            <expan>audic<ex>i</ex>o<ex>n</ex>is</expan> non
                                <expan>inveneri<ex>n</ex>t</expan>
<expan>p<ex>ro</ex>ut</expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan>, <expan>freque<ex>n</ex>s</expan>
                        accessus nos non sive querelis instruxit ac <expan>insup<ex>er</ex></expan>
<expan>auditu<ex>m</ex></expan>
<expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>sepi<ex>us</ex></expan> fatigavit, sub spe
                            <expan>t<ex>ame</ex>n</expan> et fiducia bona
                            <expan>qua<ex>m</ex></expan> ad <expan>v<ex>est</ex>ram</expan>
<expan>g<ex>e</ex>n<ex>er</ex>ositate<ex>m</ex></expan>
<add>ac</add>
<expan>m<ex>u</ex>ltiplici<ex>u</ex><hi rend="sup">m</hi></expan>
<expan>virtutu<ex>m</ex></expan>
<expan>v<ex>est</ex>ror<ex>um</ex></expan> merita
                            <expan>gerim<ex>us</ex></expan> et ne <expan>forsanq<ex>ue</ex></expan>
                        obinde cultus <expan>ip<ex>s</ex>i<ex>us</ex></expan>
<expan>gl<ex>or</ex>iossi<ex>m</ex>e</expan>
<expan>virgi<ex>n</ex>is</expan>
<expan>cu<ex>m</ex></expan>
<expan>p<ex>ro</ex>le</expan>
<expan>p<ex>er</ex></expan>
<expan>ip<ex>s</ex>os</expan>
<expan>p<ex>rae</ex>p<ex>osi</ex>t<ex>u</ex>m</expan> et
                                <expan>mans<ex>ionarios</ex></expan> detrahi
                                <expan>poss<ex>i</ex><hi rend="sup">t</hi></expan>. Iam
                                <expan>it<ex>eru</ex>m</expan>
<expan>p<ex>ro</ex>parte</expan>
<expan>eor<ex>um</ex></expan>
<expan>d<ex>omi</ex>nor<ex>um</ex></expan> preces
                            <expan>n<ex>ost</ex>ras</expan>
<expan>attenci<ex>us</ex></expan>
<expan>dirige<ex>re</ex></expan>
<expan>duxi<ex>mus</ex></expan> ad eandem, <expan>om<ex>n</ex>i</expan>
                        studio et fervore <expan>precant<ex>is</ex></expan>
<expan>q<ex>ua</ex>t<ex>enu</ex>s</expan> de innata
                                <expan>benig<ex>nita</ex><hi rend="sup">te</hi></expan>
<expan>g<ex>e</ex>n<ex>er</ex>ositat<ex>is</ex></expan>
<expan>v<ex>est</ex>re</expan> necnon <expan>p<ex>rae</ex>cipue</expan> zelo
                        cultus divini <expan>atq<ex>ue</ex></expan>
<expan>n<ex>ost</ex>ror<ex>um</ex></expan>
<expan>obsequior<ex>um</ex></expan> intuitu eadem debita
                                <expan>p<ex>rae</ex>tactis</expan>
<expan>d<ex>omi</ex>nis</expan>
<expan>p<ex>rae</ex>p<ex>osito</ex></expan> et
                            <expan>mans<ex>ionaris</ex></expan>
<expan>absq<ex>ue</ex></expan> ulteriori
                                <expan>p<ex>ro</ex>rogac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>real<ex>ite</ex>r</expan> expedire et
                            <expan>b<ex>e</ex>nivole</expan>
<expan>p<ex>er</ex>solve<ex>re</ex></expan> velitis ac
                            <expan>ip<ex>s</ex>os</expan> favore <expan>p<ex>ro</ex>sequi</expan>
<expan>grac<ex>i</ex>oso</expan>. Ineo ut <add><expan>no<ex>n</ex></expan>
<expan>ambigim<ex>us</ex></expan></add>
<expan>salute<ex>m</ex></expan> et honorem
                                <expan>a<ex>n</ex>i<expan>ma</expan>e</expan> tam eximii
                                <expan>fundator<ex>is</ex></expan> aule
                            <expan>p<ex>rae</ex>scripte</expan>
<expan>p<ex>ro</ex>movebit<ex>is</ex></expan> nobis
                            <expan>quoq<ex>ue</ex></expan>
<expan>b<ex>e</ex>nivolen<ex>ter</ex></expan> valde
                            <expan>grata<ex>m</ex></expan>
<expan>facient<ex>is</ex></expan>
<add><expan>p<ex>ro</ex></expan>
<expan>ead<ex>em</ex></expan>
                                    g<expan><ex>e</ex>n<ex>er</ex>os<ex>ita</ex><hi rend="sup">te</hi></expan>
<expan>v<ex>est</ex>ra</expan> sollicite</add>
<expan>recolend<ex>am</ex></expan>. <expan>Dat<ex>um</ex></expan> die
                            viii<hi rend="sup">no</hi> may anno etc. xix<hi rend="sup">no</hi>.</ab>
</div>
