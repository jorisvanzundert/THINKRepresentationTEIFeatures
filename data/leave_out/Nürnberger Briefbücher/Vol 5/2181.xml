<add><ab facs="#facs_52_r1l10">Jr oder <expan>dhein<ex>er</ex></expan> der ewrn </ab></add> cʒu <expan>demſelb<ex>e</ex>n</expan> <expan>Armman<ex>n</ex></expan> icht </ab>
<ab facs="#facs_52_r1l12"><expan>cʒeſprech<ex>e</ex>n</expan> / darümb <expan>wölle<ex>n</ex></expan> euch dy <expan>eg<ex>enanten</ex></expan> ~ <expan>vnſ<ex>e</ex>r</expan> <expan>Burge<ex>r</ex></expan> </ab>
<ab facs="#facs_52_r1l13">von <expan>de<ex>m</ex>ſelb<ex>e</ex>n</expan> <expan>Jre<ex>m</ex></expan> <expan>Armman<ex>n</ex></expan> <expan>vnu<ex>er</ex>cʒog<ex>en</ex></expan> ſleunigs <expan>rehte<ex>n</ex></expan> <expan>g<ex>er</ex>n</expan> </ab>
<ab facs="#facs_52_r1l14"><expan>helffe<ex>n</ex></expan> vvenn ſie des ermant <expan>werde<ex>n</ex></expan> . vnd lat vns des <expan>ew<ex>r</ex></expan> </ab>
