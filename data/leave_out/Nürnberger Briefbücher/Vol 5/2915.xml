<ab facs="#facs_448_r1l17">habe vnd kauffmanſchaft wegen . ſo Jr 
<add><ab facs="#facs_448_r1l16"><expan>vnſ<ex>er</ex>n</expan> <expan>Burg<ex>er</ex>n</expan> </ab></add> fricʒen <expan>Schoſʒharte<ex>n</ex></expan> </ab>
<ab facs="#facs_448_r1l18"><expan>Elſpete<ex>n</ex></expan> <expan>ſein<ex>er</ex></expan> <expan>wirtin<ex>n</ex></expan> . <expan>heincʒe<ex>n</ex></expan> herbſt vnd <expan>Gerhawſe<ex>n</ex></expan> <expan>ſeın<ex>er</ex></expan> </ab>
<ab facs="#facs_448_r1l19">wirtin aufgehalten habt / 
<del rend="strikethrough">Nu </del>
<add><ab facs="#facs_448_line_1577284445386_8585">Alſo </ab></add> ſind die <expan>egen<ex>anten</ex></expan> <expan>vnſ<ex>er</ex>r</expan> <expan>burge<ex>r</ex></expan> </ab>
