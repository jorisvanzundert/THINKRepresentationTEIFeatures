<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan> Peter, wir <expan>hab<ex>e</ex>n</expan> dir
                                <expan>am<ex>m</ex></expan>
<app>
<note><q type="date"><expan>nehstv<ex>er</ex>gang<ex>en</ex></expan>
                                freitag</q>18.10.1420</note>
</app>
<expan>ein<ex>en</ex></expan>
<expan>botte<ex>n</ex></expan> und etwievil sache brief und
                                <expan>abschr<ex>ift</ex></expan> gesant und
                                <expan>verschr<ex>iben</ex></expan>,
                                <add><expan>sunderl<ex>ich</ex></expan></add> wie uns der Lang
                                <expan>Eberh<ex>art</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>r<ex>ömischen</ex></expan>
<expan>k<ex>ünigs</ex></expan> gewerb und brief an
                            <expan>uns<ex>er</ex>n</expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Wirczb<ex>ur</ex>g</expan> zu
                        versteen <add>gab</add> und wie wir darnach <expan>v<ex>er</ex>nomen</expan>
<expan>hett<ex>en</ex></expan>, daz <expan>uns<ex>er</ex></expan> fraw die
                        marggrefin von der juden <expan>weg<ex>en</ex></expan>
<expan>botsch<ex>aft</ex></expan> zu <expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> dem künig getan hett. Also hat uns
                                <expan>dies<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan> fraw die <expan>marggr<ex>efin</ex></expan>
                        von der juden <expan>weg<ex>en</ex></expan> bey uns seid
                                <expan>verschr<ex>iben</ex></expan> und wir iren
                                <expan>gnad<ex>en</ex></expan>
<expan>geantw<ex>ur</ex>t</expan>, als du an den
                            <expan>abschrifte<ex>n</ex></expan> hiebey wol
                            <expan>v<ex>er</ex>nemen</expan> wirst. <expan>It<ex>em</ex></expan> wir
                                <expan>schikt<ex>en</ex></expan> dir auch
                            <expan>ein<ex>en</ex></expan>
<expan>br<ex>ief</ex></expan> von <expan>h<ex>er</ex>r</expan>
<expan>Pet<ex>er</ex>n</expan> Waker an <expan>h<ex>e</ex>r</expan> Micheln
                        von Priest, daran er im den handel von der juden
                            <expan>weg<ex>en</ex></expan> bey uns als von imselbs schraib an
                                <expan>uns<ex>er</ex>n</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> künig zu <expan>bring<ex>en</ex></expan>
                        etc., <expan>ders<ex>elb</ex></expan> brief wir dir noch
                                <expan>eine<ex>n</ex></expan> hie mit
                        <expan>send<ex>en</ex></expan>, ob der <expan>vord<ex>er</ex></expan>
<expan>dernid<ex>er</ex></expan>
<expan>geleg<ex>en</ex></expan>
<expan>w<ex>er</ex>e</expan>, daz du den denn
                            <expan>antw<ex>ur</ex>test</expan>; ist <expan>ab<ex>er</ex></expan> der
                                <expan>vord<ex>er</ex></expan>
<expan>geantw<ex>ur</ex>t</expan>, so verhalt den.
                            <expan>It<ex>em</ex></expan> wir <expan>schikt<ex>en</ex></expan> dir
                        auch <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Öting<ex>en</ex></expan>, des
                                <expan>hofmeist<ex>er</ex>s</expan>,
                            <expan>v<ex>er</ex>sigelt</expan>
<expan>br<ex>ief</ex></expan> an <expan>uns<ex>er</ex>n</expan>
<expan>gnedig<ex>en</ex></expan>
<pb facs="#facs_196" id="97r"/>
<expan>h<ex>er</ex>ren</expan> den kunig und an die
                            <expan>canczl<ex>er</ex></expan> und dabey ein
                            <expan>abschr<ex>ift</ex></expan> seins <expan>br<ex>iefs</ex></expan>,
                        wie er <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>k<ex>ünig</ex></expan> schreibt. <expan>It<ex>em</ex></expan> wir
                                <expan>verschr<ex>iben</ex></expan> dir auch, wie uns nach deinr
                        auszfart von <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Wirczb<ex>ur</ex>g</expan>
<expan>weg<ex>en</ex></expan> ein fürpott <expan>kome<ex>n</ex></expan>, was
                        des wir dir ein <expan>abschr<ex>ift</ex></expan>
<expan>schikte<ex>n</ex></expan> und wie wir <expan>daru<ex>m</ex>b</expan>
<expan>uns<ex>er</ex></expan>
<expan>erb<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> zu <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>schike<ex>n</ex></expan>
<expan>wölte<ex>n</ex></expan>, <add>ob es betlich abgeen möcht</add> etc.
                        Also tun wir dir zu <expan>wiss<ex>en</ex></expan>, daz
                                <expan>dies<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan>
<expan>wid<ex>er</ex></expan>
<expan>kome<ex>n</ex></expan> ist und uns gesagt hat, daz
                                <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> von <expan>Wirczb<ex>ur</ex>g</expan>
<expan>unt<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan>
<expan>worte<ex>n</ex></expan> melde, wie wir im vil
                            <expan>hindru<ex>n</ex>g</expan> tuen, doch auf das lecz hat er das
                                <expan>vorg<ex>enante</ex></expan> fürpott auf disz zeit abgetan und
                                <expan>fall<ex>e</ex>n</expan> lassen und imselb dabey
                                <expan>behalte<ex>n</ex></expan>, werd im
                                <expan>hiezwisch<ex>en</ex></expan>
<app>
<note><q type="date"><expan>weyhenn<ex>achten</ex></expan></q>25.12.1420</note>
</app> niht <expan>frewntlich<ex>er</ex></expan>
<expan>antw<ex>ur</ex>t</expan> von uns, so mug er söliche fürpott
                                <expan>wid<ex>er</ex></expan> anfahen etc.
                            <expan>Daru<ex>m</ex>b</expan> so lass dir die sachen befolhen sein als
                        wir dir <expan>getrawe<ex>n</ex></expan>, <expan>besund<ex>er</ex></expan>
<expan>w<ex>er</ex>e</expan>
<expan>uns<ex>er</ex></expan>
<expan>meynu<ex>n</ex>g</expan>, daz du <expan>v<ex>er</ex>suchst</expan>,
                        ob du von <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>k<ex>ünig</ex></expan> in dem <expan>beste<ex>n</ex></expan> form
                        brief <expan>erlange<ex>n</ex></expan>
<add>mugst</add>, daz wir von <expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Wirczb<ex>ur</ex>g</expan> sprüch
                        und <expan>anvordru<ex>n</ex>g</expan> von der sache
                            <expan>weg<ex>en</ex></expan> mit gericht <expan>od<ex>er</ex></expan>
                        on gericht fürbas <expan>v<ex>er</ex>tragen</expan>
<expan>möchte<ex>n</ex></expan> sein, als wir uns gancz
                            <expan>v<ex>er</ex>sehen</expan>, daz du in den und
                                <expan>and<ex>er</ex>n</expan> sachen <expan>g<ex>er</ex>n</expan>
                        das best tust. <expan>Dat<ex>um</ex></expan>
<expan>s<ex>ub</ex>sigillo</expan> Sebaldi Pfinczing
                                <expan>m<ex>a</ex>g<ex>ist</ex>ri</expan>
<expan>civiu<ex>m</ex></expan>
<expan>f<ex>er</ex>ia</expan> v<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>Symo<ex>n</ex>is</expan> et Jude.</ab>
