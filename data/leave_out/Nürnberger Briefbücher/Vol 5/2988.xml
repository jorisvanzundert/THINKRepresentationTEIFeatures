<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> und <expan>gebette<ex>n</ex></expan>
                        habt, <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> bey Conrad
                            <expan>Poschendorff<ex>er</ex></expan>, <expan>ew<ex>r</ex>m</expan>
<expan>b<ex>urger</ex></expan>, von den lewffen, als
                            <expan>uns<ex>er</ex></expan> aller <expan>gnedigist<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> der römisch etc. künig und auch
                                <expan>and<ex>er</ex></expan>
<expan>h<ex>e</ex>rschaft</expan>
<expan>yecz<ex>unden</ex></expan> bey uns <expan>besam<ex>m</ex>et</expan>
                        seyn, etwas zu <expan>v<ex>er</ex>schreiben</expan> und
                                <expan>wiss<ex>en</ex></expan> zu lassen etc., das
                                <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu hat der
                            <expan>vorg<ex>enante</ex></expan> ewr <expan>b<ex>urger</ex></expan>
                        die lewffe und <expan>gelegenh<ex>eit</ex></expan> die zeit und er bey uns
                                <expan>gewes<ex>en</ex></expan> ist zu <expan>gut<ex>er</ex></expan>
                        mass wol gesehen <add>und gehöret</add>, so seyn die
                                <expan>vorgen<ex>anten</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>gnedigist<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> der römisch künig und
                            <expan>and<ex>er</ex></expan>
<expan>h<ex>e</ex>rschaft</expan> noch bey uns
                            <expan>besam<ex>m</ex>et</expan> und wir <expan>habe<ex>n</ex></expan>
<expan>uns<ex>er</ex>s</expan> teils noch niht
                                <expan>v<ex>er</ex>nom<ex>m</ex>en</expan>
<expan>entlich<ex>er</ex></expan> dink, die
                            <expan>besloss<ex>en</ex></expan> seyn, <expan>davo<ex>n</ex></expan>
                        wir <expan>ewr<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan>
<expan>wiss<ex>en</ex></expan> zu <expan>schreibe<ex>n</ex></expan>. Denn wo
                        wir <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan>
<expan>an<ex>te</ex></expan> Lorencii.</ab>
