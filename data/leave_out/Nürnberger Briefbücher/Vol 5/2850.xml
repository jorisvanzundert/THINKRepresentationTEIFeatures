<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ewr und
                                                  <expan>etlich<ex>er</ex></expan>
<expan>and<ex>er</ex>r</expan> stette,
                                                  <expan>uns<ex>er</ex>r</expan> guten frewnde,
                                                  <expan>erb<ex>er</ex>n</expan> botten nehst bey
                                                uns gewesen seyn und sich mitsampt
                                                  <expan>uns<ex>er</ex>n</expan>
<expan>frewnd<ex>en</ex></expan> von den sachen,
                                                  <expan>daru<ex>m</ex>b</expan> wir ewr
                                                  <expan>weish<ex>eit</ex></expan> desmals
                                                  <expan>v<ex>er</ex>bottschaft</expan>
<expan>hette<ex>n</ex></expan>, und auch von
                                                  <expan>and<ex>er</ex>r</expan> notdurft
                                                  <expan>unt<ex>er</ex>redt</expan> haben, als ir
                                                von <expan>ders<ex>elben</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan>
<add>nu</add> wol <expan>v<ex>er</ex>nomen</expan>
                                                habt, also <expan>bitt<ex>en</ex></expan> wir ewr
                                                  <expan>frewntsch<ex>aft</ex></expan>, daz ir ewr
                                                  <expan>erb<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> mit
                                                  <expan>volle<ex>m</ex></expan> gwalt
                                                  <expan>ewr<ex>er</ex></expan>
<expan>meynu<ex>n</ex>g</expan>
<add><expan>daru<ex>m</ex>b</expan></add>
