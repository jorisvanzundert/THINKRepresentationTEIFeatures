<del rend="strikethrough"> etc Alſo </del></ab>
<ab facs="#facs_154_r1l28">
<del rend="strikethrough"><expan>hab<ex>e</ex>n</expan> wır <expan>demſ<ex>elben</ex></expan> <expan>vom<ex>m</ex></expan> Eglo </del> <expan>botſch<ex>aft</ex></expan> getan <expan>hab<ex>e</ex>n</expan> etc / Alſo <expan>laſſ<ex>en</ex></expan> </ab>
