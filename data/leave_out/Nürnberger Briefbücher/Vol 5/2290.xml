<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von Leo,
                            <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>jude<ex>n</ex></expan>
<expan>weg<ex>en</ex></expan>, <expan>daru<ex>m</ex>b</expan> uns
                                <expan>Pet<ex>er</ex></expan>
<expan>Stetemberg<ex>er</ex></expan>, <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>amptm<ex>an</ex></expan> zu Lawden, vormals auch
                                <expan>geschr<ex>iben</ex></expan> hab etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu haben wir dem
                                <expan>vorgen<ex>anten</ex></expan>
<expan>Pet<ex>er</ex></expan>
<expan>Stetemberg<ex>er</ex></expan> vormals <expan>daru<ex>m</ex>b</expan>
<expan>geantw<ex>ur</ex>tt</expan> und dem Leo jud rechts bey uns zu
                                <expan>helffe<ex>n</ex></expan>
<expan>gebotte<ex>n</ex></expan>, als wir gefreyet und
                                <expan>herkome<ex>n</ex></expan> sein, dem auch die
                                <expan>jüdisch<ex>eit</ex></expan> bey uns noch
                                <expan>meyne<ex>n</ex></expan> nach <expan>zukome<ex>n</ex></expan>.
                        Wie <expan>daru<ex>m</ex>b</expan> so <expan>hab<ex>e</ex>n</expan> wir
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> zulieb den judenrat bey uns besant und
                        auf <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> schrift <expan>ernstl<ex>ich</ex></expan> zu
                        rede gesaczt, die <expan>hab<ex>e</ex>n</expan> uns
                            <expan>geantw<ex>ur</ex>tt</expan>, daz sie der
                            <expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan>
<expan>wed<ex>er</ex></expan> von <expan>uns<ex>er</ex>s</expan> noch
                        irselbs gewalts wegen kein hab <expan>abgenome<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>; denn was die
                            <expan>jüdisch<ex>eit</ex></expan> bey uns <expan>gemeinclich</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>römische<ex>n</ex></expan>
<expan>künig<ex>en</ex></expan>
<expan>od<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan>, den es gebürt, hab an
                                <expan>gemeine<ex>n</ex></expan>
<expan>stewre<ex>n</ex></expan> oder sust ye zu
                            <expan>zeite<ex>n</ex></expan> pflichtig <expan>gewes<ex>en</ex></expan>
                        sein <expan>od<ex>er</ex></expan>
<expan>gebe<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>, da sey <expan>dies<ex>elb</ex></expan>
<expan>Secklin<ex>n</ex></expan> umb ir anczal allweg nach
                                <expan>gleiche<ex>n</ex></expan>
<expan>pilliche<ex>n</ex></expan>
<expan>dinge<ex>n</ex></expan> und nach <expan>ir<ex>er</ex></expan>
