<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                                                  <expan>hoch<ex>wirdikeit</ex></expan> von Nikel
                                                Erharts <expan>weg<ex>en</ex></expan> nehst
                                                  ver<expan>schribe<ex>n</ex></expan> und wir
                                                darnach <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>
<expan>Burkart<ex>en</ex></expan> Reikarczhofer zu
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<add><expan>daru<ex>m</ex>b</expan></add> gesandt
                                                  <expan>hette<ex>n</ex></expan>,
                                                  <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan>, als ewr
                                                  <expan>furstenl<ex>ich</ex></expan> gnade die zeit
                                                  <expan>ynn<ex>er</ex></expan> lands niht was, bey
                                                  <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>stathalt<ex>er</ex></expan>
<expan>gewese<ex>n</ex></expan> ist. Also
                                                  <expan>sende<ex>n</ex></expan> wir
                                                  <expan>dens<ex>elben</ex></expan>
<expan>Reikarczhof<ex>er</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>
<expan>wid<ex>er</ex></expan> zu
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>, <add>dem wir
                                                  aber</add>
<expan>befolhe<ex>n</ex></expan>
<add><expan>hab<ex>e</ex>n</expan></add>, mit
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>davo<ex>n</ex></expan> zu reden. Und
                                                  <expan>bitt<ex>en</ex></expan> ewr
                                                  <expan>fürstenl<ex>ich</ex></expan> gnade mit
                                                fleiss, was <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> in
                                                  <expan>ders<ex>elben</ex></expan> sache zu disem
                                                mal von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr gnade
                                                  <expan>w<ex>er</ex>be</expan>, daz ir in darinn
                                                gnediklich <expan>v<ex>er</ex>hören</expan>, im des
                                                  <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und
                                                  <expan>günstikl<ex>ich</ex></expan> von
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>fertig<ex>en</ex></expan> wellet. Als wir
                                                  <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> etc. Das
                                                  <expan>well<ex>e</ex>n</expan> etc.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Bartholomei.</ab>
</div>
