<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat, wie Rüdel Eckstein von Fewcht
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> fürbracht hab, daz in
                            <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> der jung <expan cert="unknown">H<ex>einrich</ex></expan> Hutt <expan>etlich<ex>er</ex></expan>
<expan>unglimpflich<ex>er</ex></expan> sach beschuldige etc., das
                                <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu <expan>habe<ex>n</ex></expan> wir
                                <expan>dens<ex>elben</ex></expan> Eckstein und auch
                                <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> den <expan>Hutte<ex>n</ex></expan> gen
                                ein<expan>and<ex>er</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>v<ex>er</ex>höret</expan> und <expan>bitt<ex>en</ex></expan> ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade mit fleiss, uns
                                <expan>dies<ex>elb</ex></expan> sache zu befelhen. So
                                <expan>welle<ex>n</ex></expan> wir das
                            <expan>entrichte<ex>n</ex></expan> nach dem als uns dunkt, daz es
                        gehandelt sey, und <expan>getrawe<ex>n</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> wol, daz ir uns des niht
                            <expan>v<ex>er</ex>czeihet</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> dienst und wolgefallen etc. Und lat
                        uns <expan>daru<ex>m</ex>b</expan> ewr gnedig
                            <expan>verschr<ex>iben</ex></expan>
<expan>antw<ex>ur</ex>t</expan>
<expan>wid<ex>er</ex></expan>
<expan>wiss<ex>en</ex></expan> bey dem botten. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Mathei <expan>app<ex>osto</ex>li</expan>.</ab>
