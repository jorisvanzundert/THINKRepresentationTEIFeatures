<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Amptm<ex>an</ex></expan>, als ir uns
                                                  <expan>verschr<ex>iben</ex></expan> habt, wie Leo
                                                jud, der <expan>uns<ex>er</ex>s</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan> Otten jud sey,
                                                spreche, daz das hawse, da die
                                                  <expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan> bey uns wonhaft
                                                innensicze und die hab, die sie
                                                  <expan>unt<ex>er</ex>handen</expan> hab, sein sey
                                                mit <expan>and<ex>er</ex>n</expan>
<expan>seine<ex>n</ex></expan>
                                                  mit<expan>erbe<ex>n</ex></expan> die darczu gehörn
                                                etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                                                  <expan>vernom<ex>en</ex></expan> und ist uns
                                                  <expan>davo<ex>n</ex></expan> niht
                                                  <expan>wissenlich<ex>e</ex>n</expan>. Und als ir
                                                uns fürbas schreibt, wie
                                                  <expan>ders<ex>elb</ex></expan> Leo jud klag, daz
                                                  <expan>ders<ex>elb</ex></expan>
<expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan> sölich hab entwert
                                                sey <expan>word<ex>en</ex></expan>, daz ir die
                                                  <expan>jude<ex>n</ex></expan> bey uns
                                                  <expan>gesess<ex>en</ex></expan>
<expan>abgenome<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>,
                                                  <expan>daru<ex>m</ex>b</expan>
<expan>hab<ex>e</ex>n</expan> wir die
                                                  <expan>Secklin<ex>n</ex></expan>
<expan>jüdin<ex>n</ex></expan>
<expan>v<ex>er</ex>höret</expan> die spricht, daz ir
                                                die <expan>jude<ex>n</ex></expan> bey uns
                                                  <expan>gesess<ex>en</ex></expan> kein hab entwert
                                                  <expan>hab<ex>e</ex>n</expan>. So
                                                  <expan>hab<ex>e</ex>n</expan> wir die
                                                  <expan>jüdisch<ex>eit</ex></expan> bey uns
                                                  <expan>daru<ex>m</ex>b</expan> auch
                                                  <expan>ernstl<ex>ich</ex></expan> zu red gesaczt;
                                                die <expan>spreche<ex>n</ex></expan>, daz sie
                                                  <expan>ders<ex>elben</ex></expan>
<expan>Secklin<ex>n</ex></expan> kein hab entwert
                                                noch <expan>abgenome<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>. Wie
                                                  <expan>daru<ex>m</ex>b</expan> dewht den
                                                  <expan>vorg<ex>enanten</ex></expan> Leo juden, daz
                                                er <expan>darüb<ex>er</ex></expan> zu dem
                                                  <expan>egen<ex>anten</ex></expan> hawse und hab
                                                  <expan>od<ex>er</ex></expan> zu
                                                  <expan>yema<ex>n</ex>t</expan> bey uns, des wir
                                                mechtig sein, ichts <expan>zu
                                                  spreche<ex>n</ex></expan> hett, so
                                                  <expan>well<ex>e</ex>n</expan> wir im
                                                  <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit
                                                  <expan>seine<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt von
                                                  <expan>uns<ex>er</ex>s</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan> Otten und
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>weg<ex>en</ex></expan>
<expan>frewntl<ex>ich</ex></expan> slewnigs
                                                  <expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor
                                                  <expan>uns<ex>er</ex>m</expan> rate
                                                  <expan>od<ex>er</ex></expan> vor des reichs
                                                gericht bey uns <expan>od<ex>er</ex></expan> vor dem
                                                judenrate bey uns
                                                  <expan>ungev<ex>er</ex>lichen</expan>. Denn wo wir
                                                dem <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>,
                                                  <expan>h<ex>er</ex>czog</expan> Otten,
                                                  <expan>gediene<ex>n</ex></expan> und
                                                  <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb
                                                  <expan>od<ex>er</ex></expan> dienst etc.
                                                  <expan>Dat<ex>um</ex></expan> ut
                                                  <expan>s<ex>upra</ex></expan>.</ab>
</div>
</div></body>
