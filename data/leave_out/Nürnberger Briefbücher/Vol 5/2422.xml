                            <expan>dems<ex>elben</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>b<ex>urger</ex></expan>
<expan>dieselb<ex>e</ex>n</expan> seine schafe
                            <expan>widergeb<ex>e</ex>n</expan> und on hindernüsse
                                <expan>volge<ex>n</ex></expan> lassen wöllet
                            <expan>d<ex>ur</ex>h</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan>. Als etc. Das <expan>wölle<ex>n</ex></expan>
