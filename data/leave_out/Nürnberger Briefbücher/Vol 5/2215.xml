<div type="addressee"><ab facs="#facs_68_r1l4">Hercʒog <expan>Johannſ<ex>en</ex></expan> </ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab facs="#facs_68_r1l5"><expan>Gnedıg<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> . als vns / eẅr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>yecʒ<ex>unden</ex></expan>
<expan>ab<ex>er</ex></expan>
<expan>verſchr<ex>iben</ex></expan> hat von <expan>vnſ<ex>er</ex>s</expan>
<expan>gnedıge<ex>n</ex></expan>
</ab>
<ab facs="#facs_68_r1l6"><expan>h<ex>er</ex>ren</expan> Burggraf
