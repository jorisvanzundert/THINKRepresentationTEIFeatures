                                <expan>egen<ex>anten</ex></expan>
<expan>uns<ex>er</ex>n</expan> burger von sölcher klag und
                                <expan>ladu<ex>n</ex>g</expan> czu wysen, so wolt
                                <expan>ew<ex>r</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>de<ex>m</ex></expan>
<expan>egen<ex>anten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>burg<ex>er</ex></expan> von <expan>demselb<ex>e</ex>n</expan>
<expan>Swarczemberg<ex>er</ex></expan> des rehten vor
                            <expan>ewre<ex>m</ex></expan> rete <expan>schicke<ex>n</ex></expan>
