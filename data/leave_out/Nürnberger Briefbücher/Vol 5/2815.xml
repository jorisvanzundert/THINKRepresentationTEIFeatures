<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>ab<ex>er</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von <expan>Hanns<ex>en</ex></expan>
<expan>vom<ex>m</ex></expan> Eglofstein <expan>weg<ex>en</ex></expan> zu
                                <expan>Mülhaws<ex>en</ex></expan> und <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan> Peters Ryeters etc., das haben wir wol
                                <expan>vernom<ex>en</ex></expan> und haben
                            <expan>dens<ex>elben</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan>
<expan>Pet<ex>er</ex></expan> Ryeter <expan>ew<ex>r</ex></expan>
<expan>gnad<ex>en</ex></expan> brief hören <expan>lass<ex>en</ex></expan>,
                        so steet sein antwurt und des <expan>vorg<ex>enanten</ex></expan>
<expan>Hanns<ex>en</ex></expan>
<expan>vom<ex>m</ex></expan> Eglofstein rede gar ungeleich. Wie
                                <expan>daru<ex>m</ex>b</expan> so <expan>habe<ex>n</ex></expan> wir
                        doch <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> zu eren mit dem
                            <expan>obgen<ex>anten</ex></expan>
<expan>Pet<ex>er</ex></expan>
<expan>Ryet<ex>er</ex></expan>
<expan>sov<ex>er</ex>ren</expan> geredt, daz er uns
                            <expan>geantw<ex>ur</ex>tt</expan> hat, daz der
                                <expan>eg<ex>ena</ex>nt<ex>e</ex></expan> Hanns
                            <expan>vom<ex>m</ex></expan> Eglofstein vor im sicher sein sol uncz
                                <expan>ders<ex>elb</ex></expan> Ryeter
                            <expan>selb<ex>er</ex></expan> oder <expan>ab<ex>er</ex></expan> sein
                                <expan>botsch<ex>aft</ex></expan> zu <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>kome<ex>n</ex></expan>
<expan>ungev<ex>er</ex>lichen</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und wolgefallen etc.
                                <expan>Dat<ex>um</ex></expan> ut <expan>s<ex>upra</ex></expan>.</ab>
