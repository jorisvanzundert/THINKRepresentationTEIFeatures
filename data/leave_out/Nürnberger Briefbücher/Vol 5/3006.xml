<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>Conr<ex>ad</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt von der ladung
                                <expan>weg<ex>en</ex></expan>, die <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> der <expan>Pering<ex>er</ex></expan> etlichen
                                <expan>b<ex>urgern</ex></expan> zu Wemding auf das
                                <expan>lantger<ex>icht</ex></expan> gen
                            <expan>Nür<ex>emberg</ex></expan> getan hat etc., das
                                <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>habe<ex>n</ex></expan> umb
                                <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>dens<ex>elben</ex></expan>
<expan>Pering<ex>er</ex></expan> für uns besandt und
                            <expan>sov<ex>er</ex>ren</expan> mit im <expan>davo<ex>n</ex></expan>
                        geredt, daz er uns <expan>geantw<ex>ur</ex>tt</expan> und zugesagt hat,
                        sölich <expan>ladu<ex>n</ex>g</expan> und klag gen den
                                <expan>vorg<ex>enante</ex>n</expan>
<expan>b<ex>urger</ex></expan>
<add>zu Wemding</add> abczutun und fallen <expan>zu lass<ex>en</ex></expan>.
                        Nu hat <add>er</add> uns dabey gesagt wie desmals, als er zu Wemding
                                <expan>w<ex>er</ex>e</expan>, ein <expan>genan<ex>n</ex>te</expan>
<expan>sume<ex>n</ex></expan> gelts <expan>v<ex>er</ex>schaiden</expan>
                        wurd, die im etlich <expan>b<ex>urger</ex></expan> zu Wemding zu zilen
                                <expan>gebe<ex>n</ex></expan>
<expan>sölte<ex>n</ex></expan>, als ewr <expan>erberk<ex>eit</ex></expan>
                        das auch wol <expan>wissenl<ex>ich</ex></expan> süll seyn, der sie im seid
                        niht beczalt noch geben <expan>habe<ex>n</ex></expan>, als er spricht,
                                <expan>bitt<ex>en</ex></expan> wir ewch mit fleiss,
                                <expan>dies<ex>elben</ex></expan>
<expan>b<ex>urger</ex></expan> zu Wemding zu
                                <expan>unt<ex>er</ex>weis<ex>en</ex></expan>, den
                                <expan>obg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> zu beczaln <add>und</add> unklaghaft
                                <expan>daru<ex>m</ex>b</expan> zu machen, möcht des niht gesein, daz
                        ir im denn <expan>frewntl<ex>ich</ex></expan> slewnigs
                                <expan>rechte<ex>n</ex></expan> von
                            <expan>denselbe<ex>n</ex></expan> helffet. Hett den keinr der
                                <expan>vorg<ex>enanten</ex></expan>
<expan>b<ex>urger</ex></expan> zu Wemding zu <add>im</add> icht
                                <expan>zuspreche<ex>n</ex></expan> den <expan>od<ex>er</ex></expan>
                        iren <expan>scheinbott<ex>en</ex></expan> mit <expan>ire<ex>m</ex></expan>
<expan>volle<ex>n</ex></expan> gwalt <expan>welle<ex>n</ex></expan> wir
                                <expan>frewntl<ex>ich</ex></expan> slewnigs
                            <expan>rechte<ex>n</ex></expan> auch <expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> bey uns anheim ist, on
                            <expan>gev<ex>er</ex>de</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb oder dienst etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan>
<expan>p<ex>ost</ex></expan>
<expan>nati<ex>vi</ex>tat<ex>is</ex></expan> Marie
                            <expan>virg<ex>in</ex>is</expan>.</ab>
</div>
</div></body>
