<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als wir etlich <expan>uns<ex>er</ex></expan>
                        frewnd und <expan>ratgesell<ex>e</ex>n</expan> nehst bey uns und seid zu
                        Flohberg <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>unt<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan>
<expan>ding<ex>en</ex></expan> erczeln und
                            <expan>fürbring<ex>en</ex></expan>
<expan>hab<ex>e</ex>n</expan>
<expan>lass<ex>en</ex></expan> der <expan>uns<ex>er</ex>n</expan> notdurft
                        von der Venedyer fart <expan>weg<ex>en</ex></expan>, die die
                                <expan>uns<ex>er</ex>n</expan> und etlich
                            <expan>and<ex>er</ex></expan> stette von <expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>römische<ex>n</ex></expan> etc.
                        künigs gebotts und geheiss <expan>weg<ex>en</ex></expan> langczeit her
                        gemyden <expan>hab<ex>e</ex>n</expan> und meiden, daz doch
                                <expan>unausztregenlich<ex>e</ex>n</expan> ist, wan
                                <expan>dies<ex>elb</ex></expan> strasse von
                            <expan>and<ex>er</ex>n</expan> dadurch niht
                            <expan>v<ex>er</ex>myden</expan> und dennoch
                            <expan>gepawe<ex>n</ex></expan> wirdt und allein die
                                <expan>uns<ex>er</ex>n</expan> und die, die
                                <expan>dems<ex>elben</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> dem künig in den
                            <expan>sache<ex>n</ex></expan> gehorsam sein, zu
                                <expan>merkliche<ex>n</ex></expan>
<expan>schede<ex>n</ex></expan>
<expan>kome<ex>n</ex></expan>, und <expan>and<ex>er</ex></expan> ungehorsam
                                <expan>dazwische<ex>n</ex></expan> iren nucz
                            <expan>schik<ex>en</ex></expan>, als das ewr gnade wol
                                <expan>v<ex>er</ex>steen</expan> und on uns auch
                            <expan>v<ex>er</ex>nomen</expan> mag <expan>hab<ex>e</ex>n</expan>,
                        sölich unser <expan>gew<ex>er</ex>be</expan> ewr gnade
                                <expan>günstikl<ex>ich</ex></expan>
<expan>aufgenom<ex>en</ex></expan> und sich
                            <expan>gnedikl<ex>ich</ex></expan> darczu
                            <expan>erbotte<ex>n</ex></expan> hat, des wir
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> mit <expan>gancze<ex>m</ex></expan> fleisz
                                <expan>danke<ex>n</ex></expan>. Und <expan>dies<ex>elb</ex></expan>
                        ewr gnade <expan>dienstliche<ex>n</ex></expan>
<expan>bitte<ex>n</ex></expan>, daz ir umb <expan>uns<ex>er</ex>r</expan>
<expan>willig<ex>en</ex></expan> dienst <expan>will<ex>e</ex>n</expan> den
                                <expan>vorg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>gnedigist<ex>en</ex></expan>
