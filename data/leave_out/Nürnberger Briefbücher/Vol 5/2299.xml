<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>amptm<ex>an</ex></expan>, als ir uns aber
                            <expan>verschr<ex>iben</ex></expan>
<add>habt</add> von Selen der <expan>Toppl<ex>er</ex>in</expan>
<expan>weg<ex>en</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan> wir
                        wol <expan>vernom<ex>en</ex></expan>. Nu <expan>hab<ex>e</ex>n</expan> wir
                        ewch, do ir uns nehst von iren <expan>weg<ex>en</ex></expan>
<expan>v<ex>er</ex>schrybt</expan>, <expan>geantw<ex>ur</ex>tt</expan>, daz
                        wir etlich unser <expan>b<ex>urger</ex></expan>, die das antreff,
                                <expan>daru<ex>m</ex>b</expan> zu red gesaczt und sie uns
                                <expan>geantw<ex>ur</ex>tt</expan>
<expan>hett<ex>en</ex></expan> auf sölich <expan>meynu<ex>n</ex>g</expan>,
                        daz sie niht <expan>weste<ex>n</ex></expan>, daz sie der
                                <expan>vorg<ex>enanten</ex></expan> Selen
                            <expan>Topllerin<ex>n</ex></expan> ichtes schuldig
                            <expan>w<ex>er</ex>en</expan>, <add>und wie</add> wir ir
                                <expan>od<ex>er</ex></expan> irem
                            <expan>scheinbott<ex>en</ex></expan> mit <expan>ire<ex>m</ex></expan>
<expan>voll<ex>e</ex>n</expan> gwalt <add>von den unsern</add>
<expan>frewntl<ex>ich</ex></expan> slewnigs <expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan>
<add><expan>wölte<ex>n</ex></expan></add> vor des reichs
                                <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan> etc. Wie
                            <expan>daru<ex>m</ex>b</expan> so <expan>hab<ex>e</ex>n</expan> wir
                                <expan>Jacobe<ex>n</ex></expan>
<expan>Toppl<ex>er</ex></expan> umb <expan>ew<ex>r</ex>n</expan>
<expan>will<ex>e</ex>n</expan>
<expan>ab<ex>er</ex></expan> für uns besandt und
                            <expan>daru<ex>m</ex>b</expan> zu rede gesaczt. Der hat uns
                                <expan>ab<ex>er</ex></expan>
<expan>geantw<ex>ur</ex>tt</expan>, daz er niht wisse, daz er
                                <expan>od<ex>er</ex></expan> ander die
                            <expan>uns<ex>er</ex>n</expan> der <expan>obg<ex>enante</ex></expan>
                        Selen <expan>Toppl<ex>er</ex>in</expan> ichtes schuldig sein. Dewcht nu
                                <expan>dies<ex>elb</ex></expan>
<expan>Toppl<ex>er</ex>in</expan>, daz sie <expan>darub<ex>er</ex></expan>
                        zu dem <expan>vorg<ex>enanten</ex></expan>
<expan>Jacobe<ex>n</ex></expan>
<expan>Toppl<ex>er</ex></expan>
<expan>od<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan> den <expan>uns<ex>er</ex>n</expan> icht zu
                                <expan>spreche<ex>n</ex></expan> hett, so
                            <expan>welle<ex>n</ex></expan> wir ir <expan>od<ex>er</ex></expan> irem
                                <expan>scheinbott<ex>en</ex></expan> mit irem
                            <expan>voll<ex>e</ex>n</expan> gwalt <expan>frewntl<ex>ich</ex></expan>
                        slewnigs <expan>recht<ex>en</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nür<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>dies<ex>elben</ex></expan>
                        die <expan>uns<ex>er</ex>n</expan>, zu den sie
                            <expan>zuspreche<ex>n</ex></expan> hett, anheim sein on
                                <expan>gev<ex>er</ex>de</expan>. <expan>Getrawe<ex>n</ex></expan>
                        wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan>, ir unterweist die
                                <expan>eg<ex>e</ex>n<ex>ante</ex></expan> Selen
                                <expan>Toppl<ex>er</ex>in</expan>, daz sie daran ein
                                <expan>genüg<ex>en</ex></expan> habe, wan uns dunkt, daz wir
                            <add>ir</add> von der <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> glimpf und rechts gnug
                            <expan>piete<ex>n</ex></expan> und die <expan>uns<ex>er</ex>n</expan>
