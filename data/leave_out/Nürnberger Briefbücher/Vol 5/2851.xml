<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, uns haben etlich
                            <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> und kawfflewte
                            <expan>furbr<ex>acht</ex></expan>, wie in ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> czollner ir hab und
                        kawffmanschafft gen Landshüt hab füren lassen und sie daselbst
                                <expan>bekümb<ex>er</ex>t</expan> hab,
                            <expan>dar<ex>umb</ex></expan> wir czu <expan>ew<ex>r</ex>n</expan>
<expan>fürst<ex>enlichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>B<ex>urkhart</ex></expan>
<expan>Reickarczhof<ex>er</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, <expan>schik<ex>en</ex></expan>.
                                <expan>Ro<ex>gamus</ex></expan>, waz derselb
                            <expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> czu disemmal von der sach
                                <expan>weg<ex>en</ex></expan> an euch werbe etc. in
                                <expan>for<ex>ma</ex></expan>
<expan>cred<ex>encie</ex></expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> v<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan>
<expan>oc<ex>u</ex>li</expan>.</ab>
</div>
