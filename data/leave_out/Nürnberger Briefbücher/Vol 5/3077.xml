<body><div type="diplomatic"><pb facs="#facs_543" id="270v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee"><ab facs="#facs_543_line_1610395901661_202">frawn Elıʒabet 
<del rend="strikethrough">von <expan>vvirtemb<ex>er</ex>g</expan> etc </del></ab>
<ab facs="#facs_543_r1l2">Burggrefin 
<del rend="strikethrough">b </del> ʒu <expan>Nüremb<ex>er</ex>g</expan> vnd </ab>
<ab facs="#facs_543_r1l3"><expan>Grefin<ex>n</ex></expan> ʒu <expan>vvirtemb<ex>er</ex>g</expan> <expan>vvıtib<ex>e</ex>n</expan> </ab>
</div>
