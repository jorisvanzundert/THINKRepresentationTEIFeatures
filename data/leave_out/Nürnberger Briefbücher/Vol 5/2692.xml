<add><expan>ſc<ex>ri</ex>pt<ex>I,</ex></expan></add>
<del rend="strikethrough"><expan>Dat<ex>um</ex></expan></del> <expan>f<ex>er</ex>ıa</expan> ıııȷ<hi rend="sup">a</hi> <expan>p<ex>oſt</ex></expan> <expan>exalta<ex>ci</ex><hi rend="sup">o<ex>n</ex>ıs</hi></expan> <expan>ſ<ex>an</ex>c<ex>t</ex>e</expan> <expan>Cruc<ex>is</ex></expan> </ab>
