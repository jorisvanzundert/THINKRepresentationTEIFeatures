                                <expan>menig<ex>er</ex>m</expan> male fleissig
                                <expan>gebette<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>, die
                            <expan>vorg<ex>ena</ex>n<ex>te</ex></expan> sache
                                <expan>zwisch<ex>e</ex>n</expan>
<expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> und der <expan>jüdisch<ex>eit</ex></expan>
                        bey uns zu <expan>entschaid<ex>en</ex></expan> nach lawt
                                <expan>uns<ex>er</ex>s</expan>
<pb facs="#facs_66" id="32r"/>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des künigs brief,
