<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, wir tun <expan>ewr<ex>er</ex></expan>
<add><expan>frewnts<ex>chaft</ex></expan></add> zu
                            <expan>wiss<ex>en</ex></expan>, daz wir auf
                            <expan>Graispach<ex>er</ex></expan>
<expan>lantger<ex>iht</ex></expan>
<expan>gelade<ex>n</ex></expan> sein <expan>word<ex>en</ex></expan>, daz wir
                        uns <expan>am<ex>m</ex></expan>
<expan>lantger<ex>iht</ex></expan> auf dem Stöffenhart <app>
<note><q type="date"><expan>am<ex>m</ex></expan> ertag vor sand Kathrein tag
                                        <expan>nehstv<ex>er</ex>gang<ex>en</ex></expan></q>21.11.1419</note>
</app>
<expan>v<ex>er</ex>antwurt</expan> solten <expan>hab<ex>e</ex>n</expan>. Und
                        ist uns <expan>ders<ex>elb</ex></expan>
<expan>ladbr<ex>ief</ex></expan> erst nach der
                            <expan>vorg<ex>enanten</ex></expan> zeit
                            <expan>geantw<ex>ur</ex>tt</expan>
<expan>word<ex>en</ex></expan>, daz wir niht <expan>wiss<ex>en</ex></expan>,
                        wenn <expan>od<ex>er</ex></expan> wa das nehst
                            <expan>lantger<ex>iht</ex></expan> daselbs
                            <expan>w<ex>er</ex>den</expan> sol. <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>weish<ex>eit</ex></expan> mit
                        fleiss, daz ir uns bey disem <expan>bott<ex>en</ex></expan>
<expan>verschr<ex>eiben</ex></expan> wellet,
                                <add><expan>alsv<ex>er</ex>r</expan> ewch das
                                    <expan>wissenl<ex>ich</ex></expan> sey, wenn</add> und wahin
                        dasselb <expan>lantger<ex>iht</ex></expan> zu nehst berüft sey und
                                <expan>w<ex>er</ex>den</expan> sulle und ob ir ewch
                                <expan>v<ex>er</ex>sehet</expan>, ob es fürsich geen
                                <expan>w<ex>er</ex>de</expan>
<expan>od<ex>er</ex></expan> niht als etc. Das
                            <expan>well<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Nicolai.</ab>
