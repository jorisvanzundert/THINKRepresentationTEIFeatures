<ab facs="#facs_336_r1l27"><expan>eẅ<ex>r</ex>n</expan> <expan>fürſtenl<ex>ichen</ex></expan> <expan>gnad<ex>en</ex></expan> <expan>fürkome<ex>n</ex></expan> <expan>w<ex>er</ex>e</expan> / daʒ ein <expan>vnſ<ex>er</ex></expan> <expan>b<ex>urger</ex></expan> Jacob granetel </ab>
