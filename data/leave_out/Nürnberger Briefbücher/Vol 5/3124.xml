                                <expan>v<ex>este</ex>r</expan> conthoralis
                            <expan>nosterq<ex>ue</ex></expan> fautor et amicus
                            <expan>p<ex>rae</ex>cipuus</expan>, diem <expan>suu<ex>m</ex></expan>
<expan>clausit<ex>ur</ex></expan>
<expan>extremu<ex>m</ex></expan>. De quo <expan>no<ex>n</ex></expan>
                        inmerito turbati <expan>sum<ex>us</ex></expan>
<expan>na<ex>m</ex></expan> in eo nobis et <expan>n<ex>ost</ex>ris</expan>
                        cecidit <expan>p<ex>ro</ex>moc<ex>i</ex>o<ex>n</ex>is</expan>
<expan>subsidiu<ex>m</ex></expan>
<expan>atq<ex>ue</ex></expan>
<expan>scutu<ex>m</ex></expan> defensionis
