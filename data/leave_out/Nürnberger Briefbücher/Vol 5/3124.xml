<expan>p<ex>er</ex>venit</expan>
<expan>noticia<ex>m</ex></expan>
<expan>qual<ex>ite</ex>r</expan>, <expan>hon<ex>orabi</ex><hi rend="sup">li</hi></expan> et famosus
