<expan>altissi<ex>mus</ex></expan>
<add><expan>tonant<ex>is</ex></expan>
<expan>gr<ex>ati</ex>a<ex>m</ex></expan></add>
<expan>p<ex>er</ex>sona<ex>m</ex></expan>
<expan>v<ex>est</ex>ram</expan>
