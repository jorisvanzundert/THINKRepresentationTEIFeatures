<expan>nequim<ex>us</ex></expan>
<expan>ideoq<ex>ue</ex></expan> eum, <expan>speram<ex>us</ex></expan> et
                                <expan>optam<ex>us</ex></expan> requiescere in
                            <expan>s<ex>anc</ex>ta</expan> pace, <expan>prete<ex>r</ex>a</expan>
<expan>d<ex>omi</ex>na</expan>
<expan>p<ex>rae</ex>cara</expan>
<expan>v<ex>est</ex>ram</expan>
<expan>honestate<ex>m</ex></expan>
<expan>dep<ex>re</ex>care</expan>
<add><expan>decrevim<ex>us</ex></expan></add>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan> ensem
