<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan>habt, wie ewch
                                <expan>Stepf<ex>an</ex></expan> Kumpf und
                            <expan>Heinr<ex>ich</ex></expan> Prawn, ewr
                            <expan>b<ex>urger</ex></expan>, fürbracht <expan>habe<ex>n</ex></expan>,
                        daz Kathrey <expan>Füchslin<ex>n</ex></expan> selig, <add>Micheln
                            Beheim</add>, <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan>, und die <expan>vorg<ex>enanten</ex></expan>
                        zwen ewr <expan>b<ex>urger</ex></expan> zu <expan>vormünde<ex>n</ex></expan>
                        gebetten hab und wie <expan>dies<ex>elb</ex></expan> sache seid gehandelt
                        sey etc., das <expan>habe<ex>n</ex></expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>habe<ex>n</ex></expan> mit
                        dem <expan>eg<ex>enante</ex>n</expan> Micheln Beheim
                            <expan>davo<ex>n</ex></expan> geredt, der hat uns
                                <expan>geantw<ex>ur</ex>tt</expan>, wie er niht
                                <expan>and<ex>er</ex>s</expan> verstanden hab, denn daz in die
                        Füchslin zu einr zetteln beͣte, <expan>dies<ex>elben</ex></expan> zettel zu
                                <expan>gut<ex>er</ex></expan> mass aufgericht sey; wie
                                <expan>daru<ex>m</ex>b</expan> so <expan>habe<ex>n</ex></expan> wir,
                        umb <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>sov<ex>er</ex>ren</expan> mit im geredt, daz er uns
                                <expan>geantw<ex>ur</ex>t</expan> hat, er well sich der
                                <expan>obg<ex>enante</ex>n</expan> vormuntschaft
                                <expan>anneme<ex>n</ex></expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>.</ab>
</div>
