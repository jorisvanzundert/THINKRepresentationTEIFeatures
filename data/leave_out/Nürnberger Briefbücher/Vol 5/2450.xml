<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>Wernh<ex>er</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt, von der krieg und spenn
                                <expan>weg<ex>en</ex></expan>
<expan>zwische<ex>n</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<add>gnedigen</add>
<expan>h<ex>er</ex>ren</expan> den <expan>furste<ex>n</ex></expan> und
                                <expan>h<ex>er</ex>ren</expan> etc.,
                                <add><expan>ders<ex>elb</ex></expan> ewr brief ist uns erst auf hewt
                                    <expan>geantw<ex>ur</ex>t</expan>
<expan>word<ex>en</ex></expan>. Nu sein uns sölich zwytracht</add>
<add>auf beid seiten</add> niht lieb. Und als ir <add>uns</add> fürbas
                        schreibt, mit <expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urgern</ex></expan>, die <expan>pfantsch<ex>aft</ex></expan>
                        oder gut von <expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> dem <expan>marggraf<ex>en</ex></expan>
                        innenhaben, zu reden etc., also <expan>hab<ex>e</ex>n</expan> wir etlich
                                <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, als vil uns denn auf disz zeit wissend
                                <expan>gewes<ex>en</ex></expan> sein, die
                            <expan>sölich<ex>er</ex></expan> sache zu schiken
                            <expan>hab<ex>e</ex>n</expan>, für uns besandt und
                            <expan>sov<ex>er</ex>ren</expan> mit in geredt, daz sie ewch selbs
                                <expan>daru<ex>m</ex>b</expan> antwurt tun
                            <expan>süll<ex>e</ex>n</expan>. <expan>Bitt<ex>en</ex></expan> wir ewr
                                <expan>erberk<ex>eit</ex></expan> mit fleiss, also darob zu sein und
                        auch <expan>zu bestell<ex>e</ex>n</expan>, daz unser und der
                                <expan>uns<ex>er</ex>n</expan> geschont
                            <expan>w<ex>er</ex>de</expan>, als denn unser
                            <expan>h<ex>er</ex>re</expan> herczog <expan>Lud<ex>wig</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>erb<ex>er</ex>n</expan>
<expan>botsch<ex>aft</ex></expan>
<expan>gnedikl<ex>ich</ex></expan> zugesagt hat und wir
                                <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> auch wol getrawen. Denn wo wir ewch lieb
                        oder dienst etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>Symo<ex>n</ex>is</expan> et Jude.</ab>
</div>
