</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, wir <expan>lass<ex>en</ex></expan> ewch
                                <expan>wiss<ex>en</ex></expan>, daz <expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des römischen etc. künigs rete, nemlich der
                        edel <expan>h<ex>e</ex>r</expan>
<expan>Albr<ex>echt</ex></expan>, <expan>h<ex>er</ex>re</expan> zu Colldicz,
                                <expan>hawbtm<ex>an</ex></expan> zu Pressla und zur Sweidnicz,
                                <expan>camermeist<ex>er</ex></expan>, und
                            <expan>h<ex>e</ex>r</expan> Hartung Clux in kürcz zu uns
                                <expan>kome<ex>n</ex></expan> seyn mit
                            <expan>dess<ex>elben</ex></expan>
<expan>uns<ex>er</ex>s</expan> gnedigen <expan>h<ex>er</ex>ren</expan> des
                        künigs <expan>glawbbr<ex>ief</ex></expan>, der <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> und den <expan>and<ex>er</ex>n</expan>
                        reichs <expan>stett<ex>en</ex></expan> in <expan>Frank<ex>en</ex></expan>,
                                <expan>uns<ex>er</ex>n</expan> guten
                            <expan>frewnd<ex>en</ex></expan>, auch steet, als ir an der
                                <expan>abschr<ex>ift</ex></expan>
<expan>dess<ex>elben</ex></expan>
<expan>br<ex>iefs</ex></expan>
<expan>hierynn<ex>en</ex></expan>
<expan>v<ex>er</ex>sloss<ex>en</ex></expan> wol
                            <expan>v<ex>er</ex>nemen</expan>
<expan>w<ex>er</ex>det</expan>. Und darauf <expan>habe<ex>n</ex></expan>
<expan>dies<ex>elben</ex></expan> rete seinr
                            <expan>künigliche<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>meynu<ex>n</ex>g</expan> an uns <expan>geworbe<ex>n</ex></expan> und
                                <expan>beg<ex>er</ex>t</expan>, <expan>ewr<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan> das auch zu
                                <expan>v<ex>er</ex>künd<ex>en</ex></expan>, wan uns denn dunkt, daz
                        das müntlich besser sey denn schriftlich. So <expan>bitt<ex>en</ex></expan>
                        und <expan>beg<ex>er</ex>n</expan> wir an ewch, daz ir ewr erber
                                <expan>botsch<ex>aft</ex></expan> von <expan>ew<ex>r</ex>m</expan>
    rate zu uns schiket auf nu den <app><note><q type="date">weiszen sunntag</q>01.03.1422</note></app> zu nacht, genant
                                <expan>invocav<ex>i</ex><hi rend="sup">t</hi></expan>,
                                <expan>dies<ex>elben</ex></expan> ewr und der
                            <expan>and<ex>er</ex>n</expan> stett <expan>botsch<ex>aft</ex></expan>,
                        den wir des <add>gleichen</add> auch <expan>geschribe<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>, des <expan>obg<ex>enanten</ex></expan> unsers
                                <expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>k<ex>ünigs</ex></expan>
<expan>meynu<ex>n</ex>g</expan> also müntlich zu
                            <expan>unt<ex>er</ex>richten</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb etc. <expan>Dat<ex>um</ex></expan> in
                                <expan>vigi<ex>lia</ex></expan> Mathie.</ab>
</div>
