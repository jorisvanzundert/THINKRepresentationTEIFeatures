<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat, wie ewch furbracht sey, daz
                                <expan>Bercht<ex>old</ex></expan>
<expan>Teichsl<ex>er</ex></expan>, <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>, von <expan>seine<ex>n</ex></expan> und seinr
                                <expan>brüd<ex>er</ex></expan>
<expan>weg<ex>en</ex></expan> etliche <expan>güt<ex>er</ex></expan>, die
                                <expan>H<ex>er</ex>man</expan> Meyrs <expan>kind<ex>er</ex></expan>
                        zu Spalt <expan>gelass<ex>en</ex></expan>
<expan>hab<ex>e</ex>n</expan>, für das <expan>lantger<ex>iht</ex></expan> zu
                                <expan>Nür<ex>emberg</ex></expan> geladen hab etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan> ewr
                        gnade <expan>wiss<ex>en</ex></expan>, daz wir den
                                <expan>vorgen<ex>anten</ex></expan>
<expan>Berchtold<ex>en</ex></expan>
<expan>Teichsl<ex>er</ex></expan>, <expan>Engelh<ex>art</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>brud<ex>er</ex></expan> und ir <expan>beid<ex>er</ex></expan>
<expan>mut<ex>er</ex></expan> für uns besant, <expan>daru<ex>m</ex>b</expan>
                        zu red gesaczt und <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> zu lieb <expan>sov<ex>er</ex>ren</expan> mit
                        in geredt <expan>hab<ex>e</ex>n</expan>, daz sie die
                                <expan>obg<ex>ena</ex>n<ex>te</ex></expan>
<expan>ladu<ex>n</ex>g</expan> und klag <expan>am<ex>m</ex></expan>
<expan>lantger<ex>iht</ex></expan> zu disem mal abgetan und
                                <expan>fall<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan> lassen. <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>hoch<ex>wirdikeit</ex></expan>
                        mit fleiss, ob die <expan>egen<ex>anten</ex></expan> die
                                <expan>uns<ex>er</ex>n</expan> in <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>gerichte<ex>n</ex></expan> von der
                            <expan>vorg<ex>enanten</ex></expan> sache <expan>weg<ex>en</ex></expan>
                        rechts <expan>beg<ex>er</ex>n</expan> und <expan>erford<ex>er</ex>n</expan>
                        wurden, daz ir mit <expan>ew<ex>r</ex>n</expan>
<expan>amptlewt<ex>en</ex></expan>
<expan>bestell<ex>e</ex>n</expan> wellet, daz in slewnig recht recht
                                <expan>daru<ex>m</ex>b</expan> gee und
                            <expan>wid<ex>er</ex>fare</expan> als etc. Das
                            <expan>well<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> v<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan><ex>con</ex>cep<ex>ci</ex><hi rend="sup">o<ex>n</ex>is</hi></expan>
                        Marie <expan>virg<ex>in</ex>is</expan>.</ab>
