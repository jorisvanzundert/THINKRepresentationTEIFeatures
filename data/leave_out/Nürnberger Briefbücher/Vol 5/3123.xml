<expan>p<ex>rae</ex>cipuo</expan></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab>Obsequiosa <expan>voluntat<ex>is</ex></expan>
<expan>p<ex>ro</ex>mptitudi<ex>n</ex>e</expan>
<expan>v<ex>est</ex>ris</expan> benignis amiciciis sedule
                                <expan>preassumpt<ex>is</ex></expan>, <expan>hon<ex>orabi</ex><hi rend="sup">lis</hi></expan> fautor et amice precare.
                                <expan>Que<ex>m</ex>admodu<ex>m</ex></expan> pie memorie
                                <expan>n<ex>ost</ex>er</expan>
<expan>sp<ex>eci</ex>alis</expan> fautore amicus
                                <expan>m<ex>a</ex>g<ex>iste</ex>r</expan> Petrus Heym civis
                                <expan>Lovan<ex>ensis</ex></expan>
<expan>hacten<ex>us</ex></expan> annuatim <expan>no<ex>n</ex></expan> paucis
                                <expan>t<ex>em</ex>p<ex>or</ex>ib<ex>us</ex></expan>
<expan>t<ex>ra</ex>n<ex>s</ex>fact<ex>is</ex></expan>
<expan>v<ex>est</ex>r<ex>u</ex>m</expan> ensem
                            <expan>duab<ex>us</ex></expan>
<expan>cu<ex>m</ex></expan> cyrothecis <expan>atq<ex>ue</ex></expan> bacillo
                        ex <expan>n<ex>ost</ex>ri</expan> parte <expan>p<ex>ro</ex>ut</expan> ex
                        solito <expan>tenem<ex>ur</ex></expan>
<expan>occasio<ex>n</ex>e</expan>
<expan>libertatu<ex>m</ex></expan> ac
                                <expan>c<ex>on</ex>suetudi<ex>ne</ex><hi rend="sup">m</hi></expan>
<expan>mercator<ex>um</ex></expan>
<expan>n<ex>ost</ex>ror<ex>um</ex></expan>
<expan>cu<ex>m</ex></expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan> mercimoniis et
                                <expan>reb<ex>us</ex></expan> in partibus Brabantie etc.
                                <expan>abulant<ex>is</ex></expan>. Illustri et excelso principi
                                <expan>d<ex>omi</ex>no</expan> duci Brabantie etc.
                                <expan>d<ex>omi</ex>no</expan>
<expan>n<ex>ost</ex>ro</expan>
<expan>grac<ex>i</ex>oso</expan> cum <expan>solemnitatib<ex>us</ex></expan>
                        ac <expan>reve<ex>re</ex>ntiis</expan> debitis et
                            <expan>c<ex>on</ex>suetis</expan> duxerat
                                <expan>p<ex>raese</ex>ntand<ex>um</ex></expan>,
                            <expan>p<ex>ro</ex>ut</expan>
<expan>h<ex>o</ex><hi rend="sup">c</hi></expan>
<expan>ve<ex>st</ex>ram</expan> sagacitatem <expan>credim<ex>us</ex></expan>
<expan>no<ex>n</ex></expan> latere. Quare nuper civis
                            <expan>n<ex>oste</ex>r</expan>
<expan>Cristann<ex>us</ex></expan> Coler nobis retulit
                                <expan>qual<ex>ite</ex>r</expan>
<expan>ip<ex>s</ex>e</expan>
<expan>unacu<ex>m</ex></expan> quibusdam aliis
                            <expan>civib<ex>us</ex></expan> ac <expan>mercatorib<ex>us</ex></expan>
<expan>n<ex>ost</ex>ris</expan>
<expan>p<ex>ro</ex></expan>
<expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>f<ex>ac</ex>to</expan> sive
                                <expan>p<ex>raese</ex>ntat<ex>i</ex>o<ex>n</ex>is</expan>
<expan>negoc<ex>i</ex>o</expan> ammodo <expan>exp<ex>er</ex>te</expan>
<expan>n<ex>ost</ex>ri</expan>
<expan>exequend<ex>um</ex></expan>, <expan>v<ex>est</ex>ram</expan>
<expan>prudentia<ex>m</ex></expan> ut pate <add>nobis in hac
                            p<ex>ar</ex>te</add>
<expan>ydonea<ex>m</ex></expan> et <expan>habilissi<ex>m</ex><hi rend="sup">am</hi></expan> accesserint <expan>ip<ex>s</ex>am</expan>
<expan>since<ex>r</ex>is</expan>
<expan>aff<ex>e</ex>c<ex>t</ex>ib<ex>us</ex></expan>
<expan>d<ex>e</ex>pr<ex>e</ex>cando</expan> ut intuitu
                            <expan>n<ex>ost</ex>ri</expan>
<expan>mercator<ex>um</ex></expan>
<expan>n<ex>ost</ex>ror<ex>um</ex></expan>, onus
                            <expan>p<ex>rae</ex>tacti</expan> negocii
                            <expan>vid<ex>elicet</ex></expan>
<expan>p<ex>raese</ex>ntat<ex>ione</ex>m</expan>
<expan>ens<ex>is</ex></expan>
<expan>iux<ex>ter</ex></expan>
<expan>c<ex>on</ex>suetudi<ex>n</ex>em</expan> et
                            <expan>ritu<ex>m</ex></expan>
<expan>p<ex>er</ex></expan>
<expan>d<ex>i</ex>c<ex>tu</ex>m</expan>
<expan>m<ex>a</ex>g<ex>ist</ex>r<ex>u</ex>m</expan>
<expan>Petru<ex>m</ex></expan> Heym <expan>hacten<ex>us</ex></expan>
<expan>observat<ex>is</ex></expan>
<expan>assume<ex>re</ex></expan> velletis. Ad quod
                                <expan>assumend<ex>um</ex></expan> et
                            <expan>exequend<ex>um</ex></expan>
<add>vos </add>in eo <add>nobis</add>
<expan>c<ex>on</ex>placendi</expan>
<add><expan>sinceru<ex>m</ex></expan> et</add>
<expan>b<ex>e</ex>nivole</expan>
<add><expan>reddidist<ex>is</ex></expan></add> de quo
                            <expan>v<ex>est</ex>ris</expan> benignis amiciciis referre
                                <expan>duxi<ex>mus</ex></expan>
<expan>m<ex>u</ex>ltas</expan> grates, et <expan>insup<ex>er</ex></expan>
                        eisdem amiciciis <expan>cu<ex>m</ex></expan> Eberhardo
                            <expan>nu<ex>n</ex>cio</expan>
<expan>n<ex>ost</ex>ro</expan>
<expan>har<ex>um</ex></expan>
<expan>latore<ex>m</ex></expan>
<expan>unu<ex>m</ex></expan>
<expan>gladiu<ex>m</ex></expan>
<expan>destinam<ex>us</ex></expan>, <expan>precib<ex>us</ex></expan>
<expan>studios<ex>is</ex></expan>
<expan>supplicant<ex>is</ex></expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan>
<expan>eunde<ex>m</ex></expan>
<expan>gladiu<ex>m</ex></expan>
<expan>p<ex>ro</ex></expan> anno <expan>futu<ex>r</ex>o</expan>
<expan>p<ex>raesen</ex>tand<ex>um</ex></expan> penes vos
                                <expan>res<ex>er</ex>vare</expan>
<expan>necno<ex>n</ex></expan> enesem
                            <expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>que<ex>m</ex></expan>
<expan>p<ex>rae</ex>fatus</expan>
<expan>m<ex>a</ex>g<ex>iste</ex>r</expan> Petrus in sua
                                <expan>p<ex>otes</ex>tate</expan> reliquit qui
                                <expan>p<ex>raese</ex>ntand<ex>um</ex></expan> est in anno
                                <expan>p<ex>raese</ex>nti</expan>
<expan>t<ex>em</ex>p<ex>or</ex>e</expan> suo ab <expan>ip<ex>s</ex>a</expan>
                        relicta <expan>p<ex>rae</ex>no<ex>t</ex>ati</expan>
<expan>m<ex>a</ex>g<ex>ist</ex>ri</expan> Petri
                                <add><expan>unacu<ex>m</ex></expan> quitancia anni elapsi</add>
<expan>assume<ex>re</ex></expan> et <expan>exp<ex>er</ex>te</expan>
<expan>n<ex>ost</ex>ri</expan>
<add><expan>ip<ex>su</ex>m</expan> ensem</add>
<expan>cu<ex>m</ex></expan>
<expan>solemnitatib<ex>us</ex></expan> et
                            <expan>reve<ex>re</ex>ntiis</expan> ut
                            <expan>p<ex>rae</ex>sertim</expan>
<expan>p<ex>raese</ex>ntar<ex>is</ex></expan>
<expan>studeat<ex>is</ex></expan> et <expan>desup<ex>er</ex></expan>
<expan>quita<ex>n</ex>c<ex>i</ex>am</expan>
<expan>iux<ex>ter</ex></expan>
<expan>forma<ex>m</ex></expan>
<add>prius <expan>data<ex>m</ex></expan> accipere</add> qua recepta nobis
                                <expan>p<ex>rae</ex>te<ex>r</ex></expan>
<expan>v<ex>est</ex>ra</expan> cum <expan>responsio<ex>n</ex>e</expan>
                        benivola <expan>p<ex>er</ex></expan>
<expan>nu<ex>n</ex>ciu<ex>m</ex></expan>
<expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>p<ex>rae</ex>fatu<ex>m</ex></expan> religare velitis
                                <expan>nova<ex>m</ex></expan>
<add><expan>quitancia<ex>m</ex></expan></add> apud vos
                            <expan>p<ex>ro</ex></expan> anno <expan>futu<ex>r</ex>o</expan>
<expan>des<ex>er</ex>viente</expan>
<add>retinere</add>. In eo fautor et amice diligende nobis et
                                <expan>n<ex>ost</ex>ratib<ex>us</ex></expan><pb facs="#facs_569" id="283v"/>
<expan>v<ex>est</ex>ram</expan> exhibetis
                                <expan>b<ex>e</ex>nivolencia<ex>m</ex></expan> ac
                                <expan>p<ex>ro</ex>moc<ex>i</ex>o<ex>n</ex>is</expan>
<expan>eff<ex>e</ex>c<ex>tu</ex>m</expan>
<expan>p<ex>ro</ex></expan>
<expan>v<ex>est</ex>ra</expan> benigna amicicia iugiter
                                <expan>remerend<ex>um</ex></expan>
<expan>p<ex>rae</ex>terea</expan>
<expan>p<ex>rae</ex>fato</expan>
<expan>nu<ex>n</ex>cio</expan>
<expan>n<ex>ost</ex>ro</expan> sumptus et expensas
                            <expan>c<ex>on</ex>suetas</expan>, <expan>p<ex>ro</ex></expan>
<expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>p<ex>raese</ex>ntat<ex>i</ex>o<ex>ne</ex>m</expan> ensis anni
                                <expan>p<ex>raese</ex>ntis</expan>
<expan>c<ex>om</ex>misimus</expan> expedire.
                            <expan>Altissi<ex>mus</ex></expan>
<expan>persona<ex>m</ex></expan>
<expan>v<ex>est</ex>ram</expan>
<expan>incolume<ex>m</ex></expan>
<add>ac <expan>p<ex>ro</ex>spere</expan></add>
<expan>c<ex>on</ex>s<ex>er</ex>vare</expan>
<expan>dignet<ex>ur</ex></expan> et <expan>dirige<ex>re</ex></expan>
<expan>nu<ex>n</ex>c</expan> et semper. <expan>Dat<ex>um</ex></expan> octavo
                        die ianuarii anno <add>a nativitate</add>
<expan>d<ex>omi</ex>ni</expan> millesimo
                            <expan>quadragentesi<ex>m</ex>o</expan> vicesimo tercio etc.</ab>
