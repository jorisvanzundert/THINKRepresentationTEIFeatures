<ab><expan>Hon<ex>orabi</ex><hi rend="sup">li</hi></expan> ac egregio viro
                                <expan>d<ex>omi</ex>no</expan> Iohanni Dewitt
                                <expan>m<ex>a</ex>gist<ex>ro</ex></expan>
<expan>civi<ex>u</ex><hi rend="sup">m</hi></expan>
