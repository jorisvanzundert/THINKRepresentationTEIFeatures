<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> vicztum, als uns ewr
                            <expan>erberk<ex>eit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat, wie der hochgeborn fürst
                                <expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, <expan>h<ex>er</ex>czog</expan>
<expan>Lud<ex>wig</ex></expan> von Peyern, graf zu Mortani etc., und ir in
                        etwas <expan>irru<ex>n</ex>g</expan> mit <expan>einand<ex>er</ex></expan>
                        seyt von <expan>etlich<ex>er</ex></expan>
<expan>v<ex>er</ex>sprechnüss</expan>
<expan>weg<ex>en</ex></expan>, darauf ir uns bitt, uns der sache
                                <expan>zwisch<ex>e</ex>n</expan> dem
                            <expan>vorg<ex>enante</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan>
<expan>Lud<ex>wig</ex></expan> und <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> recht <expan>zu spreche<ex>n</ex></expan>
<expan>anczuneme<ex>n</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan>
                        wir wol <expan>vernom<ex>en</ex></expan>. Nu sein uns sölich irrung niht
                        lieb und daz die gütlich <expan>abgieng<ex>en</ex></expan> und
                                <expan>entschaid<ex>en</ex></expan>
<expan>wurd<ex>en</ex></expan>, das seͣhen wir <expan>g<ex>er</ex>n</expan>.
                        Könden wir auch darczu icht guts gedienen, des
                            <expan>wölt<ex>en</ex></expan> wir dem <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan>
<expan>Lud<ex>wig</ex></expan> zu dienst und <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> zu lieb willig sein, aber
                                <expan>sölich<ex>er</ex></expan> sache recht zu
                                <expan>spreche<ex>n</ex></expan>, das ist bisher unser
                                <expan>gewonh<ex>eit</ex></expan> niht gewesen.
                                <expan>Bitt<ex>en</ex></expan> wir ewr
                            <expan>erberk<ex>eit</ex></expan> mit fleiss, das von uns in gut zu
                        versteen. Denn wo wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>ip<ex>s</ex>a</expan> die <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
<expan>Joh<ex>ann</ex>is</expan>
<expan>an<ex>te</ex></expan>
<expan>porta<ex>m</ex></expan>
<expan>latina<ex>m</ex></expan>.</ab>
</div>
