</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat von Nikel Erharts
                                <expan>weg<ex>en</ex></expan> etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>.
                        Und <expan>well<ex>e</ex>n</expan>
<expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> bey <expan>uns<ex>er</ex></expan> selbs
                                <expan>botsch<ex>aft</ex></expan> kürczlich
                            <expan>daru<ex>m</ex>b</expan> ein antwurt tun. Denn wo wir
                                <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> dienst und
                            <expan>wolgefall<ex>e</ex>n</expan> etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Viti.</ab>
