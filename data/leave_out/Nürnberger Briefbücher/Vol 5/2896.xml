<expan>ersamk<ex>eit</ex></expan>
<expan>kein<ex>en</ex></expan> schaden bringe, daz ir ewch auf
                                <expan>dems<ex>elben</ex></expan>
<expan>lantger<ex>icht</ex></expan> niht <expan>v<ex>er</ex>antwurtt</expan>
