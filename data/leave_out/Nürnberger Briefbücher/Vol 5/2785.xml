<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><del rend="crossout"><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als ewr
                                <expan>durchleuhtik<ex>eit</ex></expan> uns vormals, do
                                    <expan>ew<ex>r</ex></expan> gnade hie
                                <expan>ob<ex>e</ex>n</expan> zu <expan>Amb<ex>er</ex>g</expan> was,
                                <add>auff <expan>uns<ex>er</ex>n</expan> brief, den wir
                                        <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> santten</add> von Peter Luczen
                            und <expan>Cuncze<ex>n</ex></expan> Wirczburgers
                                <expan>uns<ex>er</ex>r</expan>
<expan>burge<ex>r</ex></expan> wegen, als etlich
                                <expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> von Kaczenelmbogen diener
                                    <expan>dieselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>burge<ex>r</ex></expan> gefangen <expan>hab<ex>e</ex>n</expan>,
                            gar gnediklich <expan>geschr<ex>iben</ex></expan> und
                                    <expan>geantw<ex>ur</ex>t</expan> hat, also
                                <expan>wen<ex>n</ex></expan> ewr
                                <expan>durchl<ex>euhtikeit</ex></expan> hinab an den Rein kum, sey
                                    <expan>dan<ex>n</ex></expan>
<expan>ymand<ex>en</ex></expan>, der ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> daran mane, so wolle in ewr
                            gnade darynne gnedige <expan>fürdru<ex>n</ex>g</expan> beweisen etc., nu
                                    <expan>hab<ex>e</ex>n</expan> uns die
                                <expan>eg<ex>enanten</ex></expan> unser
                                <expan>burge<ex>r</ex></expan>
<expan>yeczund<ex>en</ex></expan> fürbraht, wie sie einer gennt Hanman
                            von Rinheim gemant hab zu stellen in ein slosz Deern bey der Laen
                            gelegen. Hyrümb <expan>ro<ex>gamus</ex></expan>, daz ir ewr
                                <expan>fürstenlich</expan> gnade den
                                <expan>vorgen<ex>anten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>b<ex>urger</ex></expan> darynne durch
                                <expan>uns<ex>er</ex>r</expan>
<expan>willige<ex>n</ex></expan> dinste <expan>wille<ex>n</ex></expan>
                            geruchet zu beweisen, damit sie <expan>derselb<ex>e</ex>n</expan>
                            venknüsse ledig werden, <expan>wan<ex>n</ex></expan> die
                                    <expan>uns<ex>er</ex>n</expan> gar ungeverlich darczu
                                    <expan>kume<ex>n</ex></expan> sein, als wir das
                                    <expan>dan<ex>n</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan>
<add>in dem <expan>vorgeschr<ex>iben</ex></expan>
<expan>uns<ex>er</ex>m</expan> brief</add> eygentlich
                                    <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan>. Das <expan>wölle<ex>n</ex></expan> wir
                            ümb ewr <expan>hoch<ex>wirdikeit</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>.
                                <expan>Sc<ex>ri</ex>pt<ex>um</ex></expan>
<expan>sabb<ex>a</ex>to</expan>
<expan>p<ex>ost</ex></expan>
<expan>ephy<ex>pha</ex><hi rend="sup">nie</hi></expan>
<expan>d<ex>omi</ex>ni</expan>.</del><app>
<note place="bottom">Abest <expan>h<ex>ae</ex><hi rend="sup">c</hi></expan> forma <expan>no<ex>n</ex></expan> est
                                        <expan>p<ex>rese</ex>nt<ex>ata</ex></expan>. </note>
</app></ab></div>
</div></body>
