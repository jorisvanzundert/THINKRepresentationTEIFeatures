<ab facs="#facs_370_r1l26">gnedige <expan>fürdru<ex>n</ex>g</expan> beweiſen etc 
<del rend="strikethrough">Alſo <expan>Ro<ex>gamus</ex></expan></del> Nu <expan>hab<ex>e</ex>n</expan> vns die <expan>eg<ex>enanten</ex></expan> </ab>
