                                    </div>
</div>
<div type="regularised">
<pb facs="#facs_301"/>
<!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Duci <expan>Venetiar<ex>um</ex></expan> etc.</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab> Magnifice et excelse <expan>nobilesq<ex>ue</ex></expan>
<expan>p<ex>re</ex>potentes</expan>
<expan>d<ex>omi</ex>ni</expan> honorandi. Quia non
                            <expan>diut<ex>ur</ex>nis</expan>
<expan>t<ex>ra</ex>nsactis</expan>
<expan>t<ex>em</ex>p<ex>or</ex>ib<ex>us</ex></expan> casu se penes nos
                                <expan>offe<ex>re</ex>nt<ex>es</ex></expan>,
                                <expan>videl<ex>i</ex>z<ex>et</ex></expan>
<expan>q<ex>uod</ex></expan>
<expan>quid<ex>am</ex></expan> cives <expan>n<ex>ost</ex>ri</expan> et
                        incole <expan>quenda<ex>m</ex></expan>
<expan>Nycolau<ex>m</ex></expan>
<expan>di<ex>ctu</ex>um</expan> Halbwachsen,
                            <expan>p<ex>ro</ex>tu<ex>n</ex>c</expan>
<expan>etia<ex>m</ex></expan> civem
                        <expan>n<ex>ost</ex>r<ex>u</ex>m</expan>, <expan>p<ex>ro</ex></expan>
<expan>quoda<ex>m</ex></expan> nephas <expan>ip<ex>s</ex>is</expan>
<expan>p<ex>er</ex></expan>
<expan>eu<ex>m</ex></expan>
<expan>illatu<ex>m</ex></expan> ac sponte <expan>c<ex>on</ex>fessum</expan>
                        mediante iusticia ad <expan>captivitate<ex>m</ex></expan>
<expan>n<ex>ost</ex>ram</expan>
<expan>detentu<ex>m</ex></expan>
<expan>c<ex>om</ex>portaru<ex>n</ex>t</expan>; <expan>p<ex>ro</ex></expan>
                        quo <expan>ip<ex>s</ex>e</expan> reus <expan>iux<ex>ta</ex></expan> iuris
                        rigorem ac <expan>leg<ex>is</ex></expan>
<expan>municipal<ex>is</ex></expan>
<expan>n<ex>ost</ex>re</expan>
<expan>civitat<ex>is</ex></expan>
<expan>mort<ex>is</ex></expan>
<expan>amaritudi<ex>n</ex>em</expan>
<expan>no<ex>n</ex></expan> immerito congutasset,
                            <expan>s<ex>ed</ex></expan> sibi arridente
                            <expan>fortu<ex>n</ex>a</expan>, <expan>q<ex>uod</ex></expan>
<expan>no<ex>n</ex>nulli</expan>
<expan>illustr<ex>es</ex></expan>
<expan>p<ex>ri</ex>ncipes</expan> et magnates
                                <expan>p<ex>ro</ex>ceresq<ex>ue</ex></expan>
<expan>d<ex>omi</ex>ni</expan> et armigeri <expan>p<ex>ro</ex></expan> eo
                        attente <expan>ip<ex>s</ex>is</expan>
<expan>actorib<ex>us</ex></expan>
<expan>m<ex>u</ex>ltiplices</expan>
<expan>exortat<ex>i</ex>o<ex>n</ex>es</expan>
<expan>direxeru<ex>n</ex>t</expan> et preces, per quas eosdem actores ab
                                <expan>ip<ex>s</ex>or<ex>um</ex></expan> querelis et
                                <expan>p<ex>ro</ex>po<ex>s</ex>itis</expan> penitus
                                <expan>c<ex>om</ex>pescebant</expan>; et insuper
                                    <add><expan>ip<ex>s</ex>i<ex>s</ex></expan> actores
                                    <expan>unacu<ex>m</ex></expan>
<expan>eisde<ex>m</ex></expan>
<expan>p<ex>ri</ex>ncipib<ex>us</ex></expan>,
                                <expan>d<ex>omi</ex>nis</expan> et armigeris</add>
<expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>attemtant<ex>es</ex></expan>
<expan>consensu<ex>m</ex></expan> et favorem
                            <expan>studiosi<ex>us</ex></expan>
<expan>supplicand<ex>um</ex></expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan>
<expan>ecia<ex>m</ex></expan>
<expan>ipsor<ex>um</ex></expan>
<expan>peticionib<ex>us</ex></expan>
<expan>acquiesce<ex>re</ex></expan> et
                                <expan>p<ex>re</ex>d<ex>i</ex>c<ex>tu</ex>m</expan> Nicolaum ab
                                <expan>hui<ex>usm</ex>o<ex>d</ex>i</expan> captivitate
                                <expan>liber<ex>um</ex></expan> et <expan>solutu<ex>m</ex></expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan> intuitu
                            <expan>dimitte<ex>re</ex></expan>
<expan>vellem<ex>us</ex></expan>: nos <expan>v<ex>er</ex>o</expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan>
<expan>supplicatio<ex>n</ex>ib<ex>us</ex></expan> et
                            <expan>p<ex>re</ex>sertim</expan>
<expan>eor<ex>un</ex>dem</expan>
<expan>p<ex>ri</ex>ncipu<ex>m</ex></expan> et
                            <expan>magnat<ex>um</ex></expan>
<expan>d<ex>omi</ex>nore<ex>um</ex></expan> comode denegare
                                <expan>no<ex>n</ex></expan> valentes, ad suam
                                <expan>c<ex>om</ex>placencia<ex>m</ex></expan>
<expan>p<ex>re</ex>d<ex>i</ex>c<ex>tu</ex>m</expan>
<expan>Nicolau<ex>m</ex></expan> ab
                            <expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>captivi<ex>ta</ex><hi rend="sup">te</hi></expan>
<expan>salvu<ex>m</ex></expan> et <expan>solutu<ex>m</ex></expan>
<expan>dimisi<ex>mus</ex></expan>; sic <expan>q<ex>uod</ex></expan>
<expan>ip<ex>s</ex>e</expan>
<expan>cauc<ex>i</ex>o<ex>ne</ex>m</expan> mediante suo iuramento ac
                                <expan>l<ex>itte</ex>ris</expan>
<expan>sigillat<ex>is</ex></expan>, <expan>p<ex>ro</ex>ut</expan> moris est,
                        fecit et firmavit, <expan>q<ex>uod</ex></expan> ultra montes se
                                <expan>t<ex>ra</ex>nsferre</expan> et redire non deberet
                                <expan>t<ex>em</ex>p<ex>or</ex>ib<ex>us</ex></expan> vite sue, et
                                <expan>q<ex>uod</ex></expan>
<expan>ip<ex>s</ex>e</expan>
<add>aut</add> aliquis <expan>v<ex>e</ex>l</expan> aliqui vice
                                <expan>v<ex>e</ex>l</expan> ex <expan>p<ex>ar</ex>te</expan> sui
                                <expan>hui<ex>usm</ex>o<ex>d</ex>i</expan>
<expan>capt<ex>ivitatem</ex></expan>
<expan>v<ex>e</ex>l</expan>
<expan>quecu<ex>m</ex>q<ex>ue</ex></expan> inde secuta seu inchoata
                                <expan>n<ex>u</ex>llaten<ex>us</ex></expan> vindicare vellet aut
                        deberet <expan>neq<ex>ue</ex></expan>
<expan>face<ex>ret</ex></expan>
<expan>p<ex>ro</ex>curare</expan> seu <expan>c<ex>on</ex>sentire</expan>
                        ullo modo; <expan>ecia<ex>m</ex></expan> si <expan>cu<ex>m</ex></expan>
<expan>n<ex>ost</ex>ratib<ex>us</ex></expan>
<expan>quitq<ex>ua</ex><hi rend="sup">m</hi></expan> tractare sive ventilare
                                <expan>habe<ex>re</ex>t</expan>
<expan>v<ex>e</ex>l</expan>
<expan>intende<ex>re</ex>t</expan>, <expan>q<ex>uod</ex></expan>
<expan>h<ex>o</ex><hi rend="sup">c</hi></expan> iuridice
                            <expan>p<ex>er</ex></expan>
<expan>su<ex>u</ex>m</expan>
<expan>p<ex>ro</ex>curatore<ex>m</ex></expan>
<expan>legitti<ex>mu</ex><hi rend="sup">m</hi></expan>
<expan>cora<ex>m</ex></expan> nobis aut <expan>imp<ex>er</ex>ii</expan>
                        sacri <expan>iudic<ex>i</ex>o</expan> penes nos et non alibi postulare
                        deberet et finiri, <expan>p<ex>ro</ex>ut</expan> hoc in
                            <expan>ip<ex>s</ex>is</expan>
<expan>l<ex>ite</ex>ris</expan>
<expan>desup<ex>er</ex></expan>
<expan>c<ex>on</ex>fectis</expan>
<expan>pleni<ex>us</ex></expan>
<expan>c<ex>on</ex>tinet<ex>ur</ex></expan>. <expan>Nup<ex>er</ex></expan>
<expan>v<ex>er</ex>o</expan>, <expan>q<ex>uo</ex>d</expan> satis amaro
                                <expan>sustinem<ex>us</ex></expan>
<expan>a<ex>n</ex>i<ex>m</ex>o</expan>, <expan>p<ex>er</ex></expan>
<expan>f<ex>rat</ex>res</expan> eiusdem Nicoklai nec non alios cives
                                <expan>n<ex>ost</ex>ros</expan> ad
                            <expan>n<ex>ost</ex>r<ex>u</ex>m</expan>
<expan>auditu<ex>m</ex></expan> querulose est
                            <expan>deductu<ex>m</ex></expan>, <expan>quali<ex>ter</ex></expan> idem
                        Nicolaus <expan>b<ex>e</ex>n<ex>e</ex>ficiis</expan> sibi ut
                                <expan>p<ex>re</ex>fectur</expan>
<expan>impens<ex>is</ex></expan>
<expan>p<ex>ro</ex>rsus</expan> immemor <expan>c<ex>on</ex>tra</expan>
<expan>suu<ex>m</ex></expan>
<expan>iuramentu<ex>m</ex></expan> ac <expan>l<ex>ite</ex>ras</expan>
<expan>p<ex>re</ex>tactas</expan>
<expan>p<ex>er</ex></expan> eum datas eosdem <expan>f<ex>rat</ex>res</expan>
                        suos <expan>aliosq<ex>ue</ex></expan> cives et mercatores
                                <expan>n<ex>ost</ex>ros</expan>
<expan>cu<ex>m</ex></expan>
<expan>ip<ex>s</ex>or<ex>um</ex></expan> bonis, rebus et mercimoniis
                                <expan>p<ex>re</ex>ter</expan>
<expan>iustutia<ex>m</ex></expan>
<expan>invade<ex>re</ex></expan> intendat ac de facto
                            <expan>p<ex>er</ex></expan> suos coadiutores <expan>h<ex>e</ex><hi rend="sup">c</hi></expan> fieri <expan>disposu<ex>er</ex>it</expan>,
                                <expan>p<ex>ro</ex>ut</expan>
<expan>v<ex>est</ex>ris</expan> magnificenciis <expan>p<ex>er</ex></expan>
<expan>ip<ex>s</ex>os</expan>
<expan>f<ex>rat</ex>res</expan> suos ac alios cives
                            <expan>n<ex>ost</ex>ros</expan>
<expan>h<ex>e</ex><hi rend="sup">c</hi></expan>
<expan>distincti<ex>us</ex></expan> explicari
                            <expan>debent<ex>ur</ex></expan>. <expan>V<ex>est</ex>ras</expan>
<expan>igit<ex>ur</ex></expan>
<expan>d<ex>omi</ex>nac<ex>i</ex>o<ex>n</ex>es</expan> magnificas, quas
                                <expan>semp<ex>er</ex></expan> nobis et
                            <expan>n<ex>ost</ex>ris</expan>
<expan>m<ex>u</ex>ltimodis</expan>
<expan>b<ex>e</ex>n<ex>e</ex>ficiis</expan> et
                            <expan>favorib<ex>us</ex></expan>
<expan>sensim<ex>us</ex></expan> inclinatas, <expan>duxi<ex>mus</ex></expan>
<expan>supplicit<ex>er</ex></expan>
<expan>exorand<ex>um</ex></expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan> eisdem
                            <expan>civib<ex>us</ex></expan>
<expan>n<ex>ost</ex>ris</expan>
<expan>n<ex>ost</ex>r<ex>orum</ex></expan>
<expan>s<ex>er</ex>vic<ex>i</ex>or<ex>um</ex>um</expan> intuitu
                                <expan>v<ex>est</ex>r<ex>u</ex>m</expan>
<expan>auxiliu<ex>m</ex></expan> ac
                                <expan>p<ex>ro</ex>moc<ex>i</ex>o<ex>n</ex>is</expan>
<expan>effectu<ex>m</ex></expan>
<expan>p<ex>re</ex>stare</expan> velitis, quo mediante
                                <expan>p<ex>re</ex>d<ex>i</ex>c<ex>t</ex>us</expan> Nicolaus ad hoc
                        licite <expan>teneat<ex>ur</ex></expan>, ut suis
                            <expan>l<ex>itte</ex>eris</expan>,
                            <expan>sponsio<ex>n</ex>ib<ex>us</ex></expan> et
                                <expan>iurament<ex>is</ex></expan>
<expan>p<ex>re</ex>stit<ex>is</ex></expan> satisfacit et
                                <expan>n<ex>u</ex>ll<ex>u</ex>m</expan> nobis aut
                                <expan>n<ex>ost</ex>ris</expan> ammodo gravamen inferat sive
                                <expan>dampnu<ex>m</ex></expan>. In eo,
                            <expan>d<ex>omi</ex>ni</expan>
<expan>p<ex>re</ex>stan<ex>tissi</ex><hi rend="sup">mi</hi></expan>,
                                <expan>v<ex>est</ex>ra</expan> excellencia nobis et
                                <expan>n<ex>ost</ex>ris</expan> singularem, ymo
                                <expan>gratissi<ex>m</ex>am</expan>
<expan>b<ex>e</ex>nivolen<ex>tiam</ex></expan> exhibebit,
                                <expan>p<ex>ro</ex></expan>
<expan>v<ex>est</ex>ris</expan>
<expan>dignitatib<ex>us</ex></expan> magnificis ac
                                <expan>v<ex>est</ex>ratib<ex>us</ex></expan>
<expan>o<ex>mn</ex>i</expan>
<expan>t<ex>em</ex>p<ex>or</ex>e</expan> totis
                            <expan>nisib<ex>us</ex></expan>
<expan>recolend<ex>am</ex></expan>.
                            <expan>Sc<ex>ri</ex>pt<ex>um</ex></expan> xii<hi rend="sup">o</hi>
                        iulii.</ab>
