<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab>Gnediger herre, als ewr durchleuhtikeit <add>uns</add> nehst von <expan>Amb<ex>er</ex>g</expan>
<add>herab</add> von Peter Luczen und <expan>C<ex>unzen</ex></expan>
                        Wirczburgers, <expan>uns<ex>er</ex>r</expan>
<expan>burge<ex>r</ex></expan>, wegen, als <add>etlich</add>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan> von Kaczenelmbogen dyner
                                <expan>dieselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex></expan>
<expan>burge<ex>r</ex></expan>
<expan>gefange<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>, gar gnediklich
                            <expan>geschr<ex>iben</ex></expan> und <expan>geantw<ex>ur</ex>t</expan>
                        hat, <expan>wen<ex>n</ex></expan> ewr <expan>hoch<ex>wirdikeit</ex></expan>
                        hinab an den Rein kum, sey <expan>dan<ex>n</ex></expan>
<expan>ymand<ex>en</ex></expan>, der ewr
                            <expan>durch<ex>leuhtikeit</ex></expan> daran mane, so wöllet ir in
                        darynn ewr gnedige <expan>fürdru<ex>n</ex>g</expan> beweisen etc. Also
                                <expan>ro<ex>gamus</ex></expan>, <add>den
                                <expan>eg<ex>enanten</ex></expan>
<expan>uns<ex>ern</ex></expan>
<expan>burg<ex>er</ex>n</expan> also
                                <expan>furderlich<ex>e</ex>n</expan> ze sein</add> durch
                                <expan>uns<ex>er</ex>r</expan> willigen dinste
                                <expan>wille<ex>n</ex></expan>, damit
                                die<add><expan>selb<ex>e</ex>n</expan></add>
<expan>uns<ex>er</ex></expan>
<expan>burge<ex>r</ex></expan> ledig werden als etc. Das
                                <expan>wolle<ex>n</ex></expan> etc.
                                <expan>Sc<ex>ri</ex>pt<ex>um</ex></expan>
<expan>sabb<ex>a</ex><hi rend="sup">to</hi></expan>
<expan>p<ex>ost</ex></expan> Martini <expan>a<ex>nno</ex></expan> xxi<hi rend="sup">o</hi>. <app>
<note place="bottomright">
<expan>No<ex>ta</ex></expan>
<expan>p<ex>re</ex>scripta</expan>
<expan>l<ex>itte</ex>ra</expan>
<expan>no<ex>n</ex></expan> est <expan>p<ex>raese</ex>ntata</expan>.
                            </note>
</app></ab></div>
