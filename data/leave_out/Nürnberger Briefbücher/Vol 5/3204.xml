<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan> Francziscen zu Gran und
                            <expan>h<ex>er</ex>n</expan> Micheln zu Boleslan,
                                <expan>pröbst<ex>en</ex></expan>, <expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, des römischen etc. künigs,
                                <expan>p<ex>ro</ex>thonarien</expan>
</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Erwirdig<ex>en</ex></expan> und <expan>l<ex>ieben</ex></expan>
<expan>h<ex>er</ex>ren</expan>, wir haben <expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> dem <expan>r<ex>ömischen</ex></expan> etc.
                        künig und auch <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> nehst <expan>verschr<ex>iben</ex></expan>
                        und <expan>wiss<ex>en</ex></expan> niht, ob ewch ewr
                            <expan>br<ex>ief</ex></expan>
<expan>geantw<ex>ur</ex>t</expan>
<expan>w<ex>er</ex>de</expan>. <add>Also</add>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>wirdik<ex>eit</ex></expan> zu
                                <expan>wiss<ex>en</ex></expan>, als <expan>uns<ex>er</ex></expan>
<expan>lieb<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> und <expan>ratg<ex>esell</ex></expan>,
                                <expan>Pet<ex>er</ex></expan>
<expan>Volkm<ex>eir</ex></expan>, nehst <expan>unt<ex>er</ex></expan>
<expan>and<ex>er</ex>n</expan>
<expan>ding<ex>en</ex></expan> an den <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> den <expan>k<ex>ünig</ex></expan>
<expan>geworbe<ex>n</ex></expan> hat von der
                            <expan>anvordru<ex>n</ex>g</expan>
<expan>weg<ex>en</ex></expan>, die der edel <expan>h<ex>er</ex>re</expan>,
                                <expan>h<ex>e</ex>r</expan>
<expan>Reynh<ex>art</ex></expan>, <expan>h<ex>er</ex>re</expan> zu Hanaw, an
                        uns tut umb i<hi rend="sup">c</hi>
<expan>guld<ex>en</ex></expan> gelts, die er meynt zu
                            <expan>habe<ex>n</ex></expan> auf unser stewre, die wir doch einem
                                <expan>r<ex>ömischen</ex></expan> kunig und dem
                                <expan>heilig<ex>en</ex></expan> reich pflichtig seyn <expan>zu
                                gebe<ex>n</ex></expan>, darauf sein
                            <expan>künigl<ex>ich</ex></expan> majestat
                            <expan>dems<ex>elben</ex></expan> von Hanaw <expan>ab<ex>er</ex></expan>
<expan>geschr<ex>iben</ex></expan> hat, uns <expan>daru<ex>m</ex>b</expan>
                        on <expan>vordru<ex>n</ex>g</expan> zu <expan>lass<ex>en</ex></expan>, wan
                        sein <expan>künigl<ex>ich</ex></expan> gnade
                            <expan>ders<ex>elben</ex></expan> sache mit im zu awsztrag
                                <expan>kome<ex>n</ex></expan> welle vor
                            <expan>uns<ex>er</ex>n</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> den <expan>kurfürst<ex>en</ex></expan> etc.,
                        hat uns der <expan>obg<ex>enante</ex></expan>
<expan>Volkm<ex>eir</ex></expan> wol gesagt, wie ir ewch in den und
                                <expan>and<ex>er</ex>n</expan>
<expan>uns<ex>er</ex>n</expan>
<expan>sache<ex>n</ex></expan>
<expan>frewntl<ex>ich</ex></expan> und <expan>furderl<ex>ich</ex></expan>
                        beweiset, des wir <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> mit <expan>g<ex>anczem</ex></expan>
<expan>f<ex>eiss</ex></expan>
<expan>dank<ex>en</ex></expan>. Nu <expan>habe<ex>n</ex></expan> wir des
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>k<ex>ünigs</ex></expan>
<expan>br<ex>ief</ex></expan> dem von Hanaw <expan>ab<ex>er</ex></expan>
                        gesant; der hat dem <expan>bott<ex>en</ex></expan> gesagt, daz <pb facs="#facs_611" id="304v"/>er seinselbs <expan>botsch<ex>aft</ex></expan> zu
                                <expan>seine<ex>n</ex></expan>
<expan>küniglich<ex>en</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>schik<ex>en</ex></expan> welle. <expan>Daru<ex>m</ex>b</expan>
<expan>bitt<ex>en</ex></expan> wir ewr <expan>erberk<ex>eit</ex></expan>
<expan>fleissikl<ex>ich</ex></expan>, sey, daz
                            <expan>ders<ex>elb</ex></expan>
<expan>h<ex>er</ex>re</expan> von Hanaw sein
                            <expan>botsch<ex>aft</ex></expan> zu <expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, dem <expan>k<ex>ünig</ex></expan>, also tun
                                <expan>w<ex>er</ex>de</expan>, daz ir denn umb
                            <expan>uns<ex>er</ex>n</expan>
<expan>wille<ex>n</ex></expan> darczu <expan>furderl<ex>ich</ex></expan> und
                                <expan>beholff<ex>en</ex></expan> wellet sein, daz mit
                                <expan>ders<ex>elben</ex></expan>
<expan>botsch<ex>aft</ex></expan> bestellet <expan>w<ex>er</ex>de</expan>,
                        daz uns der <expan>obg<ex>enante</ex></expan> von Hanaw
                                <expan>anvordru<ex>n</ex>g</expan>
<expan>daru<ex>m</ex>b</expan>
<expan>v<ex>er</ex>trage</expan> und der sache mit dem
                                <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>m</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>, dem <expan>k<ex>ünig</ex></expan>, zu
                        awsztrag <expan>kom<ex>m</ex>e</expan>, als auch
                            <expan>dies<ex>elbe</ex></expan> sache <expan>seine<ex>n</ex></expan>
<expan>künigliche<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan> zusteet, und uns und die
                                <expan>uns<ex>er</ex>n</expan>
<expan>ewr<ex>er</ex></expan>
<expan>wirdik<ex>eit</ex></expan> in den und <expan>and<ex>er</ex>n</expan>
                        sachen hinfur auch <expan>gunstikl<ex>ich</ex></expan> befolhen lasset sein,
                        als etc. Das wellen etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> ii<hi rend="sup">a</hi>
<expan>p<ex>ost</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan>
<expan>palma<ex>rum</ex></expan>. </ab>
