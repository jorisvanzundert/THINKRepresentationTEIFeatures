<div type="addressee"><ab facs="#facs_600_r1l1"><expan>h<ex>er</ex>n</expan> francʒen cʒü Gran vnd <expan>h<ex>er</ex>n</expan> Micheln cʒü Boleſlan pröbſten </ab>
<ab facs="#facs_600_r1l2"><expan>vnſ<ex>er</ex>s</expan> <expan>gnedıgıſt<ex>en</ex></expan> <expan>h<ex>er</ex>ren</expan> des <expan>Romiſch<ex>e</ex>n</expan> etc kunigs <expan>p<ex>ro</ex>thonotarien</expan> </ab>
</div>
