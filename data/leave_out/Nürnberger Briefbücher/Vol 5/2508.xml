<ab facs="#facs_225_line_1577133939916_1743"><expan>Heınr<ex>ich</ex></expan> von <expan>parſp<ex>er</ex>g</expan> <expan>pfleg<ex>er</ex></expan> ʒu <expan>hırſp<ex>er</ex>g</expan> <expan>gebrud<ex>er</ex>n</expan> . <expan>ſı<ex>mi</ex>l<ex>ite</ex>r</expan> </ab>
