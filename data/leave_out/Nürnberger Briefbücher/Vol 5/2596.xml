<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt, wie ir
                                <expan>v<ex>er</ex>nom<ex>m</ex>en</expan> habt, daz unser gnedig
                                <expan>h<ex>er</ex>ren</expan> die
                            <expan>kurfürste<ex>n</ex></expan> und <expan>and<ex>er</ex></expan>
                        fürsten und stette gen Wirczburg bey<expan>einand<ex>er</ex></expan>
<expan>kome<ex>n</ex></expan> wellen etc., das <expan>habe<ex>n</ex></expan>
                        wir wol <expan>v<ex>er</ex>nomen</expan> und <expan>lass<ex>en</ex></expan>
                        ewr <expan>weish<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir <expan>davo<ex>n</ex></expan> niht
                                <expan>v<ex>er</ex>nomen</expan> haben. Wol haben wir
                                <expan>v<ex>er</ex>nom<ex>m</ex>en</expan>, daz
                                <expan>uns<ex>er</ex></expan> gnedig <expan>h<ex>er</ex>ren</expan>
                        die kurfürsten und auch die stette alls von <app>
<note><q type="date">morgen sunntag über acht tag</q>25.05.1421</note>
</app> gen Wesel <expan>kome<ex>n</ex></expan> süllen, dahin wir
                                <expan>uns<ex>er</ex></expan>
<expan>erb<ex>er</ex>n</expan>
<expan>bottsch<ex>aft</ex></expan> auch <expan>meyne<ex>n</ex></expan> zu
                                <expan>schike<ex>n</ex></expan>, da mag sich ewr
                                <expan>frewntsch<ex>aft</ex></expan> wol
                            <expan>wiss<ex>en</ex></expan> nach <expan>zu richte<ex>n</ex></expan>.
                            <pb facs="#facs_273" id="135v"/>Und als ir uns <expan>verschr<ex>iben</ex></expan>
                        habt von <expan>uns<ex>er</ex>s</expan>
<expan>gnedigist<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> des <expan>römisch<ex>en</ex></expan> etc.
                        künigs <expan>weg<ex>en</ex></expan>, <expan>davo<ex>n</ex></expan> haben
                        wir seid niht <expan>treffenlich<ex>er</ex></expan> meͣr
                                <expan>v<ex>er</ex>nome<ex>n</ex></expan>, denn als wir ewch nehst
                                <expan>verschr<ex>iben</ex></expan>
<expan>habe<ex>n</ex></expan>; auch <expan>sage<ex>n</ex></expan> ettlich
                        bey uns, daz sein <expan>künigl<ex>ich</ex></expan> gnade dennoch in kürcz
                        zu Prünn sülle <expan>gewese<ex>n</ex></expan> seyn. So
                                <expan>habe<ex>n</ex></expan> wir <expan>ewr<ex>er</ex></expan>
<expan>weish<ex>eit</ex></expan> nehst <expan>verschr<ex>iben</ex></expan>,
                        daz etlich <expan>uns<ex>er</ex></expan> frewnde zu dem
                                <expan>salpet<ex>er</ex></expan> und swefel füre bey uns bestellt
                                <expan>habe<ex>n</ex></expan> vor xii <expan>tage<ex>n</ex></expan>,
                                <expan>ewr<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> den zu
                            <expan>antw<ex>ur</ex>ten</expan>, <expan>wölte<ex>n</ex></expan> wir
                                <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>steen</expan>, ob ewch <expan>ders<ex>elb</ex></expan>
                        zewg also <expan>geantw<ex>ur</ex>tt</expan>
<expan>w<ex>er</ex>e</expan>. Denn wo wir <expan>ewr<ex>er</ex></expan>
<expan>ersamk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan>
<expan>an<ex>te</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan> trinitatis.</ab>
