<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Erwirdig<ex>er</ex></expan> und lieber <expan>h<ex>e</ex>r</expan>
<add><expan>com<ex>m</ex>entewr</expan></add>, als ir uns
                                <expan>verschr<ex>iben</ex></expan> habt von des pferds
                                <expan>weg<ex>en</ex></expan>, daz unser
                                <expan>vorstmeist<ex>er</ex></expan> den
                            <expan>ew<ex>r</ex>n</expan> aber <expan>genome<ex>n</ex></expan> hab
                        als von des walds <expan>weg<ex>en</ex></expan> etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan> und <expan>lass<ex>en</ex></expan> ewr
                                <expan>wirdik<ex>eit</ex></expan>
<expan>wiss<ex>en</ex></expan>, daz wir des walds ambtlewt
                                <expan>daru<ex>m</ex>b</expan> verhöret <add>und sie</add> uns
                        gesagt <add><expan>hab<ex>e</ex>n</expan></add>, daz die
                            <expan>ew<ex>r</ex>n</expan>
<expan>and<ex>er</ex>s</expan>
<expan>im<ex>m</ex></expan> wald gehawen <expan>hab<ex>e</ex>n</expan>, denn
                        sie pillich <expan>süll<ex>e</ex>n</expan>; <expan>daru<ex>m</ex>b</expan>
                        sey in das pferd <expan>genome<ex>n</ex></expan>
<expan>worde<ex>n</ex></expan>, daz <add>wolt</add> man in <add>doch</add>
<expan>g<ex>er</ex>n</expan>
<expan>auszgeb<ex>e</ex>n</expan>
<expan>hab<ex>e</ex>n</expan> auf des walds recht. <add>So</add>
<expan>hab<ex>e</ex>n</expan> die <expan>ew<ex>r</ex>n</expan>
<add>des</add> niht <expan>well<ex>e</ex>n</expan>
<expan>auszneme<ex>n</ex></expan>, wie <expan>daru<ex>m</ex>b</expan>
<expan>well<ex>e</ex>n</expan> die <expan>ew<ex>r</ex>n</expan> das pferd
                        noch <expan>auszneme<ex>n</ex></expan> auf des walds recht, das sol man in
                        umb <expan>ew<ex>r</ex>n</expan>
<expan>will<ex>e</ex>n</expan>
<expan>g<ex>er</ex>n</expan> also <expan>auszgeb<ex>e</ex>n</expan>. Denn wo
                        wir <expan>ewr<ex>er</ex></expan>
<expan>erwirdik<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> margarete.</ab>
</div>
