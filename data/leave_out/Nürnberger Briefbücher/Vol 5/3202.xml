<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr <expan>hoch<ex>wirdikeit</ex></expan>
<add>aber </add>
<expan>verschr<ex>iben</ex></expan> hat von F. Win<expan>terstein<ex>er</ex>s</expan>,
            ewrs <expan>dien<ex>er</ex>s</expan>, und <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>weg<ex>en</ex></expan>
<expan>S<ex>eicz</ex></expan> Gewders etc., das haben wir wol
              <expan>vernom<ex>en</ex></expan>. Nu meynt <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan>
<expan>S<ex>eicz</ex></expan>
<expan>Gewd<ex>er</ex></expan> als vor, er hab des F.
              <expan>Winterstein<ex>er</ex>s</expan> hab nichts ynnen; so seyn die sache
                <expan>zwisch<ex>en</ex></expan> in vor mit recht zu ende
              <expan>kome<ex>n</ex></expan>. Wie <expan>daru<ex>m</ex>b</expan> so
                <expan>habe<ex>n</ex></expan> wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> zu eren <expan>sov<ex>er</ex>ren</expan> mit <add>
<expan>S<ex>eiczen</ex></expan>
<expan>Gewd<ex>er</ex></expan></add> geredt, daz er uns
              <expan>geantw<ex>ur</ex>tt</expan> hat, er welle selbs zu <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> reiten <expan>hiezwisch<ex>en</ex></expan>
<app>
<note><q type="date">sand <expan>Walp<ex>ur</ex>gen</expan> tag
                schierist</q>01.05.1423</note>
</app> und <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> die sache erczeln, daz er hoff, ewr gnade
                <expan>w<ex>er</ex>d</expan> versteen, daz er redlichen darob
                <expan>gewes<ex>en</ex></expan> und noch sey; denn wo wir
              <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> dienst und wolgefallen etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> vi<hi rend="sup"> a </hi>
<expan>an<ex>te</ex></expan>
<expan>d<ex>omi</ex>nicam</expan>
<expan>palma<ex>rum</ex></expan>. </ab>
</div>
