<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>hawbtm<ex>an</ex></expan>, als uns ewr
                            <expan>erberk<ex>eit</ex></expan>
<expan>verschr<ex>iben</ex></expan> hat, wie ir
                            <expan>und<ex>er</ex>weiset</expan> seyt <expan>word<ex>en</ex></expan>,
                        daz <expan>h<ex>e</ex>r</expan>
<expan>Fridr<ex>ich</ex></expan> und <expan>h<ex>e</ex>r</expan> Hanns,
                                <expan>gebrud<ex>er</ex></expan>, von Colobrat in
                                <expan>ein<ex>en</ex></expan> unfrid gen uns
                                ge<expan>trette<ex>n</ex></expan> sein von
                            <expan>Fricze<ex>n</ex></expan>
<expan>vom<ex>m</ex></expan>
<expan>Eglofst<ex>ein</ex></expan>
<expan>weg<ex>en</ex></expan>, <expan>dies<ex>elben</ex></expan> von
                        Colobrat an ewch bracht und <expan>gebette<ex>n</ex></expan>
<expan>hab<ex>e</ex>n</expan>, seiddemmal <expan>F<ex>ricz</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Eglofst<ex>ein</ex></expan>
<expan>gestorbe<ex>n</ex></expan> ist, daz sie uns noch den
                                <expan>uns<ex>er</ex>n</expan> in keinrley weis schedlich sein noch
                                <expan>unwill<ex>e</ex>n</expan>
<expan>beweis<ex>en</ex></expan>
<expan>well<ex>e</ex>n</expan>, <expan>sund<ex>er</ex></expan> uns und den
                                <expan>uns<ex>er</ex>n</expan>
<expan>beg<ex>er</ex>n</expan> zu dienen und sie sein des
                                <expan>vollkomenl<ex>ich</ex></expan> auf ewch
                            <expan>kome<ex>n</ex></expan> etc., das <expan>hab<ex>e</ex>n</expan>
                        wir wol <expan>vernom<ex>en</ex></expan>. Und
                            <expan>sölich<ex>er</ex></expan>
<expan>ewr<ex>er</ex></expan>
<expan>frewntlich<ex>en</ex></expan> schrift <expan>dank<ex>en</ex></expan>
                        wir <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> mit <expan>g<ex>anczem</ex></expan> fleiss
                        und <expan>lass<ex>en</ex></expan> ewch <expan>wiss<ex>en</ex></expan>, daz
                        uns die <expan>vorg<ex>enante</ex>n</expan> von Colobrat entsagt und
                        etwievil <expan>and<ex>er</ex>r</expan> mit in zu
                            <expan>veynd<ex>en</ex></expan> gemacht <expan>hab<ex>e</ex>n</expan>
                        von des <expan>vorg<ex>enanten</ex></expan>
<expan>F<ex>ricz</ex></expan>
<expan>vo<ex>n</ex></expan>
<expan>Eglofst<ex>ein</ex></expan> und auch von
                            <expan>Conr<ex>ad</ex></expan>
<expan>Truchsess<ex>en</ex></expan>
<expan>weg<ex>en</ex></expan>, <expan>vom<ex>m</ex></expan> Holnstein, des
                        wir doch umb <expan>dies<ex>elben</ex></expan>
<expan>vo<ex>n</ex></expan> Colobrat niht <expan>v<ex>er</ex>dient</expan>
