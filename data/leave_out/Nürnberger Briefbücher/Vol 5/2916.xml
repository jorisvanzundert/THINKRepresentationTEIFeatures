<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan> Hartman, als wir ewch
                                                die pfründe zu sand Kathreyn bey uns zu
                                                  <expan>Nür<ex>emberg</ex></expan>, die nach
                                                  <expan>ir<ex>er</ex></expan>
<expan>instituc<ex>i</ex>on</expan>
<add>zu</add> halten und <add>selb</add> leiplich
                                                  <pb facs="#facs_449" id="223v"/><expan>zu
                                                  v<ex>er</ex>wesen</expan>, <add>umb gots
                                                  willen</add> gelihen haben, also
                                                  <expan>erford<ex>er</ex>n</expan> wir ewch mit
                                                disem <expan>br<ex>ief</ex></expan>, daz ir on
                                                  <expan>v<ex>er</ex>cziehen</expan>
<expan>hiezwische<ex>n</ex></expan> <app><note><q type="date">sand Johanns tag
                                            <expan>sünwend<ex>en</ex></expan> schierist
                                            künftig</q>24.06.1422</note></app> zu uns <expan>kom<ex>m</ex>et</expan> und
                                                dieselben pfründe leiplichen
                                                  <expan>v<ex>er</ex>weset</expan> und awszrichtet,
                                                als ir des <expan>uns<ex>er</ex>m</expan>
<expan>h<ex>e</ex>rgot</expan> und ewchselbs
                                                schuldig seyt und ewch auch des zu tun
                                                  <expan>v<ex>er</ex>punden</expan> habt. Daran tut
                                                ir genczlich <expan>uns<ex>er</ex>n</expan> willen,
                                                wan gescheͣh des niht, so
                                                  <expan>möchte<ex>n</ex></expan> wir von gewissen
                                                  <expan>weg<ex>en</ex></expan> niht
                                                  <expan>gelass<ex>en</ex></expan> darczu zu tun als
                                                uns gepürot, damit dieselb pfründe nach
                                                  <expan>ir<ex>er</ex></expan>
<expan>instituc<ex>i</ex>on</expan>
<expan>v<ex>er</ex>wesen</expan> und auszgericht
                                                wurde. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi>.</ab>
</div>
