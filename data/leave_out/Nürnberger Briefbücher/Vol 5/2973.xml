<ab facs="#facs_483_r2l31">
<del rend="strikethrough">da </del> <expan>Sc<ex>ri</ex>pt<ex>um</ex></expan> <expan>do<ex>min</ex>ıca</expan> <expan>an<ex>te</ex></expan> Margarete <expan>virg<ex>inis</ex></expan> </ab></del>
</div>
</div><div type="regularised"><pb facs="#facs_483" id="240v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><del rend="crossout">Erczbysschof czu Meincz</del></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                                <expan>hoch<ex>wirdikeit</ex></expan>
<expan>yecz<ex>unden</ex></expan>
<add>als von geleits</add> wegen <expan>verschrib<ex>e</ex>n</expan> hat
                            etc., das <expan>hab<ex>e</ex>n</expan> wir wol
                                <expan>v<ex>er</ex>nomen</expan>. Nu als uns ewr
                                    <expan>hoch<ex>wirdikeit</ex></expan>
<add>nehst mitsampt</add>
<expan>and<ex>er</ex>n</expan>
<expan>ew<ex>r</ex>n</expan> mitkürfürsten,
                                <expan>uns<ex>er</ex>en</expan> gnedigen
                                <expan>h<ex>er</ex>ren</expan>, <add>auch von
                                        <expan>dess<ex>elben</ex></expan></add> geleits wegen
                                    <expan>v<ex>er</ex>schrib<ex>e</ex>n</expan>
<add>het, in <expan>demselb<ex>e</ex>n</expan>
<expan>br<ex>ief</ex></expan></add>
<add>begriffen was</add>, daz wir darümb von ewr aller wegen
                                    <expan>uns<ex>er</ex>m</expan> gnedigen
                                <expan>h<ex>er</ex>ren</expan> dem marggraf von
                                    <expan>Brande<ex>n</ex>b<ex>ur</ex>g</expan> etc. antwurtten
                                    <expan>solte<ex>n</ex></expan>, darauff
                                <expan>hab<ex>e</ex>n</expan> wir dessmals
                                <expan>demselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>m</expan>
<expan>h<ex>er</ex>ren</expan> dem margrafen
                                <expan>uns<ex>er</ex>n</expan> offen besigelten geleitsbrief gesant
                            und <expan>geantw<ex>ur</ex>t</expan> und sein on czweyfel, ee
                                    <expan>ew<ex>r</ex>n</expan> gnaden diser
                                <expan>uns<ex>er</ex></expan> brief werde, ez hab der
                                    <expan>eg<ex>enante</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> der margraf dasselbe
                                        <add><expan>ew<ex>r</ex>n</expan> gnaden</add> verkundiget
                            und zu wissen getan. Und wo etc.
                                <expan>Sc<ex>ri</ex>pt<ex>um</ex></expan>
<expan>do<ex>min</ex>ica</expan>
<expan>an<ex>te</ex></expan> Margarete
                            <expan>virg<ex>inis</ex></expan>.</del></ab>
</div>
