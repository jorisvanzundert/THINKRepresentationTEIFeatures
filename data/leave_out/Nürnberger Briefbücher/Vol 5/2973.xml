<add><ab facs="#facs_483_r2l15">nehſt mitſampt </ab></add> <expan>and<ex>er</ex>n</expan> <expan>ew<ex>r</ex>n</expan> mitkürfürſten <expan>vnſ<ex>er</ex>en</expan> </ab>
<ab facs="#facs_483_r2l18">gnedigen <expan>h<ex>er</ex>ren</expan>
<del rend="strikethrough"><expan>v<ex>er</ex>ſchrib<ex>e</ex>n</expan> <expan>hab<ex>e</ex>n</expan> vormals 
<add><ab facs="#facs_483_r2l17">auch </ab></add> von </del></ab>
<ab facs="#facs_483_r2l20">
<add><ab facs="#facs_483_r1l1">auch von <expan>deſſ<ex>elben</ex></expan> </ab></add> geleits wegen <expan>v<ex>er</ex>ſchrib<ex>e</ex>n</expan>
<del rend="strikethrough"><expan>hab<ex>e</ex>n</expan> darynne <expan>begriffe<ex>n</ex></expan> iſt </del>
<add><ab facs="#facs_483_line_1592198681252_645">het Jn <expan>demſelb<ex>e</ex>n</expan> <expan>br<ex>ief</ex></expan> </ab></add> </ab>
<ab facs="#facs_483_r2l21">
<add><ab facs="#facs_483_r1l2">begrıffen was </ab></add> daʒ vvir darümb von ewr aller wegen <expan>vnſ<ex>er</ex>m</expan> </ab>
<ab facs="#facs_483_r2l22">gnedigen <expan>h<ex>er</ex>ren</expan> ~ dem Marggraf von <expan>Brande<ex>n</ex>b<ex>ur</ex>g</expan> etc </ab>
