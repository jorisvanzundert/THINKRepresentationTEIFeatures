<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als ir uns
                            <expan>verschr<ex>iben</ex></expan> habt, von
                            <expan>ew<ex>r</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>Hanns<ex>en</ex></expan> Porers und <expan>uns<ex>er</ex>s</expan>
<expan>b<ex>urgers</ex></expan>
<expan>weg<ex>en</ex></expan>
<expan>gena<ex>n</ex>t</expan> der Wolf etc., das
                            <expan>hab<ex>e</ex>n</expan> wir wol <expan>vernom<ex>en</ex></expan>
                        und <expan>lass<ex>en</ex></expan> ewch <expan>wiss<ex>en</ex></expan>, daz
                        wir nach <expan>dems<ex>elben</ex></expan> Wolf gesandt
                                <expan>hette<ex>n</ex></expan> und <expan>wolte<ex>n</ex></expan>
                        mit im <expan>davo<ex>n</ex></expan> geredt <expan>habe<ex>n</ex></expan>,
                        do ward von seinr <expan>wirtin<ex>n</ex></expan> zu
                            <expan>wiss<ex>en</ex></expan> getan, daz er auf disz zeit niht anheim
                        bey uns <expan>w<ex>er</ex>e</expan>; doch wenn er
                            <expan>h<ex>er</ex>heim</expan> kombt, so <expan>well<ex>e</ex>n</expan>
                        wir umb <expan>ew<ex>r</ex>n</expan>
<expan>wille<ex>n</ex></expan>
<expan>g<ex>er</ex>n</expan> mit im <expan>davo<ex>n</ex></expan> reden, ob
                        wir daran gemant <expan>w<ex>er</ex>den</expan>. Dewht
                            <expan>ab<ex>er</ex></expan> den <expan>vorg<ex>enanten</ex></expan>
<expan>Hanns<ex>en</ex></expan> Porer <expan>ew<ex>r</ex>n</expan>
<expan>b<ex>urger</ex></expan>, daz er <expan>darüb<ex>er</ex></expan> zu
                        dem <expan>obg<ex>enanten</ex></expan> Wolf <expan>uns<ex>er</ex>m</expan>
<expan>b<ex>urger</ex></expan> icht <expan>zuspreche<ex>n</ex></expan> hett,
                        so <expan>well<ex>e</ex>n</expan> wir im <expan>od<ex>er</ex></expan>
<expan>seine<ex>m</ex></expan>
<expan>scheinbott<ex>en</ex></expan> mit <expan>seine<ex>m</ex></expan>
<expan>volle<ex>n</ex></expan> gwalt <expan>frewntl<ex>ich</ex></expan>
                        slewnigs <expan>rechte<ex>n</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> vor des reichs
                            <expan>richt<ex>er</ex></expan> bey uns zu
                            <expan>Nur<ex>emberg</ex></expan>, wenn wir des ermant
                                <expan>w<ex>er</ex>den</expan>, so <expan>ders<ex>elb</ex></expan>
                        Wolf <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> bey uns anheim ist on
                            <expan>gev<ex>er</ex>de</expan>. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>frewnts<ex>chaft</ex></expan> lieb <expan>od<ex>er</ex></expan>
                        dienst etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iii<hi rend="sup">a</hi>
<expan>i<ex>n</ex></expan> festo <expan>penthecost<ex>en</ex></expan>.</ab>
