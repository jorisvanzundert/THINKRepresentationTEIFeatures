<ab facs="#facs_391_r2l28"><expan>pran<ex>n</ex>t</expan> <expan>habe<ex>n</ex></expan> on ſchuld vnd on ſache . <expan>daru<ex>m</ex>b</expan> etlıch <expan>vnſ<ex>er</ex></expan> <expan>burg<ex>er</ex></expan> </ab>
