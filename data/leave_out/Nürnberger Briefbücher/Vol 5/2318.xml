<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir <expan>bitt<ex>en</ex></expan> ewr gnade
                        mit fleiss, daz ir von <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>schik<ex>en</ex></expan> und <expan>bestell<ex>e</ex>n</expan>
                        wellet, daz <expan>uns<ex>er</ex></expan>
<expan>b<ex>urger</ex></expan> und kawfflewt und auch ir hab und
                                <expan>kawffmansch<ex>aft</ex></expan> und die iren
                                <expan>yeczu<ex>n</ex>d</expan> in
                            <expan>Nördling<ex>er</ex></expan> markt und
                            <expan>wid<ex>er</ex></expan> darausz durch ewr
                            <expan>h<ex>e</ex>rschaft</expan> und gepiete
                            <expan>sich<ex>er</ex></expan> geleytet <expan>w<ex>er</ex>den</expan>,
                        wenn sie <expan>od<ex>er</ex></expan> die iren zu
                            <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> oder den <expan>ew<ex>r</ex>n</expan>
<expan>daru<ex>m</ex>b</expan>
<expan>kome<ex>n</ex></expan> und des begern <expan>w<ex>er</ex>den</expan>.
                        Als etc. Das <expan>well<ex>e</ex>n</expan> etc. Und
                            <expan>bitt<ex>en</ex></expan> des ewr gnedig
                                <expan>verschr<ex>iben</ex></expan> antwurt
                            <expan>wid<ex>er</ex></expan> bey disem <expan>uns<ex>er</ex>m</expan>
<expan>dien<ex>er</ex></expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan>
<expan>festu<ex>m</ex></expan>
<expan>penthecost<ex>en</ex></expan>.</ab>
</div>
<div type="similiter">
<ab><expan>H<ex>er</ex>n</expan>
