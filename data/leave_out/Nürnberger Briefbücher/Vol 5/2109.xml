<div type="content">
<ab><expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, als
                                                  <expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> marggraf
                                                  <expan>Fridr<ex>ich</ex></expan> von
                                                  <expan>Brandemb<ex>ur</ex>g</expan> nehst ewr und
                                                  <expan>etlich<ex>er</ex></expan>
<expan>and<ex>er</ex>r</expan> reichs stette,
                                                  <expan>uns<ex>er</ex>r</expan> guten frewnde,
                                                  <expan>erb<ex>er</ex>n</expan> botten zu
                                                  <expan>seine<ex>n</ex></expan>
<expan>gnad<ex>en</ex></expan> gen
                                                  <expan>Nördling<ex>en</ex></expan> zu
                                                  <expan>sende<ex>n</ex></expan>
<expan>geford<ex>er</ex>t</expan> hat, darczu wir
                                                  <expan>uns<ex>er</ex></expan>
<expan>erb<ex>er</ex></expan>
<expan>botsch<ex>aft</ex></expan> auch gesant
                                                  <expan>hab<ex>e</ex>n</expan>, die uns
                                                  <expan>desselb<ex>e</ex>n</expan>
<expan>uns<ex>er</ex>s</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>marggraf<ex>en</ex></expan>
<expan>gew<ex>er</ex>be</expan> wol fürbracht hat,
                                                  <expan>desgleiche<ex>n</ex></expan> ir sölich
                                                  <expan>gew<ex>er</ex>be</expan> von
                                                  <expan>ew<ex>r</ex></expan>
<expan>erb<ex>er</ex>n</expan>
<expan>bottsch<ex>aft</ex></expan> nu auch wol
                                                  <expan>v<ex>er</ex>nomen</expan> habt.
                                                  <expan>L<ex>ieben</ex></expan>
<expan>fr<ex>eunde</ex></expan>, ob ir nu ewr und
                                                  <expan>uns<ex>er</ex></expan> gut frewnde des
                                                reichs stette <expan>daru<ex>m</ex>b</expan>
                                                  zu<expan>same<ex>n</ex></expan>
<expan>mane<ex>n</ex></expan> woltet, so wolten wir
                                                  <expan>uns<ex>er</ex></expan> er[ber]
                                                  <expan>botsch<ex>aft</ex></expan>
<expan>g<ex>er</ex>n</expan> darczu
                                                  <expan>sende<ex>n</ex></expan>, sich da von den
                                                  <expan>sache<ex>n</ex></expan>
<expan>beratenl<ex>ich</ex></expan> zu
                                                  <expan>unt<ex>er</ex>reden</expan>, wi[e] sich
                                                darinn zu <expan>halte<ex>n</ex></expan> und darczu
                                                zu <expan>antw<ex>ur</ex>ten</expan>
<expan>w<ex>er</ex>e</expan>, wan uns des
                                                  <add>und</add> den <expan>stette<ex>n</ex></expan>
                                                ein grosse notdurft dewcht.
                                                  <expan>Alsv<ex>er</ex>r</expan> ewch das auch
                                                gefallt und geraten dunkt und ob ir
                                                  <expan>sölich<ex>er</ex></expan>
<expan>manu<ex>n</ex>g</expan> also zu rat würdt und
                                                wohin <expan>od<ex>er</ex></expan> wie ir ewch
                                                  <expan>davo<ex>n</ex></expan>
<expan>unt<ex>er</ex>redt</expan> habt,
                                                  <expan>bitt<ex>en</ex></expan> wir ewr
                                                  <expan>weish<ex>eit</ex></expan> mit fleiss uns
                                                des bey disem <expan>uns<ex>er</ex>m</expan>
<expan>bott<ex>en</ex></expan> in
                                                  <expan>gut<ex>er</ex></expan>
<expan>frewntsch<ex>aft</ex></expan> zu
                                                  <expan>verschr<ex>eiben</ex></expan>, als vil ewch
                                                füklich sey als etc. Das
                                                  <expan>well<ex>e</ex>n</expan> etc.
                                                  <expan>Dat<ex>um</ex></expan> ut
                                                  <expan>s<ex>upra</ex>.</expan>
</ab>
