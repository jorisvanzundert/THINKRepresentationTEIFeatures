<div type="addressee">
<ab><expan>Rot<ex>emburg</ex></expan>, <expan>Winsh<ex>eim</ex></expan>,
                                <expan>Weissemb<ex>ur</ex>g</expan>
<expan>cuil<ex>ibet</ex></expan>
