</div><div type="regularised"><pb facs="#facs_201" id="99v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan> Wilhelm, <expan>lantgraf<ex>en</ex></expan> in
                        Döringen und <expan>marggraf<ex>en</ex></expan> zu Meichsen</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als uns ewr
                            <expan>hoch<ex>wirdikeit</ex></expan> zunehst
                                <expan>verschr<ex>iben</ex></expan> hat von Nikel Erharts
                                <expan>weg<ex>en</ex></expan> etc., also
                            <expan>schik<ex>en</ex></expan> wir zu <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>Burkart<ex>en</ex></expan>
<expan>Reikarczhof<ex>er</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>dien<ex>er</ex></expan>, dem wir <expan>befolhe<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>, mit <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>davo<ex>n</ex></expan> czu reden; und <expan>bitt<ex>en</ex></expan>
                        ewr <expan>hoch<ex>wirdikeit</ex></expan> mit fleiss, was
                                <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> in <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> zu disem mal von
                            <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr gnade werbe, daz ir in darinn
                                <expan>gnedikl<ex>ich</ex></expan>
<expan>v<ex>er</ex>hören</expan>, im des <expan>genczl<ex>ich</ex></expan>
                        gelawben und <expan>günstikl<ex>ich</ex></expan>
<expan>daru<ex>m</ex>b</expan> von ew <expan>fertig<ex>en</ex></expan>
                        wellet, als wir <expan>ew<ex>r</ex>n</expan>
<expan>furstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wol getrawen. Das
                            <expan>well<ex>e</ex>n</expan> wir umb ewr
                            <expan>hoch<ex>wirdikeit</ex></expan>
<expan>willikl<ex>ich</ex></expan> und gern
                            <expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan> post <expan>om<ex>n</ex>i</expan>
<expan>s<ex>an</ex>c<ex>t</ex>o<ex>rum</ex></expan>.</ab>
</div>
