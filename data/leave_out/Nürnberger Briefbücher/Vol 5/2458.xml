<ab facs="#facs_201_r1l5"><expan>gnad<ex>en</ex></expan> <expan>Burkart<ex>en</ex></expan> <expan>Reıkarcʒhof<ex>er</ex></expan> <expan>vnſ<ex>er</ex>n</expan> <expan>dıen<ex>er</ex></expan> Dem wır <expan>befolhe<ex>n</ex></expan> <expan>habe<ex>n</ex></expan> </ab>
