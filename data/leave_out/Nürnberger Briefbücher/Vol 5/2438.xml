<ab facs="#facs_189_r2l31"><expan>volle<ex>n</ex></expan> <expan>g<ex>ewalt</ex></expan> <expan>vnu<ex>er</ex>cʒog<ex>en</ex></expan> helffen <expan>wölle<ex>n</ex></expan> . <expan>vven<ex>n</ex></expan> vvir des </ab>
<ab facs="#facs_189_r2l32">ermant <expan>vverde<ex>n</ex></expan> ſo derſelb ~ <expan>vnſ<ex>er</ex></expan> <expan>B<ex>urger</ex></expan> anheim iſt </ab>
