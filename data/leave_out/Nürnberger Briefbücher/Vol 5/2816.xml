<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content"><ab><app>
<note place="marginleft">+ </note>
</app>
<expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir bitten ewr
                                                  <expan>hoch<ex>wirdikeit</ex></expan> mit
                                                  <expan>gancze<ex>m</ex></expan> fleisz, daz ewr
                                                gnade <expan>uns<ex>er</ex></expan>
<expan>burg<ex>er</ex></expan> und kawfflewt und
                                                auch ir habe und
                                                  <expan>kawffmans<ex>chaft</ex></expan> und die
                                                iren in die <expan>nehstkünftig<ex>en</ex></expan>
<expan>Frankfurt<ex>er</ex></expan> vastenmesse und
                                                wider darawsz mit geleyt
                                                  <expan>gnedikl<ex>ich</ex></expan> fürsehen welle;
                                                also wenn sie oder die iren zu
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> oder aber den
                                                  <expan>ew<ex>r</ex>n</expan>
<expan>daru<ex>m</ex>b</expan>
<expan>kome<ex>n</ex></expan> und des begern, daz
                                                denn sie und das ir durch
                                                  <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> lande,
                                                  <expan>h<ex>e</ex>rschaft</expan> und gepiete
                                                sicher geleytet <expan>w<ex>er</ex>den</expan>, als
                                                wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> wol getrawen. Das
                                                wellen wir umb ewr
                                                  <expan>hoch<ex>wirdikeit</ex></expan>
<expan>willikl<ex>ich</ex></expan> und
                                                  <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>
<add>und <expan>bitt<ex>en</ex></expan> des ewr
                                                  gnedig <expan>verschr<ex>iben</ex></expan> antwurt
                                                  <expan>wid<ex>er</ex></expan> bey disem
                                                  <expan>uns<ex>er</ex>m</expan> diener</add>.
                                                  <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan>
<add>v<hi rend="sup">a</hi></add>
<expan>p<ex>ost</ex></expan> Scolastice
                                                  <expan>virg<ex>in</ex>is</expan>. </ab></div>
