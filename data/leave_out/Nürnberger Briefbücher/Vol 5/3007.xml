</div><div type="regularised"><pb facs="#facs_504" id="251r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Ludwig<ex>en</ex></expan>, <expan>pfallnczgraf<ex>en</ex></expan> bey
                        Reyn, des <expan>heilig<ex>en</ex></expan>
<expan>römische<ex>n</ex></expan> reichs ercztruchsess und
                                <expan>h<ex>er</ex>czog</expan> in Peyern,
                            <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, wir <expan>schik<ex>en</ex></expan> zu
                                <expan>ewr<ex>er</ex></expan>
<expan>durchlewchtik<ex>eit</ex></expan> Jobs
                        <expan>Kapf<ex>er</ex></expan>, <expan>uns<ex>er</ex>n</expan>
<expan>schreib<ex>er</ex></expan>, dem wir befolhen
                            <expan>habe<ex>n</ex></expan>, mit <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> zu <expan>red<ex>en</ex></expan> von
                        den sachen, die sich <expan>zwische<ex>n</ex></expan>
<expan>uns<ex>er</ex></expan> und <expan>Hanns<ex>en</ex></expan> von
                                <expan>Rosemb<ex>er</ex>g</expan>
<expan>ergang<ex>en</ex></expan> haben und auch von des newen zolles
                                <expan>weg<ex>en</ex></expan>, den man in dem lande zu
                                <expan>Franke<ex>n</ex></expan> untersteen meynt <expan>zu
                                neme<ex>n</ex></expan>, und <expan>bitt<ex>en</ex></expan> ewr
                                <expan>fürstenl<ex>ich</ex></expan> gnade mit fleiss, was
                                <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>dien<ex>er</ex></expan> in den <expan>vorgen<ex>anten</ex></expan>
                        sachen zu disem mal von <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr <expan>durchl<ex>euhtikeit</ex></expan>
<expan>w<ex>er</ex>be</expan>, daz ewr <expan>hoch<ex>wirdikeit</ex></expan>
                        in darinn <expan>gnedikl<ex>ich</ex></expan>
<expan>v<ex>er</ex>hören</expan>, im des <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und <expan>günstikl<ex>ich</ex></expan> von
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>daru<ex>m</ex>b</expan>
<expan>fertig<ex>en</ex></expan>
<add>geruche</add>, als wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> etc. Denn wo wir
                            <expan>ewr<ex>er</ex></expan>
<expan>durchl<ex>euhtikeit</ex></expan> dienst und wolgefallen etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>d<ex>omi</ex>nica</expan> die <expan>an<ex>te</ex></expan>
                            exaltac<ex>i</ex>o<ex>n</ex>is <expan>s<ex>an</ex>c<ex>t</ex>e</expan>
                        crucis.</ab>
</div>
