</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Nob<ex>i</ex>lis</expan> et <expan>g<ex>e</ex>n<ex>er</ex>ose</expan>
<expan>d<ex>omi</ex>ne</expan>,
                            <expan>p<ex>ro</ex>posueru<ex>n</ex>t</expan> nobis
                                <expan>it<ex>eru</ex>m</expan>.
                            <expan>P<ex>rae</ex>p<ex>osi</ex>tus</expan> et sui mansionarii de aula
                                <expan>gl<ex>or</ex>iose</expan>
<expan>virg<ex>in</ex>is</expan> Marie penes nos,
                            <expan>quali<ex>ter</ex></expan> debita <expan>ip<ex>s</ex>a</expan>
<expan>p<ex>ro</ex></expan>
<expan>quib<ex>us</ex></expan>
<expan>v<ex>est</ex>re</expan>
<expan>nob<ex>i</ex>li<ex>ta</ex><hi rend="sup">ti</hi></expan>
<expan>pl<ex>ur</ex>ies</expan>
<expan>sc<ex>ri</ex>psim<ex>us</ex></expan>
<expan>ip<ex>s</ex>is</expan> nondum sint soluta
                            <expan>q<ex>uo</ex>d</expan>
<expan>utiq<ex>ue</ex></expan> in <expan>ip<ex>s</ex>ar<ex>um</ex></expan>
                        grave <expan>dispendi<ex>u</ex><hi rend="sup">m</hi></expan> redundare
                                <expan>videt<ex>ur</ex></expan>.
                            <expan>Quap<ex>ro</ex>pt<ex>er</ex></expan> ad
                            <expan>v<ex>est</ex>ram</expan>
<expan>g<ex>e</ex>n<ex>er</ex>ositate<ex>m</ex></expan>
<expan>p<ex>ro</ex></expan>
<expan>nu<ex>n</ex>c</expan>
<expan>it<ex>eru</ex>m</expan> ad <expan>instancia<ex>m</ex></expan>
<expan>eorund<ex>em</ex></expan>
<expan>p<ex>rae</ex>p<ex>osi</ex>ti</expan> et
                                <expan>mansionarior<ex>um</ex></expan>
<expan>porrige<ex>re</ex></expan>
<expan>duxi<ex>mus</ex></expan>
<expan>p<ex>re</ex>ces</expan>
<expan>n<ex>ost</ex>ras</expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan>
<expan>obsequior<ex>um</ex></expan>
<expan>n<ex>ost</ex>ror<ex>um</ex></expan> intuitu necnon
                                <expan>p<ex>rae</ex>cipue</expan> ob honorem et
                                <expan>reve<ex>re</ex>ncia<ex>m</ex></expan> tam eximii
                                <expan>fundator<ex>is</ex></expan> aule
                                <expan>p<ex>rae</ex>sc<ex>ri</ex>pte</expan>
<expan>ip<ex>s</ex>a</expan> debita <expan>p<ex>rae</ex>tacto</expan>
<expan>p<ex>rae</ex>p<ex>osi</ex>to</expan><pb facs="#facs_60" id="29r"/> qui
                                <expan>p<ex>ro</ex>p<ex>ri</ex>a</expan> in
                            <expan>p<ex>er</ex>sona</expan>
<expan>nob<ex>i</ex>li<ex>ta</ex><hi rend="sup">te<ex>m</ex></hi></expan>
<expan>v<ex>est</ex>ra<ex>m</ex></expan> obinde
                            <expan>accede<ex>re</ex></expan>
<expan>conat<ex>ur</ex></expan> velitis <expan>absq<ex>ue</ex></expan>
                        ulteriori <expan>p<ex>ro</ex>rogac<ex>i</ex>o<ex>n</ex>e</expan>
<expan>g<ex>lo</ex>r<ex>i</ex>osi<ex>us</ex></expan>
<expan>p<ex>er</ex>solve<ex>re</ex></expan> ac
                            <expan>real<ex>ite</ex>r</expan> expedire, <expan>p<ex>ro</ex>ut</expan>
                        de <expan>v<ex>est</ex>ra</expan>
<expan>g<ex>e</ex>n<ex>er</ex>ositate</expan> plene
                                <expan>c<ex>on</ex>fidim<expan>us</expan></expan>. Quod
                                <expan>p<ex>er</ex></expan> eadem
                                <expan>g<ex>e</ex>n<ex>er</ex>osi<ex>ta</ex><hi rend="sup">te</hi></expan>
<expan>v<ex>est</ex>ra</expan>
<expan>volumu<ex>us</ex></expan>
<expan>iugit<ex>er</ex></expan>
<expan>p<ex>ro</ex>mereri</expan>. <expan>Datum</expan> xxiiii<hi rend="sup">mo</hi>die octobris anno etc. xix<hi rend="sup">no</hi>.</ab>
