<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, es hat Hanns
                            <expan>Fridereck<ex>er</ex></expan> an uns und etlichen den
                                <expan>uns<ex>er</ex>n</expan> etwas
                            <expan>begang<ex>en</ex></expan>, daz er sich
                            <expan>etlich<ex>er</ex></expan> der <expan>uns<ex>er</ex>n</expan> hab
                        und gut <expan>ungetrewl<ex>ich</ex></expan>
<expan>unt<ex>er</ex>wunden</expan> und die <expan>h<ex>er</ex>n</expan>
<expan>Conr<ex>ad</ex></expan>
<expan>Truchsess<ex>en</ex></expan> gen
                        <expan>Pom<ex>m</ex>ers</expan>felden zugefürt und bracht hat, darumb wir
                                <expan>Barthl<ex>omes</ex></expan> Neythart,
                            <expan>uns<ex>er</ex>n</expan>
<expan>ratschr<ex>eiber</ex></expan>, zu <expan>ewr<ex>er</ex></expan>
<expan>durchlewch<ex>tikeit</ex></expan>
<expan>schik<ex>en</ex></expan>, dem wir <expan>befolhe<ex>n</ex></expan>
<expan>habe<ex>n</ex></expan>, mit <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> davon <expan>zu red<ex>en</ex></expan>
                        und den handel zu erczeln; und <expan>bitt<ex>en</ex></expan> ewr
                                    <add><expan>furst<ex>lich</ex></expan> gnad</add> mit fleisz,
                        was <expan>ders<ex>elb</ex></expan>
<expan>Barth<ex>o</ex>l<ex>omes</ex></expan> Neythart in
                                <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> zu disem mal von
                            <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr <expan>hoch<ex>wirdikeit</ex></expan>
                        werbe, daz im ewr gnade umb <expan>uns<ex>er</ex>r</expan> dienst
                                <expan>wille<ex>n</ex></expan>
<expan>gnedikl<ex>ich</ex></expan> darinn <expan>v<ex>er</ex>hören</expan>,
                        im des <expan>genczl<ex>ich</ex></expan> gelawben,
                                <expan>günstikl<ex>ich</ex></expan> von <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>fertig<ex>en</ex></expan>
<pb facs="#facs_586" id="292r"/>und gütlich darinn <expan>beweis<ex>en</ex></expan>
                        geruchet, als wir <expan>ew<ex>r</ex>n</expan>
<expan>furstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> etc. Denn wo wir
                            <expan>ewer<ex>er</ex></expan>
<expan>durchlewchtik<ex>eit</ex></expan> dienst und wolgefallen etc.
                                <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> v<hi rend="sup">a</hi>
<expan>an<ex>te</ex></expan> Valentini. </ab>
</div>
