<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><del rend="crossout"><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, als ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> wol mag
                                <expan>v<ex>er</ex>nomen</expan>
<expan>hab<ex>e</ex>n</expan>, wie <expan>uns<ex>er</ex></expan>
<expan>gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> Herczog <expan>Stepf<ex>an</ex></expan>
                            von Peyern in schrift mit uns <expan>kome<ex>n</ex></expan> ist von
                                    <expan>weg<ex>en</ex></expan> ein seinr
                                <expan>gnad<ex>en</ex></expan> jüdinn und einr jüdinn bey uns
                            wonhaft, darumb <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan> herczog <expan>Stepf<ex>an</ex></expan>
                            uns und den <expan>uns<ex>er</ex>n</expan>
<add>etwas</add> ungnedig ist und villeiht
                                <expan>unwill<ex>e</ex>n</expan> meynt zu
                                <expan>beweis<ex>en</ex></expan>, des wir doch, als wir hoffen, niht
                                    <expan>v<ex>er</ex>schuldt</expan>
<expan>hab<ex>e</ex>n</expan>. Also <expan>schik<ex>en</ex></expan> wir
                            zu <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>uns<ex>er</ex>n</expan> lieben <expan>b<ex>urger</ex></expan> und
                                    <expan>ratgesell<ex>e</ex>n</expan> Wilhelm Mendel, dem wir
                            befolhen <expan>hab<ex>e</ex>n</expan> mit
                                <expan>dens<ex>elben</ex></expan>
<expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> von <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> zu reden und
                                <expan>bitt<ex>en</ex></expan> ewr
                                <expan>hoch<ex>wirdikeit</ex></expan> dienstlich mit
                                    <expan>gancze<ex>m</ex></expan> fleiss, was
                                    <expan>ders<ex>elb</ex></expan>
<expan>uns<ex>er</ex></expan> ratgeselle in
                                <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> zu disem mal von
                                <expan>uns<ex>er</ex>n</expan>
<expan>weg<ex>en</ex></expan> an ewr <expan>fürstenl<ex>ich</ex></expan>
                            gnade <expan>w<ex>er</ex>be</expan>, daz ir in umb
                                <expan>uns<ex>er</ex>r</expan>
<expan>willig<ex>en</ex></expan> dienst <expan>will<ex>e</ex>n</expan>
                            darinn <expan>gnedikl<ex>ich</ex></expan>
<expan>v<ex>er</ex>hörn</expan>, im des
                                <expan>genczl<ex>ich</ex></expan>
<expan>gelawbe<ex>n</ex></expan> und uns in
                                <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> ewr gnade und guten
                                <expan>will<ex>e</ex>n</expan>
<expan>günstikl<ex>ich</ex></expan> beweisen wellet, als wir
                                    <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wol getrawn. Das
                                    <expan>well<ex>e</ex>n</expan> wir umb ewr
                                    <expan>furstenl<ex>ich</ex></expan> gnade
                                    <expan>willikl<ex>ich</ex></expan> und
                                <expan>g<ex>er</ex>n</expan>
<expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan> ut
                                    <expan>s<ex>upra</ex></expan>.</del></ab>
</div>
