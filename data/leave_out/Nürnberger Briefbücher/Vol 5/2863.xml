</div><div type="regularised"><pb facs="#facs_418" id="208r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Dem edeln <expan>wolgebor<ex>e</ex>n</expan>
<expan>h<ex>er</ex>ren</expan>, <expan>h<ex>er</ex>n</expan>
<expan>Heinr<ex>ich</ex></expan> von Plawen, <expan>h<ex>er</ex>ren</expan>
                        zu Künigswart, <expan>uns<ex>er</ex>m</expan> lieben
                            <expan>h<ex>er</ex>ren</expan></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Wolgeborn<ex>er</ex></expan> lieber <expan>h<ex>er</ex>re</expan>,
                        als uns ewr gnade <expan>verschr<ex>iben</ex></expan> hat von
                                <expan>uns<ex>er</ex>r</expan>
<expan>h<ex>er</ex>ren</expan>
<expan>weg<ex>en</ex></expan> von <expan>Nur<ex>emberg</ex></expan> und
                        begert, in von <expan>ewr<ex>er</ex></expan> edell
                            <expan>weg<ex>en</ex></expan> zu <expan>piete<ex>n</ex></expan>, daz ir
                        mit in <expan>fürkome<ex>n</ex></expan> wellet für
                            <expan>uns<ex>er</ex>n</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> marggraf <expan>Fridr<ex>ich</ex></expan> von
                                <expan>Brandemb<ex>ur</ex>g</expan> oder
                            <expan>and<ex>er</ex></expan>
<expan>h<ex>er</ex>ren</expan> und stette in <expan>ew<ex>r</ex>m</expan>
                        brief benennet etc., das <expan>habe<ex>n</ex></expan> wir
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan> zu dienst an <expan>uns<ex>er</ex></expan>
<expan>h<ex>er</ex>ren</expan> von <expan>Nür<ex>emberg</ex></expan> also
                        bracht. Die <expan>habe<ex>n</ex></expan> uns
                            <expan>geantw<ex>ur</ex>t</expan> und <expan>befolhe<ex>n</ex></expan>,
                                <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>wid<ex>er</ex>umb</expan>
<expan>zu schreibe<ex>n</ex></expan>, daz sie mit
                            <expan>ewr<ex>er</ex></expan> edell <expan>hiezwische<ex>n</ex></expan>
<app><note><q type="date"><expan>pfingst<ex>en</ex></expan> schierist</q>31.05.1422</note></app> auch
                            <expan>g<ex>er</ex>n</expan>
<expan>fürkome<ex>n</ex></expan>
<expan>welle<ex>n</ex></expan> zu <expan>eine<ex>m</ex></expan>
<expan>v<ex>er</ex>hören</expan> ewch <expan>zu beid<ex>er</ex></expan>seit
                        für den <expan>vorg<ex>enanten</ex></expan>
<expan>uns<ex>er</ex>n</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> marggraf <expan>Fridr<ex>ich</ex></expan> von
                                <expan>Brandemb<ex>ur</ex>g</expan>; was darinn
                                <expan>ewr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan>
<expan>meynu<ex>n</ex>g</expan> sein welle, des lat uns ewr gütlich
                                <expan>verschr<ex>iben</ex></expan> antwurt
                            <expan>wiss<ex>en</ex></expan> bey dem <expan>bott<ex>en</ex></expan>.
                        Denn wo wir <expan>ew<ex>r</ex>n</expan>
<expan>gnad<ex>en</ex></expan>
<expan>gediene<ex>n</ex></expan>
<expan>möchte<ex>n</ex></expan>, des <expan>w<ex>er</ex>en</expan> wir
                        willig. <expan>Dat<ex>um</ex></expan>
<expan>sab<ex>at</ex>o</expan>
<expan>an<ex>te</ex></expan>
<expan>d<ex>omi</ex>nica<ex>m</ex></expan> letare.<lb/>Sebold
                                <expan>Im<ex>m</ex>hof</expan> und Conrad Herspruker zu
                                <expan>Nüremb<ex>er</ex>g</expan>.</ab>
</div>
