<ab facs="#facs_470_r1l13"><expan>weıſu<ex>n</ex>g</expan>
<expan>eẅr<ex>er</ex></expan>
<expan>gnad<ex>en</ex></expan> brıefs etc das <expan>habe<ex>n</ex></expan>
                        wır wol <expan>vernom<ex>en</ex></expan> Vnd <expan>danke<ex>n</ex></expan>
</ab>
<ab facs="#facs_470_r1l14">des <expan>eẅ<ex>r</ex>n</expan>
<expan>fürſtenl<ex>ichen</ex></expan>
