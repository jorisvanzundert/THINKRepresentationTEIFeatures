<expan>fürſtenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan>
</ab>
<ab facs="#facs_247_r1l19">vnd den <expan>eẅ<ex>r</ex>n</expan> geleyt cʒu
