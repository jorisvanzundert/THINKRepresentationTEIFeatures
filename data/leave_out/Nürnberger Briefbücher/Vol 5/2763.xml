</div>
</div><div type="regularised"><pb facs="#facs_359" id="178v"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Illustri et <add>excelso</add> principi et <expan>d<ex>omi</ex>nio</expan>,
                                <expan>d<ex>omi</ex>no</expan> Amedeo, duci Sabaudie, Chablaysii et
                        Anguste in <expan>Ytaliaq<ex>ue</ex></expan> marchioni, necnon comiti
                                <expan>Pedemon<hi rend="sup">ciu<ex>m</ex></hi></expan> et
                                <expan>Gebenn<ex>ensis</ex></expan></ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab>Illustris et excelse <expan>p<ex>ri</ex>nceps</expan> et
                                <expan>d<ex>omi</ex>ne</expan>. <expan>Subiect<ex>is</ex></expan>
<expan>s<ex>er</ex>vitor<ex>um</ex></expan>
<expan>p<ex>ro</ex>mptitudi<ex>n</ex>e</expan> diligenti
                                <expan>v<ex>est</ex>ris</expan> exellenciis sedule
                                <expan>p<ex>rae</ex>oblatis</expan>. Magnifice
                            <expan>p<ex>ri</ex>nceps</expan>
<expan>d<ex>omi</ex>ne</expan>
<expan>g<ex>ene</ex>roso</expan>, quia suavi fama penes nos per
                                <expan>civitate<ex>m</ex></expan>
<expan>Nürembergen<ex>sem</ex></expan> predicante
                                <expan>p<ex>er</ex>cepim<ex>us</ex></expan>
<expan>qual<ex>ite</ex>r</expan> cives et mercatores
                            <expan>n<ex>ost</ex>ri</expan>
<expan>unacu<ex>m</ex></expan> suis mercimoniis rebus et bonis
                                <expan>tr<ex>an</ex>seuntes</expan> per regiones,
                                <expan>t<ex>er</ex>ras</expan> et <expan>district<ex>us</ex></expan>
<expan>v<ex>est</ex>re</expan> celsitudini <expan>subiect<ex>is</ex></expan>
<expan>undiq<ex>ue</ex></expan> tam pie tam humane
                            <expan>tamq<ex>ue</ex></expan> benigne tractari
                            <expan>atq<ex>ue</ex></expan> tute et salve conduci soleant.
                                <expan>Que<ex>m</ex>admodu<ex>m</ex></expan> ut
                            <expan>v<ex>est</ex>rates</expan> et
                            <expan>nichilomi<ex>nus</ex></expan>
<expan>du<ex>m</ex></expan>
<expan>ip<ex>s</ex>i</expan>
<expan>n<ex>ost</ex>rates</expan> se <expan>v<ex>est</ex>ris</expan>
                        magnificis <expan>conspectib<ex>us</ex></expan> in
                            <expan>eor<ex>um</ex></expan>
<expan>ca<ex>us</ex>is</expan> seu negociis offerre
                            <expan>conant<ex>ur</ex></expan> mox <expan>ip<ex>s</ex>a</expan>
<expan>g<ex>ene</ex>rosa</expan>
<expan>magnificenc<ex>ia</ex></expan>
<expan>v<ex>est</ex>ra</expan>
<expan>ip<ex>s</ex>os</expan> in
                            <expan>expedic<ex>i</ex>o<ex>n</ex>e</expan> celeri
                                <expan>p<ex>ropicie</ex></expan> suscipiat
                            <expan>reco<ex>m</ex>missos</expan>
<expan>h<ex>i</ex><hi rend="sup">c</hi></expan>
<expan>quid<ex>em</ex></expan> civis <expan>n<ex>oste</ex>r</expan> et
                        incola <expan>Nürembergen<ex>sis</ex></expan> Iodocus Hawg pridie coram
                        nobis in consilio constanter affirmavit et
                            <expan>p<ex>rae</ex>sertim</expan>
<expan>quo<ex>niam</ex></expan>
<expan>v<ex>est</ex>ra</expan> illustris magnificencia
                            <expan>nup<ex>er</ex>ime</expan> motu <expan>p<ex>ro</ex>prio</expan>
                        sibi in suis <expan>ca<ex>us</ex>is</expan> et negociis
                            <expan>v<ex>est</ex>ro</expan> in districtu <expan>p<ex>er</ex></expan>
<expan>eu<ex>m</ex></expan>
<expan>ventilat<ex>is</ex></expan>
<expan>gra<ex>tia</ex>m</expan> ac
                                <expan>p<ex>ro</ex>moc<ex>i</ex>o<ex>n</ex>is</expan>
<expan>effectu<ex>m</ex></expan>
<expan>p<ex>rae</ex>buerit</expan> valde magnam <expan>p<ex>ro</ex></expan>
<expan>quib<ex>us</ex></expan> eisdem magnificenciis
                            <expan>v<ex>est</ex>ris</expan>
<expan>refe<ex>r</ex>im<ex>us</ex></expan>
<expan>gra<ex>tiarum</ex></expan>
<expan>qu<ex>an</ex>tas</expan>
<expan>possum<ex>us</ex></expan>
<expan>act<ex>i</ex>o<ex>n</ex>es</expan> profecto
                                <expan>iudicant<ex>is</ex></expan> nos et
                            <expan>n<ex>ost</ex>rates</expan> in <expan>v<ex>est</ex>re</expan> pio
                                <expan>caritat<ex>is</ex></expan>
<expan>b<ex>e</ex>n<ex>e</ex>ficio</expan>
<expan>no<ex>n</ex></expan> modice
                            <expan>c<ex>on</ex>tiner<ex>is</ex></expan>
<expan>quodq<ex>ue</ex></expan>
<expan>no<ex>n</ex></expan>
<add><expan>n<ex>ost</ex>ris</expan> aut</add>
<expan>n<ex>ost</ex>ror<ex>um</ex></expan> meritis
                                <expan>p<ex>rae</ex>cedentib<ex>us</ex></expan>
<expan>s<ex>ed</ex></expan> innatis clemenciis
                            <expan>v<ex>est</ex>ris</expan>
<expan>asscribend<ex>um</ex></expan> merito in veritate
                                <expan>fatem<ex>ur</ex></expan>. Quo circa
                            <expan>p<ex>ri</ex>nceps</expan> inclite <expan>v<ex>est</ex>ram</expan>
                        ilustrem <expan>magnificencia<ex>m</ex></expan>
<expan>hu<ex>m</ex>il<ex>ite</ex>r</expan> duxi <expan>c<ex>on</ex></expan>
<expan>o<ex>mn</ex>i</expan>
<expan>cu<ex>m</ex></expan> diligencia <expan>exorand<ex>um</ex></expan>
<expan>q<ex>ua</ex>t<ex>en</ex>us</expan>
<expan>p<ex>rae</ex>fate</expan>
<expan>celsitudi<ex>ni</ex>s</expan>
<expan>clemen<ex>ti</ex><hi rend="sup">am</hi></expan> erga nos et
                                <expan>n<ex>ost</ex>rates</expan>
<expan>g<ex>ene</ex>rose</expan>
<expan>c<ex>on</ex>tinuare</expan>
<expan>dignemi<ex>ni</ex></expan> ut exinde
                            <expan>ip<ex>s</ex>ar<ex>um</ex></expan> benignis
                                <expan>valeam<ex>us</ex></expan>
<expan>since<ex>r</ex>itatib<ex>us</ex></expan> graculari. Ad
                                <expan>cui<ex>us</ex></expan>
<expan>c<ex>on</ex>placentia<ex>m</ex></expan>
<expan>gl<ex>or</ex>iam</expan> et <expan>honore<ex>m</ex></expan>
<expan>offerim<ex>us</ex></expan> nos
                            <expan>obsequiosissi<ex>mi</ex>s</expan>
<expan>aff<ex>e</ex>c<ex>t</ex>ib<ex>us</ex></expan> letamente
                                <expan>p<ex>ar</ex>atos</expan>
<expan>qua<ex>m</ex></expan> dextera
                            <expan>om<ex>n</ex>ipotent<ex>is</ex></expan>
<expan>incolume<ex>m</ex></expan>
<expan>c<ex>on</ex>servare</expan>
<expan>dignet<ex>ur</ex></expan> et <expan>dirige<ex>re</ex></expan>
                        feliciter <expan>nu<ex>n</ex>c</expan> et <expan>semp<ex>er</ex></expan>.
                                <expan>Script<ex>is</ex></expan>.</ab>
<note place="below">
<expan>P<ex>ro</ex>cons<ex>ules</ex></expan>.</note>
</div>
</div></body>
