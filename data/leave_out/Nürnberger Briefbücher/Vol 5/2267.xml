</div>
</div><div type="regularised"><pb facs="#facs_96" id="47r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab>Provido et honesto Heinrico de Tyechlewicz residenti seu civi in Luna
                        etc.</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab>Obsequiosa voluntate <expan>p<ex>rae</ex>missa</expan>.
                                <expan>L<ex>itte</ex>ra<ex>m</ex></expan>
<expan>nob<ex>i</ex>lis</expan> ac <expan>g<ex>e</ex>n<ex>er</ex>osi</expan>
<expan>d<ex>omi</ex>ni</expan> Wenczeslai de Duba regni Boemie sub camerarii
                                <expan>atq<ex>ue</ex></expan>
<expan>v<ex>est</ex>ra<ex>m</ex></expan>
<expan>diligent<ex>er</ex></expan>
<expan>advertim<ex>us</ex></expan>.
                            <expan>Quap<ex>ro</ex>pt<ex>er</ex></expan> vos
                            <expan>cupim<ex>us</ex></expan> non latere <expan>q<ex>ui</ex></expan>
<expan>desup<ex>er</ex></expan> eidem <expan>d<ex>omi</ex>no</expan>
                        Wenczeslao <expan>responsu<ex>m</ex></expan>
<expan>scripsim<ex>us</ex></expan>
<expan>p<ex>ro</ex>ut</expan> ab <expan>ip<ex>s</ex>o</expan> si
                                <expan>gliscit<ex>is</ex></expan> informari
                            <expan>potest<ex>is</ex></expan>
<expan>v<ex>est</ex>ram</expan>
<expan>insup<ex>er</ex></expan>
<expan>amicicia<ex>m</ex></expan> attente
                                <expan>p<ex>rae</ex>cant<ex>is</ex></expan>,
                                <expan>q<ex>ua</ex>t<ex>en</ex>us</expan>
<expan>n<ex>ost</ex>rates</expan> velitis <expan>b<ex>e</ex>nevole</expan>
                        ac <expan>favorab<ex>i</ex>l<ex>ite</ex>r</expan>
<expan>suscip<ex>er</ex>e</expan>
<expan>recomiss<ex>is</ex></expan>, <expan>p<ex>ro</ex>ut</expan>
<expan>v<ex>est</ex>re</expan> sagacitati
                                <expan>c<ex>on</ex>fidimu<ex>us</ex></expan>.
                            <expan>Q<ex>uo</ex>d</expan>
<expan>p<ex>er</ex></expan> amicicia <expan>v<ex>est</ex>ra</expan>
<expan>volum<ex>us</ex></expan> remereri. <expan>Dat<ex>um</ex></expan> ut
                                <expan>sup<ex>ra</ex></expan>.</ab>
