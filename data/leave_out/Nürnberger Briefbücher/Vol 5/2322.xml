<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>L<ex>ieber</ex></expan>
<expan>h<ex>e</ex>r</expan>
<expan>amptm<ex>an</ex></expan>, als ir uns aber
                            <expan>verschr<ex>iben</ex></expan> habt von Selen der
                                <expan>Toppl<ex>er</ex>in</expan>
<expan>weg<ex>en</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wie sie meyne,
                            <expan>eine<ex>n</ex></expan> der <expan>uns<ex>er</ex>n</expan>, den
                        die sache antreffe an dem gericht bey uns zuzusprechen etc., das
                                <expan>hab<ex>e</ex>n</expan> wir wol
                            <expan>vernom<ex>en</ex></expan>. Nu <expan>hab<ex>e</ex>n</expan> wir
                        mit <expan>etliche<ex>n</ex></expan> den <expan>uns<ex>er</ex>n</expan>, die
                        das angeet, <expan>davo<ex>n</ex></expan> geredt und ir rede gehöret; wie
                                <expan>daru<ex>m</ex>b</expan> wenn die
                                <expan>vorg<ex>ena</ex>nt<ex>e</ex></expan> Selend
                                <expan>Toppl<ex>er</ex>in</expan>
<expan>hiezwisch<ex>en</ex></expan>
<app>
<note><q type="date">sand Johanns tag <expan>sünwend<ex>en</ex></expan>
                                    schierist</q>24.06.1420</note>
</app> zu uns kombt, so sol sie und die sie mit ir brecht
                                <expan>ungev<ex>er</ex>lichen</expan> zu und von uns für uns und die
                                <expan>uns<ex>er</ex>n</expan> und bey uns für
                            <expan>all<ex>er</ex>meniklichen</expan> on geverd geleyt
                                <expan>hab<ex>e</ex>n</expan>, den <expan>sache<ex>n</ex></expan>
                        mit recht bey uns nach <expan>zukome<ex>n</ex></expan>. Alsdenn
                                <expan>well<ex>e</ex>n</expan> wir ir von den
                            <expan>uns<ex>er</ex>n</expan>, den sie zuzusprechen meynt und die
                        anheim bey uns sein, <expan>frewntl<ex>ich</ex></expan> slewnigs rechten vor
                        des reichs <expan>richt<ex>er</ex></expan> bey uns zu
                                <expan>Nür<ex>emberg</ex></expan>
<expan>g<ex>er</ex>n</expan>
<expan>helff<ex>en</ex></expan> nach <expan>uns<ex>er</ex>r</expan> stat
                                <expan>gewonh<ex>eit</ex></expan> und
                            <expan>herkome<ex>n</ex></expan>
<expan>ungev<ex>er</ex>lichen</expan>. Denn wo wir
                            <expan>uns<ex>er</ex>m</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan>
<expan>h<ex>er</ex>czog</expan>
<expan>Otte<ex>n</ex></expan>
<expan>gediene<ex>n</ex></expan> und <expan>ewr<ex>er</ex></expan>
<expan>erberk<ex>eit</ex></expan> lieb <expan>od<ex>er</ex></expan> dienst
                        etc. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> v<hi rend="sup">a</hi>
<expan>i<ex>n</ex></expan> festo <expan>penthecost<ex>en</ex></expan>.</ab>
</div>
