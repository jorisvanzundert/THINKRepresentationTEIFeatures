</div><div type="regularised"><pb facs="#facs_62" id="30r"/><!--The following div is the container for the adress lines of the letter.-->
<div type="addressee">
<ab><expan>H<ex>er</ex>n</expan>
<expan>Ludweig<ex>en</ex></expan>, <expan>pfallnczgraf<ex>en</ex></expan>
                        bey Reyn, des heiligen <expan>römische<ex>n</ex></expan> reichs
                                <expan>ercztruchsess<ex>en</ex></expan> und
                            <expan>h<ex>er</ex>czogen</expan> in Peyern,
                            <expan>uns<ex>er</ex>m</expan> gnedigen <expan>h<ex>er</ex>ren</expan>
</ab>
</div>
<!-- This div contains the letter itselfs. Additions to the text are contained in <add/> elements, struck text in <hi> elements with the attribute 'strikethrough' set to true. -->
<div type="content">
<ab><expan>Gnedig<ex>er</ex></expan>
<expan>h<ex>er</ex>re</expan>, <add>uns hat</add>
<expan>Hanns<ex>en</ex></expan>
<expan>Mawr<ex>er</ex></expan>, <expan>unser</expan> diener, <add>den wir
                            nehst</add> zu <expan>ewer<ex>er</ex></expan>
<expan>durchlewchtik<ex>eit</ex></expan> gesant
                            <expan>hette<ex>n</ex></expan> von <expan>uns<ex>er</ex>s</expan>
<expan>gnedig<ex>en</ex></expan>
<expan>h<ex>er</ex>ren</expan> herczog <expan>Stepf<ex>an</ex></expan>,
                                <expan>ew<ex>r</ex>s</expan>
<expan>brud<ex>er</ex>s</expan>, <expan>weg<ex>en</ex></expan>, wol gesagt,
                        wie sich ewr <expan>hoch<ex>wirdikeit</ex></expan> in
                                <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> gar <expan>gnediklich<ex>e</ex>n</expan>
                        beweiset hab, des wir <expan>ew<ex>r</ex>n</expan>
<expan>fürstenl<ex>ichen</ex></expan>
<expan>gnad<ex>en</ex></expan> mit <expan>gancze<ex>m</ex></expan> fleiss
                                <expan>danke<ex>n</ex></expan> und auch
                            <expan>willikl<ex>ich</ex></expan> begern <expan>zu
                            v<ex>er</ex>dienen</expan>. Also schiken wir
                            <expan>dens<ex>elben</ex></expan>
<expan>uns<ex>er</ex>n</expan> diener <expan>daru<ex>m</ex>b</expan>
<expan>wid<ex>er</ex></expan> zu <expan>ewr<ex>er</ex></expan>
<expan>durchlewtik<ex>eit</ex></expan> mit ew <expan>davo<ex>n</ex></expan>
                        zu reden und <expan>bitt<ex>en</ex></expan> ewr
                            <expan>fürstenl<ex>ich</ex></expan> gnade
                            <expan>dienstl<ex>ich</ex></expan> und mit fleiss, was
                                <expan>ders<ex>elb</ex></expan> Hanns <expan>Mawr<ex>er</ex></expan>
                        in <expan>dens<ex>elben</ex></expan>
<expan>sache<ex>n</ex></expan> zu disem mal an <expan>ewr<ex>er</ex></expan>
<expan>hoch<ex>wirdikeit</ex></expan> werbe, daz ir im des
                                <expan>genczl<ex>ich</ex></expan> gelawben,
                                <expan>gnediklich<ex>e</ex>n</expan> verhörn und ewr gnade und guten
                                <expan>will<ex>e</ex>n</expan> beweisen und
                                <expan>günstikl<ex>ich</ex></expan> von ewch
                                <expan>fertig<ex>en</ex></expan> wellet, als wir
                                <expan>ewr<ex>er</ex></expan>
<expan>durchlewchtik<ex>eit</ex></expan>
<expan>sunderl<ex>ich</ex></expan> wol getrawn. Das
                            <expan>well<ex>e</ex>n</expan> wir umb ewr
                            <expan>fürstenl<ex>ich</ex></expan> gnade
                            <expan>willikl<ex>ich</ex></expan> und gern
                            <expan>v<ex>er</ex>dienen</expan>. <expan>Dat<ex>um</ex></expan>
<expan>f<ex>er</ex>ia</expan> iiii<hi rend="sup">a</hi>
<expan>ip<ex>s</ex>a</expan> die <expan>s<ex>an</ex>c<ex>t</ex>i</expan>
                        Luce <expan>ewan<ex>gelis</ex><hi rend="sup">te</hi></expan>.</ab>
