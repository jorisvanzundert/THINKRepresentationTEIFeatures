      <zone xml:id="a13_1v-b" ana="hc:Column">
        <line xml:id="l_a13_1v-b.line_1" n="1">er ſprach nach minem tœde.</line>
        <line xml:id="l_a13_1v-b.line_2" n="2">do frævt ſich ælliu div ſtat zerome.</line>
        <line xml:id="l_a13_1v-b.line_3" n="3">zware ſi begrabent mich morgen niha <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a13_1v-b.line_4" n="4">ir ieglich mvz ſínen frivnt wainen.</line>
        <line xml:id="l_a13_1v-b.line_5" n="5"><hei:initial ana="hc:Lombard">A</hei:initial>ls er daz wort volle ſprach.</line>
        <line xml:id="l_a13_1v-b.line_6" n="6">Daz ſwert er ín ſich ſtach</line>
        <line xml:id="l_a13_1v-b.line_7" n="7">inder ſelben zît.</line>
        <line xml:id="l_a13_1v-b.line_8" n="8">Hvp ſich zerome michel ſtrît. <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <line xml:id="l_a13_1v-b.line_9" n="9">auf Schröder sind von Ian Holt übernommen. Vgl. Holt, Drei Fragmente [...], ZfdA 141 (2012), S. 480.</line>
        <anchor xml:id="end.a13_ep8" />
      </zone>
