    <surface ana="hc:Page" n="1r" xml:id="a1_1r">
      <zone xml:id="a1_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="25" xml:id="a1_ep25" spanTo="#end.a1_ep25"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a1_ep25.en" />Gallienus<anchor xml:id="end.head.a1_ep25.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a1_ep25.de" />Gallienus<anchor xml:id="end.head.a1_ep25.de" />
        <line xml:id="l_a1_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> Beidiv ader <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> lít. Er hvͦp alrerſte den ſít. Daz man díe lívte</line>
        <line xml:id="l_a1_1r-a.line_1_above-1" n="1_above" rend="above">ſtumblet</line>
        <line xml:id="l_a1_1r-a.line_2" n="2">bi den ovgen. Ern wolte ſih ſín ê niht gloͮben. Vnz er aller ſiner erzenie</line>
        <line xml:id="l_a1_1r-a.line_3" n="3"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Text links am Rande abgeschnitten</note> nde komen. Die heiden begvnden alle ſínen wistum lobeten. Der kvnich</line>
        <line xml:id="l_a1_1r-a.line_4" n="4"><gap unit="chars" ana="hc:Lost"></gap> lienus. <note ana="hc:TranscriptionNote">{<gap unit="chars" ana="hc:Illegible"></gap> ienus} am Ende der letzten Zeile durchstrichen; Name in dieser Zeile erneut geschrieben, aber Wortanfang später abgeschnitten</note> Der was eín wiſer phylophus. Eines nahtes er an den ſternen ſach.</line>
        <line xml:id="l_a1_1r-a.line_5" n="5"><gap unit="chars" ana="hc:Lost"></gap> ime deſ tageſ chunftich waſ. Daz ime die romæ̂re vergeben wolten.</line>
        <line xml:id="l_a1_1r-a.line_6" n="6"><gap unit="chars" ana="hc:Lost"></gap> kvních deſ niht dolte. Do er wiſte ir willen. Do er wiſte ir willen.</line>
        <line xml:id="l_a1_1r-a.line_7" n="7"><gap unit="chars" ana="hc:Lost"></gap> wêich vil ſtille. Vnz der tages vber den tisch geſaz.</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a1_1v">
      <zone xml:id="a1_1v-a" ana="hc:Column">
        <line xml:id="l_a1_1v-a.line_1" n="1">Do vil manich furſte bi ime waſ. Do der truhſæze daz <gap unit="chars" ana="hc:Illegible"></gap> Nihteſ <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_2" n="2">Wan er weſte daz wol. Daz er daran vnſchuldig <note ana="hc:TranscriptionNote">{vnſch <gap unit="chars" ana="hc:Illegible"></gap>} vor {vnſchuldig} durchstrichen</note> waſ. <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_3" n="3"><choice><abbr>Vñ</abbr><expan>Vnd(e)</expan></choice> enthielt ſih allez mit liſten. <hei:initial ana="hc:Lombard">A</hei:initial>ls der ſchenche do vur gie. Daz <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_4" n="4">Er begonde eine wile. Harte ge zwiueln. <note ana="hc:TranscriptionNote">{gezwiueln} durch Lombarde in der vorigen Zeile in zwei geteilt; {ge} gerade noch zu erkennen</note> Er gewan manigen gedan <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_5" n="5">ſih vf vber lanch. Er ſprah trac her naher liebe. Du ſolt <note ana="hc:TranscriptionNote">{ſolt} gerade noch zu erkennen</note> trinchen ſchiere. Die <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_6" n="6">alle ſehen. Waz dv mir da woltest geben. Nv la vnſ ſehen wie ez dir <gap unit="chars" ana="hc:Illegible"></gap> ge. So t <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_7" n="7">nah denne. Do der ſchenche gesah daz. Daz ez vrvm niht waſ. Er ſprah ih bit <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a1_1v-a.line_8" n="8">Durh dine chvnicliche er. Nv enthabe din gemvt. Bescheine an mir din <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a1_ep25" />
      </zone>
