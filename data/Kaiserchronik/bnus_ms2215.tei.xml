  <sourceDoc>
    <surface ana="hc:Page" n="1r" xml:id="a14_1r">
      <zone xml:id="a14_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="7.1" xml:id="a14_ep7.1" spanTo="#end.a14_ep7.1"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a14_ep7.1.en" />Faustinian and Claudius: Crisis and separation § 1<anchor xml:id="end.head.a14_ep7.1.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a14_ep7.1.de" />Faustinianus und Claudius: Krise und Trennung § 1<anchor xml:id="end.head.a14_ep7.1.de" />
        <line xml:id="l_a14_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription stützt sich gelegentlich auf den Abdruck von Karl August Barack (1880) - vgl. oben "Hinweise zu diesem Textzeugen"</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> Er ſtrafet vns dar vmbe ſere</line>
        <line xml:id="l_a14_1r-a.line_2" n="2">Ez wer ouch im nith ein ere</line>
        <line xml:id="l_a14_1r-a.line_3" n="3">Der <choice><abbr>h͛re</abbr><expan>herre</expan></choice> <choice><abbr>ſpᷓch</abbr><expan>ſprach</expan></choice> daz ers nith <choice><abbr>lazẽ</abbr><expan>lazen</expan></choice> wolde</line>
        <line xml:id="l_a14_1r-a.line_4" n="4">Ober darvmbe ſterben ſolde</line>
        <line xml:id="l_a14_1r-a.line_5" n="5">Er mothe dvrch nith abelozen</line>
        <line xml:id="l_a14_1r-a.line_6" n="6">Er begie ſo groze vnmoze</line>
        <line xml:id="l_a14_1r-a.line_7" n="7">Nach der frowen mínne</line>
        <line xml:id="l_a14_1r-a.line_8" n="8">Daz er verzwivelte an dẽ <choice><abbr>ſinnẽ</abbr><expan>ſinnen</expan></choice></line>
        <line xml:id="l_a14_1r-a.line_9" n="9">Do nam ir dív frowe gut</line>
        <line xml:id="l_a14_1r-a.line_10" n="10">Ein tvgentlichen mvt</line>
        <line xml:id="l_a14_1r-a.line_11" n="11">Die not die ſie von im habete</line>
        <line xml:id="l_a14_1r-a.line_12" n="12">Vnder  wilen ſi im drowete</line>
        <line xml:id="l_a14_1r-a.line_13" n="13">Vil dicke ſi in vlehete</line>
        <line xml:id="l_a14_1r-a.line_14" n="14">Si <choice><abbr>ſpᷓch</abbr><expan>ſprach</expan></choice> <choice><abbr>v͛nement</abbr><expan>vernement</expan></choice> ez <choice><abbr>vnſ͛</abbr><expan>vnſer</expan></choice> mage</line>
        <line xml:id="l_a14_1r-a.line_15" n="15">Daz leben ſtet vns <choice><abbr>and͛</abbr><expan>ander</expan></choice> wage</line>
        <line xml:id="l_a14_1r-a.line_16" n="16">Vnd ander romere</line>
        <line xml:id="l_a14_1r-a.line_17" n="17">Ez wirt in vil ſwere</line>
        <line xml:id="l_a14_1r-a.line_18" n="18">Si heizent vns lithe ſteinen</line>
        <line xml:id="l_a14_1r-a.line_19" n="19">Dv frowe begonde weinen</line>
        <line xml:id="l_a14_1r-a.line_20" n="20"><hei:initial ana="hc:Lombard">D</hei:initial>annoch wolte ſich <choice><abbr>d͛</abbr><expan>der</expan></choice> <choice><abbr>h͛re</abbr><expan>herre</expan></choice></line>
        <line xml:id="l_a14_1r-a.line_21" n="21"><choice><abbr>D͛</abbr><expan>Der</expan></choice> rede nith bekeren</line>
        <line xml:id="l_a14_1r-a.line_22" n="22">Si <choice><abbr>ſpᷓch</abbr><expan>ſprach</expan></choice> ſwiget die rede nv lat</line>
        <line xml:id="l_a14_1r-a.line_23" n="23">Ich w <gap unit="chars" ana="hc:Lost"></gap> ch geben guten rat</line>
        <line xml:id="l_a14_1r-a.line_24" n="24">Ir ſ <gap unit="chars" ana="hc:Lost"></gap> warten der zite</line>
        <line xml:id="l_a14_1r-a.line_25" n="25">So der wirt vz gerite</line>
        <line xml:id="l_a14_1r-a.line_26" n="26">vnd hie zehoue werde ſtille</line>
        <line xml:id="l_a14_1r-a.line_27" n="27">Ich hon zv vch guten willen</line>
        <line xml:id="l_a14_1r-a.line_28" n="28">Daz geſtet ouch vnlange</line>
        <line xml:id="l_a14_1r-a.line_29" n="29">Mit kinde bin ich <choice><abbr>vmbevangẽ</abbr><expan>vmbevangen</expan></choice></line>
        <line xml:id="l_a14_1r-a.line_30" n="30">Ez mag zv diſen <choice><abbr>zitẽ</abbr><expan>ziten</expan></choice> nith ſin</line>
        <line xml:id="l_a14_1r-a.line_31" n="31">Vil lieber nv geſwige min</line>
        <line xml:id="l_a14_1r-a.line_32" n="32">Gip mir gutlichen vriſt</line>
        <line xml:id="l_a14_1r-a.line_33" n="33">Ich tvn ſwaz dir liep iſt</line>
        <line xml:id="l_a14_1r-a.line_34" n="34"><choice><abbr>D͛</abbr><expan>Der</expan></choice> <choice><abbr>h͛re</abbr><expan>herre</expan></choice> gewerte ſie der bete</line>
        <line xml:id="l_a14_1r-a.line_35" n="35">Sin gemute ſtillet er do mite</line>
        <line xml:id="l_a14_1r-a.line_36" n="36">Div frowe gedathe <choice><abbr>manig͛</abbr><expan>maniger</expan></choice> liſte</line>
        <line xml:id="l_a14_1r-a.line_37" n="37">wie ſie ir ere gefriſte</line>
        <line xml:id="l_a14_1r-a.line_38" n="38">wie ſie den wuth <choice><abbr>grĩme</abbr><expan>grimme</expan></choice>n</line>
        <line xml:id="l_a14_1r-a.line_39" n="39">von der rede mothe <choice><abbr>bringẽ</abbr><expan>bringen</expan></choice></line>
        <line xml:id="l_a14_1r-a.line_40" n="40">Do ſi des kindelins genas</line>
      </zone>
      <zone xml:id="a14_1r-b" ana="hc:Column">
        <line xml:id="l_a14_1r-b.line_1" n="1">Da mit ſi bekvmmert was</line>
        <line xml:id="l_a14_1r-b.line_2" n="2">Des erfroweten ſich zware</line>
        <line xml:id="l_a14_1r-b.line_3" n="3">Vriunt vnd mage</line>
        <line xml:id="l_a14_1r-b.line_4" n="4">Sie <choice><abbr>vundẽ</abbr><expan>vunden</expan></choice>  im einen ſ<choice><abbr>chonẽ</abbr><expan>chonen</expan></choice> <choice><abbr>namẽ</abbr><expan>namen</expan></choice></line>
        <line xml:id="l_a14_1r-b.line_5" n="5">Da von ſi nie gehorten ſagen</line>
        <line xml:id="l_a14_1r-b.line_6" n="6">Er wart geheizen clemens</line>
        <line xml:id="l_a14_1r-b.line_7" n="7">Er wart zerome ſit babeſt</line>
        <line xml:id="l_a14_1r-b.line_8" n="8">Er iſt ein marterer here</line>
        <line xml:id="l_a14_1r-b.line_9" n="9">Er ſol vns gnedic ſin <choice><abbr>ímm͛</abbr><expan>ímmer</expan></choice> mere</line>
        <line xml:id="l_a14_1r-b.line_10" n="10"><hei:initial ana="hc:Lombard">D</hei:initial>o der frowen kom der tac</line>
        <line xml:id="l_a14_1r-b.line_11" n="11">Daz ſi genas als ſi da lac</line>
        <line xml:id="l_a14_1r-b.line_12" n="12">Bi ir herren <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> er en ſlief</line>
        <line xml:id="l_a14_1r-b.line_13" n="13">Wie lute in div frowe an rief</line>
        <line xml:id="l_a14_1r-b.line_14" n="14">Hilf dv mir herre enzit</line>
        <line xml:id="l_a14_1r-b.line_15" n="15">E. daz ich ver lieſe den lip</line>
        <line xml:id="l_a14_1r-b.line_16" n="16">Der kunic ſere erſchricte</line>
        <line xml:id="l_a14_1r-b.line_17" n="17">Er ſpranc uf in algerithe</line>
        <line xml:id="l_a14_1r-b.line_18" n="18">Ellv mín wnne</line>
        <line xml:id="l_a14_1r-b.line_19" n="19">Daz mir din got <note ana="hc:TranscriptionNote">{got} durch Verweiszeichen vor {gunne} eingefügt</note> gunne</line>
        <line xml:id="l_a14_1r-b.line_20" n="20">was iſt dir beſchehen</line>
        <line xml:id="l_a14_1r-b.line_21" n="21">E. verwandelt ich daz leben</line>
        <line xml:id="l_a14_1r-b.line_22" n="22">E. dir zeleide ith geſchehe</line>
        <line xml:id="l_a14_1r-b.line_23" n="23">waz iſt <choice><abbr>dc</abbr><expan>daz</expan></choice> dv indẽ trovme ſehe</line>
        <line xml:id="l_a14_1r-b.line_24" n="24"><hei:initial ana="hc:Lombard">D</hei:initial>v frowe antwrte im do</line>
        <line xml:id="l_a14_1r-b.line_25" n="25">Si ſprach <choice><abbr>nĩmer</abbr><expan>nimmer</expan></choice> wird ich vro</line>
        <line xml:id="l_a14_1r-b.line_26" n="26">Ich hon ſogetan dinc geſehen</line>
        <line xml:id="l_a14_1r-b.line_27" n="27">Ich mag nith lange han daz <choice><abbr>lebẽ</abbr><expan>leben</expan></choice></line>
        <line xml:id="l_a14_1r-b.line_28" n="28">Ouch ſage ich dir vur war</line>
        <line xml:id="l_a14_1r-b.line_29" n="29">vnſer kint <choice><abbr>gelebẽt</abbr><expan>gelebent</expan></choice> <choice><abbr>niem͛</abbr><expan>niemer</expan></choice> ein iar</line>
        <line xml:id="l_a14_1r-b.line_30" n="30">Dv enheizeſt ſie die buch leren</line>
        <line xml:id="l_a14_1r-b.line_31" n="31">wol troſte ſie der herren</line>
        <line xml:id="l_a14_1r-b.line_32" n="32">Din trovm ſi dir zeheile</line>
        <line xml:id="l_a14_1r-b.line_33" n="33">vnderwint dich <choice><abbr>d͛</abbr><expan>der</expan></choice> kinde beider</line>
        <line xml:id="l_a14_1r-b.line_34" n="34">vnd er var <choice><abbr>vnd͛</abbr><expan>vnder</expan></choice> den holden min</line>
        <line xml:id="l_a14_1r-b.line_35" n="35">wa die gutẽ meiſter ſin</line>
        <line xml:id="l_a14_1r-b.line_36" n="36">Sie tvgendent alſo vru</line>
        <line xml:id="l_a14_1r-b.line_37" n="37">Ich verſihe mich gutes dar zu</line>
        <line xml:id="l_a14_1r-b.line_38" n="38">Si werdent vns ze frvmekeit</line>
        <line xml:id="l_a14_1r-b.line_39" n="39">Iſt ez nith din arbeit</line>
        <line xml:id="l_a14_1r-b.line_40" n="40">Dines rates uolge ich gerne</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a14_1v">
      <zone xml:id="a14_1v-a" ana="hc:Column">
        <line xml:id="l_a14_1v-a.line_1" n="1">Sprach der tvrliche herre</line>
        <line xml:id="l_a14_1v-a.line_2" n="2">Dv frowe hiez dv ſchif zieren</line>
        <line xml:id="l_a14_1v-a.line_3" n="3">Bereiten harte ſchiere</line>
        <line xml:id="l_a14_1v-a.line_4" n="4">Do ez allez geandet was</line>
        <line xml:id="l_a14_1v-a.line_5" n="5">Die livte horten ſagen daz</line>
        <line xml:id="l_a14_1v-a.line_6" n="6">Daz man die iungen helde</line>
        <line xml:id="l_a14_1v-a.line_7" n="7">wolte verſenden inellende</line>
        <line xml:id="l_a14_1v-a.line_8" n="8">Sie begonden heize weinen</line>
        <line xml:id="l_a14_1v-a.line_9" n="9">wan ſi die mit trvwẽ <choice><abbr>meindẽ</abbr><expan>meinden</expan></choice></line>
        <line xml:id="l_a14_1v-a.line_10" n="10">Die ſine vorderſten man</line>
        <line xml:id="l_a14_1v-a.line_11" n="11">woldent ez erwendet han</line>
        <line xml:id="l_a14_1v-a.line_12" n="12">Do ſprach der kvnic here</line>
        <line xml:id="l_a14_1v-a.line_13" n="13">vernement e. mine lere</line>
        <line xml:id="l_a14_1v-a.line_14" n="14"><choice><abbr>Sw͛</abbr><expan>Swer</expan></choice> deme boeſen entlibet</line>
        <line xml:id="l_a14_1v-a.line_15" n="15">Den ſvn hazzet <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> nidet</line>
        <line xml:id="l_a14_1v-a.line_16" n="16">Zuth vnd vorhte iſt gut</line>
        <line xml:id="l_a14_1v-a.line_17" n="17">Swer ouch des nith entut</line>
        <line xml:id="l_a14_1v-a.line_18" n="18">Darz <note ana="hc:TranscriptionNote">{rz} in {Darz} ist nach Barack als Schreibfehler für {z} anzusehen</note> er in zearte wil haben</line>
        <line xml:id="l_a14_1v-a.line_19" n="19">Der mac wol da nach <choice><abbr>verzagẽ</abbr><expan>verzagen</expan></choice></line>
        <line xml:id="l_a14_1v-a.line_20" n="20">Swen er kvmet zv den <choice><abbr>witzẽ</abbr><expan>witzen</expan></choice></line>
        <line xml:id="l_a14_1v-a.line_21" n="21">Daz er da erbe ſol beſitzen</line>
        <line xml:id="l_a14_1v-a.line_22" n="22">So enkan er ze mazen</line>
        <line xml:id="l_a14_1v-a.line_23" n="23">weder tvn noch gelazen</line>
        <line xml:id="l_a14_1v-a.line_24" n="24">So bringet in ſin kinteit</line>
        <line xml:id="l_a14_1v-a.line_25" n="25">Dicke in groze arbeit</line>
        <line xml:id="l_a14_1v-a.line_26" n="26"><choice><abbr>Vñ</abbr><expan>Vnd(e)</expan></choice> kan die ſelbe nith <choice><abbr>getragẽ</abbr><expan>getragen</expan></choice></line>
        <line xml:id="l_a14_1v-a.line_27" n="27">Ich horte minen vater ſagen</line>
        <line xml:id="l_a14_1v-a.line_28" n="28">Daz der ſvn vnd der knet</line>
        <line xml:id="l_a14_1v-a.line_29" n="29">Haben geliche ein reth</line>
        <line xml:id="l_a14_1v-a.line_30" n="30">Swenner geweſſet zemanne</line>
        <line xml:id="l_a14_1v-a.line_31" n="31">Daz erbe beſitzet er danne</line>
        <line xml:id="l_a14_1v-a.line_32" n="32">Hat er danne wiſtum</line>
        <line xml:id="l_a14_1v-a.line_33" n="33">Der leret in ere vnd frum</line>
        <line xml:id="l_a14_1v-a.line_34" n="34">Mínv kint <choice><abbr>muzẽ</abbr><expan>muzen</expan></choice> <choice><abbr>w͛dẽ</abbr><expan>werden</expan></choice> <choice><abbr>betwngẽ</abbr><expan>betwngen</expan></choice></line>
        <line xml:id="l_a14_1v-a.line_35" n="35">Mit vroſte <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> mit hvnger</line>
        <line xml:id="l_a14_1v-a.line_36" n="36">Mit noeten <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> mit arbeit</line>
        <line xml:id="l_a14_1v-a.line_37" n="37"><choice><abbr>vberwindẽt</abbr><expan>vberwindent</expan></choice> ſie die kinteit</line>
        <line xml:id="l_a14_1v-a.line_38" n="38">Der wiſtum eret wol daz riche</line>
        <line xml:id="l_a14_1v-a.line_39" n="39">Sie <note ana="hc:TranscriptionNote">{e} in {Sie} aus {s} korrigiert</note> mugent ſi vroliche</line>
        <line xml:id="l_a14_1v-a.line_40" n="40">Leben immer mit eren</line>
      </zone>
      <zone xml:id="a14_1v-b" ana="hc:Column">
        <line xml:id="l_a14_1v-b.line_1" n="1">Do ſprachen die herren</line>
        <line xml:id="l_a14_1v-b.line_2" n="2">Vnd was in wol geneme</line>
        <line xml:id="l_a14_1v-b.line_3" n="3">Dar zv den iũch<choice><abbr>errẽ</abbr><expan>erren</expan></choice> gezeme</line>
        <line xml:id="l_a14_1v-b.line_4" n="4"><hei:initial ana="hc:Lombard">D</hei:initial>o es alles gereit wart</line>
        <line xml:id="l_a14_1v-b.line_5" n="5">Div kint huben ſich vf die</line>
        <line xml:id="l_a14_1v-b.line_5_below-1" n="5_below" rend="below">vart</line>
        <line xml:id="l_a14_1v-b.line_6" n="6">Vf das mer vil breit</line>
        <line xml:id="l_a14_1v-b.line_7" n="7">Sie kamen ingroz arbeit</line>
        <line xml:id="l_a14_1v-b.line_8" n="8">Der maſpoum wagete</line>
        <line xml:id="l_a14_1v-b.line_9" n="9">Die marner uer zageten</line>
        <line xml:id="l_a14_1v-b.line_10" n="10">Da kamen groze winde</line>
        <line xml:id="l_a14_1v-b.line_11" n="11">Daz daz ſchif mit den <choice><abbr>kindẽ</abbr><expan>kinden</expan></choice></line>
        <line xml:id="l_a14_1v-b.line_12" n="12"><choice><abbr>v͛ſanc</abbr><expan>verſanc</expan></choice> <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> allez daz daz <choice><abbr>dĩne</abbr><expan>dinne</expan></choice> was</line>
        <line xml:id="l_a14_1v-b.line_13" n="13">Daz da nithes nith genas</line>
        <line xml:id="l_a14_1v-b.line_14" n="14">wan die <choice><abbr>iũcherren</abbr><expan>iuncherren</expan></choice> beide</line>
        <line xml:id="l_a14_1v-b.line_15" n="15">Daz gab in got zeheile</line>
        <line xml:id="l_a14_1v-b.line_16" n="16">Die vnde <choice><abbr>ſlugẽ</abbr><expan>ſlugen</expan></choice> ſie an ein ſtein <choice><abbr>wãt</abbr><expan>want</expan></choice></line>
        <line xml:id="l_a14_1v-b.line_17" n="17">Da ſi ein viſcher vant</line>
        <line xml:id="l_a14_1v-b.line_18" n="18">Der zoch ſi mit eim netze vz</line>
        <line xml:id="l_a14_1v-b.line_19" n="19">Er vurte ſi hein inſin hus</line>
        <line xml:id="l_a14_1v-b.line_20" n="20">Div kint <note ana="hc:TranscriptionNote">Rasur oder Pergamentschaden vor {kint}?</note> ſich berieten</line>
        <line xml:id="l_a14_1v-b.line_21" n="21">Daz ſie daz nieman ſeiten</line>
        <line xml:id="l_a14_1v-b.line_22" n="22">wan ſi komen weren</line>
        <line xml:id="l_a14_1v-b.line_23" n="23">Des nam ſi groz hele <note ana="hc:TranscriptionNote">Pergamentloch am Zeilenende - kein Textverlust in dieser Zeile</note></line>
        <line xml:id="l_a14_1v-b.line_24" n="24">Als liſtecliche redeten ſi <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a14_1v-b.line_25" n="25">Der eine ſolte heizen nizeta</line>
        <line xml:id="l_a14_1v-b.line_26" n="26">Der ander ſol heizen aquila</line>
        <line xml:id="l_a14_1v-b.line_27" n="27"><hei:initial ana="hc:Lombard">D</hei:initial>o geviel ez an einen tac</line>
        <line xml:id="l_a14_1v-b.line_28" n="28">Ein groz market da bi lac</line>
        <line xml:id="l_a14_1v-b.line_29" n="29">Der viſcher nam dív kint bi <choice><abbr>d͛</abbr><expan>der</expan></choice> <choice><abbr>hãt</abbr><expan>hant</expan></choice></line>
        <line xml:id="l_a14_1v-b.line_30" n="30">Zv eime ſtecken er ſi bant</line>
        <line xml:id="l_a14_1v-b.line_31" n="31">Er bot ſie do ueile</line>
        <line xml:id="l_a14_1v-b.line_32" n="32">Alle die gemeine</line>
        <line xml:id="l_a14_1v-b.line_33" n="33">Die inder burc waren</line>
        <line xml:id="l_a14_1v-b.line_34" n="34">Die ilten dar zware</line>
        <line xml:id="l_a14_1v-b.line_35" n="35">Daz ſie die kint geſehen</line>
        <line xml:id="l_a14_1v-b.line_36" n="36">Sie wnderte <choice><abbr>wannẽ</abbr><expan>wannen</expan></choice> ſie weren</line>
        <line xml:id="l_a14_1v-b.line_37" n="37">Oder <choice><abbr>wãne</abbr><expan>wanne</expan></choice> ſie weren geborn</line>
        <line xml:id="l_a14_1v-b.line_38" n="38">Waz ſi <choice><abbr>gevragetẽ</abbr><expan>gevrageten</expan></choice> ez was verlorn</line>
        <line xml:id="l_a14_1v-b.line_39" n="39">Dv kint ez niemanne ſageten</line>
        <line xml:id="l_a14_1v-b.line_40" n="40">Swie vil man ſi gevragete <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a14_ep7.1" />
      </zone>
    </surface>
