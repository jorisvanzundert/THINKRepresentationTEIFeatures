  <sourceDoc>
    <surface ana="hc:Page" n="1r" xml:id="a7_1r">
      <zone xml:id="a7_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="7.1" xml:id="a7_ep7.1" spanTo="#end.a7_ep7.1"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a7_ep7.1.en" />Faustinian and Claudius: Crisis and separation § 1<anchor xml:id="end.head.a7_ep7.1.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a7_ep7.1.de" />Faustinianus und Claudius: Krise und Trennung § 1<anchor xml:id="end.head.a7_ep7.1.de" />
        <line xml:id="l_a7_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription enthält ausschließlich noch mit größerer Sicherheit lesbaren Text. Bei den stark verwischten foll. 1r und 2v konnte Joseph Diemer 1851 noch deutlich mehr erkennen, Schröder 1882 schon weniger - vgl. oben "Hinweise zu diesem Textzeugen"</note> <note ana="hc:TranscriptionNote">Beschreibstoff oben abgeschnitten</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <gap unit="chars" ana="hc:Lost"></gap> <gap unit="chars" ana="hc:Illegible"></gap> vniginne er gie mit den <gap unit="chars" ana="hc:Illegible"></gap> ſie <gap unit="chars" ana="hc:Illegible"></gap> uie <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_2" n="2">ſine bruͦſte. ſiner boſen geluͦſte. braht er ſi innen <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_3" n="3">er ſi gerne wolte minnen. er ne <gap unit="chars" ana="hc:Illegible"></gap> ni <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_4" n="4">er moͮſe fer <gap unit="chars" ana="hc:Illegible"></gap> leben<pc><g ref="#char_pe"></g></pc> im w <gap unit="chars" ana="hc:Illegible"></gap> re g <gap unit="chars" ana="hc:Illegible"></gap> te de <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_5" n="5">hulfe im uz der not ſin dink ſ <gap unit="chars" ana="hc:Illegible"></gap> r genad <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_6" n="6">der frowen harte ſw <gap unit="chars" ana="hc:Illegible"></gap> ſprach im <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_7" n="7">dir herre wie du <gap unit="chars" ana="hc:Illegible"></gap> erla mi <gap unit="chars" ana="hc:Illegible"></gap> worte <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_8" n="8"><gap unit="chars" ana="hc:Illegible"></gap> orhte uil lieb iſt mir min man dine red <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_9" n="9"><gap unit="chars" ana="hc:Illegible"></gap> iſt dir nehe <gap unit="chars" ana="hc:Illegible"></gap> goͮt. <gap unit="chars" ana="hc:Illegible"></gap> dir nehan ich <gap unit="chars" ana="hc:Illegible"></gap> einen <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_10" n="10">ſol mich niht an dich wenden. n <gap unit="chars" ana="hc:Illegible"></gap> min <gap unit="chars" ana="hc:Illegible"></gap> koͮnne <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_11" n="11">den<pc><g ref="#char_pe"></g></pc> unt freiſ <gap unit="chars" ana="hc:Illegible"></gap> ez min herre. er gerefſet <gap unit="chars" ana="hc:Illegible"></gap> darum <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_12" n="12"><hei:initial ana="hc:Lombard">D</hei:initial>er herre ſprach daz er ſin niht en <gap unit="chars" ana="hc:Illegible"></gap> wolte<pc><g ref="#char_pe"></g></pc> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_13" n="13">be ſterben ſolte. <gap unit="chars" ana="hc:Illegible"></gap> ſin wrde. er <gap unit="chars" ana="hc:Illegible"></gap> etane buͦ <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_14" n="14"><gap unit="chars" ana="hc:Illegible"></gap> mit nihte f <gap unit="chars" ana="hc:Illegible"></gap> maze<pc><g ref="#char_pe"></g></pc> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_15" n="15"><gap unit="chars" ana="hc:Illegible"></gap> <hei:initial ana="hc:Lombard">D</hei:initial>o <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_16" n="16">we <gap unit="chars" ana="hc:Illegible"></gap> oͮ <gap unit="chars" ana="hc:Illegible"></gap> lichen <gap unit="chars" ana="hc:Illegible"></gap> ieme <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_17" n="17">not di <gap unit="chars" ana="hc:Illegible"></gap> im habete <gap unit="chars" ana="hc:Illegible"></gap> der w <gap unit="chars" ana="hc:Illegible"></gap> len <gap unit="chars" ana="hc:Illegible"></gap> droͮ <gap unit="chars" ana="hc:Illegible"></gap> uil <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_18" n="18">ſi ſprach <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Illegible"></gap> unſ <gap unit="chars" ana="hc:Illegible"></gap> mage <gap unit="chars" ana="hc:Illegible"></gap> werden w <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_19" n="19"><gap unit="chars" ana="hc:Illegible"></gap> nde <gap unit="chars" ana="hc:Illegible"></gap> e<pc><g ref="#char_pe"></g></pc> <gap unit="chars" ana="hc:Illegible"></gap> l ſware. <gap unit="chars" ana="hc:Illegible"></gap> nſ l <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_20" n="20">begund <gap unit="chars" ana="hc:Illegible"></gap> w <gap unit="chars" ana="hc:Illegible"></gap> n. <gap unit="chars" ana="hc:Illegible"></gap> d <gap unit="chars" ana="hc:Illegible"></gap> nn <gap unit="chars" ana="hc:Illegible"></gap> her <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_21" n="21">niht b <gap unit="chars" ana="hc:Illegible"></gap> ſprach ge <gap unit="chars" ana="hc:Illegible"></gap> w <gap unit="chars" ana="hc:Illegible"></gap> m <gap unit="chars" ana="hc:Illegible"></gap> t <gap unit="chars" ana="hc:Illegible"></gap> toͮ alſ ich <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_22" n="22">te <gap unit="chars" ana="hc:Illegible"></gap> wi <gap unit="chars" ana="hc:Illegible"></gap> hie zehoue w <gap unit="chars" ana="hc:Illegible"></gap> d <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_23" n="23">han zoͮ dir g <gap unit="chars" ana="hc:Illegible"></gap> ten willen. daz ge <gap unit="chars" ana="hc:Illegible"></gap> t <gap unit="chars" ana="hc:Illegible"></gap> unlange. mit k <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_24" n="24">nu beuangen ſin ne mac zediſen ziten niht ſin <pc><g ref="#char_pe"></g></pc> uil lieber g <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_25" n="25">gib mir goͮtlichen eine friſt<pc><g ref="#char_pe"></g></pc> ich leiſte gerne alez daz dir <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_1r-a.line_26" n="26"><hei:initial ana="hc:Lombard">D</hei:initial>er herre gewerte ſi der bete<pc><g ref="#char_pe"></g></pc> ſin gemoͮte ſtilte der da <gap unit="chars" ana="hc:Lost"></gap></line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a7_1v">
      <zone xml:id="a7_1v-a" ana="hc:Column">
        <line xml:id="l_a7_1v-a.line_1" n="1"> <note ana="hc:TranscriptionNote">Beschreibstoff oben abgeschnitten</note><gap unit="chars" ana="hc:Lost"></gap> ahte maniger liſte. wie ſi ir ere gefriſte. wi ſi den w <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_1v-a.line_2" n="2"><gap unit="chars" ana="hc:Lost"></gap> der rede machte bringen do <gap unit="chars" ana="hc:Illegible"></gap> indelineſ genaſ<pc><g ref="#char_pe"></g></pc> dannen</line>
        <line xml:id="l_a7_1v-a.line_3" n="3"><gap unit="chars" ana="hc:Lost"></gap> aſ<pc><g ref="#char_pe"></g></pc> des gefroͮweten ſich zware frivnte unt mage<pc><g ref="#char_pe"></g></pc> ſi uoͮnden</line>
        <line xml:id="l_a7_1v-a.line_4" n="4"><gap unit="chars" ana="hc:Lost"></gap> ſchoniſten namen<pc><g ref="#char_pe"></g></pc> dannen ſi ie gehorten ſagen<pc><g ref="#char_pe"></g></pc> er wart ge-</line>
        <line xml:id="l_a7_1v-a.line_5" n="5"><gap unit="chars" ana="hc:Lost"></gap> nſ<pc><g ref="#char_pe"></g></pc> ſit wart er zerome babeſ<pc><g ref="#char_pe"></g></pc> er iſt eîn marterare here<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_6" n="6"><gap unit="chars" ana="hc:Lost"></gap> gen hie andem lîbe unt dort an der ſele. <hei:initial ana="hc:Lombard">D</hei:initial>o div froͮwe kom</line>
        <line xml:id="l_a7_1v-a.line_7" n="7"><gap unit="chars" ana="hc:Lost"></gap> r kraft<pc><g ref="#char_pe"></g></pc> unt ſi des nahte bi dem koͮnige gelak<pc><g ref="#char_pe"></g></pc> alſ der herre</line>
        <line xml:id="l_a7_1v-a.line_8" n="8"><gap unit="chars" ana="hc:Lost"></gap> ute in diu froͮwe an rîef<pc><g ref="#char_pe"></g></pc> hilf du mir herre enzit<pc><g ref="#char_pe"></g></pc> ê ich bos-</line>
        <line xml:id="l_a7_1v-a.line_9" n="9"><gap unit="chars" ana="hc:Lost"></gap> den lib<pc><g ref="#char_pe"></g></pc> der koͮnic harte erſcrichte<pc><g ref="#char_pe"></g></pc> er ſpranc uf in al gerich</line>
        <line xml:id="l_a7_1v-a.line_10" n="10"><gap unit="chars" ana="hc:Lost"></gap> elliu min wunne. daz mir din got guͦnne<pc><g ref="#char_pe"></g></pc> waz iſt dir liebe</line>
        <line xml:id="l_a7_1v-a.line_11" n="11"><gap unit="chars" ana="hc:Lost"></gap> gerner ferwandelt ich daz leben<pc><g ref="#char_pe"></g></pc> ê dir iemer ieht zelaide</line>
        <line xml:id="l_a7_1v-a.line_12" n="12"><gap unit="chars" ana="hc:Lost"></gap> waz iſt daz du in dinem troͮme geſahe. <hei:initial ana="hc:Lombard">D</hei:initial>iv froͮwe antwrte</line>
        <line xml:id="l_a7_1v-a.line_13" n="13"><gap unit="chars" ana="hc:Lost"></gap> ach herre ich nemac niemer werden fro<pc><g ref="#char_pe"></g></pc> ich han ſo getaniu</line>
        <line xml:id="l_a7_1v-a.line_14" n="14"><gap unit="chars" ana="hc:Lost"></gap> n<pc><g ref="#char_pe"></g></pc> ich nemac niht lange leben<pc><g ref="#char_pe"></g></pc> oͮch ſage ich dir foͮr war<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_15" n="15"><gap unit="chars" ana="hc:Lost"></gap> nt gelebent niemer ein iar<pc><g ref="#char_pe"></g></pc> du neheizeſt ſi diu boͮch leren<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_16" n="16"><gap unit="chars" ana="hc:Lost"></gap> e ſi der herre<pc><g ref="#char_pe"></g></pc> liebe ſprach er din troͮm erge dir niht zelaide<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_17" n="17"><gap unit="chars" ana="hc:Lost"></gap> winte dich der kinde beider<pc><g ref="#char_pe"></g></pc> unt eruar under holden min<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_18" n="18"><gap unit="chars" ana="hc:Lost"></gap> oͮten meister sin<pc><g ref="#char_pe"></g></pc> uertige selbe diniu kint<pc><g ref="#char_pe"></g></pc> da die aller wiſten</line>
        <line xml:id="l_a7_1v-a.line_19" n="19"><gap unit="chars" ana="hc:Lost"></gap> ntent also froͮ<pc><g ref="#char_pe"></g></pc> ich fersihe nach aller eren dar zoͮ<pc><g ref="#char_pe"></g></pc> ſi werdent</line>
        <line xml:id="l_a7_1v-a.line_20" n="20"><gap unit="chars" ana="hc:Lost"></gap> ekeit<pc><g ref="#char_pe"></g></pc> ich ne chlage niht wan din arbeit<pc><g ref="#char_pe"></g></pc> dineſ rateſ uolge ich</line>
        <line xml:id="l_a7_1v-a.line_21" n="21"><gap unit="chars" ana="hc:Lost"></gap> <pc><g ref="#char_pe"></g></pc> ſprach der tivrliche herre. <hei:initial ana="hc:Lombard">D</hei:initial>iv froͮwe hiez diu ſchef zieren<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_22" n="22"><gap unit="chars" ana="hc:Lost"></gap> il ſchîere. do iz allez gar waſ<pc><g ref="#char_pe"></g></pc> die livte horten ſagen daz<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_23" n="23"><gap unit="chars" ana="hc:Lost"></gap> wolte ferſenden<pc><g ref="#char_pe"></g></pc> uerre in ellende<pc><g ref="#char_pe"></g></pc> die iunkheren bêide<pc><g ref="#char_pe"></g></pc> ſi</line>
        <line xml:id="l_a7_1v-a.line_24" n="24"><gap unit="chars" ana="hc:Lost"></gap> heize weinen<pc><g ref="#char_pe"></g></pc> die ſine uordeſten man<pc><g ref="#char_pe"></g></pc> die wolten iz ger-</line>
        <line xml:id="l_a7_1v-a.line_25" n="25"><gap unit="chars" ana="hc:Lost"></gap> det han<pc><g ref="#char_pe"></g></pc> do ſprach der koͮnic here<pc><g ref="#char_pe"></g></pc> nu fernemet min lere<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_1v-a.line_26" n="26"><gap unit="chars" ana="hc:Lost"></gap> beſem entlibet<pc><g ref="#char_pe"></g></pc> den ſun hazzet unt nidet<pc><g ref="#char_pe"></g></pc> zoͮht unt uorhte</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="2r" xml:id="a7_2r">
      <zone xml:id="a7_2r-a" ana="hc:Column">
        <line xml:id="l_a7_2r-a.line_1" n="1"> <note ana="hc:TranscriptionNote">Beschreibstoff oben abgeschnitten</note>ſwenne der iunge man<pc><g ref="#char_pe"></g></pc> mit zo <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a7_2r-a.line_2" n="2">da er ſol<pc><g ref="#char_pe"></g></pc> ſo ſtat ſin dink wol<pc><g ref="#char_pe"></g></pc> zoͮht unt triwe<pc><g ref="#char_pe"></g></pc> ſcoͮln ſamet boͮwen. ſwa ſich</line>
        <line xml:id="l_a7_2r-a.line_3" n="3">die geſchêident<pc><g ref="#char_pe"></g></pc> ich wan iz ſcaden zaiget<pc><g ref="#char_pe"></g></pc> er bedarf grozzer wizze<pc><g ref="#char_pe"></g></pc> ſwer</line>
        <line xml:id="l_a7_2r-a.line_4" n="4">zerome ſol ſizzen<pc><g ref="#char_pe"></g></pc> mitten in dem ſenate<pc><g ref="#char_pe"></g></pc> unt daz beſte ſol raten<pc><g ref="#char_pe"></g></pc> dar zoͮ be-</line>
        <line xml:id="l_a7_2r-a.line_5" n="5">richten manik riche<pc><g ref="#char_pe"></g></pc> ſprichet min ſun da wiſliche<pc><g ref="#char_pe"></g></pc> deſ habet ir groze êre<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_6" n="6">ſo gezimet er iu wol zeherren<pc><g ref="#char_pe"></g></pc> Clementem den iungelink<pc><g ref="#char_pe"></g></pc> dar nach elliu</line>
        <line xml:id="l_a7_2r-a.line_7" n="7">miniv dink<pc><g ref="#char_pe"></g></pc> beuilhe ich ze iwern genaden<pc><g ref="#char_pe"></g></pc> da wart ein michel iamer.</line>
        <line xml:id="l_a7_2r-a.line_8" n="8"><hei:initial ana="hc:Lombard">I</hei:initial>e dannoch tet der herre<pc><g ref="#char_pe"></g></pc> uil manige goͮte lere<pc><g ref="#char_pe"></g></pc> er nam daz kindelin bi</line>
        <line xml:id="l_a7_2r-a.line_9" n="9">der hant<pc><g ref="#char_pe"></g></pc> er beualh in inir aller gewalt<pc><g ref="#char_pe"></g></pc> daz ſi ſin wol wielten<pc><g ref="#char_pe"></g></pc> ir êre</line>
        <line xml:id="l_a7_2r-a.line_10" n="10">dar ane behielten<pc><g ref="#char_pe"></g></pc> wol gehiezen im alle ſîne man<pc><g ref="#char_pe"></g></pc> er kerte an daz mere</line>
        <line xml:id="l_a7_2r-a.line_11" n="11">fram<pc><g ref="#char_pe"></g></pc> er foͮr durch ſyciliam<pc><g ref="#char_pe"></g></pc> dar nach durch calabriam<pc><g ref="#char_pe"></g></pc> do er da nineuant<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_12" n="12">do kerter in affrikanſkiu lant<pc><g ref="#char_pe"></g></pc> do uoͮr er durch alexandriam<pc><g ref="#char_pe"></g></pc> dannen</line>
        <line xml:id="l_a7_2r-a.line_13" n="13">in die w<hi rendition="hc:Superscript">o</hi>ſten romaniam<pc><g ref="#char_pe"></g></pc> iz geſchach in einer mitter naht<pc><g ref="#char_pe"></g></pc> do hoͮb ſich</line>
        <line xml:id="l_a7_2r-a.line_14" n="14">der goteſ ſlak<pc><g ref="#char_pe"></g></pc> daz ſchef allez zebraſt<pc><g ref="#char_pe"></g></pc> daz da nihteſ niht genaſ<pc><g ref="#char_pe"></g></pc> wan der</line>
        <line xml:id="l_a7_2r-a.line_15" n="15">herre tivre<pc><g ref="#char_pe"></g></pc> der kom an die ſtivre<pc><g ref="#char_pe"></g></pc> ein holz begreif er mit den handen<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_16" n="16">die unde w<hi rendition="hc:Superscript">o</hi>rfen in zelande<pc><g ref="#char_pe"></g></pc> im wart uil manik groz ſlak<pc><g ref="#char_pe"></g></pc> ie dannoch ner</line>
        <line xml:id="l_a7_2r-a.line_17" n="17">te in diu goteſ kraft. <hei:initial ana="hc:Lombard">D</hei:initial>er herre begunde an dem libe<pc><g ref="#char_pe"></g></pc> harte gezwiueln<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_18" n="18">daz ſin niemer woͮde rat<pc><g ref="#char_pe"></g></pc> naket ſtuͦnt er ane wât<pc><g ref="#char_pe"></g></pc> richtoͮm waſ im fremede<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_19" n="19">wan in ſinem nazzen hemede<pc><g ref="#char_pe"></g></pc> der ê des richeſ herre waſ<pc><g ref="#char_pe"></g></pc> zuvare ſagen ich</line>
        <line xml:id="l_a7_2r-a.line_20" n="20">iu daz<pc><g ref="#char_pe"></g></pc> dem waſ ſo gar zeruͦnnen<pc><g ref="#char_pe"></g></pc> uon diu ne darf ſich niemen ferkoͮnnen<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_21" n="21">deſ ubelen noch deſ goͮten<pc><g ref="#char_pe"></g></pc> wan alſ in got wil behoͮten<pc><g ref="#char_pe"></g></pc> ia rîef er dem tôde<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a7_2r-a.line_22" n="22">dem ê diente rome<pc><g ref="#char_pe"></g></pc> dem ê dienten elliu lant<pc><g ref="#char_pe"></g></pc> froſt unt huͦnger in do dwank</line>
        <line xml:id="l_a7_2r-a.line_23" n="23">walt unt ſtêine<pc><g ref="#char_pe"></g></pc> lief er al gemeine<pc><g ref="#char_pe"></g></pc> dri tage unt dri naht<pc><g ref="#char_pe"></g></pc> daz er mazzeſ</line>
        <line xml:id="l_a7_2r-a.line_24" n="24">ni neplac. <hei:initial ana="hc:Lombard">I</hei:initial>e dannoch wolte in got nern<pc><g ref="#char_pe"></g></pc> do ſach er uͦf bi dem mere<pc><g ref="#char_pe"></g></pc> einen</line>
        <line xml:id="l_a7_2r-a.line_25" n="25">eſelare varn<pc><g ref="#char_pe"></g></pc> uil luͦte begunde er im nah harn<pc><g ref="#char_pe"></g></pc> der eſelare wart <note ana="hc:TranscriptionNote">{w} in {wart} aus {v} gebessert: zusätzliches {v} üdZ nachgetragen</note> ſin gewar</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="2v" xml:id="a7_2v">
      <zone xml:id="a7_2v-a" ana="hc:Column">
        <line xml:id="l_a7_2v-a.line_1" n="1"><note ana="hc:TranscriptionNote">Beschreibstoff oben abgeschnitten</note> <note ana="hc:TranscriptionNote">ca. 2/3 des Blattes vollständiger Textverlust durch „reagentien“ (Schröder, S. 18). Text erst ab Zeile 1758 (nach Schröder) leidlich lesbar. Diemer erkennt schon Zeile 1722</note><gap unit="chars" ana="hc:Lost"></gap> e ar <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_2v-a.line_2" n="2"><gap unit="chars" ana="hc:Illegible"></gap> die <gap unit="chars" ana="hc:Illegible"></gap> eit er h <gap unit="chars" ana="hc:Illegible"></gap> loͮg <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_2v-a.line_3" n="3"><gap unit="chars" ana="hc:Illegible"></gap> daz <gap unit="chars" ana="hc:Illegible"></gap> in allen l <gap unit="chars" ana="hc:Illegible"></gap> waſ <gap unit="chars" ana="hc:Illegible"></gap> z <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_2v-a.line_4" n="4"><gap unit="chars" ana="hc:Illegible"></gap> er hete w <gap unit="chars" ana="hc:Illegible"></gap> he <gap unit="chars" ana="hc:Illegible"></gap> waſ alſo wort <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_2v-a.line_5" n="5"><gap unit="chars" ana="hc:Illegible"></gap> en daz ſ <gap unit="chars" ana="hc:Illegible"></gap> der da <gap unit="chars" ana="hc:Illegible"></gap> ware.<anchor xml:id="end.a7_ep7.1" /><milestone ana="hc:Chapter" n="7.2" xml:id="a7_ep7.2" spanTo="#end.a7_ep7.2"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a7_ep7.2.en" />Faustinian and Claudius: Encounters with Peter § 2<anchor xml:id="end.head.a7_ep7.2.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a7_ep7.2.de" />Faustinianus und Claudius: Begegnungen mit Petrus § 2<anchor xml:id="end.head.a7_ep7.2.de" /><gap unit="chars" ana="hc:Illegible"></gap> u horen wir d <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a7_2v-a.line_6" n="6"><gap unit="chars" ana="hc:Illegible"></gap> agen under diu ko <gap unit="chars" ana="hc:Illegible"></gap> n ze hier <gap unit="chars" ana="hc:Illegible"></gap> lem geuarn<pc><g ref="#char_pe"></g></pc> koͮf <gap unit="chars" ana="hc:Illegible"></gap> n</line>
        <line xml:id="l_a7_2v-a.line_7" n="7"><gap unit="chars" ana="hc:Illegible"></gap> e<pc><g ref="#char_pe"></g></pc> man enp <gap unit="chars" ana="hc:Illegible"></gap> e ſi uil ſchone<pc><g ref="#char_pe"></g></pc> mit michelme flize<pc><g ref="#char_pe"></g></pc> in aller ſ <gap unit="chars" ana="hc:Illegible"></gap></line>
