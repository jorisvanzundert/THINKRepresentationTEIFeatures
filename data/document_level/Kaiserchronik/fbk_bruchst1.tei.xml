  <sourceDoc>
    <surface ana="hc:Page" n="1r/v" xml:id="a8_1r_v">
      <zone xml:id="a8_1r_v-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="13" xml:id="a8_ep13" spanTo="#end.a8_ep13"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a8_ep13.en" />Vespasian<anchor xml:id="end.head.a8_ep13.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a8_ep13.de" />Vespasianus<anchor xml:id="end.head.a8_ep13.de" />
        <line xml:id="l_a8_1r_v-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription des verschollenen Fragments basiert auf dem Abdruck von Franz Hobich (1898) und kann den Text in seiner ursprünglichen Form nur bedingt darstellen - vgl. oben "Hinweise zu diesem Textzeugen"</note> <note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <note ana="hc:TranscriptionNote">ersten beiden Buchstaben fehlen, Hobich ersetzt „Ro“ (Hobich, S. 272)</note> maer mit nide ersprancten. in vier</line>
        <line xml:id="l_a8_1r_v-a.line_2" n="2">halben si si anranden. harte <choice><abbr>v͛mez</abbr><expan>vermez</expan></choice></line>
        <line xml:id="l_a8_1r_v-a.line_3" n="3">zenlichen. mit slegen vnd mit stich</line>
        <line xml:id="l_a8_1r_v-a.line_4" n="4">en. ze flvhte si si dwungen. di schar</line>
        <line xml:id="l_a8_1r_v-a.line_5" n="5">si dvrh drvngen. der chvnic wart</line>
        <line xml:id="l_a8_1r_v-a.line_6" n="6">gevangen. mit sînen tivristen <choice><abbr>mã</abbr><expan>man</expan></choice></line>
        <line xml:id="l_a8_1r_v-a.line_7" n="7">nen. si tratten vnd vîengen. swaz si</line>
        <line xml:id="l_a8_1r_v-a.line_8" n="8">ir begiengen. si slvͦgen si vnd schan</line>
        <line xml:id="l_a8_1r_v-a.line_9" n="9">den div lant si <choice><abbr>v͛branden</abbr><expan>verbranden</expan></choice>. si fv̂ren</line>
        <line xml:id="l_a8_1r_v-a.line_10" n="10">vrôliche.  in romischiv riche. <hei:initial ana="hc:Lombard">D</hei:initial>o</line>
        <line xml:id="l_a8_1r_v-a.line_11" n="11">dîe herren chomen. <note ana="hc:TranscriptionNote">Zirkumflex o. ä. ohne klare Zuordnung über der Zeile nach {chomen}</note> wider ze rome.</line>
        <line xml:id="l_a8_1r_v-a.line_12" n="12">Romær oͮz der stat riten und gîen</line>
        <line xml:id="l_a8_1r_v-a.line_13" n="13">gen. den chvnic si wol enphiengen.</line>
        <line xml:id="l_a8_1r_v-a.line_14" n="14">alte vnd ivnge. groz lob si ime svn</line>
        <line xml:id="l_a8_1r_v-a.line_15" n="15">gen. ze ware sagen ih iv daz. do wa</line>
        <line xml:id="l_a8_1r_v-a.line_16" n="16">rt der chvnic Hylâs. geworfen in einen charchære. si sprachen daz er</line>
        <line xml:id="l_a8_1r_v-a.line_17" n="17">des todes dar vmbe schvldic wære.</line>
        <line xml:id="l_a8_1r_v-a.line_18" n="18">er het wider romischez riche get</line>
        <line xml:id="l_a8_1r_v-a.line_19" n="19">an. do weget im <choice><abbr>d͛</abbr><expan>der</expan></choice> hilig edil man.</line>
        <line xml:id="l_a8_1r_v-a.line_20" n="20">Tytvs nert in von dem tode. er san</line>
        <line xml:id="l_a8_1r_v-a.line_21" n="21">te in von Rome. heim in sin riche.</line>
        <line xml:id="l_a8_1r_v-a.line_22" n="22">Vespasianus lebet do chvnicliche.</line>
        <line xml:id="l_a8_1r_v-a.line_23" n="23">nv saget das bvͦch fur war. dar nah</line>
        <line xml:id="l_a8_1r_v-a.line_24" n="24">ahte iar. vnd zehen manode mere.</line>
        <line xml:id="l_a8_1r_v-a.line_25" n="25">an dem blvͦt <choice><abbr>ṽschiet</abbr><expan>verschiet</expan></choice> <note ana="hc:TranscriptionNote">{<choice><abbr>ṽschiet</abbr><expan>verschiet</expan></choice>} wahrscheinlich Fehler Hobichs; wohl {<choice><abbr>v͛schiet</abbr><expan>verschiet</expan></choice>}</note> der herre.</line>
        <anchor xml:id="end.a8_ep13" /><milestone ana="hc:Chapter" n="14" xml:id="a8_ep14" spanTo="#end.a8_ep14"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a8_ep14.en" />Titus<anchor xml:id="end.head.a8_ep14.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a8_ep14.de" />Titus<anchor xml:id="end.head.a8_ep14.de" />
        <line xml:id="l_a8_1r_v-a.line_26" n="26"><milestone ana="hc:Heading" spanTo="#end.rub.1" /><hi rendition="hc:Enlarged">Daz ist von Tyten.</hi><anchor xml:id="end.rub.1" /></line>
        <line xml:id="l_a8_1r_v-a.line_27" n="27"><hei:initial>D</hei:initial>az riche stvͦnt do lære. si sprachen</line>
        <line xml:id="l_a8_1r_v-a.line_28" n="28">daz Tytvs wære. milt</line>
        <line xml:id="l_a8_1r_v-a.line_29" n="29">vnd chv̂ne. edil gnvͦgi. vnd daz er</line>
        <line xml:id="l_a8_1r_v-a.line_30" n="30">wol gezæme. ze voget vnd ze rihtæ</line>
        <line xml:id="l_a8_1r_v-a.line_31" n="31">re. Romær niht entwelten. Tytum</line>
        <line xml:id="l_a8_1r_v-a.line_32" n="32">si erwelten. si wolden ir willen bi im</line>
        <line xml:id="l_a8_1r_v-a.line_33" n="33">haben. do hiez er die phaht fûr <choice><abbr>tragẽ</abbr><expan>tragen</expan></choice>.</line>
        <line xml:id="l_a8_1r_v-a.line_34" n="34">ern wolde nie niht gerihten. wan al</line>
        <line xml:id="l_a8_1r_v-a.line_35" n="35">so im seit div phahte. <hei:initial ana="hc:Lombard">D</hei:initial>o waren ze</line>
        <line xml:id="l_a8_1r_v-a.line_36" n="36">Rome tvmbe herren. die dem chvnig</line>
        <line xml:id="l_a8_1r_v-a.line_37" n="37">rieten an sin ere tavgenliche. daz si</line>
        <line xml:id="l_a8_1r_v-a.line_38" n="38">wider tæten fræviliche.  si wolden</line>
        <line xml:id="l_a8_1r_v-a.line_39" n="39">in gern haben erslagen. do mohten</line>
        <line xml:id="l_a8_1r_v-a.line_40" n="40">si der stat niht haben. der chvnic w</line>
        <line xml:id="l_a8_1r_v-a.line_41" n="41">art gewarnot. si chomen alle in g</line>
        <line xml:id="l_a8_1r_v-a.line_42" n="42">roz not. <choice><abbr><hei:initial ana="hc:Lombard">T</hei:initial>ytꝰ</abbr><expan><hei:initial ana="hc:Lombard">T</hei:initial>ytus</expan></choice> der riche. warp h</line>
        <line xml:id="l_a8_1r_v-a.line_43" n="43">arte wisliche. er besante ir einen dra</line>
        <line xml:id="l_a8_1r_v-a.line_44" n="44">te. er chom ze siner cheminate. also er</line>
        <line xml:id="l_a8_1r_v-a.line_45" n="45">in ane sach. vil gvͦtliche er im zû spr</line>
        <line xml:id="l_a8_1r_v-a.line_46" n="46">ach do ich daz riche aller erst gewan</line>
        <line xml:id="l_a8_1r_v-a.line_47" n="47">do wurde dv zehande min man. waz</line>
        <line xml:id="l_a8_1r_v-a.line_48" n="48">getet ich îe <choice><abbr>wid͛</abbr><expan>wider</expan></choice> dih. ode wes schvldig</line>
        <line xml:id="l_a8_1r_v-a.line_49" n="49">ist dv mih Nv sag mir oͮf din triͮwe.</line>
        <line xml:id="l_a8_1r_v-a.line_50" n="50">iz nedarf dih niemer geriͮwen. waz</line>
        <line xml:id="l_a8_1r_v-a.line_51" n="51">woldest dv han getan. mæhtist dv</line>
        <line xml:id="l_a8_1r_v-a.line_52" n="52">min sâme gvͦten gewalt han. also dv</line>
        <line xml:id="l_a8_1r_v-a.line_53" n="53">in miner gewalt bist. nv sag mir di</line>
        <line xml:id="l_a8_1r_v-a.line_54" n="54">nen list. woldist dv mih lazen leben.</line>
        <line xml:id="l_a8_1r_v-a.line_55" n="55">dv solt mir der warheit iehen.</line>
        <line xml:id="l_a8_1r_v-a.line_56" n="56"><hei:initial ana="hc:Lombard">D</hei:initial>o antwurte ime sûs. der schvl</line>
        <line xml:id="l_a8_1r_v-a.line_57" n="57">dig ariolus. ih wil dir wærlich sagen. mæht ih din also gvͦten gew</line>
        <line xml:id="l_a8_1r_v-a.line_58" n="58">alt haben. wærist dv mir also heim</line>
        <line xml:id="l_a8_1r_v-a.line_59" n="59">lich chomên. dinen lip het ich dir beno</line>
        <line xml:id="l_a8_1r_v-a.line_60" n="60">men. dv nemæhtist is niemer vber</line>
        <line xml:id="l_a8_1r_v-a.line_61" n="61">werden. von mînen handen mvͦsist</line>
        <line xml:id="l_a8_1r_v-a.line_62" n="62">dv ersterben. dines gerihtes bist</line>
        <line xml:id="l_a8_1r_v-a.line_63" n="63">dv grimme. wirn haben zv dir deh</line>
        <line xml:id="l_a8_1r_v-a.line_64" n="64">ein minne. dar vmbe wellen wir d</line>
        <line xml:id="l_a8_1r_v-a.line_65" n="65">ih erslan. daz hast dv vns ze leide</line>
        <line xml:id="l_a8_1r_v-a.line_66" n="66">getan. <hei:initial ana="hc:Lombard">D</hei:initial>o sprah <choice><abbr>Tytꝰ</abbr><expan>Tytus</expan></choice> der riche.</line>
        <line xml:id="l_a8_1r_v-a.line_67" n="67">harte wisliche. ob ih nah der phahte. <note ana="hc:TranscriptionNote">{phahte} aus {phafte} gebessert: {h} über der Zeile nachgetragen. Hinweis bei Hobich, S. 274</note></line>
        <line xml:id="l_a8_1r_v-a.line_68" n="68">daz livt riht rehte. daz dv mih dar vm</line>
        <line xml:id="l_a8_1r_v-a.line_69" n="69">be slahen wil. der schvlde ist doch niht</line>
        <line xml:id="l_a8_1r_v-a.line_70" n="70">vil. wil dv mir den lip nemen. so wil</line>
        <line xml:id="l_a8_1r_v-a.line_71" n="71">ih dir min golt geben. so dv aller meis</line>
        <line xml:id="l_a8_1r_v-a.line_72" n="72">te maht getragen. er hiez ime rûmen</line>
        <line xml:id="l_a8_1r_v-a.line_73" n="73">daz gadem. er hiez in beleiten wider</line>
        <line xml:id="l_a8_1r_v-a.line_74" n="74">oͮz. er gahit heim in sin hûs. Do <choice><abbr>stṽt</abbr><expan>stvnt</expan></choice></line>
        <line xml:id="l_a8_1r_v-a.line_75" n="75">iz do vnlange. do besante er den and</line>
        <line xml:id="l_a8_1r_v-a.line_76" n="76">êrn. so tet er den eitgnozen allensamt.</line>
        <line xml:id="l_a8_1r_v-a.line_77" n="77">vnz er di warheit bevant. Sin golt</line>
        <line xml:id="l_a8_1r_v-a.line_78" n="78">er in allen gab. besvnder er si bat. daz</line>
        <line xml:id="l_a8_1r_v-a.line_79" n="79">si in alle da welten. wedirz si haben wol</line>
        <line xml:id="l_a8_1r_v-a.line_80" n="80">ten. daz si sîne man oder frivnt waren.</line>
        <line xml:id="l_a8_1r_v-a.line_81" n="81">swedirs si baz gezæme. <hei:initial ana="hc:Lombard">D</hei:initial>ie eitgnoze</line>
        <line xml:id="l_a8_1r_v-a.line_82" n="82">zwelfe. chomen wider zesamine. si sp</line>
        <line xml:id="l_a8_1r_v-a.line_83" n="83">rachen daz si so gelastert waren. daz</line>
        <line xml:id="l_a8_1r_v-a.line_84" n="84">ir vordern nîe gischæhe. iz moht niht</line>
        <line xml:id="l_a8_1r_v-a.line_85" n="85">beliben vngerochen. der chvnic het sih</line>
        <line xml:id="l_a8_1r_v-a.line_86" n="86">vbersprochen. Si frv̂mten ir mezzir. so</line>
        <line xml:id="l_a8_1r_v-a.line_87" n="87">si endorften bezzir. Div waren beident</line>
        <line xml:id="l_a8_1r_v-a.line_88" n="88">halben wæhse. vnd snîten sam div sch</line>
        <line xml:id="l_a8_1r_v-a.line_89" n="89">arsahse. ob si sih niht offenlichen mah</line>
        <line xml:id="l_a8_1r_v-a.line_90" n="90">ten gerechen. si wolden in aber toͮgenl</line>
        <line xml:id="l_a8_1r_v-a.line_91" n="91">ich stechen. <hei:initial ana="hc:Lombard">T</hei:initial>ytus der miltê. lac an</line>
        <line xml:id="l_a8_1r_v-a.line_92" n="92">sinem bette. einen troͮm er gesach. da inne leit er vngemach. wi er rite in ei</line>
        <line xml:id="l_a8_1r_v-a.line_93" n="93">nem walde. da</line>
        <line xml:id="l_a8_1r_v-a.line_94" n="94">sah er lewen wilde. sîe</line>
        <line xml:id="l_a8_1r_v-a.line_95" n="95">wolden in nider zihen. der herre be</line>
        <line xml:id="l_a8_1r_v-a.line_96" n="96">gvnde fliehen. er chom vil choͮme. Zei</line>
        <line xml:id="l_a8_1r_v-a.line_97" n="97">nem dvrren boͮme. do neheten sin este.</line>
        <line xml:id="l_a8_1r_v-a.line_98" n="98">deheiner slaht veste. an swelhen ast</line>
        <line xml:id="l_a8_1r_v-a.line_99" n="99"><gap unit="chars" ana="hc:Illegible"></gap> <note ana="hc:TranscriptionNote">Hinweis zu unleserlicher Stelle bei Hobich, S. 275</note> schier er enzwei brast. so be</line>
        <line xml:id="l_a8_1r_v-a.line_100" n="100">greif er einen andern. der verswant</line>
        <line xml:id="l_a8_1r_v-a.line_101" n="101">ime oͮz den handen. der herre in gro</line>
        <line xml:id="l_a8_1r_v-a.line_102" n="102">zen sorgen was. vnlange stvͦnt daz.</line>
        <line xml:id="l_a8_1r_v-a.line_103" n="103">einen andern boͮm chos er da bi. der</line>
        <line xml:id="l_a8_1r_v-a.line_104" n="104">het grv̂niv zwî. den wiphil neict er</line>
        <line xml:id="l_a8_1r_v-a.line_105" n="105">zv der erde. do erholte sih der herre.</line>
        <line xml:id="l_a8_1r_v-a.line_106" n="106">er swanc sih oͮf enrihte. der chvnic</line>
        <line xml:id="l_a8_1r_v-a.line_107" n="107">oͮz dem slafe erschrihte. <hei:initial ana="hc:Lombard">D</hei:initial>o der</line>
        <line xml:id="l_a8_1r_v-a.line_108" n="108">chvnic erwahte. den troͮm er selbe</line>
        <line xml:id="l_a8_1r_v-a.line_109" n="109">betrahte. als er oͮch sit ergîe. wislich</line>
        <line xml:id="l_a8_1r_v-a.line_110" n="110">er iz ane vîe. der chvnic gvͦte. schvf</line>
        <line xml:id="l_a8_1r_v-a.line_111" n="111">sin hv̂te. di in wol bewahten. ze ta</line>
        <line xml:id="l_a8_1r_v-a.line_112" n="112">ge vnd ze naht. daz si ime niht moh</line>
        <line xml:id="l_a8_1r_v-a.line_113" n="113">ten geschaden. weder gestechen noh</line>
        <line xml:id="l_a8_1r_v-a.line_114" n="114">geslahen. <hei:initial ana="hc:Lombard">B</hei:initial>i den ziten was ze ro</line>
        <line xml:id="l_a8_1r_v-a.line_115" n="115">me ein spilhoͮs. geheizen waz ez asîlus.</line>
        <line xml:id="l_a8_1r_v-a.line_116" n="116">der herren site was so getan. da w</line>
        <line xml:id="l_a8_1r_v-a.line_117" n="117">olden si iemer ze nône ingan. an ein</line>
        <line xml:id="l_a8_1r_v-a.line_118" n="118">ander si do sageten. waz si gehoret</line>
        <line xml:id="l_a8_1r_v-a.line_119" n="119">habeten. von werltlichen êren. <note ana="hc:TranscriptionNote">Zirkumflex o. ä. ohne klare Zuordnung über der Zeile nach {êren}</note> des</line>
        <line xml:id="l_a8_1r_v-a.line_120" n="120">flizten sih alle die herren. <hei:initial ana="hc:Lombard">T</hei:initial>ytus der riche. warb vil lutichliche. er h</line>
        <line xml:id="l_a8_1r_v-a.line_121" n="121">iez sin spehære. vber alle di stat sagen</line>
        <line xml:id="l_a8_1r_v-a.line_122" n="122">mære. daz er mit sînen heimlichen</line>
        <line xml:id="l_a8_1r_v-a.line_123" n="123">mannen. hin ze dem spilhv̂se wâre</line>
        <line xml:id="l_a8_1r_v-a.line_124" n="124">gegangen. einhalb gienc er in daz sp</line>
        <line xml:id="l_a8_1r_v-a.line_125" n="125">ilhv̂s. anderhalb stal er sih dar oͮz.</line>
        <line xml:id="l_a8_1r_v-a.line_126" n="126">er hiez sih wafen alle sîne man. êrn</line>
        <line xml:id="l_a8_1r_v-a.line_127" n="127">wolde deheinem sagen. waz er frvm</line>
        <line xml:id="l_a8_1r_v-a.line_128" n="128">en wolde. er sprah daz er haben solde.</line>
        <line xml:id="l_a8_1r_v-a.line_129" n="129">ze michiler note. die helden bereiten</line>
        <line xml:id="l_a8_1r_v-a.line_130" n="130">sih drate. <hei:initial ana="hc:Lombard">D</hei:initial>o saget man</line>
        <line xml:id="l_a8_1r_v-a.line_131" n="131">vber al di bvrch mære. daz der</line>
        <line xml:id="l_a8_1r_v-a.line_132" n="132">chvnic in dem spilhoͮs wære Di vien</line>
        <line xml:id="l_a8_1r_v-a.line_133" n="133">de waren des vil vro. schiere <choice><abbr>sametẽ</abbr><expan>sameten</expan></choice> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a8_ep14" />
      </zone>
