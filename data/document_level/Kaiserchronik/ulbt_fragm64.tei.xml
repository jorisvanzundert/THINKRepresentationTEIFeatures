  <sourceDoc>
    <surface ana="hc:Page" n="1r" xml:id="c2_1r">
      <zone xml:id="c2_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="27.2" xml:id="c2_ep27.2" spanTo="#end.c2_ep27.2"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c2_ep27.2.en" />Constantine: Maternal conflict § 2<anchor xml:id="end.head.c2_ep27.2.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c2_ep27.2.de" />Constantinus: Konflikt mit der Mutter § 2<anchor xml:id="end.head.c2_ep27.2.de" />
        <line xml:id="l_c2_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Da Schönbach (1889) etwas mehr am Original erkennen konnte als an den Aufnahmen deutlich lesbar ist, wird in dieser Transkription an einigen schwer bzw. nicht leserlichen Stellen Text von seinem Abdruck übernommen - vgl. oben "Hinweise zu diesem Textzeugen"</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <gap unit="chars" ana="hc:Lost"></gap> <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c2_1r-a.line_2" n="2"><gap unit="chars" ana="hc:Lost"></gap> chainer inne wart</line>
        <line xml:id="l_c2_1r-a.line_3" n="3">waz wær der boten vart</line>
        <line xml:id="l_c2_1r-a.line_4" n="4">Sine boten er ſande</line>
        <line xml:id="l_c2_1r-a.line_5" n="5">ze tivſchem lande</line>
        <line xml:id="l_c2_1r-a.line_6" n="6">Da waſ dev chvnigyn Elena</line>
        <line xml:id="l_c2_1r-a.line_7" n="7">di boten fvnden ſi da</line>
        <line xml:id="l_c2_1r-a.line_8" n="8">Er enbot der vrowen <choice><abbr>h͛</abbr><expan>her</expan></choice></line>
        <line xml:id="l_c2_1r-a.line_9" n="9"><choice><abbr>chintlich͛</abbr><expan>chintlicher</expan></choice> trivwen ler</line>
        <line xml:id="l_c2_1r-a.line_10" n="10">Si het alſ groz <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note></line>
        <line xml:id="l_c2_1r-a.line_11" n="11">ſo ín der werlt imen mere <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note></line>
        <line xml:id="l_c2_1r-a.line_12" n="12"> Elliv Romiſchiv lant</line>
        <line xml:id="l_c2_1r-a.line_13" n="13">ſtvͦnden gar ín ir hant</line>
        <line xml:id="l_c2_1r-a.line_14" n="14">Waz ir wære genæme <note ana="hc:TranscriptionNote">Zeile an der Aufnahme beinahe ganz unleserlich wegen Pergamentschaden - Transkription geht auf Schönbach zurück, der allerdings 'nur die Spitzen' der Buchstaben erkennen konnte (S. 381)</note></line>
        <line xml:id="l_c2_1r-a.line_15" n="15"><note ana="hc:TranscriptionNote">Pergamentloch</note> wol in <note ana="hc:TranscriptionNote">Pergamentloch</note> <note ana="hc:TranscriptionNote">{wol in} gerade noch leserlich</note></line>
        <line xml:id="l_c2_1r-a.line_16" n="16">Vil <note ana="hc:TranscriptionNote">Zeilenanfang an der Aufnahme unleserlich - {Vil} von Schönbachs Abdruck übernommen (vgl. Cod. 2685: {Auwe})</note> libiv <choice><abbr>mvͦt͛</abbr><expan>mvͦter</expan></choice> min</line>
        <line xml:id="l_c2_1r-a.line_17" n="17">nv la dir nicht lait ſin</line>
        <line xml:id="l_c2_1r-a.line_18" n="18">Daz ich dir chlagen wil</line>
        <line xml:id="l_c2_1r-a.line_19" n="19">míner noͤte waſ ſo vil</line>
        <line xml:id="l_c2_1r-a.line_20" n="20">Daz dir niem geſagen mac</line>
        <line xml:id="l_c2_1r-a.line_21" n="21">vnz mir chom der tac</line>
        <line xml:id="l_c2_1r-a.line_22" n="22">Daz mein got gervͦchte</line>
        <line xml:id="l_c2_1r-a.line_23" n="23">mit boten er mich ſvͦchte</line>
        <line xml:id="l_c2_1r-a.line_24" n="24">Do ich ervollet ir gebot</line>
        <line xml:id="l_c2_1r-a.line_25" n="25">do wart ich geſvnt von got</line>
        <line xml:id="l_c2_1r-a.line_26" n="26"><gap ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="c2_1r-b" ana="hc:Column">
        <line xml:id="l_c2_1r-b.line_1" n="1"><gap unit="chars" ana="hc:Lost"></gap> trechtein</line>
        <line xml:id="l_c2_1r-b.line_2" n="2">ſwi dv wil ſo wil ich dann ſin</line>
        <line xml:id="l_c2_1r-b.line_3" n="3"><hei:initial ana="hc:Lombard">A</hei:initial>ls Elena dv brief gelas</line>
        <line xml:id="l_c2_1r-b.line_4" n="4">ir hertz vil trowric waſ</line>
        <line xml:id="l_c2_1r-b.line_5" n="5">Brief ſi ſchriben hiez</line>
        <line xml:id="l_c2_1r-b.line_6" n="6">ir botſchaft ſi nicht líez</line>
        <line xml:id="l_c2_1r-b.line_7" n="7">Rom ſi wolte ſtoren</line>
        <line xml:id="l_c2_1r-b.line_8" n="8">daz lie ſi ſei alle horen</line>
        <line xml:id="l_c2_1r-b.line_9" n="9">Vnt elliv Romiſchiv riche</line>
        <line xml:id="l_c2_1r-b.line_10" n="10">er mvͦſe ſelb ſchantliche</line>
        <line xml:id="l_c2_1r-b.line_11" n="11">Leben immer mere</line>
        <line xml:id="l_c2_1r-b.line_12" n="12"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note> <choice><abbr>chaiſ͛</abbr><expan>chaiſer</expan></choice> here <note ana="hc:TranscriptionNote">Zeilenende kaum noch leserlich - {<choice><abbr>chaiſ͛</abbr><expan>chaiſer</expan></choice>} von Schönbachs Abdruck übernommen</note></line>
        <line xml:id="l_c2_1r-b.line_13" n="13"><milestone ana="hc:SectionMarker" spanTo="#end.par.1"/>¶<anchor xml:id="end.par.1" /> Conſtantino nicht dochte <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note></line>
        <line xml:id="l_c2_1r-b.line_14" n="14"> ze hællen noch enmochte</line>
        <line xml:id="l_c2_1r-b.line_15" n="15">Er enbot ez ſinem <choice><abbr>maiſt͛</abbr><expan>maiſter</expan></choice> da</line>
        <line xml:id="l_c2_1r-b.line_16" n="16">dem gvͦten ſant <choice><abbr>Silveſt͛</abbr><expan>Silveſter</expan></choice> ſa</line>
        <line xml:id="l_c2_1r-b.line_17" n="17">Als der heilige man <note ana="hc:TranscriptionNote">diese und die nächste Zeile z.T. kaum leserlich - Transkription stützt sich auf Schönbach</note></line>
        <line xml:id="l_c2_1r-b.line_18" n="18">di botſchaft vernan</line>
        <line xml:id="l_c2_1r-b.line_19" n="19">Er antwrt im ſus</line>
        <line xml:id="l_c2_1r-b.line_20" n="20">te deum <choice><abbr>Laudamꝰ</abbr><expan>Laudamus</expan></choice></line>
        <line xml:id="l_c2_1r-b.line_21" n="21">Lob dir herre træchtin</line>
        <line xml:id="l_c2_1r-b.line_22" n="22">der grozen genaden din</line>
        <line xml:id="l_c2_1r-b.line_23" n="23">Wan dv den dinen gehieze</line>
        <line xml:id="l_c2_1r-b.line_24" n="24">ſwer ſich an dich <choice><abbr>v͛lieze</abbr><expan>verlieze</expan></choice></line>
        <line xml:id="l_c2_1r-b.line_25" n="25">Daz der gwiſſeliche</line>
        <line xml:id="l_c2_1r-b.line_26" n="26">bowte in himelriche</line>
        <line xml:id="l_c2_1r-b.line_27" n="27"><hei:initial ana="hc:Lombard">D</hei:initial>er pabeſt ſprach zv d̃ <choice><abbr>botẽ</abbr><expan>boten</expan></choice> do</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="c2_1v">
      <zone xml:id="c2_1v-a" ana="hc:Column">
        <line xml:id="l_c2_1v-a.line_1" n="1">H <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_1v-a.line_2" n="2">mit recht an dich minne</line>
        <line xml:id="l_c2_1v-a.line_3" n="3">Daz laz ſi danne ſchín</line>
        <line xml:id="l_c2_1v-a.line_4" n="4">daz enbivt der mvͦter din</line>
        <line xml:id="l_c2_1v-a.line_5" n="5">Der rat dovcht den chvnic gvͦt</line>
        <line xml:id="l_c2_1v-a.line_6" n="6">ſin trowriger <note ana="hc:TranscriptionNote">Zeilenfüllung vor {mvͦt}</note>  mvͦt</line>
        <line xml:id="l_c2_1v-a.line_7" n="7">Im ſo entſlifen began</line>
        <line xml:id="l_c2_1v-a.line_8" n="8">er hiez <choice><abbr>gewinnẽ</abbr><expan>gewinnen</expan></choice> ſine man</line>
        <line xml:id="l_c2_1v-a.line_9" n="9">Er enbot der chvniginne</line>
        <line xml:id="l_c2_1v-a.line_10" n="10">dienſt vnt <note ana="hc:TranscriptionNote">Zeilenfüllung vor {mínne}</note> mínne</line>
        <line xml:id="l_c2_1v-a.line_11" n="11">Daz ſvn der <choice><abbr>mvͦt͛</abbr><expan>mvͦter</expan></choice> enbieten ſolt</line>
        <line xml:id="l_c2_1v-a.line_12" n="12">ob ſi ir zorn lazen wolt</line>
        <line xml:id="l_c2_1v-a.line_13" n="13">Ob ſi rainen ſent wolt han</line>
        <line xml:id="l_c2_1v-a.line_14" n="14">liezen ze ſamen gan <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note></line>
        <line xml:id="l_c2_1v-a.line_15" n="15"> Der haiden wiſe ſchribære</line>
        <line xml:id="l_c2_1v-a.line_16" n="16"><choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> <choice><abbr>ſw͛</abbr><expan>ſwer</expan></choice> <choice><abbr>d͛</abbr><expan>der</expan></choice> ê <choice><abbr>vnd͛</abbr><expan>vnder</expan></choice> den jvden bære</line>
        <line xml:id="l_c2_1v-a.line_17" n="17">Vernem di red manik valt</line>
        <line xml:id="l_c2_1v-a.line_18" n="18">ſwem dan <choice><abbr>d͛</abbr><expan>der</expan></choice> ſig <choice><abbr>w͛d</abbr><expan>werd</expan></choice> gezalt</line>
        <line xml:id="l_c2_1v-a.line_19" n="19">Der ſolt ſin geniezen</line>
        <line xml:id="l_c2_1v-a.line_20" n="20">vnt di anderen ſwigen hiezen</line>
        <line xml:id="l_c2_1v-a.line_21" n="21"><milestone ana="hc:SectionMarker" spanTo="#end.par.2"/>¶<anchor xml:id="end.par.2" /> Div botſchaft chom <choice><abbr>d͛</abbr><expan>der</expan></choice> chvnigin dan</line>
        <line xml:id="l_c2_1v-a.line_22" n="22">ir wiſiſte man</line>
        <line xml:id="l_c2_1v-a.line_23" n="23">Hiez ſi ir gewinnen</line>
        <line xml:id="l_c2_1v-a.line_24" n="24">mit michelen vnminnen</line>
        <line xml:id="l_c2_1v-a.line_25" n="25">Beriet ſi ſich ſan</line>
        <line xml:id="l_c2_1v-a.line_26" n="26">ſi <choice><abbr>ſpᷓchen</abbr><expan>ſprachen</expan></choice> ſi ſolt den ſent han</line>
        <line xml:id="l_c2_1v-a.line_27" n="27">Der chriſtenhait ze vare</line>
        <line xml:id="l_c2_1v-a.line_28" n="28">ſi <choice><abbr>ſpᷓchen</abbr><expan>ſprachen</expan></choice> zeware</line>
        <line xml:id="l_c2_1v-a.line_29" n="29"><gap ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="c2_1v-b" ana="hc:Column">
        <line xml:id="l_c2_1v-b.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_1v-b.line_2" n="2"><hei:initial ana="hc:Lombard">D</hei:initial> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_1v-b.line_3" n="3">brief <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_1v-b.line_4" n="4">Den Jvden vnt den <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_1v-b.line_5" n="5">ſi enbot in vil beſchaiden</line>
        <line xml:id="l_c2_1v-b.line_6" n="6">Di deſ wiſtvmeſ phlagen</line>
        <line xml:id="l_c2_1v-b.line_7" n="7">der chvnft nicht betragen</line>
        <line xml:id="l_c2_1v-b.line_8" n="8"><choice><abbr>Sw͛</abbr><expan>Swer</expan></choice> daz ſwert wol lait</line>
        <line xml:id="l_c2_1v-b.line_9" n="9">ſi chomen geín der <choice><abbr>chriſtẽhait</abbr><expan>chriſtenhait</expan></choice></line>
        <line xml:id="l_c2_1v-b.line_10" n="10">Moht ſi ez gezechen</line>
        <line xml:id="l_c2_1v-b.line_11" n="11">ſi wolt ir laſter rechen</line>
        <line xml:id="l_c2_1v-b.line_12" n="12">Deſ mæreſ vrewten ſi ſich</line>
        <line xml:id="l_c2_1v-b.line_13" n="13"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note> lle ge <gap unit="chars" ana="hc:Lost"></gap> lich</line>
        <line xml:id="l_c2_1v-b.line_14" n="14"><milestone ana="hc:SectionMarker" spanTo="#end.par.3"/>¶<anchor xml:id="end.par.3" /> Der pabeſt waſ ſpat vnt vrvͦ <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note></line>
        <line xml:id="l_c2_1v-b.line_15" n="15"> dehain mvͦde irret in dazv</line>
        <line xml:id="l_c2_1v-b.line_16" n="16">Siner rvͦe lvtzel was</line>
        <line xml:id="l_c2_1v-b.line_17" n="17">vnz daz div chriſten <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note> gen <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c2_1v-b.line_18" n="18">Sine boten er do ſande</line>
        <line xml:id="l_c2_1v-b.line_19" n="19">von Lande ze Lande</line>
        <line xml:id="l_c2_1v-b.line_20" n="20">Allen gelerten livten</line>
        <line xml:id="l_c2_1v-b.line_21" n="21">daz goteſ wort tivten</line>
        <line xml:id="l_c2_1v-b.line_22" n="22">Di alten vnt di ivnge</line>
        <line xml:id="l_c2_1v-b.line_23" n="23">chomen an di ſamenvnge</line>
        <line xml:id="l_c2_1v-b.line_24" n="24">Ze helfe der chriſtenhait</line>
        <line xml:id="l_c2_1v-b.line_25" n="25">michel waſ ir arbait</line>
        <line xml:id="l_c2_1v-b.line_26" n="26"><hei:initial ana="hc:Lombard">D</hei:initial>Er chaiſer gebot gemainlich</line>
        <line xml:id="l_c2_1v-b.line_27" n="27">vber elliv div rich</line>
        <line xml:id="l_c2_1v-b.line_28" n="28"><choice><abbr>Swe͛</abbr><expan>Swer</expan></choice> daz ſwert wol lait <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss des zweiten Unterkapitels nicht erhalten</note></line>
        <anchor xml:id="end.c2_ep27.2" />
      </zone>
    </surface>
    <surface ana="hc:Page" n="2r" xml:id="c2_2r">
      <zone xml:id="c2_2r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="27.3" xml:id="c2_ep27.3" spanTo="#end.c2_ep27.3"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c2_ep27.3.en" />Constantine: The disputation § 3<anchor xml:id="end.head.c2_ep27.3.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c2_ep27.3.de" />Constantinus: Das Streitgespräch § 3<anchor xml:id="end.head.c2_ep27.3.de" />
        <line xml:id="l_c2_2r-a.line_1" n="1"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Textsprung innerhalb der Constantinus-Episode - Anfang des dritten Unterkapitel nicht erhalten</note> Od wil dv in ſtoͤren</line>
        <line xml:id="l_c2_2r-a.line_2" n="2">daz laz vnſ alle hoͤren</line>
        <line xml:id="l_c2_2r-a.line_3" n="3"><hei:initial ana="hc:Lombard">D</hei:initial>o ſprach <choice><abbr>Silveſt͛</abbr><expan>Silveſter</expan></choice> ſan</line>
        <line xml:id="l_c2_2r-a.line_4" n="4">er mvͦz gewiſſelich ſtan</line>
        <line xml:id="l_c2_2r-a.line_5" n="5">Elicher hirat</line>
        <line xml:id="l_c2_2r-a.line_6" n="6">alſ in got geboten hat</line>
        <line xml:id="l_c2_2r-a.line_7" n="7">Daz baidiv man <note ana="hc:TranscriptionNote">Textvelust</note> <note ana="hc:TranscriptionNote">Pergamentloch</note></line>
        <line xml:id="l_c2_2r-a.line_8" n="8">ſin alſ ain lip</line>
        <line xml:id="l_c2_2r-a.line_9" n="9">Ane ſvnde chinden wol <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen (2e) ohne Verlust weiter</note></line>
        <line xml:id="l_c2_2r-a.line_10" n="10"> got <choice><abbr>vurchtẽ</abbr><expan>vurchten</expan></choice> vnt <choice><abbr>mínnẽ</abbr><expan>minnen</expan></choice> wol</line>
        <line xml:id="l_c2_2r-a.line_11" n="11">So iſt der heirat ſtætic</line>
        <line xml:id="l_c2_2r-a.line_12" n="12"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note> vnt heilic</line>
        <line xml:id="l_c2_2r-a.line_13" n="13"><milestone ana="hc:SectionMarker" spanTo="#end.par.4"/>¶<anchor xml:id="end.par.4" /> Der <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch/Abrieb</note> ſprach do</line>
        <line xml:id="l_c2_2r-a.line_14" n="14">herre wi chom daz ſo</line>
        <line xml:id="l_c2_2r-a.line_15" n="15">Sit elich heirat iſt recht gnvͦc</line>
        <line xml:id="l_c2_2r-a.line_16" n="16">daz in ain maget in di werlt trvͦc</line>
        <line xml:id="l_c2_2r-a.line_17" n="17">Daz er nicht <choice><abbr>vat͛</abbr><expan>vater</expan></choice> noch <choice><abbr>mvͦt͛</abbr><expan>mvͦter</expan></choice> wolt han</line>
        <line xml:id="l_c2_2r-a.line_18" n="18">daz ſoltv mich wizzen lan</line>
        <line xml:id="l_c2_2r-a.line_19" n="19"><hei:initial ana="hc:Lombard">D</hei:initial>Er pabeſt <choice><abbr>ſpᷓch</abbr><expan>ſprach</expan></choice> zehant</line>
        <line xml:id="l_c2_2r-a.line_20" n="20">di red tvͦn ich dir bechant</line>
        <line xml:id="l_c2_2r-a.line_21" n="21">Di wiſſagen hant alle geſagt</line>
        <line xml:id="l_c2_2r-a.line_22" n="22">vnſ vrowe h <gap unit="chars" ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="c2_2r-b" ana="hc:Column">
        <line xml:id="l_c2_2r-b.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_2r-b.line_2" n="2">Vnz vnſ <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c2_2r-b.line_3" n="3">der vnſ her <choice><abbr>wid͛</abbr><expan>wider</expan></choice> erloſt</line>
        <line xml:id="l_c2_2r-b.line_4" n="4">An dem bvͦch ich daz gezaigen chan</line>
        <line xml:id="l_c2_2r-b.line_5" n="5">der Jvde ſchiet an vrloup dan</line>
        <line xml:id="l_c2_2r-b.line_6" n="6"><hei:initial ana="hc:Lombard">A</hei:initial>in Jvde hiez tara</line>
        <line xml:id="l_c2_2r-b.line_7" n="7">der gienc dar vur ſa</line>
        <line xml:id="l_c2_2r-b.line_8" n="8">Sy <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch/Abrieb</note> dv <gap unit="chars" ana="hc:Lost"></gap> en <choice><abbr>chom̃</abbr><expan>chomen</expan></choice></line>
        <line xml:id="l_c2_2r-b.line_9" n="9">von den iſt <choice><abbr>vnv͛nvmen</abbr><expan>vnvernvmen</expan></choice> <note ana="hc:TranscriptionNote">Ende dieser (wie auch der vorangehenden sieben Zeilen) stark verblasst - {<choice><abbr>vnv͛nvmen</abbr><expan>vnvernvmen</expan></choice>} von Schönbach übernommen</note></line>
        <line xml:id="l_c2_2r-b.line_10" n="10">Daz ſi ie gewvnnen wiſſagen <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note> </line>
        <line xml:id="l_c2_2r-b.line_11" n="11">ir welt nach vnſerem rechte iagen</line>
        <line xml:id="l_c2_2r-b.line_12" n="12">Div e wart vnſ gegeben</line>
        <line xml:id="l_c2_2r-b.line_13" n="13">ſvllen wir <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch</note> den haiden leben</line>
        <line xml:id="l_c2_2r-b.line_14" n="14">Di e nie gewvnnen</line>
        <line xml:id="l_c2_2r-b.line_15" n="15">iſt vnſ der bvͦch zervnnen</line>
        <line xml:id="l_c2_2r-b.line_16" n="16">Vnſer e wolt ir vnſ brechen</line>
        <line xml:id="l_c2_2r-b.line_17" n="17">daz ſolten wir an iv rechen</line>
        <line xml:id="l_c2_2r-b.line_18" n="18">An den heren ſamztagen</line>
        <line xml:id="l_c2_2r-b.line_19" n="19">welt ich dehaine rvͦe tragen</line>
        <line xml:id="l_c2_2r-b.line_20" n="20">Noch in dehaime rechte lebn</line>
        <line xml:id="l_c2_2r-b.line_21" n="21">wir ſolten iv chain antwrt gebn</line>
        <line xml:id="l_c2_2r-b.line_22" n="22"><gap ana="hc:Lost"></gap></line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="2v" xml:id="c2_2v">
      <zone xml:id="c2_2v-a" ana="hc:Column">
        <line xml:id="l_c2_2v-a.line_1" n="1"><gap unit="chars" ana="hc:Lost"></gap> ten <note ana="hc:TranscriptionNote">Text stark verblasst - Transkription dieser und der nächsten vier Zeilen stützen sich auf Schönbach</note></line>
        <line xml:id="l_c2_2v-a.line_2" n="2">ir ſvlt vnſ nicht antwrten</line>
        <line xml:id="l_c2_2v-a.line_3" n="3">Got ſit ir entrvnnen</line>
        <line xml:id="l_c2_2v-a.line_4" n="4">goteſ hvlde han wir gewvnnen</line>
        <line xml:id="l_c2_2v-a.line_5" n="5"><milestone ana="hc:SectionMarker" spanTo="#end.par.5"/>¶<anchor xml:id="end.par.5" /> Got hat vnſ gehailt</line>
        <line xml:id="l_c2_2v-a.line_6" n="6"><gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_2v-a.line_7" n="7"><gap ana="hc:Illegible"></gap></line>
        <line xml:id="l_c2_2v-a.line_8" n="8">g <gap unit="chars" ana="hc:Illegible"></gap> <note ana="hc:TranscriptionNote">Text setzt sich nach dieser unleserlichen Stelle auf dem zweiten Streifen fort</note></line>
        <line xml:id="l_c2_2v-a.line_9" n="9"> An dem ſvnnentage wart er geborn</line>
        <line xml:id="l_c2_2v-a.line_10" n="10">da von daz hail iſt vnſ erchoren</line>
        <line xml:id="l_c2_2v-a.line_11" n="11">An dem ſvnnentage ſtvͦnt er von dẽ grabe <note ana="hc:TranscriptionNote">Zeilenanfang an der Aufnahme kaum leserlich - {An} von Schönbach übernommen</note></line>
        <line xml:id="l_c2_2v-a.line_12" n="12">dv waiſt wol daz ich <note ana="hc:TranscriptionNote">Zeile kaum leserlich - Text von Schönbach übernommen</note> <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch/Abrieb</note></line>
        <line xml:id="l_c2_2v-a.line_13" n="13">An dem ſvnnentage</line>
        <line xml:id="l_c2_2v-a.line_14" n="14">daz iſt ein wariv ſage</line>
        <line xml:id="l_c2_2v-a.line_15" n="15">Sant er vnſ den heiligen gaiſt</line>
        <line xml:id="l_c2_2v-a.line_16" n="16">den vͦben wir billich aller maiſt</line>
        <line xml:id="l_c2_2v-a.line_17" n="17">Den ſvnnentac ſvl wir eren</line>
        <line xml:id="l_c2_2v-a.line_18" n="18">dvrch vnſeren ſchepher heren</line>
        <line xml:id="l_c2_2v-a.line_19" n="19">Ich ſag dir wærlich Tara</line>
        <line xml:id="l_c2_2v-a.line_20" n="20">der ſvnnentac ist div recht octaua</line>
        <line xml:id="l_c2_2v-a.line_21" n="21">Der <gap unit="chars" ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="c2_2v-b" ana="hc:Column">
        <line xml:id="l_c2_2v-b.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c2_2v-b.line_2" n="2">in der chrippe vant man den fvnt</line>
        <line xml:id="l_c2_2v-b.line_3" n="3">Dri chvnige von verren</line>
        <line xml:id="l_c2_2v-b.line_4" n="4">brachten ir <choice><abbr>oph͛</abbr><expan>opher</expan></choice> dem herren</line>
        <line xml:id="l_c2_2v-b.line_5" n="5">Golt mirre vnt wirowch</line>
        <line xml:id="l_c2_2v-b.line_6" n="6">di vrchvnten ez ovch</line>
        <line xml:id="l_c2_2v-b.line_7" n="7">Swer im dienen wil</line>
        <line xml:id="l_c2_2v-b.line_8" n="8"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Pergamentloch/Abrieb</note></line>
        <line xml:id="l_c2_2v-b.line_9" n="9">Arm vnt riche <note ana="hc:TranscriptionNote">Text geht auf dem zweiten Streifen ohne Verlust weiter</note></line>
        <line xml:id="l_c2_2v-b.line_10" n="10"> enphahet er algeliche</line>
        <line xml:id="l_c2_2v-b.line_11" n="11">Do fvͦr der chvnic edel</line>
        <line xml:id="l_c2_2v-b.line_12" n="12">ze iervſalem vf aínem eſel</line>
        <line xml:id="l_c2_2v-b.line_13" n="13">Di juden gein im giengen</line>
        <line xml:id="l_c2_2v-b.line_14" n="14">mit ſang ſiin enphiengen</line>
        <line xml:id="l_c2_2v-b.line_15" n="15">Div wenigen chindelin</line>
        <line xml:id="l_c2_2v-b.line_16" n="16">erfvlden och daz lop ſín</line>
        <line xml:id="l_c2_2v-b.line_17" n="17">Si ſvngen im gewiſ</line>
        <line xml:id="l_c2_2v-b.line_18" n="18">gloria in excelſiſ</line>
        <line xml:id="l_c2_2v-b.line_19" n="19">Von aller ordenvnge</line>
        <line xml:id="l_c2_2v-b.line_20" n="20">alt vnt ivnge</line>
        <line xml:id="l_c2_2v-b.line_21" n="21">Die megde lobten ſine macht</line>
        <line xml:id="l_c2_2v-b.line_22" n="22"><gap unit="chars" ana="hc:Lost"></gap> wen erten in tag vnd nacht</line>
        <line xml:id="l_c2_2v-b.line_23" n="23"><gap unit="chars" ana="hc:Lost"></gap> man</line>
        <line xml:id="l_c2_2v-b.line_24" n="24"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
