  <sourceDoc>
    <surface ana="hc:Page" n="1r" xml:id="a12beta_1r">
      <zone xml:id="a12beta_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="17" xml:id="a12beta_ep17" spanTo="#end.a12beta_ep17"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a12beta_ep17.en" />Trajan<anchor xml:id="end.head.a12beta_ep17.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a12beta_ep17.de" />Trajanus<anchor xml:id="end.head.a12beta_ep17.de" />
        <line xml:id="l_a12beta_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription des verschollenen Fragments basiert auf der Abdruck von Gerold Bickel (1882) und wurde soweit wie möglich den Transkriptions-Richtlinien dieser Edition angepasst - vgl. oben "Hinweise zu diesem Textzeugen"</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <hei:initial ana="hc:Lombard">D</hei:initial>o rihte der cheiſer wiſliche. </line>
        <line xml:id="l_a12beta_1r-a.line_2" n="2">in allem ſinem riche. grozen</line>
        <line xml:id="l_a12beta_1r-a.line_3" n="3">uride er worhte. ſo er baz in</line>
        <line xml:id="l_a12beta_1r-a.line_4" n="4">dorfte. ſwer ſinen uride</line>
        <line xml:id="l_a12beta_1r-a.line_5" n="5">brach. wie harte erz an im</line>
        <line xml:id="l_a12beta_1r-a.line_6" n="6">rach. deſ er ſit groze gnade</line>
        <line xml:id="l_a12beta_1r-a.line_7" n="7">gwan. ein uil heiliger man</line>
        <line xml:id="l_a12beta_1r-a.line_8" n="8">giheizen Gregorie.  der loſte</line>
        <line xml:id="l_a12beta_1r-a.line_9" n="9">in uzer ſorgen. daz ſeit daz</line>
        <line xml:id="l_a12beta_1r-a.line_10" n="10">buch uur war. daz giſchach</line>
        <line xml:id="l_a12beta_1r-a.line_11" n="11">ſit uber zwei hundert iar.</line>
        <line xml:id="l_a12beta_1r-a.line_12" n="12">do er ſante Peterſ ſtul biſaz.</line>
        <line xml:id="l_a12beta_1r-a.line_13" n="13"><choice><abbr>uñ</abbr><expan>und(e)</expan></choice> er die urumcheit uon</line>
        <line xml:id="l_a12beta_1r-a.line_14" n="14">im laſ. do erbarmt er im</line>
        <line xml:id="l_a12beta_1r-a.line_15" n="15">uil ſere. daz der tivreliche <note ana="hc:TranscriptionNote">{li} in {tivreliche} aus {u} korrigiert</note></line>
        <line xml:id="l_a12beta_1r-a.line_16" n="16">herre. datze helle witze</line>
        <line xml:id="l_a12beta_1r-a.line_17" n="17">dolte. wie harte er ſich</line>
        <line xml:id="l_a12beta_1r-a.line_18" n="18">dar umbe cholte.</line>
        <line xml:id="l_a12beta_1r-a.line_19" n="19"><hei:initial ana="hc:Lombard">E</hei:initial>ineſ nahteſ do er ze ſi</line>
        <line xml:id="l_a12beta_1r-a.line_20" n="20">nem <note ana="hc:TranscriptionNote">{bette} vor {gibete} durchstrichen</note> gibete giuie.</line>
        <line xml:id="l_a12beta_1r-a.line_21" n="21"><choice><abbr>uñ</abbr><expan>und(e)</expan></choice> er uur ſin grab gie. do</line>
        <line xml:id="l_a12beta_1r-a.line_22" n="22">gidaht er an ſin gut gerihte.</line>
        <line xml:id="l_a12beta_1r-a.line_23" n="23">hintze himel er blihte. er</line>
        <line xml:id="l_a12beta_1r-a.line_24" n="24"><note ana="hc:TranscriptionNote">{giſach} vor {giſaz} durchstrichen</note> giſaz nider an die</line>
        <line xml:id="l_a12beta_1r-a.line_25" n="25">erde. er gidaht ob er immer</line>
      </zone>
      <zone xml:id="a12beta_1r-b" ana="hc:Column">
        <line xml:id="l_a12beta_1r-b.line_1" n="1">irloſet ſolte werden.</line>
        <line xml:id="l_a12beta_1r-b.line_2" n="2">er uiel ſine uenie. do chom</line>
        <line xml:id="l_a12beta_1r-b.line_3" n="3">uom himele. der goteſ</line>
        <line xml:id="l_a12beta_1r-b.line_4" n="4">engel irſchein im do. er</line>
        <line xml:id="l_a12beta_1r-b.line_5" n="5">ſprach ze ſante Gregorio.</line>
        <line xml:id="l_a12beta_1r-b.line_6" n="6">iz ſolt da mit gnuc ſin.</line>
        <line xml:id="l_a12beta_1r-b.line_7" n="7">daz dich irhorte min træh</line>
        <line xml:id="l_a12beta_1r-b.line_8" n="8">tin. ob du die chriſten.</line>
        <line xml:id="l_a12beta_1r-b.line_9" n="9">mit dinem gebet moh</line>
        <line xml:id="l_a12beta_1r-b.line_10" n="10">teſt uriſten. ia ſint die</line>
        <line xml:id="l_a12beta_1r-b.line_11" n="11">heiden. uon den chriſten</line>
        <line xml:id="l_a12beta_1r-b.line_12" n="12">giſcheiden. du haſt unreh</line>
        <line xml:id="l_a12beta_1r-b.line_13" n="13">te gitan. do irweinete</line>
        <line xml:id="l_a12beta_1r-b.line_14" n="14">der heilige man.</line>
        <line xml:id="l_a12beta_1r-b.line_15" n="15"><hei:initial ana="hc:Lombard">D</hei:initial>er engel ſprah im aber</line>
        <line xml:id="l_a12beta_1r-b.line_16" n="16">zu. ich ſage dir Gregorio</line>
        <line xml:id="l_a12beta_1r-b.line_17" n="17">wie du tu. du biſt ein warer</line>
        <line xml:id="l_a12beta_1r-b.line_18" n="18">gotiſ ſchalch. nu habe</line>
        <line xml:id="l_a12beta_1r-b.line_19" n="19">uon gote den gwalt.</line>
        <line xml:id="l_a12beta_1r-b.line_20" n="20">daz du den heiden lazeſt</line>
        <line xml:id="l_a12beta_1r-b.line_21" n="21">liden. daz er garnet habe</line>
        <line xml:id="l_a12beta_1r-b.line_22" n="22">mit dem libe. ode daz</line>
        <line xml:id="l_a12beta_1r-b.line_23" n="23">du der ſele immer pflegeſt.</line>
        <line xml:id="l_a12beta_1r-b.line_24" n="24"><choice><abbr>uñ</abbr><expan>und(e)</expan></choice> ſiben ſuhte dar zu ne</line>
        <line xml:id="l_a12beta_1r-b.line_25" n="25">miſt. daz dir der nimmer</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a12beta_1v">
      <zone xml:id="a12beta_1v-a" ana="hc:Column">
        <line xml:id="l_a12beta_1v-a.line_1" n="1">buz muge werden. untze</line>
        <line xml:id="l_a12beta_1v-a.line_2" n="2">du doch ſulſt irſterben.</line>
        <line xml:id="l_a12beta_1v-a.line_3" n="3">iſt daz din wille. ſo nim</line>
        <line xml:id="l_a12beta_1v-a.line_4" n="4">die ſele uz der helle. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice></line>
        <line xml:id="l_a12beta_1v-a.line_5" n="5">biwar ſi untze an den</line>
        <line xml:id="l_a12beta_1v-a.line_6" n="6">iungeſten tac. do entlouh</line>
        <line xml:id="l_a12beta_1v-a.line_7" n="7">ſich daz grab. diu ſele <choice><abbr>chõ</abbr><expan>chom</expan></choice></line>
        <line xml:id="l_a12beta_1v-a.line_8" n="8">wider zu dem <choice><abbr>lichnam̃</abbr><expan>lichnamen</expan></choice>.</line>
        <line xml:id="l_a12beta_1v-a.line_9" n="9">die engel ſi do namen.</line>
        <line xml:id="l_a12beta_1v-a.line_10" n="10">ſi enpfulhen ſi dem hei</line>
        <line xml:id="l_a12beta_1v-a.line_11" n="11">ligen man. der tieuel</line>
        <line xml:id="l_a12beta_1v-a.line_12" n="12">muſe dannen uarn. uil</line>
        <line xml:id="l_a12beta_1v-a.line_13" n="13">liute ſchrei er we. ne</line>
        <line xml:id="l_a12beta_1v-a.line_14" n="14">weder ſit noch ê. gihorte</line>
        <line xml:id="l_a12beta_1v-a.line_15" n="15">ir nie ſolh ungemach.</line>
        <line xml:id="l_a12beta_1v-a.line_16" n="16">die ture er alle zebrach.</line>
        <line xml:id="l_a12beta_1v-a.line_17" n="17">diu liet elliu irlaſchen. die</line>
        <line xml:id="l_a12beta_1v-a.line_18" n="18">ſchindelin zebrachen. der</line>
        <line xml:id="l_a12beta_1v-a.line_19" n="19">tieuel uur in gotiſ haz. der</line>
        <line xml:id="l_a12beta_1v-a.line_20" n="20">engel ſeit ſante Gregorii</line>
        <line xml:id="l_a12beta_1v-a.line_21" n="21">daz. daz er ſiben ſuhte wiel</line>
        <line xml:id="l_a12beta_1v-a.line_22" n="22">te. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> die ſele da zu behielte.</line>
        <line xml:id="l_a12beta_1v-a.line_23" n="23">untze hin ze dem iungeſtẽ</line>
        <line xml:id="l_a12beta_1v-a.line_24" n="24">urteile. dar diu werlt <choice><abbr>chũt</abbr><expan>chunt</expan></choice></line>
        <line xml:id="l_a12beta_1v-a.line_25" n="25">al gimeine. da ſol er ſi uur</line>
      </zone>
      <zone xml:id="a12beta_1v-b" ana="hc:Column">
        <line xml:id="l_a12beta_1v-b.line_1" n="1">bringen. nu habe wir zegote</line>
        <line xml:id="l_a12beta_1v-b.line_2" n="2">gidingen. ir werde ze iungiſt</line>
        <line xml:id="l_a12beta_1v-b.line_3" n="3">gut rat. nu er ſich ir under</line>
        <line xml:id="l_a12beta_1v-b.line_4" n="4">wnden hat.</line>
        <line xml:id="l_a12beta_1v-b.line_5" n="5"><hei:initial ana="hc:Lombard">N</hei:initial>u ſuln alle werlt chunige.</line>
        <line xml:id="l_a12beta_1v-b.line_6" n="6">dabi nehmen bilde. wie der edele</line>
        <line xml:id="l_a12beta_1v-b.line_7" n="7">cheiſer Traian. diſe gnade umbe</line>
        <line xml:id="l_a12beta_1v-b.line_8" n="8">got gwan. wande er rehteſ ge</line>
        <line xml:id="l_a12beta_1v-b.line_9" n="9">rihteſ pflegete. die wile er in</line>
        <line xml:id="l_a12beta_1v-b.line_10" n="10">dirre werlet lebte. der ſelben</line>
        <line xml:id="l_a12beta_1v-b.line_11" n="11">gnaden ſuln ſi gwiſ ſin. <choice><abbr>bihaltẽt</abbr><expan>bihaltent</expan></choice></line>
        <line xml:id="l_a12beta_1v-b.line_12" n="12">ſi an ir gerihte minen <note ana="hc:TranscriptionNote">{m} in {minen} infolge des Einbindens durchlöchert</note> træhtin.</line>
        <line xml:id="l_a12beta_1v-b.line_13" n="13"><hei:initial ana="hc:Lombard">D</hei:initial>er cheiſer lebete in dirre</line>
        <line xml:id="l_a12beta_1v-b.line_14" n="14">werlt gutlichen. dem liute</line>
        <line xml:id="l_a12beta_1v-b.line_15" n="15">rihtet er uorhtlichen. ſeit unſ</line>
        <line xml:id="l_a12beta_1v-b.line_16" n="16">daz buch uur war. rehte</line>
        <line xml:id="l_a12beta_1v-b.line_17" n="17">niuntzehen <note ana="hc:TranscriptionNote">{t} in {niuntzehen} aus {c} korrigiert</note> iar. <choice><abbr>un<g ref="#char_lig_de"></g></abbr><expan>unde</expan></choice> zweier</line>
        <line xml:id="l_a12beta_1v-b.line_18" n="18">manode mere. romære chlag</line>
        <line xml:id="l_a12beta_1v-b.line_19" n="19">ten ſinen tot ſeRe. <note ana="hc:TranscriptionNote">{R} in {ſeRe} evtl. Druckfehler</note></line>
        <anchor xml:id="end.a12beta_ep17" /><milestone ana="hc:Chapter" n="18" xml:id="a12beta_ep18" spanTo="#end.a12beta_ep18"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a12beta_ep18.en" />Philip and Decius<anchor xml:id="end.head.a12beta_ep18.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a12beta_ep18.de" />Philippus und Decius<anchor xml:id="end.head.a12beta_ep18.de" />
        <line xml:id="l_a12beta_1v-b.line_20" n="20"><milestone ana="hc:Heading" spanTo="#end.rub.1" /><hi rendition="hc:Enlarged">Daz iſt uon Philippo</hi><anchor xml:id="end.rub.1" /></line>
        <line xml:id="l_a12beta_1v-b.line_21" n="21"><hei:initial>D</hei:initial>az buch chundet unſ</line>
        <line xml:id="l_a12beta_1v-b.line_22" n="22">ſus. daz riche biſaz do <choice><abbr>Philippꝰ.</abbr><expan>Philippus.</expan></choice></line>
        <line xml:id="l_a12beta_1v-b.line_23" n="23">der waſ der aller erſte herre.</line>
        <line xml:id="l_a12beta_1v-b.line_24" n="24">der den gwalt <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> die ere. <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a12beta_ep18" />
      </zone>
    </surface>
  </sourceDoc>
</TEI>

