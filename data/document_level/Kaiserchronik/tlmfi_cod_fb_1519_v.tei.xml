    <surface ana="hc:Page" n="1r" xml:id="a5beta_1r">
      <zone xml:id="a5beta_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="29" xml:id="a5beta_ep29" spanTo="#end.a5beta_ep29"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a5beta_ep29.en" />Heraclius<anchor xml:id="end.head.a5beta_ep29.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a5beta_ep29.de" />Heraclius<anchor xml:id="end.head.a5beta_ep29.de" />
        <line xml:id="l_a5beta_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Bei schwer leserlichen Stellen stützt sich diese Transkription auf den Abdruck von Oswald Zingerle (1888); nur mit größerer Sicherheit lesbarer Text wird jedoch wiedergegeben - vgl. oben "Hinweise zu diesem Textzeugen"</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> din ſele nimmer zu de <gap unit="chars" ana="hc:Illegible"></gap> Der heiden antwrte im</line>
        <line xml:id="l_a5beta_1r-a.line_2" n="2">do. îane gitun ich nim <gap unit="chars" ana="hc:Illegible"></gap> ich lide ê uon dir den tot<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1r-a.line_3" n="3">ê ich gloube an dinen <gap unit="chars" ana="hc:Illegible"></gap> ñ laze die ſele ê immer inder</line>
        <line xml:id="l_a5beta_1r-a.line_4" n="4">helle<pc><g ref="#char_pe"></g></pc> ê ich mih indem <gap unit="chars" ana="hc:Illegible"></gap> zer toufen welle<pc><g ref="#char_pe"></g></pc> Dem chunige</line>
        <line xml:id="l_a5beta_1r-a.line_5" n="5">wart daz unwert<pc><g ref="#char_pe"></g></pc> uz zu <gap unit="chars" ana="hc:Illegible"></gap> er daz ſwert<pc><g ref="#char_pe"></g></pc> uil ſciere ſluc er im</line>
        <line xml:id="l_a5beta_1r-a.line_6" n="6">abe den hals ſin<pc><g ref="#char_pe"></g></pc> deſ h <gap unit="chars" ana="hc:Illegible"></gap> ſelbe min trahtin<pc><g ref="#char_pe"></g></pc> Do der</line>
        <line xml:id="l_a5beta_1r-a.line_7" n="7">chunic die heiden ub <gap unit="chars" ana="hc:Illegible"></gap> <pc><g ref="#char_pe"></g></pc> <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> er daz heilige cruce da</line>
        <line xml:id="l_a5beta_1r-a.line_8" n="8">uant<pc><g ref="#char_pe"></g></pc> do hiez er brech <gap unit="chars" ana="hc:Illegible"></gap> en ſ <gap unit="chars" ana="hc:Illegible"></gap> <pc><g ref="#char_pe"></g></pc> <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> nider ſtozen uber al<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1r-a.line_9" n="9">den himel zu der erd <gap unit="chars" ana="hc:Illegible"></gap> cruce nam er uil werde. Era</line>
        <line xml:id="l_a5beta_1r-a.line_10" n="10">cliuſ ein helt uil gut. <gap unit="chars" ana="hc:Illegible"></gap> lten Coſdroam er ſluc<pc><g ref="#char_pe"></g></pc> den</line>
        <line xml:id="l_a5beta_1r-a.line_11" n="11">ſun er uf dem himel uie<pc><g ref="#char_pe"></g></pc> daz im ſit uil wol ergie<pc><g ref="#char_pe"></g></pc> wan</line>
        <line xml:id="l_a5beta_1r-a.line_12" n="12">er in ze rome uz der to <gap unit="chars" ana="hc:Illegible"></gap> e hup er wart ein christen uil gut<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1r-a.line_13" n="13">cẏrillus wart er gnennet uon dem daz buh michel</line>
        <line xml:id="l_a5beta_1r-a.line_14" n="14">tuginde zellet<pc><g ref="#char_pe"></g></pc> Do u <gap unit="chars" ana="hc:Illegible"></gap> romare her<pc><g ref="#char_pe"></g></pc> wider ſpilende</line>
        <line xml:id="l_a5beta_1r-a.line_15" n="15">zu dem mer<pc><g ref="#char_pe"></g></pc> mit groz <gap unit="chars" ana="hc:Illegible"></gap> r ub <gap unit="chars" ana="hc:Illegible"></gap> r mute<pc><g ref="#char_pe"></g></pc> iz chom in zemicheln</line>
        <line xml:id="l_a5beta_1r-a.line_16" n="16">noten<pc><g ref="#char_pe"></g></pc> Dô ſi <choice><abbr>ierſlm</abbr><expan>ierusalem</expan></choice> b <gap unit="chars" ana="hc:Illegible"></gap> n nahen<pc><g ref="#char_pe"></g></pc> daz ſi das temple</line>
        <line xml:id="l_a5beta_1r-a.line_17" n="17">an ſahen<pc><g ref="#char_pe"></g></pc> ir ieglih w <gap unit="chars" ana="hc:Illegible"></gap> den andern uarn<pc><g ref="#char_pe"></g></pc> ad</line>
        <line xml:id="l_a5beta_1r-a.line_18" n="18">specioſam portam. d <gap unit="chars" ana="hc:Illegible"></gap> ſ engil in do irſcêin<pc><g ref="#char_pe"></g></pc> deſ</line>
        <line xml:id="l_a5beta_1r-a.line_19" n="19">ist zwiuel dihein<pc><g ref="#char_pe"></g></pc> uf <gap unit="chars" ana="hc:Illegible"></gap> liehten borte<pc><g ref="#char_pe"></g></pc> der chunic imz</line>
        <line xml:id="l_a5beta_1r-a.line_20" n="20">harte iruorhte<pc><g ref="#char_pe"></g></pc> er irbe <gap unit="chars" ana="hc:Illegible"></gap> te in allen gahen<pc><g ref="#char_pe"></g></pc> den engel</line>
        <line xml:id="l_a5beta_1r-a.line_21" n="21">bigunde er fragen<pc><g ref="#char_pe"></g></pc> <gap unit="chars" ana="hc:Illegible"></gap> ah <gap unit="chars" ana="hc:Illegible"></gap> de mir herre disiv</line>
        <line xml:id="l_a5beta_1r-a.line_22" n="22">heruart<pc><g ref="#char_pe"></g></pc> von himele <gap unit="chars" ana="hc:Illegible"></gap> er geboten wart<pc><g ref="#char_pe"></g></pc> <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> ich</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a5beta_1v">
      <zone xml:id="a5beta_1v-a" ana="hc:Column">
        <line xml:id="l_a5beta_1v-a.line_1" n="1">daz here cruce w <gap unit="chars" ana="hc:Illegible"></gap> r gwan<pc><g ref="#char_pe"></g></pc> waz han ich nu wider got</line>
        <line xml:id="l_a5beta_1v-a.line_2" n="2">gitan<pc><g ref="#char_pe"></g></pc> do ſprah d <gap unit="chars" ana="hc:Illegible"></gap> gil here<pc><g ref="#char_pe"></g></pc> uirname du aber ie mere<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_3" n="3">do got ſelbe durh <gap unit="chars" ana="hc:Illegible"></gap> e miltecheit<pc><g ref="#char_pe"></g></pc> einen eſel hie reit<pc><g ref="#char_pe"></g></pc> durh</line>
        <line xml:id="l_a5beta_1v-a.line_4" n="4">diſe porte<pc><g ref="#char_pe"></g></pc> der chu <gap unit="chars" ana="hc:Illegible"></gap> im harte iruorhte<pc><g ref="#char_pe"></g></pc> <note ana="hc:TranscriptionNote">COMMENT[2]</note> er machte</line>
        <line xml:id="l_a5beta_1v-a.line_5" n="5">ſih baruuz <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> wll <gap unit="chars" ana="hc:Illegible"></gap> uil tivre pflegte er minen trahtin<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_6" n="6">daz cruce er zu im <gap unit="chars" ana="hc:Illegible"></gap> <pc><g ref="#char_pe"></g></pc> uil uroliche er durh die porte gie<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_7" n="7">er truc iz <choice><abbr>zeierſlm</abbr><expan>zeieruſalem</expan></choice> <gap unit="chars" ana="hc:Illegible"></gap> daz <choice><abbr>templũ</abbr><expan>templum</expan></choice><pc><g ref="#char_pe"></g></pc> daz iſt unſ armen ge-</line>
        <line xml:id="l_a5beta_1v-a.line_8" n="8">ſeit ad <choice><abbr>exemplũ</abbr><expan>exemplum</expan></choice><pc><g ref="#char_pe"></g></pc> <gap unit="chars" ana="hc:Illegible"></gap> div ſul wir unsern herren<pc><g ref="#char_pe"></g></pc> uurh-</line>
        <line xml:id="l_a5beta_1v-a.line_9" n="9">ten <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> flegen<pc><g ref="#char_pe"></g></pc> mit <gap unit="chars" ana="hc:Illegible"></gap> te <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> mit gute<pc><g ref="#char_pe"></g></pc> mit grozer die-</line>
        <line xml:id="l_a5beta_1v-a.line_10" n="10">mute<pc><g ref="#char_pe"></g></pc> ubirmut i <gap unit="chars" ana="hc:Illegible"></gap> gitan<pc><g ref="#char_pe"></g></pc> div giſchendet ie den man<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_11" n="11"><hei:initial ana="hc:Lombard">E</hei:initial>raclius <note ana="hc:TranscriptionNote">COMMENT[3]</note> rihte r <gap unit="chars" ana="hc:Illegible"></gap> iſc riche uur war<pc><g ref="#char_pe"></g></pc> zwei <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> drizec</line>
        <line xml:id="l_a5beta_1v-a.line_12" n="12">iar. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> dar ubir ſ <gap unit="chars" ana="hc:Illegible"></gap> zehen tage<pc><g ref="#char_pe"></g></pc> zware ich iu daz ſage<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_13" n="13">an der wazer suht er uirſciet<pc><g ref="#char_pe"></g></pc> ſin ſele div iſt got liep<pc><g ref="#char_pe"></g></pc></line>
        <anchor xml:id="end.a5beta_ep29" /><milestone ana="hc:Chapter" n="30.1" xml:id="a5beta_ep30.1" spanTo="#end.a5beta_ep30.1"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a5beta_ep30.1.en" />Narcissus: Crescentia and Dietrich § 1<anchor xml:id="end.head.a5beta_ep30.1.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a5beta_ep30.1.de" />Narcissus: Crescentia und Dietrich § 1<anchor xml:id="end.head.a5beta_ep30.1.de" />
        <line xml:id="l_a5beta_1v-a.line_14" n="14">Daz iſt uõ narciſſo<pc><g ref="#char_pe"></g></pc> <note ana="hc:TranscriptionNote">Überschrift {Daz iſt uo<hi rendition="hc:Superscript">Z</hi> narciſſo<pc><g ref="#char_pe"></g></pc>} am Ende der nächsten Zeile nachgetragen</note></line>
        <line xml:id="l_a5beta_1v-a.line_15" n="15"><hei:initial>N</hei:initial>u chunde <gap unit="chars" ana="hc:Illegible"></gap> unſ div buh ſuſ<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_16" n="16">daz riche b <gap unit="chars" ana="hc:Illegible"></gap> ſin bruder narciſſus<pc><g ref="#char_pe"></g></pc> der waſ</line>
        <line xml:id="l_a5beta_1v-a.line_17" n="17">ein alt man<pc><g ref="#char_pe"></g></pc> daz <gap unit="chars" ana="hc:Illegible"></gap> deſ niene gwan<pc><g ref="#char_pe"></g></pc> do er do chom</line>
        <line xml:id="l_a5beta_1v-a.line_18" n="18">an daz riche. do h <gap unit="chars" ana="hc:Illegible"></gap> r tageliche<pc><g ref="#char_pe"></g></pc> daz livt got flegen<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_19" n="19">daz er durh ſin ſelb <gap unit="chars" ana="hc:Illegible"></gap> ere<pc><g ref="#char_pe"></g></pc> im einen erben gabe<pc><g ref="#char_pe"></g></pc> der deſ</line>
        <line xml:id="l_a5beta_1v-a.line_20" n="20">richeſ nah im pfl <gap unit="chars" ana="hc:Illegible"></gap> e<pc><g ref="#char_pe"></g></pc> <hei:initial ana="hc:Lombard">D</hei:initial>o deſ die lute waren gerende<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_21" n="21">do wart div uro <gap unit="chars" ana="hc:Illegible"></gap> berende<pc><g ref="#char_pe"></g></pc> div urowe Elisabet<pc><g ref="#char_pe"></g></pc> zwene</line>
        <line xml:id="l_a5beta_1v-a.line_22" n="22">ſune gute<pc><g ref="#char_pe"></g></pc> gibar <gap unit="chars" ana="hc:Illegible"></gap> n einer naht<pc><g ref="#char_pe"></g></pc> nah heideniſcer pfaht<pc><g ref="#char_pe"></g></pc></line>
        <line xml:id="l_a5beta_1v-a.line_23" n="23">man nante ſi gli <gap unit="chars" ana="hc:Illegible"></gap> beide dietriche<pc><g ref="#char_pe"></g></pc> <hei:initial ana="hc:Lombard">I</hei:initial>n dem ſehſten <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a5beta_ep30.1" />
      </zone>
    </surface>
  </sourceDoc>
