        <line xml:id="l_a5alpha_2r-a.line_5" n="5"><hei:initial ana="hc:Lombard">D</hei:initial>iocletanius<pc><g ref="#char_pe">ļ‡°</g></pc> <choice><abbr>uĆ±</abbr><expan>und(e)</expan></choice> Åæin giÅæelle <choice><abbr>maximianź¯°<pc><g ref="#char_pe">ļ‡°</g></pc></abbr><expan>maximianus<pc><g ref="#char_pe">ļ‡°</g></pc></expan></choice> die grim-</line>
        <line xml:id="l_a5alpha_2r-a.line_6" n="6">migen wtriche<pc><g ref="#char_pe">ļ‡°</g></pc> die rihten harte gwalticliche<pc><g ref="#char_pe">ļ‡°</g></pc> in</line>
