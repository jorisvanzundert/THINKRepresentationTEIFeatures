    <surface ana="hc:Page" n="1r" xml:id="a12alpha_1r">
      <zone xml:id="a12alpha_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="6" xml:id="a12alpha_ep6" spanTo="#end.a12alpha_ep6"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a12alpha_ep6.en" />Gaius Caligula<anchor xml:id="end.head.a12alpha_ep6.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a12alpha_ep6.de" />Gaius Caligula<anchor xml:id="end.head.a12alpha_ep6.de" />
        <line xml:id="l_a12alpha_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> ſi irloſet het. do chom ein <choice><abbr>don͛</abbr><expan>doner</expan></choice></line>
        <line xml:id="l_a12alpha_1r-a.line_2" n="2">ſtrale. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> irſluc den chunic</line>
        <line xml:id="l_a12alpha_1r-a.line_3" n="3">zware. daz er uon dem ſtule tot</line>
        <line xml:id="l_a12alpha_1r-a.line_4" n="4">lac. driv iar er <choice><abbr><g ref="#char_lig_de"></g>ſ</abbr><expan>deſ</expan></choice> richeſ pflac.</line>
        <line xml:id="l_a12alpha_1r-a.line_5" n="5"><choice><abbr>uñ</abbr><expan>und(e)</expan></choice> zehen <choice><abbr>mano<g ref="#char_lig_de"></g></abbr><expan>manode</expan></choice> mere. <choice><abbr><g ref="#char_lig_de"></g>n</abbr><expan>den</expan></choice> got</line>
        <line xml:id="l_a12alpha_1r-a.line_6" n="6">uorhten ſi ſere.</line>
        <anchor xml:id="end.a12alpha_ep6" /><milestone ana="hc:Chapter" n="7.1" xml:id="a12alpha_ep7.1" spanTo="#end.a12alpha_ep7.1"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a12alpha_ep7.1.en" />Faustinian and Claudius: Crisis and separation § 1<anchor xml:id="end.head.a12alpha_ep7.1.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a12alpha_ep7.1.de" />Faustinianus und Claudius: Krise und Trennung § 1<anchor xml:id="end.head.a12alpha_ep7.1.de" />
        <line xml:id="l_a12alpha_1r-a.line_7" n="7"><hei:initial ana="hc:Lombard">E</hei:initial>in buh ſeit unſ ſus. daz</line>
        <line xml:id="l_a12alpha_1r-a.line_8" n="8">riche biſaz <choice><abbr>fauſtinianꝰ</abbr><expan>fauſtinianus</expan></choice>. Clau-</line>
        <line xml:id="l_a12alpha_1r-a.line_9" n="9">diuſ hiez ſin bruder. er tet im</line>
        <line xml:id="l_a12alpha_1r-a.line_10" n="10">leit gnugeſ. <choice><abbr>fauſtinianꝰ</abbr><expan>fauſtinianus</expan></choice> nam</line>
        <line xml:id="l_a12alpha_1r-a.line_11" n="11">ein wip. div waſ imſam der</line>
        <line xml:id="l_a12alpha_1r-a.line_12" n="12">leip. m <gap unit="chars" ana="hc:Lost"></gap> h <gap unit="chars" ana="hc:Lost"></gap> ilt <note ana="hc:TranscriptionNote">COMMENT[1]</note> hiez div urowe.</line>
        <line xml:id="l_a12alpha_1r-a.line_13" n="13">ſi leiſte  im groze <choice><abbr>tͥwe</abbr><expan>triwe</expan></choice>. ſi waſ</line>
        <line xml:id="l_a12alpha_1r-a.line_14" n="14">cemanigen tugenten <choice><abbr>irchor̃</abbr><expan>irchorn</expan></choice>.</line>
        <line xml:id="l_a12alpha_1r-a.line_15" n="15">ovch waſ div urowe giborn.</line>
        <line xml:id="l_a12alpha_1r-a.line_16" n="16">von cheiſerlichem chvnne. ſi</line>
        <line xml:id="l_a12alpha_1r-a.line_17" n="17">heten groze wnne. mit ir</line>
        <line xml:id="l_a12alpha_1r-a.line_18" n="18">beider libe <note ana="hc:TranscriptionNote">{libe} aus {liebe} gebessert: {e} expungiert</note> o wol der wile.</line>
        <line xml:id="l_a12alpha_1r-a.line_19" n="19">daſ ſi <note ana="hc:TranscriptionNote">{ſi} aus {ſie} gebessert:{e} durchstrichen</note> ie in diſe werlt giborn</line>
        <line xml:id="l_a12alpha_1r-a.line_20" n="20">wart. waz ſi got wcherſ hat</line>
        <line xml:id="l_a12alpha_1r-a.line_21" n="21">braht.</line>
        <line xml:id="l_a12alpha_1r-a.line_22" n="22"><hei:initial ana="hc:Lombard">D</hei:initial>o ſtunt iz unlange. untz</line>
        <line xml:id="l_a12alpha_1r-a.line_23" n="23">div muͦter mit <choice><abbr>chin<g ref="#char_lig_de"></g></abbr><expan>chinde</expan></choice> <note ana="hc:TranscriptionNote">{<choice><abbr>chin<g ref="#char_lig_de"></g></abbr><expan>chinde</expan></choice>} aus {<choice><abbr>chin<g ref="#char_lig_de"></g>n</abbr><expan>chinden</expan></choice>} gebessert: {n} radiert</note> wart</line>
        <line xml:id="l_a12alpha_1r-a.line_24" n="24">biuangen. zweier ſun ſi mit</line>
        <line xml:id="l_a12alpha_1r-a.line_25" n="25">ein ander gnaſ. owe wie fro</line>
      </zone>
      <zone xml:id="a12alpha_1r-b" ana="hc:Column">
        <line xml:id="l_a12alpha_1r-b.line_1" n="1">deſ der uater waſ. einer wart</line>
        <line xml:id="l_a12alpha_1r-b.line_2" n="2">giheizen fauſtinuſ. der <choice><abbr>and͛</abbr><expan>ander</expan></choice></line>
        <line xml:id="l_a12alpha_1r-b.line_3" n="3">Fauſtuſ. do whſſen <note ana="hc:TranscriptionNote">{h} in {whſſen} über der Zeile eingefügt</note> div <choice><abbr>chin<g ref="#char_lig_de"></g></abbr><expan>chinde</expan></choice></line>
        <line xml:id="l_a12alpha_1r-b.line_4" n="4">lin. alle romære. ſih ulizten</line>
        <line xml:id="l_a12alpha_1r-b.line_5" n="5">under in. ir ieglich uur <choice><abbr><g ref="#char_lig_de"></g>n</abbr><expan>den</expan></choice></line>
        <line xml:id="l_a12alpha_1r-b.line_6" n="6">andern. wie ſi div chint moh-</line>
        <line xml:id="l_a12alpha_1r-b.line_7" n="7">ten gihalten. al nah der uri-</line>
        <line xml:id="l_a12alpha_1r-b.line_8" n="8">unte ere. ſi waren die aller</line>
        <line xml:id="l_a12alpha_1r-b.line_9" n="9">tivreſten herren. deſ hoheſten</line>
        <line xml:id="l_a12alpha_1r-b.line_10" n="10">giſlæhteſ. daz ce rome ſin</line>
        <line xml:id="l_a12alpha_1r-b.line_11" n="11">mohte. ſi liten in der chintheit.</line>
        <line xml:id="l_a12alpha_1r-b.line_12" n="12">manige not <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> arbeit. die</line>
        <line xml:id="l_a12alpha_1r-b.line_13" n="13">ſi wol uber <choice><abbr>wn<g ref="#char_lig_de"></g>n</abbr><expan>wnden</expan></choice> ſit. ſi uer</line>
        <line xml:id="l_a12alpha_1r-b.line_14" n="14">dienten den ewigen lip.</line>
        <line xml:id="l_a12alpha_1r-b.line_15" n="15"><hei:initial ana="hc:Lombard">E</hei:initial>inen bruder het der her-</line>
        <line xml:id="l_a12alpha_1r-b.line_16" n="16">re. der muͦtte der urowen</line>
        <line xml:id="l_a12alpha_1r-b.line_17" n="17">ſere. giheizen waſ er <choice><abbr>Claudiꝰ.</abbr><expan>Claudius.</expan></choice></line>
        <line xml:id="l_a12alpha_1r-b.line_18" n="18">der tievel ſchunt in alſuſ.</line>
        <line xml:id="l_a12alpha_1r-b.line_19" n="19">ze der chuneginne er gie.</line>
        <line xml:id="l_a12alpha_1r-b.line_20" n="20">mit den armen er ſi umbe</line>
        <line xml:id="l_a12alpha_1r-b.line_21" n="21">uie. er druhte ſi anſine <note ana="hc:TranscriptionNote">{e} in {anſine} über der Zeile eingefügt</note> bruſte.</line>
        <line xml:id="l_a12alpha_1r-b.line_22" n="22">ſiner boſen gluſte. braht er</line>
        <line xml:id="l_a12alpha_1r-b.line_23" n="23">ſi innen. er ſprach daz er ſi</line>
        <line xml:id="l_a12alpha_1r-b.line_24" n="24">gern wolt minnen. ern wolt</line>
        <line xml:id="l_a12alpha_1r-b.line_25" n="25">ſiz niht langer uirheln. er</line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a12alpha_1v">
      <zone xml:id="a12alpha_1v-a" ana="hc:Column">
        <line xml:id="l_a12alpha_1v-a.line_1" n="1">muſe virwandeln daz leben.</line>
        <line xml:id="l_a12alpha_1v-a.line_2" n="2">im wær gireit der tot. ſin</line>
        <line xml:id="l_a12alpha_1v-a.line_3" n="3">hulfe im uz der not. ſin <choice><abbr>dĩc</abbr><expan>dinc</expan></choice></line>
        <line xml:id="l_a12alpha_1v-a.line_4" n="4"><choice><abbr>ſtũt</abbr><expan>ſtunt</expan></choice> an ir gnaden. daz <choice><abbr>bigũ-</abbr><expan>bigun-</expan></choice></line>
        <line xml:id="l_a12alpha_1v-a.line_5" n="5"><choice><abbr><g ref="#char_lig_de"></g></abbr><expan>de</expan></choice> der urowen uil harte ſwa-</line>
        <line xml:id="l_a12alpha_1v-a.line_5_below-1" n="5_below" rend="below">rẽ.</line>
        <line xml:id="l_a12alpha_1v-a.line_6" n="6"><hei:initial ana="hc:Lombard">D</hei:initial>iv urowe</line>
        <line xml:id="l_a12alpha_1v-a.line_7" n="7"><choice><abbr>ſpᷓch</abbr><expan>ſprach</expan></choice> im zu. ich ſage dir her</line>
        <line xml:id="l_a12alpha_1v-a.line_8" n="8">re wie du tu. irla mih ſo</line>
        <line xml:id="l_a12alpha_1v-a.line_9" n="9">getaner worhte. <note ana="hc:TranscriptionNote">{rede.} nach {getaner} expungiert; {worhte} nachgetragen. {h} in {worhte} mit Verweiszeichen über der Zeile eingefügt</note> mich</line>
        <line xml:id="l_a12alpha_1v-a.line_10" n="10">twinget groziv uorhte.</line>
        <line xml:id="l_a12alpha_1v-a.line_11" n="11"><gap unit="chars" ana="hc:Illegible"></gap> ir <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a12alpha_1v-a.line_12" n="12"><gap unit="chars" ana="hc:Illegible"></gap> la <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a12alpha_1v-a.line_13" n="13"><gap unit="chars" ana="hc:Illegible"></gap> iſt dir <choice><abbr><g ref="#char_lig_de"></g>hein</abbr><expan>dehein</expan></choice> <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a12alpha_1v-a.line_14" n="14"><gap unit="chars" ana="hc:Illegible"></gap> enhan ich <choice><abbr><g ref="#char_lig_de"></g>heinen</abbr><expan>deheinen</expan></choice> mut.</line>
        <line xml:id="l_a12alpha_1v-a.line_15" n="15">ich en <gap unit="chars" ana="hc:Illegible"></gap> mich an dih wend <gap unit="chars" ana="hc:Illegible"></gap> .</line>
        <line xml:id="l_a12alpha_1v-a.line_16" n="16">noh min edel chunne niht</line>
        <line xml:id="l_a12alpha_1v-a.line_17" n="17">ſchenden. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> ureiſchet iz</line>
        <line xml:id="l_a12alpha_1v-a.line_18" n="18">min herre. er refſet unſ dar</line>
        <line xml:id="l_a12alpha_1v-a.line_19" n="19">umbe uil ſere.</line>
        <line xml:id="l_a12alpha_1v-a.line_20" n="20"><hei:initial ana="hc:Lombard">D</hei:initial>o der herre daz ir hort.</line>
        <line xml:id="l_a12alpha_1v-a.line_21" n="21">er hup uf <choice><abbr>uñ</abbr><expan>und(e)</expan></choice> drot. daz er</line>
        <line xml:id="l_a12alpha_1v-a.line_22" n="22">ſin niht enweſen wolte.</line>
        <line xml:id="l_a12alpha_1v-a.line_23" n="23">ob er drumbe ſterben ſolte.</line>
        <line xml:id="l_a12alpha_1v-a.line_24" n="24"><choice><abbr>o<g ref="#char_lig_de"></g>r</abbr><expan>oder</expan></choice> waſ ſin wrde. er <choice><abbr>tͮge</abbr><expan>trvge</expan></choice></line>
        <line xml:id="l_a12alpha_1v-a.line_25" n="25">ſogitane burde. ern moht</line>
      </zone>
      <zone xml:id="a12alpha_1v-b" ana="hc:Column">
        <line xml:id="l_a12alpha_1v-b.line_1" n="1">iz niht uirlazen. er bigie ſo</line>
        <line xml:id="l_a12alpha_1v-b.line_2" n="2">groze unmaze. nah der uro-</line>
        <line xml:id="l_a12alpha_1v-b.line_3" n="3">wen minne. daz er zwiuelt</line>
        <line xml:id="l_a12alpha_1v-b.line_4" n="4">ein teil an ſinen ſinnen.</line>
        <line xml:id="l_a12alpha_1v-b.line_5" n="5"><hei:initial ana="hc:Lombard">D</hei:initial>o nam ir div urowe guͦt.</line>
        <line xml:id="l_a12alpha_1v-b.line_6" n="6">einen uil tugentlichen muͦt.</line>
        <line xml:id="l_a12alpha_1v-b.line_7" n="7">daz ſi nie niemen giſagte.</line>
        <line xml:id="l_a12alpha_1v-b.line_8" n="8">die not die ſi uon im habete.</line>
        <line xml:id="l_a12alpha_1v-b.line_9" n="9">under wilen ſi im drote. uil</line>
        <line xml:id="l_a12alpha_1v-b.line_10" n="10">ofte ſi in ulegote. ſi ſprah ure</line>
        <line xml:id="l_a12alpha_1v-b.line_11" n="11">iſchent <gap unit="chars" ana="hc:Illegible"></gap> ge <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Illegible"></gap> <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_a12alpha_1v-b.line_12" n="12">ſi heizent unſ lihte ſteinen.</line>
        <line xml:id="l_a12alpha_1v-b.line_13" n="13">ſi bigunde heize weinen. dan</line>
        <line xml:id="l_a12alpha_1v-b.line_14" n="14">noh enwolt ſih der herre. <choice><abbr><g ref="#char_lig_de"></g>r</abbr><expan>der</expan></choice></line>
        <line xml:id="l_a12alpha_1v-b.line_15" n="15">rede niht bicheren. ſi ſprah</line>
        <line xml:id="l_a12alpha_1v-b.line_16" n="16">gſwige min uil liep. du tu</line>
        <line xml:id="l_a12alpha_1v-b.line_17" n="17"><gap unit="chars" ana="hc:Lost"></gap> ich dir rate. wart du der</line>
        <line xml:id="l_a12alpha_1v-b.line_18" n="18">zite. ſo der wirte girite. <choice><abbr>uñ</abbr><expan>und(e)</expan></choice></line>
        <line xml:id="l_a12alpha_1v-b.line_19" n="19">hie zehoue <choice><abbr>wer<g ref="#char_lig_de"></g></abbr><expan>werde</expan></choice> <note ana="hc:TranscriptionNote">{<choice><abbr>wer<g ref="#char_lig_de"></g></abbr><expan>werde</expan></choice>} über der Zeile nachgetragen</note> ſtille. <note ana="hc:TranscriptionNote">{ſt} und hochgestelltes Zeichen nach {ſtille} rasiert</note> ich han</line>
        <line xml:id="l_a12alpha_1v-b.line_20" n="20">ze dir guten willen. daz geſtet</line>
        <line xml:id="l_a12alpha_1v-b.line_21" n="21">ouch unlange. mit chinde</line>
        <line xml:id="l_a12alpha_1v-b.line_22" n="22">bin ich nu biuangen. ſin en</line>
        <line xml:id="l_a12alpha_1v-b.line_23" n="23">mac ze diſen ziten niht ſin. <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a12alpha_ep7.1" />
      </zone>
    </surface>
  </sourceDoc>
