    <surface ana="hc:Page" n="1v" xml:id="c1_1v">
      <zone xml:id="c1_1v-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="37.20" xml:id="c1_ep37.20" spanTo="#end.c1_ep37.20"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c1_ep37.20.en" />The Germans (1st Continuation): Frederick VI, Duke of Swabia § 20<anchor xml:id="end.head.c1_ep37.20.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c1_ep37.20.de" />Die Deutschen (1. Fortsetzung): Friedrich V. (Schwaben) § 20<anchor xml:id="end.head.c1_ep37.20.de" />
        <line xml:id="l_c1_1v-a.line_1" n="1"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note></line>
        <line xml:id="l_c1_1v-a.line_2" n="2">Si iahen es zem wol dem rich</line>
        <line xml:id="l_c1_1v-a.line_3" n="3">Vnd ouch Romiſchen Richen</line>
        <line xml:id="l_c1_1v-a.line_4" n="4">Daz iahen ſíe gelichen</line>
        <line xml:id="l_c1_1v-a.line_5" n="5">Síe ſazten in an ſins vater ſtat</line>
        <line xml:id="l_c1_1v-a.line_6" n="6">Jeglicher in <choice><abbr>ſvͤnd͛</abbr><expan>ſvͤnder</expan></choice> bat</line>
        <line xml:id="l_c1_1v-a.line_7" n="7">Daz er ir herre were</line>
        <line xml:id="l_c1_1v-a.line_8" n="8">Daz lobt in der mere</line>
        <line xml:id="l_c1_1v-a.line_9" n="9">Ob ſie im gehíezen</line>
        <line xml:id="l_c1_1v-a.line_10" n="10">Daz ſie ſin nicht líezen</line>
        <line xml:id="l_c1_1v-a.line_11" n="11">Dez muſen im alle ſweren</line>
        <line xml:id="l_c1_1v-a.line_12" n="12">S <gap unit="chars" ana="hc:Lost"></gap> er ſich <gap unit="chars" ana="hc:Lost"></gap> ren</line>
        <line xml:id="l_c1_1v-a.line_13" n="13"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_1v-a.line_14" n="14"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_1v-a.line_15" n="15"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_1v-a.line_16" n="16">Die richte h <gap unit="chars" ana="hc:Illegible"></gap> abe</line>
        <line xml:id="l_c1_1v-a.line_17" n="17">Da ſie <choice><abbr>quamẽ</abbr><expan>quamen</expan></choice> hinz íeruſale</line>
        <line xml:id="l_c1_1v-a.line_18" n="18">Daz her wolte nicht fvͤrbaz me</line>
        <line xml:id="l_c1_1v-a.line_19" n="19">Si hugten heim zvͦ lande</line>
        <line xml:id="l_c1_1v-a.line_20" n="20">Daz here gein akers wande</line>
        <line xml:id="l_c1_1v-a.line_21" n="21">Da ſchiften ſie wider vf den ſe</line>
        <line xml:id="l_c1_1v-a.line_22" n="22">Daz <gap unit="chars" ana="hc:Illegible"></gap> geſament ſich <choice><abbr>niem͛</abbr><expan>niemer</expan></choice> me</line>
        <line xml:id="l_c1_1v-a.line_23" n="23"><hei:initial ana="hc:Lombard">D</hei:initial>er kunig vͦf dem mer <choice><abbr>v͛ſchiet</abbr><expan>verſchiet</expan></choice></line>
        <line xml:id="l_c1_1v-a.line_24" n="24">Also die hervart geriet</line>
        <line xml:id="l_c1_1v-a.line_25" n="25">Vns <gap unit="chars" ana="hc:Lost"></gap> daz buch fuͤr war</line>
        <line xml:id="l_c1_1v-a.line_26" n="26">Er <gap unit="chars" ana="hc:Lost"></gap> pfleger nicht <gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.c1_ep37.20" />
      </zone>
      <zone xml:id="c1_1v-b" ana="hc:Column">
        <milestone ana="hc:Chapter" n="37.21" xml:id="c1_ep37.21" spanTo="#end.c1_ep37.21"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c1_ep37.21.en" />The Germans (1st Continuation): Henry VI § 21<anchor xml:id="end.head.c1_ep37.21.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c1_ep37.21.de" />Die Deutschen (1. Fortsetzung): Heinrich VI. § 21<anchor xml:id="end.head.c1_ep37.21.de" />
        <line xml:id="l_c1_1v-b.line_1" n="1"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note></line>
        <line xml:id="l_c1_1v-b.line_2" n="2">Ein <gap unit="chars" ana="hc:Illegible"></gap> ſchone tochter er liez</line>
        <line xml:id="l_c1_1v-b.line_3" n="3">Dekein kint líez er me</line>
        <line xml:id="l_c1_1v-b.line_4" n="4">Die kuͦnigin nam der keiſer zvͦr e</line>
        <line xml:id="l_c1_1v-b.line_5" n="5">Si gab im luͤt vnd lant</line>
        <line xml:id="l_c1_1v-b.line_6" n="6">Daz waz vil wol hinze im gewant</line>
        <line xml:id="l_c1_1v-b.line_7" n="7">Wan daz ein haz w<hi rendition="hc:Superscript">o</hi>chs vͤndir in</line>
        <line xml:id="l_c1_1v-b.line_8" n="8">Daz waz ir beíder vͦngewin</line>
        <line xml:id="l_c1_1v-b.line_9" n="9"><hei:initial ana="hc:Lombard">D</hei:initial>er keiſer vͦnſchuldig  <note ana="hc:TranscriptionNote">{der} vor {waz} durchstrichen und expungiert</note> waz dar an</line>
        <line xml:id="l_c1_1v-b.line_10" n="10">Wiblich zvcht leit er ſie an</line>
        <line xml:id="l_c1_1v-b.line_11" n="11">Von grozer liebe daz geſchach</line>
        <line xml:id="l_c1_1v-b.line_12" n="12">Der líeb sin hertz gein gein ir iach</line>
        <line xml:id="l_c1_1v-b.line_13" n="13">Dez het ſie von im nicht <choice><abbr>v͛guͦt</abbr><expan>verguͦt</expan></choice></line>
        <line xml:id="l_c1_1v-b.line_14" n="14">Sie truͦg gein im vbir mut</line>
        <line xml:id="l_c1_1v-b.line_15" n="15">Dem keiſer wol ſie nicht <choice><abbr>v͛tragen</abbr><expan>vertragen</expan></choice></line>
        <line xml:id="l_c1_1v-b.line_16" n="16">Sie beguͦnd ir mage ab im klagen</line>
        <line xml:id="l_c1_1v-b.line_17" n="17">Der waz in dem lande w<hi rendition="hc:Superscript">o</hi>nder</line>
        <line xml:id="l_c1_1v-b.line_18" n="18">Vil grozer herren dar vndir</line>
        <line xml:id="l_c1_1v-b.line_19" n="19">Den riet ir böſer ſin</line>
        <line xml:id="l_c1_1v-b.line_20" n="20">Daz sie ſw<hi rendition="hc:Superscript">o</hi>ren vͤbir in</line>
        <line xml:id="l_c1_1v-b.line_21" n="21">Mit rate daz wart getan</line>
        <line xml:id="l_c1_1v-b.line_22" n="22">Si wolten die lant han</line>
        <line xml:id="l_c1_1v-b.line_23" n="23">Wem im w<hi rendition="hc:Superscript">o</hi>rde <choice><abbr>v͛geben</abbr><expan>vergeben</expan></choice></line>
        <line xml:id="l_c1_1v-b.line_24" n="24">Odir im ſus nemen daz leben</line>
        <line xml:id="l_c1_1v-b.line_25" n="25"><gap unit="chars" ana="hc:Illegible"></gap> aw melde <choice><abbr>quã</abbr><expan>quam</expan></choice> nach gewo <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_1v-b.line_26" n="26"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.c1_ep37.21" />
      </zone>
    </surface>
    <surface ana="hc:Page" n="2r" xml:id="c1_2r">
      <zone xml:id="c1_2r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="37.24" xml:id="c1_ep37.24" spanTo="#end.c1_ep37.24"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c1_ep37.24.en" />The Germans (1st Continuation): Frederick II. (and Henry VII) § 24<anchor xml:id="end.head.c1_ep37.24.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c1_ep37.24.de" />Die Deutschen (1. Fortsetzung): Friedrich II (und Heinrich VII.) § 24<anchor xml:id="end.head.c1_ep37.24.de" />
        <line xml:id="l_c1_2r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-a.line_2" n="2">Dar an der ſun nicht ged <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-a.line_3" n="3">Der keiſer in pulle het <gap unit="chars" ana="hc:Lost"></gap> ach</line>
        <line xml:id="l_c1_2r-a.line_4" n="4">Den ſuͦn hie vͦs man ri <gap unit="chars" ana="hc:Lost"></gap> ten ſach</line>
        <line xml:id="l_c1_2r-a.line_5" n="5">Daz waz der kuͦníg heinrich</line>
        <line xml:id="l_c1_2r-a.line_6" n="6">Der richt alſo vreiſlich</line>
        <line xml:id="l_c1_2r-a.line_7" n="7">Waz im zvͦ richten geſchach</line>
        <line xml:id="l_c1_2r-a.line_8" n="8">Niem nach grozerem grirchte <note ana="hc:TranscriptionNote">Pensel liest {grirchte} - {rir} an der Aufnahme nicht sicher zu erkennen</note> ſprach</line>
        <line xml:id="l_c1_2r-a.line_9" n="9">Er gebot eine hervart</line>
        <line xml:id="l_c1_2r-a.line_10" n="10">Hie zvͦ lande níe grozere wart</line>
        <line xml:id="l_c1_2r-a.line_11" n="11">Vf den herzog in baierlant</line>
        <line xml:id="l_c1_2r-a.line_12" n="12">Luͦdewig waz er genant</line>
        <line xml:id="l_c1_2r-a.line_13" n="13">Waz er dem riche het getan</line>
        <line xml:id="l_c1_2r-a.line_14" n="14">Des wart er <choice><abbr>vnd͛</abbr><expan>vnder</expan></choice> zogen ſan</line>
        <line xml:id="l_c1_2r-a.line_15" n="15">Die hervart gie in baierlant</line>
        <line xml:id="l_c1_2r-a.line_16" n="16">Daz wart beroubet vnd <choice><abbr>v͛brant</abbr><expan>verbrant</expan></choice></line>
        <line xml:id="l_c1_2r-a.line_17" n="17">Da zvͦ er groze buͦze phlag</line>
        <line xml:id="l_c1_2r-a.line_18" n="18">Der herzog ſich des bewag</line>
        <line xml:id="l_c1_2r-a.line_19" n="19">Gein dem kuͦníge heinrich</line>
        <line xml:id="l_c1_2r-a.line_20" n="20">Es mvͦs ín duͤnken billich</line>
        <line xml:id="l_c1_2r-a.line_21" n="21">Ein buͦz mit ſuͦne da erging</line>
        <line xml:id="l_c1_2r-a.line_22" n="22">Der kuͦnig den hertzog enphíng</line>
        <line xml:id="l_c1_2r-a.line_23" n="23">Vnd gab im ſíne huͦlde</line>
        <line xml:id="l_c1_2r-a.line_24" n="24"><gap ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="c1_2r-b" ana="hc:Column">
        <line xml:id="l_c1_2r-b.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_2" n="2">Daz waz vil tvͤmplih getan</line>
        <line xml:id="l_c1_2r-b.line_3" n="3">Vf ſinen vater den keiſer her</line>
        <line xml:id="l_c1_2r-b.line_4" n="4">Daz vrieſch der keiſer vnd muͦt in ſ <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_2r-b.line_5" n="5"><hei:initial ana="hc:Lombard">D</hei:initial>er herre genuͤg an im beleip</line>
        <line xml:id="l_c1_2r-b.line_6" n="6">Die der keiſer her nach <choice><abbr>v͛treip</abbr><expan>vertreip</expan></choice></line>
        <line xml:id="l_c1_2r-b.line_7" n="7">Nu hort wie ez der kuͦníg an víe</line>
        <line xml:id="l_c1_2r-b.line_8" n="8">Kein beſlozzen ſtat er lie</line>
        <line xml:id="l_c1_2r-b.line_9" n="9">Er nem in ir kindelin</line>
        <line xml:id="l_c1_2r-b.line_10" n="10">Zvͦ giſel vf den <choice><abbr>vat͛</abbr><expan>vater</expan></choice> ſin</line>
        <line xml:id="l_c1_2r-b.line_11" n="11">Als muͦſen ſi <gap unit="chars" ana="hc:Illegible"></gap> in gebn</line>
        <line xml:id="l_c1_2r-b.line_12" n="12">Wer behalten wolt ſín leben</line>
        <line xml:id="l_c1_2r-b.line_13" n="13"><hei:initial ana="hc:Lombard">N</hei:initial>u hort daz mer kuͤrtzlich ſag <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_14" n="14">Der keiſer beguͦnde ſ <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_15" n="15">Siner <choice><abbr>burg͛</abbr><expan>burger</expan></choice> kint</line>
        <line xml:id="l_c1_2r-b.line_16" n="16">Die ín zvͦ <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_17" n="17">Vbir al in tuͤſch <gap unit="chars" ana="hc:Illegible"></gap> lan <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_18" n="18">Ez wer wol ein <gap unit="chars" ana="hc:Illegible"></gap> han <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_19" n="19">Solt ich keine wile lebe <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_20" n="20">Solt man die kint nicht wi <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_2r-b.line_21" n="21">Vil ſchier dar <gap unit="chars" ana="hc:Lost"></gap> zvͦ hant</line>
        <line xml:id="l_c1_2r-b.line_22" n="22">Quam der keiſer in tuͤtſche lant</line>
        <line xml:id="l_c1_2r-b.line_23" n="23">Zvͦ Regensburg in die ſtat</line>
        <line xml:id="l_c1_2r-b.line_24" n="24"><gap unit="chars" ana="hc:Illegible"></gap> <choice><abbr>quã</abbr><expan>quam</expan></choice> ouch al der herren phat</line>
        <line xml:id="l_c1_2r-b.line_25" n="25"><gap ana="hc:Lost"></gap></line>
      </zone>
    </surface>
