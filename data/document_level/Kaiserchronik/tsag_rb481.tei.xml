    <surface ana="hc:Page" n="1r" xml:id="c1_1r">
      <zone xml:id="c1_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="37.19" xml:id="c1_ep37.19" spanTo="#end.c1_ep37.19"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c1_ep37.19.en" />The Germans (1st Continuation): Frederick I  § 19<anchor xml:id="end.head.c1_ep37.19.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c1_ep37.19.de" />Die Deutschen (1. Fortsetzung): Friedrich I. § 19<anchor xml:id="end.head.c1_ep37.19.de" />
        <line xml:id="l_c1_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription stützt sich z.T. auf den Abdruck von Franzjosef Pensel (1970), in dem etwas mehr Text identifiziert wird, als auf den Aufnahmen klar lesbar ist - vgl. oben "Hinweise zu diesem Textzeugen"</note><gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_c1_1r-a.line_2" n="2"><gap unit="chars" ana="hc:Illegible"></gap> <note ana="hc:TranscriptionNote">Text stammt wohl aus der ersten Episode der ersten KC-Fortsetzung - Pensel identifiziert das noch erkennbare {<hei:initial ana="hc:Lombard">D</hei:initial>} weiter unten mit Vers 73 der Bairischen Fortsetzung nach Schröder (siehe Pensel, S. 348) - Anfang der Episode nicht erhalten</note></line>
        <line xml:id="l_c1_1r-a.line_3" n="3"><hei:initial ana="hc:Lombard">D</hei:initial> <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_1r-a.line_4" n="4"><gap ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_1r-a.line_5" n="5"><gap ana="hc:Lost"></gap></line>
      </zone>
