        <line xml:id="l_c1_2v-b.line_3" n="3"><hei:initial ana="hc:Lombard">D</hei:initial> <gap unit="chars" ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_2v-b.line_4" n="4"><gap ana="hc:Illegible"></gap></line>
        <line xml:id="l_c1_2v-b.line_5" n="5"><note ana="hc:TranscriptionNote">unkenntlicher Lombarde sichtbar - Pensel vermutet {<hei:initial ana="hc:Lombard">G</hei:initial>}, evtl. zur Subscriptio des Textes gehörend (Pensel, S. 348)</note> <gap unit="chars" ana="hc:Illegible"></gap></line>
