  <sourceDoc>
    <surface ana="hc:Page" n="1" xml:id="c6_1">
      <zone xml:id="c6_1-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="7.1" xml:id="c6_ep7.1" spanTo="#end.c6_ep7.1"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.c6_ep7.1.en" />Faustinian and Claudius: Crisis and separation § 1<anchor xml:id="end.head.c6_ep7.1.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.c6_ep7.1.de" />Faustinianus und Claudius: Krise und Trennung § 1<anchor xml:id="end.head.c6_ep7.1.de" />
        <line xml:id="l_c6_1-a.line_1" n="1"><note ana="hc:TranscriptionNote">Die Transkription des verschollenen Fragments basiert auf der Abschrift von Daniel Eberhard Baring (1754) und kann Text und Gestalt des Originals nur bedingt wiedergeben - vgl. oben "Hinweise zu diesem Textzeugen"</note><note ana="hc:TranscriptionNote">Anfang der Episode nicht überliefert</note> Dí ſich ſo wol betrvͤg</line>
        <line xml:id="l_c6_1-a.line_2" n="2">Si was chroſtu̍ vne geſvͤg <note ana="hc:TranscriptionNote">sehr wahrscheinlich Fehler Barings - vgl. Leithandschrift (Wien, ÖNB Cod. 2685): Si waz chævſch <choice><abbr>vn<g ref="#char_lig_de"></g></abbr><expan>vnde</expan></choice> gefueg</note></line>
        <line xml:id="l_c6_1-a.line_3" n="3">Sí wont in der ſtat zwar</line>
        <line xml:id="l_c6_1-a.line_4" n="4">alſo drivzehen iar</line>
        <line xml:id="l_c6_1-a.line_5" n="5"><hei:initial ana="hc:Lombard">D</hei:initial>en chay̍ſer begvnde belan</line>
        <line xml:id="l_c6_1-a.line_5_above-1" n="5_above" rend="above">gen</line>
        <line xml:id="l_c6_1-a.line_6" n="6">Mit ſorg was er bevangen</line>
        <line xml:id="l_c6_1-a.line_7" n="7">Nach wibe vnd nach chinden</line>
        <line xml:id="l_c6_1-a.line_8" n="8">vnt nach anderen ingeſinden</line>
        <line xml:id="l_c6_1-a.line_9" n="9">di er von im vz ſande</line>
      </zone>
      <zone xml:id="c6_1-b" ana="hc:Column">
        <line xml:id="l_c6_1-b.line_1" n="1">Mvͦze vnt trakaít</line>
        <line xml:id="l_c6_1-b.line_2" n="2">wírt dích in dem alter laít</line>
        <line xml:id="l_c6_1-b.line_3" n="3">Wíſhait tugen vͤbent <note ana="hc:TranscriptionNote">evtl. Fehler Barings - vgl. Leithandschrift: wêizhait tugent vͤbet</note></line>
        <line xml:id="l_c6_1-b.line_4" n="4">vnzvcht der menſch trvbet</line>
        <line xml:id="l_c6_1-b.line_5" n="5">Swen der ivnge <note ana="hc:TranscriptionNote">zusätzliche Haste nach {n} in {ivnge} - wohl Fehler Barings</note> man</line>
        <line xml:id="l_c6_1-b.line_6" n="6">Mit ſvchten ſprechen chan</line>
        <line xml:id="l_c6_1-b.line_7" n="7">Vnt ſwiget dar er ſol</line>
        <line xml:id="l_c6_1-b.line_8" n="8">So ſtat ſin dink wol</line>
        <line xml:id="l_c6_1-b.line_9" n="9">Zvcht vnt trive <note ana="hc:TranscriptionNote">{trive} schlecht lesbar, evtl. Fehler Barings - vgl. Leithandschrift: zucht vnd treuwe</note> <note ana="hc:TranscriptionNote">Schluss der Episode nicht überliefert</note></line>
        <anchor xml:id="end.c6_ep7.1" />
      </zone>
    </surface>
