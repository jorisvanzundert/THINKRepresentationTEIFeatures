  <sourceDoc>
    <surface ana="hc:Page" n="1r" xml:id="a2_1r">
      <zone xml:id="a2_1r-a" ana="hc:Column">
        <milestone ana="hc:Chapter" n="8" xml:id="a2_ep8" spanTo="#end.a2_ep8"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a2_ep8.en" />Nero<anchor xml:id="end.head.a2_ep8.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a2_ep8.de" />Nero<anchor xml:id="end.head.a2_ep8.de" />
        <line xml:id="l_a2_1r-a.line_1" n="1"><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a2_1r-a.line_2" n="2">Dar nach von dem gegihte.</line>
        <line xml:id="l_a2_1r-a.line_3" n="3">Dar nach von miſelſvhte.</line>
        <line xml:id="l_a2_1r-a.line_4" n="4">Ze ivngeſt begvnde er zewínnen</line>
        <line xml:id="l_a2_1r-a.line_5" n="5">Er hiez ím gewínnen.</line>
        <line xml:id="l_a2_1r-a.line_6" n="6">In ſine <choice><abbr>kemenatẽ</abbr><expan>kemenaten</expan></choice>. Vs dẽ ſenate.</line>
        <line xml:id="l_a2_1r-a.line_7" n="7">Der herſten romer zehenzig <choice><abbr>vñ</abbr><expan>vnd(e)</expan></choice> dri.</line>
        <line xml:id="l_a2_1r-a.line_8" n="8">Ich ſage iv werliche da bi.</line>
        <line xml:id="l_a2_1r-a.line_9" n="9">Ir hovbet hiez er in abeſlahen.</line>
        <line xml:id="l_a2_1r-a.line_10" n="10">Daz ſwert hiez er ín dar tragen.</line>
        <line xml:id="l_a2_1r-a.line_11" n="11"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a2_ep8" />
      </zone>
      <zone xml:id="a2_1r-b" ana="hc:Column">
        <milestone ana="hc:Chapter" n="9" xml:id="a2_ep9" spanTo="#end.a2_ep9"/><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="en" spanTo="#end.head.a2_ep9.en" />Tarquin<anchor xml:id="end.head.a2_ep9.en" /><milestone ana="hc:Heading" resp="hc:Editor" xml:lang="de" spanTo="#end.head.a2_ep9.de" />Tarquinius<anchor xml:id="end.head.a2_ep9.de" />
        <line xml:id="l_a2_1r-b.line_1" n="1"><note ana="hc:TranscriptionNote">Anfang der Episode nicht erhalten</note> <gap unit="chars" ana="hc:Lost"></gap></line>
        <line xml:id="l_a2_1r-b.line_2" n="2">Swa ſi riten vf div lant.</line>
        <line xml:id="l_a2_1r-b.line_3" n="3">Da diente ím ieder helt balt</line>
        <line xml:id="l_a2_1r-b.line_4" n="4">Vnze er mít ſínẽ ſwerte.</line>
        <line xml:id="l_a2_1r-b.line_5" n="5">So groͤzſen roͮm beherte.</line>
        <line xml:id="l_a2_1r-b.line_6" n="6">Daz ſi den elenthaften man.</line>
        <line xml:id="l_a2_1r-b.line_7" n="7">Ze groſſen eren wolten han.</line>
        <line xml:id="l_a2_1r-b.line_8" n="8">Vnt <choice><abbr>dc</abbr><expan>daz</expan></choice> ín die <choice><abbr>ſnellẽ</abbr><expan>ſnellen</expan></choice>. <choice><abbr>Erweltẽ</abbr><expan>Erwelten</expan></choice> ín ſelbẽ ze</line>
        <line xml:id="l_a2_1r-b.line_8_above-1" n="8_above" rend="above"><choice><abbr>geſellẽ</abbr><expan>geſellen</expan></choice></line>
        <line xml:id="l_a2_1r-b.line_9" n="9"><hei:initial ana="hc:Lombard">I</hei:initial>n dẽ ſenate. <choice><abbr>komẽ</abbr><expan>komen</expan></choice> ſi dez ze rate.</line>
        <line xml:id="l_a2_1r-b.line_10" n="10">Swa <choice><abbr>mã</abbr><expan>man</expan></choice> deheín frumekeit <choice><abbr>woltẽ</abbr><expan>wolten</expan></choice> tvͦn.</line>
        <line xml:id="l_a2_1r-b.line_11" n="11"><gap ana="hc:Lost"></gap></line>
      </zone>
    </surface>
    <surface ana="hc:Page" n="1v" xml:id="a2_1v">
      <zone xml:id="a2_1v-a" ana="hc:Column">
        <line xml:id="l_a2_1v-a.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_a2_1v-a.line_2" n="2">Do klaget er den <choice><abbr>he͛ren</abbr><expan>herren</expan></choice>.</line>
        <line xml:id="l_a2_1v-a.line_3" n="3">Wie ez ím ergangen were.</line>
        <line xml:id="l_a2_1v-a.line_4" n="4">Si lvten ir ſcellen. Do <choice><abbr>ſamentẽ</abbr><expan>ſamenten</expan></choice> ſich die</line>
        <line xml:id="l_a2_1v-a.line_4_above-1" n="4_above" rend="above">ſnellen.</line>
        <line xml:id="l_a2_1v-a.line_5" n="5">Si <choice><abbr>ſprachẽ</abbr><expan>ſprachen</expan></choice> alle dar zvͦ. Wíe ez biterne ie</line>
        <line xml:id="l_a2_1v-a.line_5_below-1" n="5_below" rend="below">getorſte tvͦn</line>
        <line xml:id="l_a2_1v-a.line_6" n="6">Si redeten daz ez groͤz. <choice><abbr>laſt͛</abbr><expan>laſter</expan></choice></line>
        <line xml:id="l_a2_1v-a.line_7" n="7">were. Daz ez ie deheím romere geſcehe.</line>
        <line xml:id="l_a2_1v-a.line_8" n="8"><hei:initial ana="hc:Lombard">D</hei:initial>je bvrg ſi beſazſen <choice><abbr>Rom͛</abbr><expan>Romer</expan></choice> ſich <choice><abbr>v͛mazſen.</abbr><expan>vermazſen.</expan></choice></line>
        <line xml:id="l_a2_1v-a.line_9" n="9">Div bvrc mvͦſe brínnen.</line>
        <line xml:id="l_a2_1v-a.line_10" n="10">Si wolten enheiner ſlahte gedinge.</line>
        <line xml:id="l_a2_1v-a.line_11" n="11"><gap ana="hc:Lost"></gap></line>
      </zone>
      <zone xml:id="a2_1v-b" ana="hc:Column">
        <line xml:id="l_a2_1v-b.line_1" n="1"><gap ana="hc:Lost"></gap></line>
        <line xml:id="l_a2_1v-b.line_2" n="2">Von vil gvͦten knehten</line>
        <line xml:id="l_a2_1v-b.line_3" n="3">Die wol getoͤrſten vehten.</line>
        <line xml:id="l_a2_1v-b.line_4" n="4">Svmliche <choice><abbr>begvndẽ</abbr><expan>begvnden</expan></choice> aber ſcelten</line>
        <line xml:id="l_a2_1v-b.line_5" n="5">Díe ir zageheit mvͦſen engelten.</line>
        <line xml:id="l_a2_1v-b.line_6" n="6">An den ſelben ſtvnden</line>
        <line xml:id="l_a2_1v-b.line_7" n="7">Reten ſi võ ſchoͤnen roſſen. <choice><abbr>Vñ</abbr><expan>Vnd(e)</expan></choice> võ gvͦtẽ</line>
        <line xml:id="l_a2_1v-b.line_7_above-1" n="7_above" rend="above"><choice><abbr>hvndẽ</abbr><expan>hvnden</expan></choice></line>
        <line xml:id="l_a2_1v-b.line_8" n="8">Si reten ovch võ vederſpil.</line>
        <line xml:id="l_a2_1v-b.line_9" n="9">Von <choice><abbr>and͛ere</abbr><expan>anderere</expan></choice> kvrzwile vil.</line>
        <line xml:id="l_a2_1v-b.line_10" n="10">Si redten von ſchoͤnen vrowen.</line>
        <line xml:id="l_a2_1v-b.line_11" n="11"><gap unit="chars" ana="hc:Lost"></gap> <note ana="hc:TranscriptionNote">Schluss der Episode nicht erhalten</note></line>
        <anchor xml:id="end.a2_ep9" />
      </zone>
    </surface>
  </sourceDoc>
