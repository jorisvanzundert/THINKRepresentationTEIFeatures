      <ab xml:id="xxyl-Dh-2006B-01"><lb xml:id="Dh1996BrDh2006Br-0001"/>問曰<pc>：「</pc>何知守心<ptr target="#n114"/>
      <lb xml:id="Dh1996BrDh2006Br-0002"/><damage unit="char" extent="20"/><unclear reason="damage">我</unclear>心<orig reg="既"><g ref="#A01770-008"/></orig><orig reg="真"><g ref="#A02768-018"/></orig><pc>，</pc><orig reg="妄"><g ref="#A00880-004"/></orig><orig reg="想"><g ref="#Dh1996B-2-06"/></orig>
      <lb xml:id="Dh1996BrDh2006Br-0003"/><damage unit="char" extent="17"/><unclear reason="damage" unit="char" extent="3">照智生</unclear><pc>；</pc>故<pc>，</pc><orig reg="即"><g ref="#P3294-009-06"/></orig>
      <lb xml:id="Dh1996BrDh2006Br-0004"/><damage unit="char" extent="6"/><orig reg="性"><g ref="#A01328-006"/></orig>故<ptr target="#n55"/><damage unit="char" extent="16"/><ptr target="#n56"/>何<unclear reason="damage" unit="char" extent="5">知守心是入</unclear>
      <lb xml:id="Dh1996BrDh2006Br-0005"/><damage unit="char" extent="25"/>
      <lb xml:id="Dh1996BrDh2006Br-0006"/><damage unit="char" extent="2"/>教<orig reg="導">道</orig><ptr target="#n101"/>無智<unclear reason="damage">眾</unclear><damage unit="char" extent="20"/>
      <lb xml:id="Dh1996BrDh2006Br-0007"/><orig reg="成"><g ref="#P3664-552-23"/></orig><unclear reason="damage" unit="char" extent="2">佛者<pc>，</pc></unclear><orig reg="會"><g ref="#A01840-006"/></orig><orig reg="是"><g ref="#S0646-014-26"/></orig>守自<unclear reason="damage">真</unclear></ab></div>
