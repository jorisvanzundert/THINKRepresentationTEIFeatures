  <text>
    <body><div xml:id="wrap-P-3858r-0001-0025">
      <ab xml:id="cfbj-P-3858-01"><milestone unit="sheet" n="P-3858r-01"/><lb xml:id="P-3858r-0001"/><ptr target="#n21"/>未<orig reg="堪"><g ref="#A00787-003"/></orig><orig type="CJK" reg="聞">闻</orig>大道<pc>。</pc><orig reg="每" type="CJK">毎</orig><orig reg="勸"><g ref="#A00404-012"/></orig><orig type="CJK" reg="諸">诸</orig>門人<damage unit="char" extent="11"/>
      <lb xml:id="P-3858r-0002"/><pc>「</pc>三五<orig reg="年"><g ref="#A01194-037"/></orig><orig type="CJK" reg="得">淂</orig>一口食塞<orig type="Ext-B" reg="飢">𩚑</orig>瘡<pc>，</pc><damage unit="char" extent="11"/>
      <lb xml:id="P-3858r-0003"/>語<pc>。</pc><orig reg="能"><g ref="#P3664-502-06"/></orig>如<orig reg="此"><g ref="#A02068-006"/></orig>者<choice><abbr>久〻</abbr><expan>久久</expan></choice><orig reg="堪"><g ref="#A00787-003"/></orig>用<pc>。</pc>如<orig type="CJK" reg="獼">猕</orig><damage unit="char" extent="11"/>
      <lb xml:id="P-3858r-0004"/>人<orig reg="難"><g ref="#A04467-007"/></orig>有<pc>。」</pc>永<orig reg="徽"><g ref="#A01304-005"/></orig>二<orig reg="年"><g ref="#A01194-037"/></orig>八月命<damage unit="char" extent="12"/>
      <lb xml:id="P-3858r-0005"/>畢<pc>。</pc>遂<orig reg="談"><g ref="#P3858-005-03"/></orig>究鋒<orig reg="起"><g ref="#P3858-005-06"/></orig><pc>，</pc><ptr target="#n51"/><orig type="CJK" reg="爭">争</orig>希<ptr target="#n52"/><orig reg="法"><g ref="#A02168-006"/></orig><damage unit="char" extent="11"/>
      <lb xml:id="P-3858r-0006"/>之<pc>，</pc><orig reg="曰">日</orig><pc>：「</pc><orig reg="弘"><g ref="#A01248-002"/></orig><orig reg="忍"><g ref="#P3858-006-04"/></orig>差可耳<pc>！」</pc>因<orig type="CJK" reg="誡">诫</orig><orig type="CJK" reg="囑">嘱</orig><pc>，</pc><orig reg="再"><g ref="#A00298-003"/></orig><damage>明</damage><orig type="Ext-B" reg="旨">𣅀</orig><damage unit="char" extent="8"/>
      <lb xml:id="P-3858r-0007"/>怡然坐化<pc>。</pc>時<orig reg="地"><g ref="#P3858-007-06"/></orig>大動<pc>，</pc><orig reg="氛"><g ref="#P3858-007-09"/></orig>霧四合<pc>。</pc>春秋七十二<pc>。</pc></ab><ab xml:id="cfbj-P-3858-02"><orig reg="後"><g ref="#P3858-025-13"/></orig>三<orig reg="年"><g ref="#A01194-037"/></orig>四
      <lb xml:id="P-3858r-0008"/>月八日<pc>，</pc>石<orig type="CJK" reg="戶">户</orig>自<orig type="Ext-B" reg="開">𨳩</orig><pc>，</pc>容<orig reg="貌"><g ref="#P3858-008-09"/></orig>儼如生日<pc>。</pc>門人遂加<orig reg="漆"><g ref="#A02311-014"/></orig>布<pc>，</pc>更<damage>不</damage>
      <lb xml:id="P-3858r-0009"/>敢<orig type="CJK" reg="閉">閇</orig><pc>。</pc><ptr target="#n53"/><orig reg="刊" type="CJK">刋</orig>石<orig reg="勒"><g ref="#A00392-003"/></orig><orig type="Ext-B" reg="碑">𥓓</orig><pc>，</pc>中書令杜<orig reg="正"><g ref="#A02067-014"/></orig>倫撰文頌<orig type="CJK" reg="德">徳</orig><pc>。</pc>
      <lb xml:id="P-3858r-0010"/><orig type="Ext-B" reg="釋">𥼶</orig><orig reg="弘"><g ref="#A01248-002"/></orig><orig reg="忍"><g ref="#P3858-006-04"/></orig><pc>，</pc><ptr target="#n140"/><orig reg="黃"><g ref="#A04767-006"/></orig><orig type="CJK" reg="梅">梅</orig>人<pc>，</pc>俗姓周<orig reg="氏"><g ref="#P3858-010-10"/></orig><pc>。</pc>童真出家<pc>，</pc><orig reg="年"><g ref="#A01194-037"/></orig>十二<ptr target="#n54"/><orig reg="事"><g ref="#A00048-008"/></orig>信<orig reg="禪"><g ref="#P3858-010-20"/></orig><unclear>師</unclear><pc>。</pc>
      <lb xml:id="P-3858r-0011"/>性木<orig reg="訥"><g ref="#A03797-002"/></orig>沉<orig reg="厚"><g ref="#A00460-027-1"/></orig><pc>，</pc>同<orig reg="學"><g ref="#P3858-011-07"/></orig>頗<orig type="Ext-A" reg="輕">䡖</orig><orig reg="戲"><g ref="#P3858-011-10"/></orig>之<pc>，</pc>終<orig reg="默"><g ref="#P3664-561-17"/></orig><orig reg="無"><g ref="#A02416-018"/></orig><orig reg="所"><g ref="#S2054-003-17"/></orig><orig reg="對"><g ref="#A01066-013"/></orig><pc>。</pc>常<orig type="Ext-B" reg="勤">𠢄</orig>作<orig type="CJK" reg="役">伇</orig><pc>，</pc>
      <lb xml:id="P-3858r-0012"/>以體下人<pc>，</pc>信特<orig type="CJK" reg="器">噐</orig>之<pc>。</pc>晝則混<orig reg="跡"><g ref="#A04012-022"/></orig><orig type="CJK" reg="驅">駈</orig>給<pc>，</pc><orig reg="夜"><g ref="#A00843-004"/></orig>便坐<unclear reason="damage">攝</unclear><damage unit="char" extent="2"/><pc>，</pc>
      <lb xml:id="P-3858r-0013"/>未<orig type="CJK" reg="嘗">甞</orig><orig reg="懈"><g ref="#P3858-013-03"/></orig>惓<pc>。</pc>精至累<orig reg="年"><g ref="#A01194-037"/></orig><pc>。</pc>信常<orig reg="以"><g ref="#P3858-013-11"/></orig>意<orig reg="導">道</orig><pc>，</pc><ptr target="#n29"/><orig type="Ext-A" reg="洞">㓊</orig>然自<orig reg="覺"><g ref="#P3858-013-17"/></orig><pc>。</pc><orig reg="雖"><g ref="#P3436-020-02"/></orig><damage unit="char" extent="2"/>
      <lb xml:id="P-3858r-0014"/>諸<orig type="Ext-B" reg="經">𦀇</orig><orig reg="論"><g ref="#A03856-007"/></orig><pc>，</pc>聞<orig type="Ext-B" reg="皆">𣅜</orig>心<orig reg="契"><g ref="#A00864-015"/></orig><pc>。</pc><orig reg="既"><g ref="#A01770-008"/></orig>受付<orig type="CJK" reg="囑">嘱</orig><pc>，</pc>令<orig reg="望"><g ref="#P3858-014-13"/></orig><orig reg="所"><g ref="#S2054-003-17"/></orig><orig reg="歸"><g ref="#P3858-014-15"/></orig><pc>，</pc>裾<orig reg="屨"><g ref="#B00776-004"/></orig><ptr target="#n55"/>湊<damage unit="char" extent="2"/>
      <lb xml:id="P-3858r-0015"/><orig type="CJK" reg="增">増</orig>其倍<pc>。</pc>十<orig reg="餘"><g ref="#S2054-003-16"/></orig><orig reg="年"><g ref="#A01194-037"/></orig><orig type="CJK" reg="間">閒</orig>道俗<orig reg="投"><g ref="#A01520-001"/></orig><ptr target="#n118"/><orig reg="學"><g ref="#P3858-011-07"/></orig>者<pc>，</pc>天下十八九<pc>。</pc></ab><ab xml:id="cfbj-P-3858-03">自<damage unit="char" extent="2"/>
      <lb xml:id="P-3858r-0016"/><orig reg="禪"><g ref="#P3858-016-01"/></orig><orig reg="匠"><g ref="#P3858-016-02"/></orig><orig reg="傳"><g ref="#A00228-010"/></orig>化<pc>，</pc>乃莫之過<pc>。</pc><orig type="Ext-B" reg="發">𤼲</orig>言不意<pc>，</pc><orig reg="以"><g ref="#P3858-013-11"/></orig><orig reg="察"><g ref="#P3858-016-14"/></orig><orig reg="機"><g ref="#P3858-016-15"/></orig><orig type="CJK" reg="宜">冝</orig><pc>；</pc><orig reg="響"><g ref="#A04535-016"/></orig><orig reg="對"><g ref="#A01066-013"/></orig><orig reg="無"><g ref="#P3858-016-19"/></orig>端<pc>，</pc>
      <lb xml:id="P-3858r-0017"/><orig type="Ext-B" reg="皆">𣅜</orig><orig type="Ext-B" reg="冥">𡨕</orig>寂用<pc>。</pc>上元二<orig reg="年"><g ref="#A01194-037"/></orig>八月<pc>，</pc><orig reg="數"><g ref="#P3858-017-11"/></orig>見<orig reg="衰"><g ref="#P3858-017-13"/></orig><orig type="Ext-B" reg="相">𢪷</orig><pc>。</pc>十八日<pc>，</pc>因<orig reg="弟"><g ref="#P3858-017-19"/></orig>子法如
      <lb xml:id="P-3858r-0018"/><orig reg="密"><g ref="#P3858-018-01"/></orig>有<orig reg="傳"><g ref="#A00228-010"/></orig><pc>，</pc>宣<orig type="CJK" reg="明">眀</orig>一如<orig reg="所"><g ref="#S2054-003-17"/></orig><orig reg="承"><g ref="#P3858-018-09"/></orig><pc>，</pc>因<orig type="Ext-B" reg="若">𠰥</orig>不言<pc>。</pc>遂<orig reg="泯"><g ref="#B02041-001"/></orig>然坐化<pc>。</pc><ptr target="#n56"/>春秋七
      <lb xml:id="P-3858r-0019"/>十四也<pc>。</pc>
      <lb xml:id="P-3858r-0020"/><orig reg="釋"><g ref="#P3858-020-01"/></orig>法如<pc>，</pc><ptr target="#n140"/>上<orig reg="黨"><g ref="#A04780-003"/></orig>人<pc>，</pc>俗姓王<orig reg="氏"><g ref="#P3858-010-10"/></orig><pc>。</pc><orig type="Ext-A" reg="幼">㓜</orig><orig type="CJK" reg="隨">随</orig><orig reg="舅"><g ref="#P3858-020-13"/></orig>任澧<orig reg="陽"><g ref="#A04432-009"/></orig><pc>，</pc>因<orig reg="事"><g ref="#A00048-008"/></orig>青布<orig type="CJK" reg="明">眀</orig>為<orig reg="師"><g ref="#A01174-005"/></orig><pc>。</pc><orig reg="年"><g ref="#A01194-037"/></orig>
      <lb xml:id="P-3858r-0021"/>十九出家<pc>，</pc><orig reg="博"><g ref="#P3858-021-05"/></orig>窮<orig type="Ext-B" reg="經">𦀇</orig><orig reg="論"><g ref="#P3858-021-08"/></orig><pc>，</pc><orig type="CJK" reg="遊">逰</orig>方求道<pc>。</pc><orig type="CJK" reg="聞">闻</orig><orig type="Ext-B" reg="雙">𩀱</orig><orig type="CJK" reg="峰">峯</orig>山<orig reg="忍"><g ref="#P3858-006-04"/></orig><orig reg="禪"><g ref="#P3858-016-01"/></orig><orig reg="師"><g ref="#A01174-005"/></orig><orig type="Ext-B" reg="開">𨳩</orig><orig type="CJK" reg="佛">仏</orig>知
      <lb xml:id="P-3858r-0022"/>見<pc>，</pc><orig reg="遽"><g ref="#A04190-001"/></orig>往<orig reg="師"><g ref="#A01174-005"/></orig>之<pc>。</pc>精澄十六<orig reg="年"><g ref="#A01194-037"/></orig><pc>，</pc><orig reg="法"><g ref="#A02168-006"/></orig>界<orig type="CJK" reg="圓">圎</orig><orig reg="照"><g ref="#A02424-011"/></orig><pc>。</pc><orig type="CJK" reg="嘗">甞</orig><orig type="Ext-B" reg="沒">𣳚</orig>江<pc>──</pc>舟<orig reg="覆"><g ref="#S2054-027-19"/></orig><pc>，</pc>溺<orig reg="數"><g ref="#P3858-017-11"/></orig>
      <lb xml:id="P-3858r-0023"/>里<pc>──，</pc>心用<orig reg="弗"><g ref="#A01249-007-2"/></orig>動<pc>，</pc>無<orig reg="所"><g ref="#S2054-003-17"/></orig><orig reg="撓"><g ref="#A01667-003"/></orig>失<pc>。</pc>及人<damage>濟</damage>出<pc>，</pc>神<orig reg="色"><g ref="#A03427-003"/></orig>如常<pc>。</pc><orig reg="既"><g ref="#A01770-008"/></orig>而<orig reg="密"><g ref="#P3858-018-01"/></orig><orig reg="傳"><g ref="#A00228-010"/></orig><orig reg="法"><g ref="#A02168-006"/></orig>印<pc>，</pc>
      <lb xml:id="P-3858r-0024"/><orig type="CJK" reg="隨">随</orig>方行道<pc>。</pc><orig reg="屬"><g ref="#A01098-036"/></orig><space type="honorific" unit="char" extent="1"/><orig type="CJK" reg="高">髙</orig>宗昇<orig reg="遐"><g ref="#A04164-010"/></orig><pc>，</pc>度人<pc>，</pc><orig type="CJK" reg="僧">僧</orig><orig type="CJK" reg="眾">衆</orig>共<orig reg="薦">𢊁</orig><orig reg="興"><g ref="#P3858-024-16"/></orig>官名<pc>，</pc>往
      <lb xml:id="P-3858r-0025"/><orig reg="嵩"><g ref="#A01134-001"/></orig>山少林<orig reg="寺"><g ref="#A01058-001"/></orig><pc>，</pc><orig reg="數"><g ref="#P3858-017-11"/></orig><orig reg="年"><g ref="#A01194-037"/></orig><pc>，</pc>人尚未<orig reg="測">惻</orig><ptr target="#n108"/><pc>。</pc><ptr target="#n63"/>其<orig reg="後"><g ref="#P3858-025-13"/></orig>幽求<orig reg="日">曰</orig>至<pc>，</pc><orig reg="猶"><g ref="#A02529-002"/></orig>固<orig reg="讓"><g ref="#P3858-025-20"/></orig>之<pc>。</pc><orig type="Ext-B" reg="垂">𡸁</orig></ab></div>
      </body>
  </text>
