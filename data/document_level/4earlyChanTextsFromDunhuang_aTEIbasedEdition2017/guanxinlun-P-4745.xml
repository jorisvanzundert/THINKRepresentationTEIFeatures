  <text>
    <body><div xml:id="wrap-P-4745v-0001-0012">
      <ab xml:id="gxl-P-4745-01"><milestone unit="sheet" n="P-4745v-01"/><lb xml:id="P-4745v-0001"/><damage>者</damage><pc>。</pc><unclear reason="damage" unit="char" extent="2">所謂</unclear><orig reg="修"><g ref="#A00194-002"/></orig><unclear reason="damage">諸</unclear><orig reg="覺"><g ref="#A03774-015-1"/></orig>行<pc>，</pc><damage>仿</damage><damage unit="char" extent="2"/>
      <lb xml:id="P-4745v-0002"/><damage unit="char" extent="11"/><orig reg="切"><g ref="#A00332-010"/></orig>求<orig reg="解"><g ref="#P3436-036-08"/></orig><orig reg="脫" type="CJK">脱</orig>者<pc>，</pc><damage>以</damage>身為<orig reg="爐"><g ref="#A02463-003"/></orig>，以<damage unit="char" extent="3"/><pc>，</pc>
      <lb xml:id="P-4745v-0003"/>智慧為<orig reg="匠"><g ref="#A00420-002"/></orig><pc>，</pc>三<orig reg="聚"><g ref="#P4745-003-06"/></orig><orig reg="淨" type="CJK">净</orig>戒六<orig reg="波"><g ref="#S2054-091-05"/></orig>羅<orig reg="蜜"><g ref="#A03649-010-1"/></orig>以為<orig type="CJK" reg="模">摸</orig>樣<pc>，</pc><orig reg="鎔"><g ref="#P4745-03-17"/></orig><orig reg="鍊" type="CJK">錬</orig>身中<unclear reason="damage">真</unclear><damage unit="char" extent="1"/>
      <lb xml:id="P-4745v-0004"/><orig reg="佛" type="CJK">仏</orig>性<pc>，</pc><orig reg="遍"><g ref="#A04168-004"/></orig>入一<orig reg="切"><g ref="#A00332-006"/></orig>戒<orig reg="律"><g ref="#A01285-003"/></orig><orig type="CJK" reg="模">摸</orig>中<pc>，</pc>如教奉持<pc>，</pc>一<orig reg="無">旡</orig><orig reg="缺"><g ref="#A03197-010"/></orig>漏<pc>，</pc>自<unclear reason="damage">然</unclear><orig reg="成"><g ref="#A01471-014"/></orig><orig reg="就"><g ref="#A01074-027"/></orig><unclear reason="damage" unit="char" extent="2">真容</unclear>
      <lb xml:id="P-4745v-0005"/>之像<pc>。</pc><orig reg="所"><g ref="#P4745-005-03"/></orig>謂常住<orig type="Ext-B" reg="微">𢕄</orig>妙<orig reg="色"><g ref="#A03427-003"/></orig>身<pc>，</pc>非<orig reg="是"><g ref="#S0646-014-26"/></orig>有為敗<orig type="CJK" reg="壞">壊</orig>之<!--anchor corresp="T48n2009_p0368b11"/--><damage unit="char" extent="5"/>
      <lb xml:id="P-4745v-0006"/>不<orig reg="解"><g ref="#P3436-036-08"/></orig>如<orig reg="是"><g ref="#S0646-014-26"/></orig><pc>，</pc><orig reg="鑄"><g ref="#A04358-005"/></orig><orig reg="寫"><g ref="#P3777-490-16"/></orig><orig reg="真"><g ref="#A02768-018"/></orig><orig reg="容"><g ref="#A01030-005"/></orig><pc>，</pc><orig reg="憑"><g ref="#P4745-006-09"/></orig>何<orig reg="輒" type="CJK">輙</orig>言<orig reg="成"><g ref="#A01471-014"/></orig><!--anchor corresp="T85n2833_p1272a01"/--><orig reg="功" type="Ext-A">㓛</orig>德也<pc>？</pc></ab><ab xml:id="gxl-P-4745-02">故<pc>《</pc>阿<orig reg="含"><g ref="#A00539-009"/></orig><unclear>經</unclear><pc>》</pc>云<pc>：</pc>
      <lb xml:id="P-4745v-0007"/><pc>「</pc>阿難<pc>『……</pc><orig type="Ext-B" reg="若">𠰥</orig>作，有為敗<orig type="CJK" reg="壞">壊</orig>之法<pc>，</pc>欲令不<orig type="CJK" reg="壞">壊</orig><pc>，</pc><orig reg="無">旡</orig>有<orig reg="是"><g ref="#S0646-014-26"/></orig><orig reg="處"><g ref="#A03607-018"/></orig><pc>。』」</pc><ptr target="#n193"/><orig reg="徒"><g ref="#P3664-547-12"/></orig>施<damage unit="char" extent="2"/>
      <lb xml:id="P-4745v-0008"/>究竟<orig reg="獲"><g ref="#S5532-11v420"/></orig>空<orig reg="損"><g ref="#A01645-001"/></orig><orig reg="益"><g ref="#A02741-001"/></orig>顯<orig reg="然"><g ref="#A02417-007"/></orig>何勞<orig reg="致"><g ref="#A03390-016"/></orig><orig reg="或"><g ref="#A01474-010"/></orig><pc>。</pc><space type="punctuation" unit="char" extent="1"/><add place="inline-right" resp="hand2" rendition="red">故<pc>《</pc>金<orig reg="剛"><g ref="#A00362-014r"/></orig><orig reg="經" type="Ext-B">𦀇</orig><pc>》</pc>云一切有為法如夢<damage unit="char" extent="3"/></add><ptr target="#n194"/><g ref="#P4745-008-13"/><ptr target="#n195"/>又<orig reg="燒" type="CJK">焼</orig>香者<pc>，</pc><damage unit="char" extent="4"/>
      <lb xml:id="P-4745v-0009"/>有<orig type="Ext-B" reg="相">𢪷</orig>之香<pc>，</pc>乃<orig reg="是"><g ref="#S0646-014-26"/></orig><add place="inline-right" resp="hand2" rendition="red"><orig reg="無">旡</orig></add>為<orig reg="正"><g ref="#A02067-014"/></orig>法香也<pc>。</pc><orig reg="薰" type="CJK">薫</orig>諸<orig reg="臭"><g ref="#A03387-007"/></orig><orig reg="穢"><g ref="#A02950-002"/></orig><pc>，</pc><orig reg="無">旡</orig>明<orig type="Ext-B" reg="惡">𢙣</orig><orig reg="業"><g ref="#A01974-035"/></orig><pc>，</pc><orig type="Ext-B" reg="悉">𢘻</orig><damage>令</damage><damage unit="char" extent="1"/>
      <lb xml:id="P-4745v-0010"/><orig reg="滅"><g ref="#P4745-010-01"/></orig><pc>。</pc>故<pc>〈</pc>行香偈<pc>〉</pc>云<pc>：</pc>一者戒香<pc>，</pc><orig reg="所"><g ref="#P4745-005-03"/></orig>謂<orig reg="止"><g ref="#A02066-001"/></orig><orig type="Ext-B" reg="惡">𢙣</orig><orig reg="懲" type="CJK">懲</orig><orig reg="非"><g ref="#P4745-010-16"/></orig><pc>，</pc>防諸過<unclear>患</unclear><pc>；</pc><ptr target="#n196"/><damage>二</damage><damage unit="char" extent="1"/>
      <lb xml:id="P-4745v-0011"/><orig type="Ext-A" reg="定">㝎</orig>香<pc>，</pc><orig reg="所"><g ref="#P4745-005-03"/></orig>謂<orig reg="決"><g ref="#A02145-004"/></orig>信大<orig reg="乘"><g ref="#P2634-011-21"/></orig><pc>，</pc>心<orig reg="無">旡</orig>退<damage>轉</damage><pc>；</pc>三者<orig reg="慧">恵</orig>香<pc>，</pc><orig reg="所"><g ref="#P4745-005-03"/></orig>謂常<orig type="CJK" reg="於">扵</orig>身<damage unit="char" extent="1"/><pc>，</pc>
      <lb xml:id="P-4745v-0012"/><orig type="CJK" reg="內">内</orig>外<ptr target="#n109"/><orig reg="鑒"><g ref="#P3436-118-04"/></orig><orig reg="察"><g ref="#A01050-002"/></orig><pc>；</pc>四者<orig reg="解"><g ref="#P3436-036-08"/></orig><orig reg="脫"><g ref="#A03334-002"/></orig>香<pc>，</pc><orig reg="所"><g ref="#P4745-005-03"/></orig>謂<orig reg="能"><g ref="#A03329-019"/></orig><orig reg="斷" type="CJK">断</orig>一<orig reg="切"><g ref="#A00332-013"/></orig><orig reg="無">旡</orig>明<orig reg="繫"><g ref="#P3436-041-17"/></orig><orig reg="縛"><g ref="#P3294-027-17"/></orig><pc>；</pc>五者<damage unit="char" extent="2"/></ab></div>
