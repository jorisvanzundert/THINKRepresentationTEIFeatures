   <text>
      <body>
         <head>
            <app>
               <lem wit="#N35 #N35c">XIII. | LA SERA | DEL DÌ DI FESTA</lem>
               <rdg wit="#AN">Idillio | La sera del giorno festivo</rdg>
               <rdg wit="#AV">La sera del giorno festivo | Idillio II</rdg>
               <rdg wit="#NR25">LA SERA DEL GIORNO FESTIVO. | Idillio II.</rdg>
               <rdg wit="#B26">LA SERA DEL GIORNO FESTIVO | IDILLIO II</rdg>
               <rdg wit="#F31">XII. | LA SERA | DEL GIORNO FESTIVO</rdg>
            </app>
         </head>
         <lg>
            <l n="1">
               <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">Dolce e</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">Oimè,</mod> <mod change="#layer1"
                        seq="2" type="superscript">Dolce e</mod></rdg>
               </app>chiara è la notte e senza vento,</l>
            <l n="2">
               <app>
                  <lem wit="#AN #AV #NR25 #B26 #F31 #N35c">E queta</lem>
                  <rdg wit="#N35">
                     <choice>
                        <sic>E queta e</sic>
                        <corr>E queta</corr>
                     </choice></rdg>
               </app>
               <app>
                  <lem wit="#N35 #N35c">sovra i tetti e in mezzo agli orti</lem>
                  <rdg wit="#AN #AV #NR25 #B26">in mezzo a gli orti e in cima a i tetti</rdg>
                  <rdg wit="#F31">in mezzo a gli orti e sovra i tetti</rdg>
               </app>
            </l>
            <l n="3">
               <anchor xml:id="v3-4"/>Posa la luna, e di lontan rivela</l>
            <l n="4">Serena ogni montagna. <app from="#v3-4">
                  <lem wit="#N35 #N35c">Posa la luna, e di lontan rivela / Serena ogni
                     montagna.</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">La luna si riposa, e le montagne / Si
                     discopron da lungi.</rdg>
               </app> O donna mia,</l>
            <l n="5">Già tace ogni sentiero, e <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">pei</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">pe'</mod><mod change="#layer2" seq="2"
                        type="reuse">pei</mod></rdg>
               </app> balconi</l>
            <l n="6">Rara traluce la notturna lampa:</l>
            <l n="7">Tu dormi, <app>
                  <lem wit="#F31 #N35 #N35c">che</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">che</mod> <mod change="#layer3"
                        seq="2" type="reuse">chè</mod></rdg>
                  <rdg wit="#AV #NR25 #B26">chè</rdg>
               </app> t'accolse agevol sonno</l>
            <l n="8">
               <app>
                  <lem wit="#N35 #N35c">Nelle tue chete stanze;</lem>
                  <rdg wit="#AN">
                     <mod change="#layer1" seq="1"><subst><del>Nell</del><add>Ne le</add></subst> tue chete
                     stanze,</mod> <mod change="#layer3" seq="2" type="reuse">Ne le tue chete stanze;</mod></rdg>
                  <rdg wit="#AV"><mod seq="1">Ne la tua cheta stanza;</mod><mod seq="2"
                        type="reuse">Ne le tue chete stanze;</mod></rdg>
                  <rdg wit="#NR25 #B26 #F31">Ne le tue chete stanze;</rdg>
               </app> e non ti morde</l>
            <l n="9">Cura <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">nessuna;</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">nessuna,</mod> <mod change="#layer1"
                        seq="2" type="reuse">nessuna:</mod>
                     <mod change="#layer3" seq="3" type="reuse">nessuna;</mod></rdg>
               </app> e già non <app>
                  <lem wit="#N35 #N35c">sai nè pensi</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">pensi o stimi</rdg>
               </app></l>
            <l n="10">Quanta piaga m'apristi in mezzo al petto.</l>
            <l n="11"><anchor xml:id="v.11-13"/>Tu dormi: io questo ciel, che sì benigno</l>
            <l n="12">Appare in vista, a salutar m'affaccio,</l>
            <l n="13">E l’antica natura onnipossente, <app from="#v.11-13">
                  <lem wit="#F31 #N35 #N35c">Tu dormi: io questo ciel, che sì benigno / Appare
                     in vista, a salutar m’affaccio, / E l’antica natura onnipossente,</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">E bene sta, che amor da <subst>
                        <del>quand'</del>
                        <add>poi ch'</add>
                     </subst> io nacqui / Non ebbi nè sperai nè merto. Il cielo / Io qui
                     m'affaccio a salutare, il cielo</mod> <mod change="#layer3" seq="2" type="superscript">Tu
                        dormi: io questo ciel, che sì benigno / Appare in vista, a salutar
                        m’affaccio, / E l’antica natura onnipossente,</mod>
                     <mod change="#layer3" seq="3" type="reuse">Tu dormi: io questo ciel, che sì
                        benigno / Appare in vista, a salutar m’affaccio, / E l’antica Natura
                        onnipossente,</mod></rdg>
                  <rdg wit="#AV #NR25 #B26">Tu dormi: io questo ciel, che sì benigno / Appare in
                     vista, a salutar m’affaccio, / E l’antica Natura onnipossente,</rdg>
               </app></l>
            <l n="14">Che mi fece <app>
                  <lem wit="#N35 #N35c">all'affanno.</lem>
                  <rdg wit="#AN">
                     <mod change="#layer1" seq="1">al<subst>
                        <del>l</del><add/></subst> travaglio.</mod> <mod change="#layer3" seq="2" type="superscript">a
                        l'affanno.</mod></rdg>
                  <rdg wit="#AV #NR25 #B26 #F31"> a l'affanno.</rdg>
               </app> A te la speme</l>
            <l n="15">Nego, mi disse, anche la speme; e d’altro</l>
            <l n="16">
               <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">Non</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">non</mod> <mod change="#layer1"
                        seq="2" type="reuse">Non</mod></rdg>
               </app> brillin gli occhi tuoi <app>
                  <lem wit="#N35 #N35c">se non di</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">fuorchè di</mod> <mod
                        change="#layer1" seq="2" type="reuse"
                        >fuor che di</mod></rdg>
                  <rdg wit="#AV"><mod>fuorc</mod> <mod type="immediate">fuor che di</mod></rdg>
                  <rdg wit="#NR25 #B26 #F31">fuor che di</rdg>
               </app> pianto.</l>
            <l n="17">Questo dì fu solenne: or da’ trastulli</l>
            <l n="18">Prendi <app>
                  <lem wit="#B26 #F31 #N35 #N35c">riposo;</lem>
                  <rdg wit="#AN #AV #NR25">riposo,</rdg>
               </app> e forse ti rimembra</l>
            <l n="19">In sogno a quanti oggi piacesti, e quanti</l>
            <l n="20">Piacquero a te: non <app>
                  <lem wit="#N35 #N35c">io, non già, ch'io speri,</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">io certo già mai</mod> <mod
                        change="#layer3" seq="2" type="reuse">io certo giammai</mod></rdg>
                  <rdg wit="#AV #NR25 #B26 #F31">io certo giammai</rdg>
               </app></l>
            <l n="21">
               <app>
                  <lem wit="#N35 #N35c">Al pensier ti ricorro.</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">Ti ricorro al pensiero</rdg>
               </app> Intanto io <app>
                  <lem wit="#N35 #N35c">chieggo</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">chieggio</rdg>
               </app></l>
            <l n="22">Quanto a viver mi resti, e qui per terra</l>
            <l n="23">Mi <app>
                  <lem wit="#NR25 #B26 #F31 #N35 #N35c">getto, e grido, e fremo.</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">getto e mi ravvolgo.</mod> <mod
                        change="#layer2" seq="2" type="reuse">getto, e grido, e fremo.</mod></rdg>
                  <rdg wit="#AV"><mod seq="1">getto, e mi ravvolgo.</mod> <mod seq="2" type="reuse">getto, e grido, e
                        fremo.</mod></rdg>
               </app>
               <app>
                  <lem wit=" #AN #AV #NR25 #B26 #F31 #N35 #N35c">Oh giorni orrendi</lem>
                  <rdg wit="#AN" change="#layer3" ana="#altvariant" type="margin">(Oh vita o giorni orrendi)</rdg>
               </app></l>
            <l n="24">In così verde <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">etate!</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">etade.</mod> <mod change="#layer2"
                        seq="2" type="reuse">etate!</mod></rdg>
               </app>
               <app>
                  <lem wit="#B26 #F31 #N35 #N35c">Ahi,</lem>
                  <rdg wit="#AN #AV #NR25">Ahi</rdg>
               </app>per la via</l>
            <l n="25">
               <app>
                  <lem wit="#N35 #N35c">Odo</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">Sento</rdg>
               </app> non lunge il solitario canto</l>
            <l n="26">
               <app>
                  <lem wit="#N35 #N35c">Dell'</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">De l'</rdg>
               </app>
               <app>
                  <lem wit="#B26 #F31 #N35 #N35c">artigian,</lem>
                  <rdg wit="#AN #AV #NR25">artigian</rdg>
               </app> che riede a tarda <app>
                  <lem wit="#B26 #F31 #N35 #N35c">notte,</lem>
                  <rdg wit="#AN #AV #NR25">notte</rdg>
               </app></l>
            <l n="27">Dopo i <app>
                  <lem wit="#B26 #F31 #N35 #N35c">sollazzi,</lem>
                  <rdg wit="#AN #AV #NR25">sollazzi</rdg>
               </app> al suo povero <app>
                  <lem wit="#B26 #F31 #N35 #N35c">ostello;</lem>
                  <rdg wit="#AN #AV #NR25">ostello,</rdg>
               </app>
            </l>
            <l n="28">E fieramente mi si stringe il <app>
                  <lem wit="#F31 #N35 #N35c">core,</lem>
                  <rdg wit="#AN #AV #NR25 #B26">core</rdg>
               </app>
            </l>
            <l n="29">A pensar come tutto al mondo <app>
                  <lem wit="#N35 #N35c">passa,</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">passa</rdg>
               </app>
            </l>
            <l n="30">E <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">quasi orma</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">vestigio</mod> <mod change="#layer2"
                        seq="2" type="superscript">quasi orma</mod></rdg>
               </app> non lascia. Ecco è fuggito</l>
            <l n="31">Il dì festivo, ed al festivo il giorno</l>
            <l n="32">Volgar succede, e <app>
                  <lem wit="#N35 #N35c">se ne porta</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">si travolge</rdg>
               </app> il tempo</l>
            <l n="33">Ogni umano accidente. Or dov’è <app>
                  <lem wit="#N35 #N35c">il</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">'l</rdg>
               </app> suono</l>
            <l n="34">Di que’ popoli antichi? or 
               <app><lem wit="#AN #NR25 #B26 #F31 #N35 #N35c">dov’</lem>
               <rdg wit="#AV"><mod seq="1">dov'</mod><mod seq="2" type="immediate">dov'</mod></rdg></app> è
               <app>
                  <lem wit="#N35 #N35c">il</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">'l</rdg>
               </app>grido</l>
            <l n="35">De’ nostri avi famosi, e <app>
                  <lem wit="#N35 #N35c">il</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">'l</rdg>
               </app> grande impero</l>
            <l n="36">Di quella <app>
                  <lem wit="#AN #B26 #F31 #N35 #N35c">Roma,</lem>
                  <rdg wit="#AV #NR25">Roma;</rdg>
               </app> e l'<app>
                  <lem wit=" #F31 #N35 #N35c">armi,</lem>
                  <rdg wit="#AN #AV #NR25 #B26">armi</rdg>
               </app> e <app>
                  <lem wit="#N35 #N35c">il</lem>
                  <rdg wit=" #AN #AV #NR25 #B26 #F31">'l</rdg>
               </app>
               <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">fragorio</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">fragorìo</mod> <mod change="#layer1"
                        seq="2" type="reuse">fragorio</mod>
                  </rdg>
               </app>
            </l>
            <l n="37">Che n’andò per <app>
                  <lem wit="#NR25 #B26 #F31 #N35 #N35c">la terra e per l'</lem>
                  <rdg wit="#AN">la terra e l'</rdg>
                  <rdg wit="#AV"><mod seq="1">l'</mod> <mod seq="2" type="immediate">la terra e l'</mod></rdg>
               </app> oceano?</l>
            <l n="38">Tutto è <app>
                  <lem wit="#F31 #N35 #N35c">pace e silenzio,</lem>
                  <rdg wit="#AN #AV #NR25 #B26">silenzio e pace,</rdg>
               </app> e tutto <app>
                  <lem wit="#N35 #N35c">posa</lem>
                  <rdg wit="#AN #AV #NR25 #B26">cheto</rdg>
                  <rdg wit="#F31">pòsa</rdg>
               </app>
            </l>
            <l n="39">
               <app>
                  <lem wit="#F31 #N35 #N35c">Il</lem>
                  <rdg wit="#AN #AV #NR25 #B26">È 'l</rdg>
               </app> mondo, e più di lor non si <app>
                  <lem wit="#N35 #N35c">ragiona</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">favella</rdg>
               </app>. </l>
            <l n="40">
               <app>
                  <lem wit="#N35 #N35c">Nella</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">Ne la</rdg>
               </app> mia prima età, quando s’aspetta</l>
            <l n="41">Bramosamente il dì festivo, or poscia</l>
            <l n="42">Ch’ <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">egli era spento</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">egli spento</mod> <mod
                        change="#layer1" seq="2" type="inserted">egli era
                        spento</mod></rdg>
               </app>, io <app>
                  <lem wit="#F31 #N35 #N35c">doloroso, in veglia,</lem>
                  <rdg wit="#AN #AV #NR25 #B26">doloroso e desto</rdg>
               </app>
            </l>
            <l n="43">Premea le <app>
                  <lem wit="#B26 #F31 #N35 #N35c">piume;</lem>
                  <rdg wit="#AN #AV #NR25">piume,</rdg>
               </app>
               <app>
                  <lem wit="#N35 #N35c">ed alla tarda</lem>
                  <rdg wit="#AN #AV #NR25 #B26">e per la muta</rdg>
                  <rdg wit="#F31">ed a la tarda</rdg>
               </app> notte </l>
            <l n="44">
               <app>
                  <lem wit="#F31 #N35 #N35c">Un canto che s'udia</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">Questo canto che udia</mod> <mod
                        change="#layer1" seq="2" type="reuse">Questo canto ch' udia</mod>
                     <mod change="#layer3" seq="3" type="reuse">Questo canto che udia</mod></rdg>
                  <rdg wit="#AV #NR25">Questo canto che udia</rdg>
                  <rdg wit="#B26">Questo canto ch'udia</rdg>
               </app> per <anchor xml:id="v.44-45"/> li sentieri</l>
            <l n="45">Lontanando morire <app from="#v.44-45">
                  <lem wit="#F31 #N35 #N35c">li sentieri / Lontanando morire</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">lo <subst><del>sl</del><add/></subst>
                        sentiero, / E moria slontanando</mod>
                     <mod change="#layer3" seq="2" type="reuse">lo sentiero / E moria lontanando</mod>
                     <mod change="#layer3" seq="3" type="superscript">lo sentiero / Lontanando
                        morire</mod></rdg>
                  <rdg wit="#AV #NR25 #B26">lo sentiero / Lontanando morire</rdg>
               </app> a poco a poco,</l>
            <l n="46">
               <app>
                  <lem wit="#N35 #N35c">Già similmente</lem>
                  <rdg wit="#AN"><mod change="#layer1" seq="1">Fin da quegli anni</mod> <mod
                        change="#layer2" seq="2" type="superscript">Al modo istesso</mod></rdg>
                  <rdg wit="#AV #NR25 #B26">Al modo istesso</rdg>
                  <rdg wit="#F31">Pur similmente</rdg>
               </app> mi stringeva il core.</l>
         </lg>
      </body>
   </text>
