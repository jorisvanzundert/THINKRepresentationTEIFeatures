   <text>
      <body>
         <head><app>
               <lem wit="#N35 #N35c">XII. | L'INFINITO.</lem>
               <rdg wit="#AN">Idillio | L'Infinito</rdg>
               <rdg wit="#AV">Idilli | MDCCCXIX V L'Infinito | Idillio I</rdg>
               <rdg wit="#NR25">L'INFINITO. | Idillio I.</rdg>
               <rdg wit="#B26">L'INFINITO | Idillio I</rdg>
               <rdg wit="#F31">XI. | L'INFINITO.</rdg>
            </app></head>
         <lg>
            <l n="1">Sempre caro mi fu quest’ermo <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">colle,</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">colle </mod><mod change="#layer3"
                        type="reuse" seq="2">colle,</mod></rdg>
               </app></l>
            <l n="2">E questa <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">siepe,</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">siepe </mod><mod change="#layer3"
                        type="reuse" seq="2">siepe,</mod></rdg>
               </app>che da tanta parte</l>
            <l n="3"><app>
                  <lem wit="#N35 #N35c">Dell'ultimo orizzonte</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">Del celeste confine </mod><mod
                        change="#layer1" type="reuse" seq="2">De l'ultimo orizzonte</mod></rdg>
                  <rdg wit="#AV #NR25 #B26 #F31">De l'ultimo orizzonte</rdg>
               </app> il guardo esclude.</l>
            <l n="4">Ma sedendo e <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">mirando,</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">mirando </mod><mod change="#layer3"
                        type="reuse" seq="2">mirando,</mod></rdg>
               </app>
               <anchor xml:id="v.4-5"/>interminati</l>
            <l n="5">Spazi <app from="#v.4-5">
                  <lem wit="#N35 #N35c">interminati / Spazi</lem>
                  <rdg wit="#AN">
                     <mod change="#layer0" seq="1">un infinito / spazio</mod>
                     <mod change="#layer1" seq="2" type="reuse">interminato / spazio</mod></rdg>
                  <rdg wit="#AV #NR25 #B26 #F31">interminato / spazio</rdg>
               </app> di là da quella, e sovrumani</l>
            <l n="6">Silenzi, e profondissima quiete</l>
            <l n="7">Io <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">nel pensier mi</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">mi </mod><mod change="#layer0"
                        type="immediate" seq="2">nel pensier mi</mod></rdg>
               </app>
               <app>
                  <lem wit="#B26 #F31 #N35 #N35c">fingo;</lem>
                  <rdg wit="#AN #AV #NR25">fingo,</rdg>
               </app> ove per poco</l>
            <l n="8">Il cor non si spaura. E come il vento</l>
            <l n="9">Odo stormir <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">tra</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">fra </mod><mod change="#layer3"
                        type="superscript" seq="2">tra</mod></rdg>
               </app> queste piante, io quello</l>
            <l n="10">Infinito silenzio a questa voce</l>
            <l n="11">Vo <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">comparando: e</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">comparando. E </mod><mod
                        change="#layer0" type="reuse" seq="2">comparando: e</mod></rdg>
               </app> mi sovvien l’eterno,</l>
            <l n="12">E le morte stagioni, e la presente</l>
            <l n="13">E viva, <app>
                  <lem wit="#N35 #N35c">e il</lem>
                  <rdg wit=" #AN" resp="#BN #RP"><mod change="#layer0" seq="1">e' l</mod><mod
                        change="#layer0" type="immediate" seq="2">e 'l</mod></rdg>
                  <rdg wit="#AV #NR25 #B26 #F31">e 'l</rdg>
               </app> suon di lei. Così <app>
                  <lem wit="#AV #NR25 #B26 #F31 #N35 #N35c">tra</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">fra</mod>
                     <mod change="#layer1" type="superscript" seq="2">tra</mod></rdg>
               </app> questa</l>
            <l n="14"><app>
                  <lem wit="#F31 #N35 #N35c">Immensità s’annega il pensier mio:</lem>
                  <rdg wit="#AN"><mod change="#layer0" seq="1">Immensit<subst>
                           <del>ade</del>
                           <add>à</add>
                        </subst> il mio pensier s'annega, </mod><mod change="#layer1" type="reuse"
                        seq="2">Infinità s'annega il pensier mio;</mod>
                     <mod change="#layer3" type="reuse" seq="3">Infinità s'annega il pensier
                        mio:</mod></rdg>
                  <rdg wit="#AV"><mod seq="1">immensità s'annega il pensier mio: </mod><mod
                        type="reuse" seq="2">Infinità s'annega il pensier mio:</mod></rdg>
                  <rdg wit="#NR25 #B26">Infinità s'annega il pensier mio:</rdg>
               </app></l>
            <l n="15">E <app>
                  <lem wit="#N35 #N35c">il</lem>
                  <rdg wit="#AN #AV #NR25 #B26 #F31">'l</rdg>
               </app> naufragar m’è dolce in questo mare.</l>
         </lg>
      </body>
